{{>layout/header}}

<style>
    .faq-hero {
        background: #fff;
        border-bottom: 1px solid #eaecf4;
        padding: 56px 28px 0;
    }

    .faq-hero-inner {
        max-width: 1140px;
        margin: 0 auto;
        text-align: center;
        padding-bottom: 40px;
    }

    .faq-hero-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 18px;
        border-radius: 16px;
        background: #eaf0fe;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .faq-hero-icon svg {
        width: 28px;
        height: 28px;
    }

    .faq-hero-inner h1 {
        font-size: 32px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -1px;
        margin-bottom: 10px;
    }

    .faq-hero-inner p {
        font-size: 14px;
        color: #6b7280;
    }

    .faq-section {
        padding: 40px 28px 80px;
        max-width: 880px;
        margin: 0 auto;
    }

    .faq-toolbar {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 16px;
    }

    .faq-new-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        border-radius: 8px;
        background: #2563eb;
        color: #fff;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.15s;
    }

    .faq-new-btn:hover {
        background: #1d4ed8;
    }

    .faq-new-btn svg {
        width: 16px;
        height: 16px;
    }

    .faq-list {
        background: #fff;
        border: 1.5px solid #eaecf4;
        border-radius: 16px;
        overflow: hidden;
    }

    .faq-item {
        border-bottom: 1px solid #eaecf4;
    }

    .faq-item:last-child {
        border-bottom: none;
    }

    .faq-question {
        display: flex;
        align-items: center;
        gap: 14px;
        cursor: pointer;
        padding: 20px 24px;
        font-size: 14.5px;
        font-weight: 700;
        color: #1c1e26;
        transition: background 0.15s;
    }

    .faq-question:hover {
        background: #f8f9fc;
    }

    .faq-question .badge {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 8px;
        background: #eaf0fe;
        color: #2563eb;
        font-size: 13px;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .faq-question .badge.a-badge {
        background: #f8f9fc;
        color: #6b7280;
    }

    .faq-question .q-text {
        flex: 1;
    }

    .faq-question .chevron {
        flex-shrink: 0;
        width: 18px;
        height: 18px;
        color: #9ca3af;
        transition: transform 0.2s;
    }

    .faq-question.open .chevron {
        transform: rotate(180deg);
    }

    .faq-answer {
        display: none;
        align-items: flex-start;
        gap: 14px;
        padding: 0 24px 22px 24px;
        font-size: 13.5px;
        color: #4b5563;
        line-height: 1.9;
        white-space: pre-line;
    }

    .faq-answer.open {
        display: flex;
    }

    .faq-answer-body {
        flex: 1;
    }

    .faq-admin-inline {
        display: flex;
        gap: 6px;
        margin-top: 12px;
    }

    .faq-edit-btn,
    .faq-delete-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 14px;
        border-radius: 8px;
        background: #fff;
        font-size: 12px;
        font-weight: 700;
        border: 1.5px solid #eaecf4;
        cursor: pointer;
        color: #374151;
        text-decoration: none;
        transition: all 0.15s;
    }

    .faq-edit-btn svg,
    .faq-delete-btn svg {
        width: 13px;
        height: 13px;
    }

    .faq-edit-btn:hover {
        border-color: #2563eb;
        color: #2563eb;
        background: #eaf0fe;
    }

    .faq-delete-btn:hover {
        border-color: #d85a30;
        color: #d85a30;
        background: #fdf2ee;
    }

    .faq-empty {
        text-align: center;
        font-size: 13px;
        color: #9ca3af;
        padding: 48px 0;
    }
    .faq-edit-btn,
    .faq-delete-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 6px 14px;
        border-radius: 8px;
        background: #fff;
        font-size: 12px;
        font-weight: 700;
        font-family: inherit;
        line-height: 1;
        border: 1.5px solid #eaecf4;
        cursor: pointer;
        color: #374151;
        text-decoration: none;
        transition: all 0.15s;
    }
</style>

<section class="faq-hero">
    <div class="faq-hero-inner">
        <div class="faq-hero-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 17.5V17.51M12 14.5C12 12 14.5 12 14.5 10C14.5 8.5 13.4 7.5 12 7.5C10.6 7.5 9.5 8.5 9.5 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/>
            </svg>
        </div>
        <h1>자주 묻는 질문</h1>
        <p>SevMerge 이용 중 자주 묻는 질문을 확인하세요.</p>
    </div>
</section>

<section class="faq-section">

    {{#isAdmin}}
        <div class="faq-toolbar">
            <a href="/faqs/new" class="faq-new-btn">
                <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                FAQ 등록
            </a>
        </div>
    {{/isAdmin}}

    <div class="faq-list">
        {{#faqList}}
            <div class="faq-item">
                <div class="faq-question" onclick="toggleAnswer(this)">
                    <span class="badge">Q</span>
                    <span class="q-text">{{question}}</span>
                    <svg class="chevron" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="faq-answer">
                    <span class="badge a-badge">A</span>
                    <div class="faq-answer-body">
                        {{answer}}
                        {{#isAdmin}}
                            <div class="faq-admin-inline">
                                <a href="/faqs/edit/{{id}}" class="faq-edit-btn">
                                    <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M14.17 2.83a2 2 0 0 1 2.83 2.83L6.5 16.17 2.5 17.5l1.33-4L14.17 2.83Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                    수정
                                </a>
                                <form action="/faqs/delete/{{id}}" method="post" style="display:inline;">
                                    <button type="submit" class="faq-delete-btn">
                                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M4 5.5h12M8 5.5V3.5h4v2M5.5 5.5l.7 10a1 1 0 001 1h5.6a1 1 0 001-1l.7-10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        삭제
                                    </button>
                                </form>
                            </div>
                        {{/isAdmin}}
                    </div>
                </div>
            </div>
        {{/faqList}}

        {{^faqList}}
            <p class="faq-empty">등록된 FAQ가 없습니다.</p>
        {{/faqList}}
    </div>

</section>

<script>
    function toggleAnswer(el) {
        const answer = el.nextElementSibling;
        answer.classList.toggle('open');
        el.classList.toggle('open');
    }
</script>

{{>layout/footer}}

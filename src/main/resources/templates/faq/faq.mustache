{{>layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .faq-wrap { min-height: calc(100vh - 64px); display: flex; position: relative; z-index: 1; }

    /* ── 왼쪽 히어로 사이드바 ── */
    .faq-sidebar {
        width: 340px; flex-shrink: 0; position: sticky; top: 64px;
        height: calc(100vh - 64px); overflow-y: auto;
        padding: 40px 32px;
        backdrop-filter: blur(20px); background: rgba(255,255,255,.55);
        border-right: 1.5px solid rgba(255,255,255,.8);
        display: flex; flex-direction: column; gap: 20px;
    }
    .faq-logo { font-size: 22px; font-weight: 900; color: #1e3a8a; letter-spacing: -1px; margin-bottom: 4px; }
    .faq-logo .hl { color: #2563eb; }
    .faq-eyebrow {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2);
        border-radius: 999px; padding: 4px 14px;
        font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: .3px;
    }
    .faq-hero-title { font-size: 34px; font-weight: 900; line-height: 1.15; letter-spacing: -1.5px; color: #172554; }
    .faq-hero-title .hl { color: #2563eb; }
    .faq-hero-desc { font-size: 14px; color: #4a6fa5; line-height: 1.75; }

    /* 통계 카드 */
    .faq-stats { display: flex; flex-direction: column; gap: 10px; }
    .faq-stat-card {
        display: flex; align-items: center; gap: 14px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 16px; padding: 14px 18px;
        box-shadow: 0 4px 12px rgba(37,99,235,.06); text-decoration: none; transition: all .15s;
    }
    .faq-stat-card:hover { border-color: rgba(37,99,235,.3); transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.1); }
    .faq-stat-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .faq-stat-label { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #4a6fa5; margin-bottom: 3px; }
    .faq-stat-value { font-size: 18px; font-weight: 900; color: #1e3a6e; }
    .faq-stat-value.link { font-size: 14px; color: #2563eb; }

    .faq-contact-btn {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        padding: 13px; border-radius: 25px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        font-size: 14px; font-weight: 800; text-decoration: none;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .faq-contact-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    /* ── 오른쪽 FAQ 목록 ── */
    .faq-main { flex: 1; padding: 40px 36px 80px; overflow-y: auto; }
    .faq-main-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .faq-main-title { font-size: 18px; font-weight: 900; color: #1e3a6e; }
    .faq-new-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        text-decoration: none; box-shadow: 0 4px 12px rgba(37,99,235,.25); transition: all .15s;
    }
    .faq-new-btn:hover { transform: translateY(-1px); }

    .faq-list {
        backdrop-filter: blur(20px); background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 24px; overflow: hidden;
        box-shadow: 0 16px 48px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .faq-item { border-bottom: 1px solid rgba(37,99,235,.07); }
    .faq-item:last-child { border-bottom: none; }

    .faq-question {
        display: flex; align-items: center; gap: 14px;
        cursor: pointer; padding: 20px 26px;
        font-size: 14.5px; font-weight: 700; color: #1e3a6e;
        transition: background .15s; user-select: none;
    }
    .faq-question:hover { background: rgba(37,99,235,.04); }
    .faq-question.open { background: rgba(37,99,235,.05); }

    .badge {
        flex-shrink: 0; width: 28px; height: 28px; border-radius: 8px;
        background: rgba(37,99,235,.1); color: #2563eb;
        font-size: 12px; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }
    .badge.a-badge { background: rgba(100,116,139,.1); color: #4a6fa5; }
    .q-text { flex: 1; }
    .chevron { flex-shrink: 0; width: 18px; height: 18px; color: #93aecf; transition: transform .2s; }
    .faq-question.open .chevron { transform: rotate(180deg); }

    .faq-answer { display: none; padding: 8px 26px 20px; font-size: 13.5px; color: #4a6fa5; line-height: 1.9; }
    .faq-answer.open { display: flex; gap: 14px; align-items: flex-start; }
    .faq-answer-body { flex: 1; display: flex; flex-direction: column; gap: 4px; }
    .faq-answer-row { margin-top: 7px; display: flex; align-items: flex-start; gap: 14px; }
    .a-text { flex: 1; font-size: 13.5px; font-weight: 600; color: #4a6fa5; line-height: 1.9; white-space: pre-line; }

    .faq-admin-inline { display: flex; gap: 6px; margin-top: 4px; }
    .faq-edit-btn, .faq-delete-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 7px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); cursor: pointer;
        color: #2d4a7a; text-decoration: none; transition: all .15s;
    }
    .faq-edit-btn:hover { border-color: rgba(37,99,235,.4); color: #2563eb; background: rgba(239,246,255,.9); }
    .faq-delete-btn:hover { border-color: #fca5a5; color: #ef4444; background: rgba(255,243,243,.9); }

    .faq-empty { text-align: center; padding: 56px 0; font-size: 13px; color: #93aecf; }

    @media (max-width: 900px) {
        .faq-wrap { flex-direction: column; }
        .faq-sidebar { width: 100%; height: auto; position: static; }
        .faq-main { padding: 24px 20px 60px; }
    }
</style>

<div class="faq-wrap">

    <!-- 왼쪽 히어로 사이드바 -->
    <aside class="faq-sidebar">
        <div class="faq-logo">I<span class="hl">code</span>U</div>
        <div class="faq-eyebrow">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
            Help Center · FAQ
        </div>
        <h1 class="faq-hero-title">자주 묻는<br>질문을<br><span class="hl">확인하세요</span></h1>
        <p class="faq-hero-desc">코드요 이용 중 궁금한 점을<br>빠르게 해결해 드려요.</p>

        <div class="faq-stats">
            <div class="faq-stat-card">
                <div class="faq-stat-icon" style="background:rgba(37,99,235,.1);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="#2563eb"><path d="M4 18h2v2H4v2H2V4h2v14Zm16 0H6v-2h14v2Zm2-2h-2V4h2v12Zm-12-2H6v-2h4v2Zm4-4H6V8h8v2Zm6-6H4V2h16v2Z"/></svg>
                </div>
                <div>
                    <p class="faq-stat-label">Total FAQ</p>
                    <p class="faq-stat-value">{{faqList.size}}개</p>
                </div>
            </div>
            <div class="faq-stat-card">
                <div class="faq-stat-icon" style="background:rgba(16,185,129,.1);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div>
                    <p class="faq-stat-label">평균 답변시간</p>
                    <p class="faq-stat-value">5분</p>
                </div>
            </div>
            <a href="/supports" class="faq-stat-card">
                <div class="faq-stat-icon" style="background:rgba(245,158,11,.1);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.8"><path d="M3 8a5 5 0 0 1 5-5h8a5 5 0 0 1 5 5v4a5 5 0 0 1-5 5h-1l-4 3v-3H8a5 5 0 0 1-5-5V8Z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <div>
                    <p class="faq-stat-label">Need Help?</p>
                    <p class="faq-stat-value link">고객센터 문의 →</p>
                </div>
            </a>
        </div>

        <a href="/supports" class="faq-contact-btn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M4 18h2v2H4v2H2V4h2v14Zm16 0H6v-2h14v2Zm2-2h-2V4h2v12Zm-12-2H6v-2h4v2Zm4-4H6V8h8v2Zm6-6H4V2h16v2Z"/></svg>
            고객센터 바로가기
        </a>
    </aside>

    <!-- 오른쪽 FAQ 목록 -->
    <div class="faq-main">
        <div class="faq-main-header">
            <h2 class="faq-main-title">전체 질문 목록</h2>
            {{#isAdmin}}
                <a href="/faqs/save" class="faq-new-btn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11 13H5v-2h6V5h2v6h6v2h-6v6h-2v-6Z"/></svg>
                    FAQ 등록
                </a>
            {{/isAdmin}}
        </div>

        <div class="faq-list">
            {{#faqList}}
                <div class="faq-item">
                    <div class="faq-question" onclick="toggleAnswer(this)">
                        <span class="badge">Q</span>
                        <span class="q-text">{{question}}</span>
                        <svg class="chevron" viewBox="0 0 20 20" fill="none">
                            <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-body">
                            <div class="faq-answer-row">
                                <span class="badge a-badge">A</span>
                                <span class="a-text">{{answer}}</span>
                            </div>
                            {{#isAdmin}}
                                <div class="faq-admin-inline">
                                    <form action="/faqs/edit/{{id}}" method="get" style="display:inline;">
                                        <button type="submit" class="faq-edit-btn">
                                            <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M14.17 2.83a2 2 0 0 1 2.83 2.83L6.5 16.17 2.5 17.5l1.33-4L14.17 2.83Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            수정
                                        </button>
                                    </form>
                                    <form action="/faqs/delete/{{id}}" method="post" style="display:inline;"
                                          onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                        <button type="submit" class="faq-delete-btn">
                                            <svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M4 5.5h12M8 5.5V3.5h4v2M5.5 5.5l.7 10a1 1 0 001 1h5.6a1 1 0 001-1l.7-10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            삭제
                                        </button>
                                    </form>
                                </div>
                            {{/isAdmin}}
                        </div>
                    </div>
                </div>
            {{/faqList}}
            {{^faqList}}
                <p class="faq-empty">— 등록된 FAQ가 없습니다 —</p>
            {{/faqList}}
        </div>
    </div>

</div>

<script>
    function toggleAnswer(el) {
        el.nextElementSibling.classList.toggle('open');
        el.classList.toggle('open');
    }
</script>

{{>layout/footer}}
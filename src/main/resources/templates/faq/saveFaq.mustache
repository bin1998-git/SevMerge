{{>layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .faq-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52); border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }
    .faq-card form { flex: 1; display: flex; flex-direction: column; }

    /* 헤더 */
    .faq-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 26px 36px 20px; border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .faq-header-left { display: flex; align-items: center; gap: 14px; }
    .btn-back {
        width: 36px; height: 36px; border-radius: 50%;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        display: flex; align-items: center; justify-content: center;
        color: #4a6fa5; text-decoration: none; transition: all .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .faq-title { font-size: 20px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; }
    .faq-desc { font-size: 13px; color: #4a6fa5; margin-top: 2px; }

    /* 폼 바디: board-save와 동일한 2컬럼 행 배치 */
    .faq-body { flex: 1; }
    .form-row {
        display: grid; grid-template-columns: 160px 1fr;
        align-items: flex-start; padding: 20px 36px;
        border-bottom: 1px solid rgba(37,99,235,.06); transition: background .15s;
    }
    .form-row:focus-within { background: rgba(37,99,235,.02); }
    .form-row-label { display: flex; align-items: center; gap: 10px; padding-top: 13px; flex-shrink: 0; }
    .form-label-text { font-size: 14px; font-weight: 700; color: #1e3a6e; display: flex; align-items: center; gap: 4px; }
    .form-required { color: #ef4444; font-size: 13px; }

    .form-input {
        width: 100%; padding: 12px 16px; background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(37,99,235,.1); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .18s; box-sizing: border-box;
    }
    .form-input::placeholder { color: #93aecf; }
    .form-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .form-textarea { resize: vertical; min-height: 280px; line-height: 1.8; }

    /* 사이드 팁 (오른쪽에 인라인으로) */
    .form-row-with-tip { display: grid; grid-template-columns: 160px 1fr 220px; align-items: flex-start; padding: 20px 36px; border-bottom: 1px solid rgba(37,99,235,.06); gap: 20px; }
    .form-tip-card {
        backdrop-filter: blur(8px); background: rgba(239,246,255,.6);
        border: 1px solid rgba(37,99,235,.15); border-radius: 14px; padding: 14px 16px;
        font-size: 12px; color: #4a6fa5; line-height: 1.6; align-self: flex-start; margin-top: 4px;
    }
    .form-tip-title { font-size: 11px; font-weight: 700; color: #2563eb; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .5px; }
    .tip-item { display: flex; gap: 6px; margin-bottom: 5px; }
    .tip-dot { width: 4px; height: 4px; border-radius: 50%; background: #2563eb; flex-shrink: 0; margin-top: 6px; }

    /* 푸터 */
    .faq-footer {
        display: flex; justify-content: flex-end; align-items: center; gap: 10px;
        padding: 18px 36px 24px; border-top: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .btn-cancel {
        padding: 11px 24px; border-radius: 20px; font-size: 14px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85); color: #2d4a7a;
        text-decoration: none; cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .btn-cancel:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); }
    .btn-submit {
        padding: 11px 28px; border-radius: 20px; font-size: 14px; font-weight: 800;
        background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff;
        border: none; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
        display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    @media (max-width: 960px) {
        .page-wrap { padding: 12px 12px 16px; }
        .faq-header, .form-row, .form-row-with-tip, .faq-footer { padding-left: 18px; padding-right: 18px; }
        .form-row, .form-row-with-tip { grid-template-columns: 1fr; gap: 8px; }
        .form-row-label { padding-top: 0; }
        .form-tip-card { display: none; }
    }
</style>

<section class="page-wrap">
    <div class="faq-card">

        <!-- 헤더 -->
        <div class="faq-header">
            <div class="faq-header-left">
                <a href="/policys/faq" class="btn-back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                </a>
                <div>
                    <div class="faq-title">FAQ 등록</div>
                    <div class="faq-desc">자주 묻는 질문과 답변을 새로 추가합니다.</div>
                </div>
            </div>
        </div>

        <!-- 폼 -->
        <form action="/faqs/save" method="post">
            <div class="faq-body">

                <!-- 질문 -->
                <div class="form-row-with-tip">
                    <div class="form-row-label">
                        <span class="form-label-text">질문 <span class="form-required">*</span></span>
                    </div>
                    <input type="text" name="question" class="form-input" placeholder="사용자가 자주 묻는 질문을 입력하세요" required/>
                    <div class="form-tip-card">
                        <div class="form-tip-title">질문 작성 팁</div>
                        <div class="tip-item"><span class="tip-dot"></span>사용자 관점으로 간결하게</div>
                        <div class="tip-item"><span class="tip-dot"></span>구체적인 상황 중심으로</div>
                    </div>
                </div>

                <!-- 답변 -->
                <div class="form-row-with-tip">
                    <div class="form-row-label" style="padding-top:13px;">
                        <span class="form-label-text">답변 <span class="form-required">*</span></span>
                    </div>
                    <textarea name="answer" class="form-input form-textarea" placeholder="질문에 대한 상세한 답변을 입력하세요" required></textarea>
                    <div class="form-tip-card" style="margin-top:4px;">
                        <div class="form-tip-title">답변 작성 팁</div>
                        <div class="tip-item"><span class="tip-dot"></span>핵심을 먼저, 부연은 뒤에</div>
                        <div class="tip-item"><span class="tip-dot"></span>전문 용어는 쉽게 풀어서</div>
                        <div class="tip-item"><span class="tip-dot"></span>줄바꿈으로 가독성 향상</div>
                        <div class="tip-item"><span class="tip-dot"></span>등록 즉시 공개됩니다</div>
                    </div>
                </div>

            </div>

            <!-- 푸터 -->
            <div class="faq-footer">
                <a href="/policys/faq" class="btn-cancel">취소</a>
                <button type="submit" class="btn-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    등록하기
                </button>
            </div>
        </form>

    </div>
</section>

{{>layout/footer}}
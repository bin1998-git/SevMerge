{{>layout/header}}

<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>

<style>
    :root {
        --brand-blue:      #2D6BFF;
        --brand-blue-deep: #1846C9;
        --brand-ink:       #0C1424;
        --brand-slate:     #33415C;
        --brand-muted:     #5A6B85;
        --brand-mist:      #EBEEF4;
        --brand-line:      #E2E7F0;
        --brand-white:     #FFFFFF;
    }

    .sf-wrap { font-family: 'Space Grotesk', sans-serif; }

    /* ── Hero ── */
    .sf-hero {
        background: var(--brand-white);
        border-bottom: 1px solid var(--brand-line);
        padding: 48px 28px 36px;
        text-align: center;
    }

    .sf-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--brand-muted);
        margin-bottom: 12px;
    }

    .sf-hero-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 16px;
        border-radius: 16px;
        background: #dde8ff;
        color: var(--brand-blue);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .sf-hero-icon svg { width: 28px; height: 28px; }

    .sf-hero h1 {
        font-size: 30px;
        font-weight: 700;
        color: var(--brand-ink);
        letter-spacing: -.02em;
        margin-bottom: 8px;
        line-height: 1.2;
    }

    .sf-hero p {
        font-size: 14px;
        color: var(--brand-muted);
        font-weight: 500;
    }

    /* ── Content ── */
    .sf-content-bg {
        background: var(--brand-mist);
    }

    .sf-content {
        max-width: 980px;
        margin: 0 auto;
        padding: 36px 28px 80px;
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 24px;
        align-items: start;
    }

    /* ── Form Card ── */
    .sf-card {
        background: var(--brand-white);
        border: 1px solid var(--brand-line);
        border-radius: 16px;
        padding: 32px;
    }

    .sf-card-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--brand-ink);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .sf-card-title::before {
        content: "";
        display: block;
        width: 4px;
        height: 16px;
        background: var(--brand-blue);
        border-radius: 2px;
        flex-shrink: 0;
    }

    .sf-group { margin-bottom: 20px; }

    .sf-label-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 7px;
    }

    .sf-label {
        font-size: 13px;
        font-weight: 700;
        color: var(--brand-slate);
    }

    .sf-required {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        color: var(--brand-blue);
        letter-spacing: .05em;
    }

    .sf-input,
    .sf-textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 11px 14px;
        border: 1.5px solid var(--brand-line);
        border-radius: 8px;
        font-size: 13.5px;
        color: var(--brand-ink);
        font-family: 'Space Grotesk', sans-serif;
        background: var(--brand-white);
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .sf-input:focus,
    .sf-textarea:focus {
        outline: none;
        border-color: var(--brand-blue);
        box-shadow: 0 0 0 3px #dde8ff;
    }

    .sf-textarea {
        resize: vertical;
        line-height: 1.7;
    }

    .sf-divider {
        border: none;
        border-top: 1px solid var(--brand-line);
        margin: 24px 0;
    }

    .sf-actions {
        display: flex;
        gap: 10px;
    }

    .sf-btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        flex: 1;
        padding: 12px 22px;
        border-radius: 8px;
        background: var(--brand-blue);
        color: #fff;
        font-size: 13.5px;
        font-weight: 700;
        font-family: 'Space Grotesk', sans-serif;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
    }

    .sf-btn-primary:hover { background: var(--brand-blue-deep); }

    .sf-btn-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 22px;
        border-radius: 8px;
        background: var(--brand-white);
        color: var(--brand-slate);
        font-size: 13.5px;
        font-weight: 700;
        font-family: 'Space Grotesk', sans-serif;
        border: 1.5px solid var(--brand-line);
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }

    .sf-btn-secondary:hover {
        background: var(--brand-mist);
        border-color: var(--brand-muted);
    }

    /* ── Sidebar ── */
    .sf-sidebar {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .sf-side-card {
        background: var(--brand-white);
        border: 1px solid var(--brand-line);
        border-radius: 14px;
        padding: 20px;
    }

    .sf-side-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--brand-blue);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .sf-side-title svg {
        width: 13px;
        height: 13px;
    }

    .sf-tip-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .sf-tip-list li {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 12.5px;
        color: var(--brand-slate);
        line-height: 1.55;
    }

    .sf-tip-list li .tip-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--brand-blue);
        flex-shrink: 0;
        margin-top: 6px;
    }

    .sf-notice-card {
        background: #dde8ff;
        border: 1px solid #b8ccff;
        border-radius: 14px;
        padding: 18px 20px;
    }

    .sf-notice-title {
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--brand-blue);
        margin-bottom: 10px;
    }

    .sf-notice-body {
        font-size: 12.5px;
        color: var(--brand-slate);
        line-height: 1.6;
    }

    .sf-notice-body strong {
        color: var(--brand-ink);
        font-weight: 700;
    }

    @media (max-width: 768px) {
        .sf-content { grid-template-columns: 1fr; }
        .sf-sidebar { display: none; }
    }

    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    .sf-hero { backdrop-filter: blur(20px); background: rgba(255,255,255,.75); border-bottom: 1px solid rgba(255,255,255,.6); }
    .sf-content-bg { background: rgba(176,200,232,.25); backdrop-filter: blur(8px); }
    .sf-card { backdrop-filter: blur(16px); background: rgba(255,255,255,.58); border: 1.5px solid rgba(255,255,255,.85); box-shadow: 0 8px 32px rgba(37,99,235,.08); }
    .sf-input, .sf-textarea { background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.15); color: #1e3a6e; }
    .sf-input:focus, .sf-textarea:focus { border-color: #2563eb; background: rgba(255,255,255,.95); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .sf-side-card { backdrop-filter: blur(12px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); }
    .sf-notice-card { background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2); }
    .sf-btn-primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 4px 14px rgba(37,99,235,.3); border-radius: 20px; }
    .sf-btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); }
    .sf-btn-secondary { backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a; border-radius: 20px; }
    .sf-btn-secondary:hover { background: rgba(255,255,255,.9); }
</style>

<div class="sf-wrap">

    <section class="sf-hero">
        <div class="sf-eyebrow">FAQ Management</div>
        <div class="sf-hero-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h1>FAQ 등록</h1>
        <p>자주 묻는 질문과 답변을 새로 추가합니다.</p>
    </section>

    <div class="sf-content-bg">
        <div class="sf-content">

            <!-- 폼 -->
            <div class="sf-card">
                <h2 class="sf-card-title">새 FAQ 작성</h2>
                <form action="/faqs/save" method="post">
                    <div class="sf-group">
                        <div class="sf-label-row">
                            <span class="sf-label">질문</span>
                            <span class="sf-required">REQUIRED</span>
                        </div>
                        <input class="sf-input" type="text" name="question"
                               placeholder="사용자가 자주 묻는 질문을 입력하세요" required>
                    </div>
                    <div class="sf-group">
                        <div class="sf-label-row">
                            <span class="sf-label">답변</span>
                            <span class="sf-required">REQUIRED</span>
                        </div>
                        <textarea class="sf-textarea" name="answer" rows="8"
                                  placeholder="질문에 대한 상세한 답변을 입력하세요" required></textarea>
                    </div>
                    <hr class="sf-divider">
                    <div class="sf-actions">
                        <a href="/policys/faq" class="sf-btn-secondary">
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="14" height="14">
                                <path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            취소
                        </a>
                        <button type="submit" class="sf-btn-primary">
                            <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" width="14" height="14">
                                <path d="M4 10L8.5 14.5L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            등록하기
                        </button>
                    </div>
                </form>
            </div>

            <!-- 사이드바 -->
            <aside class="sf-sidebar">
                <div class="sf-side-card">
                    <div class="sf-side-title">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M10 9v5M10 6.5v.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                        작성 가이드
                    </div>
                    <ul class="sf-tip-list">
                        <li><span class="tip-dot"></span>질문은 사용자 관점으로 간결하게 작성하세요.</li>
                        <li><span class="tip-dot"></span>답변은 핵심 내용을 먼저 작성하고 부연 설명을 뒤에 추가하세요.</li>
                        <li><span class="tip-dot"></span>전문 용어 사용 시 괄호 안에 설명을 덧붙이세요.</li>
                        <li><span class="tip-dot"></span>줄바꿈을 활용해 답변의 가독성을 높이세요.</li>
                    </ul>
                </div>

                <div class="sf-notice-card">
                    <div class="sf-notice-title">등록 후 안내</div>
                    <div class="sf-notice-body">
                        등록된 FAQ는 <strong>즉시 공개</strong>됩니다.<br>
                        내용 수정이 필요하면 FAQ 목록에서 수정 버튼을 이용하세요.
                    </div>
                </div>

                <div class="sf-side-card">
                    <div class="sf-side-title">
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M3 5h14M3 10h9M3 15h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                        </svg>
                        카테고리 예시
                    </div>
                    <ul class="sf-tip-list">
                        <li><span class="tip-dot"></span>결제 / 환불 관련</li>
                        <li><span class="tip-dot"></span>계정 및 프로필 관리</li>
                        <li><span class="tip-dot"></span>프로젝트 진행 방법</li>
                        <li><span class="tip-dot"></span>수수료 및 정산 안내</li>
                    </ul>
                </div>
            </aside>

        </div>
    </div>

</div><!-- /sf-wrap -->

{{>layout/footer}}
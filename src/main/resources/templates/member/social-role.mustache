{{> layout/header}}

<style>
    .role-section {
        min-height: calc(100vh - 64px);
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 48px 28px;
        position: relative; overflow: hidden;
    }
    .role-section::before {
        content: ''; position: absolute;
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.6) 0%, transparent 70%);
        top: -80px; left: -80px; pointer-events: none;
    }
    .role-section::after {
        content: ''; position: absolute;
        width: 350px; height: 350px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.15) 0%, transparent 70%);
        bottom: -60px; right: -60px; pointer-events: none;
    }
    .role-glow-mid {
        position: absolute; width: 300px; height: 300px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%);
        top: 50%; left: 50%; transform: translate(-50%, -50%);
        pointer-events: none;
    }
    .role-particle {
        position: absolute; border-radius: 50%;
        background: rgba(255,255,255,.5);
        animation: float 6s ease-in-out infinite;
        pointer-events: none;
    }
    @keyframes float {
        0%, 100% { transform: translateY(0) scale(1); opacity: .5; }
        50% { transform: translateY(-20px) scale(1.1); opacity: .8; }
    }
    .role-inner { width: 100%; max-width: 680px; text-align: center; position: relative; z-index: 1; }
    .role-header { margin-bottom: 40px; }
    .role-logo { font-size: 24px; font-weight: 900; color: #1e3a6e; margin-bottom: 12px; letter-spacing: -1px; }
    .role-logo .hl { color: var(--blue); }
    .role-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; margin-bottom: 8px; }
    .role-desc { font-size: 13px; color: #4a6fa5; line-height: 1.7; }

    .role-connector {
        display: flex; align-items: flex-end; justify-content: center;
        height: 48px; margin-bottom: -2px; position: relative; z-index: 2;
    }
    .connector-line { width: 2px; height: 24px; background: linear-gradient(to bottom, transparent, #2563eb); }
    .connector-h { width: 160px; height: 2px; background: #2563eb; }
    .connector-dot { width: 8px; height: 8px; border-radius: 50%; background: #2563eb; margin-top: -3px; flex-shrink: 0; }

    .role-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px; }
    .role-card {
        border-radius: 28px; padding: 36px 28px 60px;
        cursor: pointer; transition: all .25s;
        position: relative; overflow: hidden; text-align: center;
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border: 1.5px solid rgba(255,255,255,.7);
    }
    .role-card-client {
        background: rgba(255,255,255,.45);
        box-shadow: 0 8px 32px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.8);
    }
    .role-card-client:hover {
        transform: translateY(-8px) scale(1.01);
        background: rgba(255,255,255,.6);
        box-shadow: 0 24px 56px rgba(37,99,235,.18), inset 0 1px 0 rgba(255,255,255,.9);
        border-color: rgba(37,99,235,.4);
    }
    .role-card-expert {
        background: rgba(255,255,255,.35);
        box-shadow: 0 8px 32px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.7);
    }
    .role-card-expert:hover {
        transform: translateY(-8px) scale(1.01);
        background: rgba(255,255,255,.5);
        box-shadow: 0 24px 56px rgba(37,99,235,.18), inset 0 1px 0 rgba(255,255,255,.9);
        border-color: rgba(37,99,235,.4);
    }
    .role-card button { display: none; }
    .card-glow {
        position: absolute; width: 200px; height: 200px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.6) 0%, transparent 70%);
        bottom: -60px; left: 50%; transform: translateX(-50%); pointer-events: none;
    }
    .role-icon-wrap { width: 140px; height: 140px; margin: 0 auto 24px; position: relative; z-index: 1; }
    .role-icon-bg {
        width: 100%; height: 100%; border-radius: 36px;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(145deg, rgba(255,255,255,.9) 0%, rgba(220,235,255,.8) 100%);
        box-shadow: 0 20px 40px rgba(37,99,235,.15), 0 4px 12px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        border: 1px solid rgba(255,255,255,.8); transition: all .25s;
    }
    .role-card:hover .role-icon-bg {
        box-shadow: 0 28px 52px rgba(37,99,235,.2), 0 8px 20px rgba(37,99,235,.15), inset 0 1px 0 rgba(255,255,255,1);
        transform: translateY(-4px) rotate(-2deg);
    }
    .role-icon-bg svg { color: #1e3a8a; filter: drop-shadow(0 4px 8px rgba(37,99,235,.3)); }
    .role-icon-reflection {
        position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);
        width: 80%; height: 20px;
        background: radial-gradient(ellipse, rgba(37,99,235,.2) 0%, transparent 70%);
        filter: blur(6px);
    }
    .role-name { font-size: 20px; font-weight: 900; color: #1e3a6e; margin-bottom: 6px; letter-spacing: -0.3px; position: relative; z-index: 1; }
    .role-sub { font-size: 13px; color: #4a6fa5; line-height: 1.65; margin-bottom: 20px; position: relative; z-index: 1; }
    .role-divider { height: 1px; background: rgba(37,99,235,.15); margin-bottom: 16px; position: relative; z-index: 1; }
    .role-benefits { display: flex; flex-direction: column; gap: 9px; position: relative; z-index: 1; text-align: left; }
    .role-benefit { display: flex; align-items: center; gap: 9px; font-size: 12px; font-weight: 600; color: #2d4a7a; }
    .benefit-dot {
        width: 20px; height: 20px; border-radius: 6px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 11px; font-weight: 800;
        background: rgba(37,99,235,.12); color: var(--blue);
    }
    .role-card-arrow {
        position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%);
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700; white-space: nowrap;
        padding: 8px 20px; border-radius: 20px;
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff; z-index: 1;
        box-shadow: 0 4px 12px rgba(37,99,235,.3); transition: all .2s;
    }
    .role-card:hover .role-card-arrow {
        box-shadow: 0 6px 20px rgba(37,99,235,.4);
        transform: translateX(-50%) translateY(-1px);
    }
    .role-hint {
        font-size: 13px; color: #4a6fa5;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        position: relative; z-index: 1;
    }
    .role-hint::before { content: ''; display: inline-block; width: 4px; height: 4px; border-radius: 50%; background: #4a6fa5; }
    @media (max-width: 560px) { .role-cards { grid-template-columns: 1fr; } }
</style>

<section class="role-section">
    <div class="role-glow-mid"></div>
    <div class="role-particle" style="width:12px;height:12px;top:15%;left:10%;animation-delay:0s;"></div>
    <div class="role-particle" style="width:8px;height:8px;top:25%;left:85%;animation-delay:1s;"></div>
    <div class="role-particle" style="width:16px;height:16px;top:70%;left:8%;animation-delay:2s;"></div>
    <div class="role-particle" style="width:10px;height:10px;top:80%;left:88%;animation-delay:0.5s;"></div>
    <div class="role-particle" style="width:6px;height:6px;top:50%;left:5%;animation-delay:1.5s;"></div>
    <div class="role-particle" style="width:14px;height:14px;top:10%;left:60%;animation-delay:2.5s;"></div>

    <div class="role-inner">
        <div class="role-header">
            <div class="role-logo">I<span class="hl">code</span>U</div>
            <h1 class="role-title">코드요를 어떻게 이용하시겠어요?</h1>
            <p class="role-desc">가입 유형을 선택해 주세요.<br>가입 이후에도 마이페이지에서 전문가 신청을 할 수 있어요.</p>
        </div>

        <div class="role-connector">
            <div style="display:flex; flex-direction:column; align-items:center;">
                <div class="connector-dot"></div>
                <div class="connector-line"></div>
                <div style="display:flex; align-items:flex-start;">
                    <div style="display:flex; flex-direction:column; align-items:flex-end;">
                        <div class="connector-h"></div>
                        <div style="width:2px; height:12px; background:#2563eb;"></div>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:flex-start;">
                        <div class="connector-h"></div>
                        <div style="width:2px; height:12px; background:#2563eb;"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="role-cards">
            <form action="/social-join" method="POST" style="display:contents;">
                <input type="hidden" name="role" value="CLIENT"/>
                <div class="role-card role-card-client" onclick="this.closest('form').submit()">
                    <div class="card-glow"></div>
                    <div class="role-icon-wrap">
                        <div class="role-icon-bg">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 8h2v12H2zm18 0h2v12h-2zM4 6h16v2H4zm0 14h16v2H4zM8 4h2v2H8zm2-2h4v2h-4zm4 2h2v2h-2z"/>
                            </svg>
                        </div>
                        <div class="role-icon-reflection"></div>
                    </div>
                    <div class="role-name">의뢰인으로 이용</div>
                    <div class="role-sub">프로젝트를 등록하고<br>검증된 전문가를 찾고 싶어요</div>
                    <div class="role-divider"></div>
                    <div class="role-benefits">
                        <div class="role-benefit"><span class="benefit-dot">✓</span> 평균 24시간 내 전문가 매칭</div>
                        <div class="role-benefit"><span class="benefit-dot">✓</span> 에스크로 안전 결제 보장</div>
                        <div class="role-benefit"><span class="benefit-dot">✓</span> 등급 인증 전문가만 연결</div>
                    </div>
                    <div class="role-card-arrow">시작하기 →</div>
                </div>
            </form>

            <form action="/social-expert-form" method="GET" style="display:contents;">
                <div class="role-card role-card-expert" onclick="this.closest('form').submit()">
                    <div class="card-glow"></div>
                    <div class="role-icon-wrap">
                        <div class="role-icon-bg">
                            <svg width="64" height="64" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 22H0v-4h2v4Zm14 0h-2v-4h2v4Zm8 0h-2v-4h2v4ZM4 18H2v-2h2v2Zm10 0h-2v-2h2v2Zm8 0h-2v-2h2v2Zm-10-2H4v-2h8v2Zm8 0h-4v-2h4v2Zm-9-4H5v-2h6v2Zm8 0h-4v-2h4v2ZM5 10H3V4h2v6Zm8 0h-2V4h2v6Zm8 0h-2V4h2v6ZM11 4H5V2h6v2Zm8 0h-4V2h4v2Z"/>
                            </svg>
                        </div>
                        <div class="role-icon-reflection"></div>
                    </div>
                    <div class="role-name">전문가로 활동</div>
                    <div class="role-sub">프로젝트에 제안서를 보내고<br>수익을 창출하고 싶어요</div>
                    <div class="role-divider"></div>
                    <div class="role-benefits">
                        <div class="role-benefit"><span class="benefit-dot">✓</span> 월평균 340만원 수익 창출</div>
                        <div class="role-benefit"><span class="benefit-dot">✓</span> 안전한 에스크로 대금 정산</div>
                        <div class="role-benefit"><span class="benefit-dot">✓</span> MASTER 등급 인증 시스템</div>
                    </div>
                    <div class="role-card-arrow">시작하기 →</div>
                </div>
            </form>
        </div>

        <p class="role-hint">카드를 클릭하면 선택한 유형으로 가입돼요.</p>
    </div>
</section>

{{> layout/footer}}
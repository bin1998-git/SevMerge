{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    body::before { content:''; position:fixed; inset:0; background-image: linear-gradient(rgba(255,255,255,.12) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,.12) 1px,transparent 1px); background-size:40px 40px; opacity:.35; pointer-events:none; z-index:0; }

    .page-wrap { min-height:calc(100vh - 64px); display:flex; align-items:stretch; position:relative; z-index:1; }

    /* 왼쪽 히어로 패널 */
    .hero-panel {
        width:380px; flex-shrink:0;
        backdrop-filter:blur(20px); background:rgba(255,255,255,.55);
        border-right:1.5px solid rgba(255,255,255,.8);
        display:flex; flex-direction:column; justify-content:center;
        padding:52px 44px; position:sticky; top:64px; height:calc(100vh - 64px);
    }
    .page-logo { font-size:22px; font-weight:900; color:#1e3a8a; letter-spacing:-1px; margin-bottom:24px; }
    .page-logo .hl { color:#2563eb; }
    .hero-icon-wrap {
        width:72px; height:72px; border-radius:22px;
        display:flex; align-items:center; justify-content:center; margin-bottom:22px;
    }
    .hero-title { font-size:28px; font-weight:900; color:#172554; letter-spacing:-1px; line-height:1.2; margin-bottom:12px; }
    .hero-desc { font-size:14px; color:#4a6fa5; line-height:1.8; }

    /* 오른쪽 콘텐츠 */
    .content-panel { flex:1; display:flex; align-items:center; justify-content:center; padding:52px 52px; }
    .content-inner { width:100%; max-width:520px; display:flex; flex-direction:column; gap:16px; }

    /* 글래스 카드 */
    .glass-card {
        backdrop-filter:blur(20px); background:rgba(255,255,255,.58);
        border:1.5px solid rgba(255,255,255,.85); border-radius:24px; padding:32px;
        box-shadow:0 16px 48px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        position:relative;
    }
    .glass-card::before { content:''; position:absolute; left:10%; right:10%; top:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,.9),transparent); }
    .card-label { font-size:11px; font-weight:700; color:#2563eb; letter-spacing:.8px; text-transform:uppercase; margin-bottom:12px; }

    /* 단계 표시 */
    .step-list { display:flex; flex-direction:column; gap:12px; }
    .step-item { display:flex; align-items:center; gap:12px; font-size:13px; font-weight:600; color:#2d4a7a; }
    .step-item.done { color:#059669; }
    .step-item.pending { color:#93aecf; }
    .step-dot { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .step-dot.done { background:rgba(16,185,129,.1); color:#059669; }
    .step-dot.active { background:rgba(37,99,235,.1); color:#2563eb; }
    .step-dot.pending { background:rgba(156,163,175,.1); color:#93aecf; }

    /* 사유 박스 */
    .reason-box { background:rgba(254,226,226,.5); border:1px solid rgba(252,165,165,.6); border-radius:14px; padding:18px 20px; }
    .reason-label { font-size:11px; font-weight:700; color:#ef4444; letter-spacing:.5px; text-transform:uppercase; margin-bottom:8px; }
    .reason-text { font-size:14px; color:#1e3a6e; line-height:1.6; }

    /* 버튼 */
    .btn-primary {
        display:block; width:100%; padding:14px;
        background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#fff;
        border:none; border-radius:20px; font-size:14px; font-weight:800;
        cursor:pointer; font-family:inherit; text-decoration:none; text-align:center;
        box-shadow:0 4px 14px rgba(37,99,235,.3); transition:all .15s;
    }
    .btn-primary:hover { transform:translateY(-1px); box-shadow:0 8px 20px rgba(37,99,235,.4); }
    .btn-outline {
        display:block; width:100%; padding:13px;
        backdrop-filter:blur(8px); background:rgba(255,255,255,.6); color:#2d4a7a;
        border:1.5px solid rgba(255,255,255,.8); border-radius:20px;
        font-size:14px; font-weight:700; text-decoration:none; text-align:center; transition:all .15s;
    }
    .btn-outline:hover { background:rgba(255,255,255,.9); border-color:rgba(37,99,235,.3); }

    /* 하단 링크 */
    .bottom-links { display:flex; flex-wrap:wrap; justify-content:center; gap:4px 14px; }
    .bottom-links a { font-size:12px; color:#4a6fa5; text-decoration:none; transition:color .15s; }
    .bottom-links a:hover { color:#2563eb; }

    /* 폼 (재신청) */
    .form-group { display:flex; flex-direction:column; gap:7px; }
    .form-label { font-size:13px; font-weight:700; color:#2d4a7a; }
    .form-label .required { color:#ef4444; margin-left:2px; }
    .form-label .opt { color:#93aecf; font-weight:500; margin-left:4px; }
    .form-input, .form-textarea {
        padding:12px 16px; background:rgba(255,255,255,.7); border:1.5px solid rgba(37,99,235,.15);
        border-radius:12px; font-size:14px; font-family:inherit; color:#1e3a6e; outline:none; transition:all .15s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color:#93aecf; }
    .form-input:focus, .form-textarea:focus { border-color:#2563eb; background:rgba(255,255,255,.95); box-shadow:0 0 0 3px rgba(37,99,235,.08); }
    .form-textarea { resize:vertical; min-height:80px; line-height:1.6; }
    .form-hint { font-size:12px; color:#4a6fa5; }
    .skill-input-wrap { display:flex; gap:8px; }
    .skill-input-wrap .form-input { flex:1; }
    .skill-add-btn { padding:0 16px; background:#1e3a6e; color:#fff; border:none; border-radius:12px; font-size:13px; font-weight:700; cursor:pointer; font-family:inherit; transition:all .15s; }
    .skill-add-btn:hover { background:#2563eb; }
    .skill-tags { display:flex; flex-wrap:wrap; gap:7px; margin-top:8px; }
    .skill-tag { display:inline-flex; align-items:center; gap:6px; padding:5px 12px; background:rgba(37,99,235,.1); color:#2563eb; border:1px solid rgba(37,99,235,.2); border-radius:20px; font-size:12px; font-weight:600; }
    .skill-tag button { background:none; border:none; color:#93c5fd; cursor:pointer; font-size:13px; line-height:1; padding:0; }
    .skill-tag button:hover { color:#ef4444; }

    @media (max-width:900px) { .hero-panel { display:none; } .content-panel { padding:32px 20px; } }
</style>
<div class="page-wrap">
    <div class="hero-panel">
        <div class="page-logo">I<span class="hl">code</span>U</div>
        <div class="hero-icon-wrap" style="background:rgba(239,68,68,.1);">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="#ef4444"><path d="M13 13h-2V7h2v6Zm0 4h-2v-2h2v2ZM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8Z"/></svg>
        </div>
        <h1 class="hero-title">신청이<br>거부되었습니다</h1>
        <p class="hero-desc">아쉽게도 이번 전문가 신청이 승인되지 않았어요. 거절 사유를 확인하고 보완해 다시 신청하실 수 있습니다.</p>
    </div>
    <div class="content-panel">
        <div class="content-inner">
            {{#reason}}
                <div class="reason-box">
                    <div class="reason-label">거절 사유</div>
                    <div class="reason-text">{{reason}}</div>
                </div>
            {{/reason}}
            {{^reason}}
                <div class="reason-box">
                    <div class="reason-label">거절 사유</div>
                    <div class="reason-text">별도 사유가 등록되지 않았습니다. 자세한 내용은 고객센터로 문의해 주세요.</div>
                </div>
            {{/reason}}
            <a href="/expert-reapply-form" class="btn-primary">전문가로 다시 신청하기</a>
            <a href="/" class="btn-outline">홈으로 가기</a>
            <div class="bottom-links">
                <a href="/login">로그인</a>
                <a href="/join-role?role=CLIENT">의뢰인으로 전환</a>
                <a href="/boards">고객센터 문의</a>
            </div>
        </div>
    </div>
</div>
{{> layout/footer}}
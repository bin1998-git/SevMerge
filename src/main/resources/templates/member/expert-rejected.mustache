{{> layout/header}}
<style>

    :root { --blue: #2563eb; --blue-dark: #1d4ed8; --navy: #172554; }

    .status-section {
        min-height: calc(100vh - 64px);
        background:
            radial-gradient(circle at 10% 10%, rgba(255,255,255,.6), transparent 25%),
            radial-gradient(circle at 90% 90%, rgba(37,99,235,.15), transparent 30%),
            linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        position: relative; overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        padding: 60px 28px;
    }
    .status-section::before {
        content: ''; position: fixed; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.12) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.12) 1px, transparent 1px);
        background-size: 40px 40px; opacity: .35; pointer-events: none;
    }
    .status-inner {
        width: 100%; max-width: 560px;
        position: relative; z-index: 2;
    }
    .glass-card {
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 28px; padding: 52px 48px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative; text-align: center;
    }
    .glass-card::before {
        content: ''; position: absolute; left: 10%; right: 10%; top: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }
    .page-logo { font-size: 22px; font-weight: 900; color: #1e3a8a; margin-bottom: 28px; letter-spacing: -1px; }
    .page-logo .hl { color: var(--blue); }
    .status-icon-wrap {
        width: 80px; height: 80px; border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 24px;
    }
    .status-title { font-size: 22px; font-weight: 900; color: var(--navy); margin-bottom: 10px; letter-spacing: -0.5px; }
    .status-desc { font-size: 14px; color: #4a6fa5; line-height: 1.8; margin-bottom: 28px; }

    /* 사유 박스 */
    .reason-box {
        background: rgba(254,226,226,.5); border: 1px solid rgba(252,165,165,.6);
        border-radius: 14px; padding: 18px 20px; text-align: left; margin-bottom: 28px;
    }
    .reason-label { font-size: 11px; font-weight: 700; color: #ef4444; letter-spacing: .5px; text-transform: uppercase; margin-bottom: 8px; }
    .reason-text { font-size: 14px; color: #1e3a6e; line-height: 1.6; }

    /* 버튼 */
    .status-btn-primary {
        display: block; width: 100%; padding: 15px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        border: none; border-radius: 25px; font-size: 15px; font-weight: 800;
        cursor: pointer; font-family: inherit; text-decoration: none;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s; margin-bottom: 10px;
    }
    .status-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }
    .status-btn-outline {
        display: block; width: 100%; padding: 14px;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); color: #2d4a7a;
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 25px;
        font-size: 14px; font-weight: 700; text-decoration: none;
        transition: all .15s; box-sizing: border-box;
    }
    .status-btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); }

    /* 하단 링크 */
    .status-links {
        display: flex; flex-wrap: wrap; justify-content: center; gap: 6px 16px;
        margin-top: 24px; padding-top: 20px; border-top: 1px solid rgba(37,99,235,.1);
    }
    .status-links a { font-size: 13px; color: #4a6fa5; text-decoration: none; transition: color .15s; }
    .status-links a:hover { color: var(--blue); text-decoration: underline; }

    /* 폼 (재신청용) */
    .form-section { text-align: left; }
    .section-label {
        font-size: 11px; font-weight: 700; color: var(--blue);
        letter-spacing: .8px; text-transform: uppercase; margin-bottom: 16px;
    }
    .f-divider { height: 1px; background: rgba(37,99,235,.1); margin: 20px 0; border: none; }
    .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: 18px; }
    .form-label { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-label .opt { color: #93aecf; font-weight: 500; margin-left: 4px; }
    .form-input, .form-textarea {
        padding: 13px 16px;
        background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.15);
        border-radius: 12px; font-size: 14px; font-family: inherit;
        color: #1e3a6e; outline: none; transition: all .15s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color: #93aecf; }
    .form-input:focus, .form-textarea:focus {
        border-color: var(--blue); background: rgba(255,255,255,.95);
        box-shadow: 0 0 0 3px rgba(37,99,235,.08);
    }
    .form-textarea { resize: vertical; min-height: 90px; line-height: 1.6; }
    .form-hint { font-size: 12px; color: #4a6fa5; }

    .skill-input-wrap { display: flex; gap: 8px; }
    .skill-input-wrap .form-input { flex: 1; }
    .skill-add-btn {
        padding: 0 18px; background: #1e3a6e; color: #fff;
        border: none; border-radius: 12px; font-size: 13px; font-weight: 700;
        cursor: pointer; font-family: inherit; white-space: nowrap; transition: all .15s;
    }
    .skill-add-btn:hover { background: var(--blue); }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .skill-tag {
        display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px;
        background: rgba(37,99,235,.1); color: var(--blue);
        border: 1px solid rgba(37,99,235,.2); border-radius: 20px;
        font-size: 12px; font-weight: 600;
    }
    .skill-tag button { background: none; border: none; color: #93c5fd; cursor: pointer; font-size: 14px; line-height: 1; padding: 0; }
    .skill-tag button:hover { color: #ef4444; }

    @media (max-width: 640px) {
        .status-section { padding: 40px 16px; }
        .glass-card { padding: 36px 24px; }
    }

</style>

<section class="status-section">
    <div class="status-inner">
        <div class="glass-card">
            <div class="page-logo">I<span class="hl">code</span>U</div>

            <div class="status-icon-wrap" style="background: rgba(239,68,68,.1);">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" style="color:#ef4444;">
                    <path d="M13 13h-2V7h2v6Zm0 4h-2v-2h2v2ZM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8Z"/>
                </svg>
            </div>

            <h1 class="status-title">전문가 신청이 거부되었습니다</h1>
            <p class="status-desc">
                아쉽게도 이번 전문가 신청이 승인되지 않았어요.<br>
                아래 사유를 확인하고 보완해 다시 신청하실 수 있습니다.
            </p>

            {{#reason}}
                <div class="reason-box">
                    <div class="reason-label">거절 사유</div>
                    <div class="reason-text">{{reason}}</div>
                </div>
            {{/reason}}
            {{^reason}}
                <div class="reason-box">
                    <div class="reason-label">거절 사유</div>
                    <div class="reason-text">별도 사유가 등록되지 않았습니다. 자세한 내용은 고객센터로 문의해 주세요.</div>
                </div>
            {{/reason}}

            <a href="/expert-reapply-form" class="status-btn-primary">전문가로 다시 신청하기</a>
            <a href="/" class="status-btn-outline">홈으로 가기</a>

            <div class="status-links">
                <a href="/login">로그인</a>
                <a href="/join-role?role=CLIENT">의뢰인으로 전환</a>
                <a href="/join-start">다른 방법으로 가입</a>
                <a href="/boards">고객센터 문의</a>
            </div>
        </div>
    </div>
</section>
{{> layout/footer}}
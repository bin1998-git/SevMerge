{{> layout/header}}
<style>

    :root {
        --blue: #2563eb; --blue-dark: #1d4ed8;
        --navy: #172554; --cyan: #00c8e0;
    }

    .page-section {
        min-height: calc(100vh - 64px);
        background:
            radial-gradient(circle at 10% 10%, rgba(255,255,255,.6), transparent 25%),
            radial-gradient(circle at 90% 90%, rgba(37,99,235,.15), transparent 30%),
            linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        position: relative; overflow: hidden;
        display: flex; align-items: flex-start; justify-content: center;
        padding: 52px 28px 80px;
    }
    .page-section::before {
        content: ''; position: fixed; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.12) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.12) 1px, transparent 1px);
        background-size: 40px 40px; opacity: .35; pointer-events: none;
    }

    .page-inner {
        width: 100%; max-width: 680px;
        position: relative; z-index: 2;
    }

    /* 헤더 */
    .form-page-header { text-align: center; margin-bottom: 32px; }
    .form-page-logo { font-size: 26px; font-weight: 900; color: #1e3a8a; margin-bottom: 10px; letter-spacing: -1px; }
    .form-page-logo .hl { color: var(--blue); }
    .form-page-title { font-size: 26px; font-weight: 900; color: var(--navy); letter-spacing: -0.5px; margin-bottom: 6px; }
    .form-page-desc { font-size: 14px; color: #4a6fa5; line-height: 1.6; }

    /* 글래스 카드 */
    .glass-card {
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 28px; padding: 48px 52px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .glass-card::before {
        content: ''; position: absolute; left: 10%; right: 10%; top: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }

    /* 섹션 구분 */
    .section-label {
        font-size: 11px; font-weight: 700; color: var(--blue);
        letter-spacing: .8px; text-transform: uppercase;
        margin-bottom: 16px; margin-top: 4px;
    }
    .f-divider, .section-divider {
        height: 1px; background: rgba(37,99,235,.1);
        margin: 20px 0; border: none;
    }

    /* 2컬럼 폼 그리드 */
    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 20px; }

    /* 폼 요소 */
    .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: 18px; }
    .form-label { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-label .opt { color: #93aecf; font-weight: 500; margin-left: 4px; }
    .form-input, .form-textarea {
        padding: 13px 16px;
        background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.15);
        border-radius: 12px; font-size: 14px; font-family: inherit;
        color: #1e3a6e; outline: none; transition: all .15s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color: #93aecf; }
    .form-input:focus, .form-textarea:focus {
        border-color: var(--blue); background: rgba(255,255,255,.95);
        box-shadow: 0 0 0 3px rgba(37,99,235,.08);
    }
    .form-input:disabled { color: #93aecf; background: rgba(240,244,250,.6); cursor: not-allowed; }
    .form-textarea { resize: vertical; min-height: 90px; line-height: 1.6; }
    .form-hint { font-size: 12px; color: #4a6fa5; }

    /* 인증 버튼 */
    .email-verify-wrap { display: flex; gap: 8px; }
    .email-verify-wrap .form-input { flex: 1; }
    .verify-btn {
        padding: 0 20px; background: #1e3a6e; color: #fff;
        border: none; border-radius: 12px; font-size: 13px; font-weight: 700;
        cursor: pointer; font-family: inherit; white-space: nowrap; transition: all .15s;
    }
    .verify-btn:hover { background: var(--blue); }
    .verify-btn:disabled { background: #93aecf; cursor: not-allowed; }

    /* 제출 버튼 */
    .submit-btn {
        width: 100%; padding: 16px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        border: none; border-radius: 25px; font-size: 15px; font-weight: 800;
        cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s; margin-top: 8px;
    }
    .submit-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    /* 업로드 버튼 */
    .upload-btn {
        display: inline-block; padding: 10px 22px;
        background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.3);
        color: var(--blue); border-radius: 10px; font-size: 13px; font-weight: 700;
        cursor: pointer; transition: all .15s;
    }
    .upload-btn:hover { background: rgba(255,255,255,.95); border-color: var(--blue); }

    /* 역할 태그 */
    .role-tag {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700; color: var(--blue);
        background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2);
        padding: 5px 14px; border-radius: 20px; margin-bottom: 4px;
    }

    /* 공지 박스 */
    .notice-box {
        background: rgba(254,243,199,.75); border: 1px solid rgba(253,230,138,.8);
        border-radius: 12px; padding: 14px 16px;
        font-size: 13px; color: #b45309; line-height: 1.6; margin-bottom: 24px;
    }

    /* 에러 박스 */
    .error-box {
        background: rgba(255,243,243,.85); border: 1px solid #fecaca;
        border-radius: 10px; padding: 12px 14px;
        font-size: 13px; color: #ef4444; font-weight: 600; margin-bottom: 8px;
    }

    /* 약관 */
    .terms-box {
        background: rgba(255,255,255,.4); border: 1px solid rgba(255,255,255,.7);
        border-radius: 12px; padding: 18px; display: flex; flex-direction: column; gap: 12px;
        margin-bottom: 8px;
    }
    .terms-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #2d4a7a; }
    .terms-item input { width: 16px; height: 16px; accent-color: var(--blue); cursor: pointer; }
    .terms-item label { cursor: pointer; }

    /* 기술 스택 */
    .sp-chip {
        padding: 6px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
        cursor: pointer; border: 1.5px solid rgba(37,99,235,.2);
        background: rgba(255,255,255,.7); color: #2d4a7a;
        font-family: inherit; transition: all .12s; user-select: none;
    }
    .sp-chip:hover { border-color: var(--blue); color: var(--blue); background: rgba(255,255,255,.95); }
    .sp-chip.selected { background: var(--blue); border-color: var(--blue); color: #fff; }
    #spBody {
        background: rgba(255,255,255,.5); border: 1.5px solid rgba(37,99,235,.15);
        border-radius: 10px; padding: 14px;
        display: flex; flex-wrap: wrap; gap: 8px; min-height: 72px;
    }
    .skill-tag {
        display: inline-flex; align-items: center; gap: 5px; padding: 5px 11px;
        background: rgba(37,99,235,.1); color: var(--blue);
        border: 1px solid rgba(37,99,235,.2); border-radius: 20px; font-size: 12px; font-weight: 600;
    }
    .skill-tag button { background: none; border: none; color: #93c5fd; cursor: pointer; font-size: 13px; line-height: 1; padding: 0; }
    .skill-tag button:hover { color: #ef4444; }
    .skill-empty { font-size: 12px; color: #93aecf; }
    select.form-input { background: rgba(255,255,255,.7); color: #1e3a6e; }

    /* 하단 링크 */
    .auth-footer {
        text-align: center; margin-top: 20px; color: #4a6fa5; font-size: 14px; line-height: 1.9;
    }
    .auth-footer a { color: var(--blue); font-weight: 700; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }

    /* 반응형 */
    @media (max-width: 720px) {
        .glass-card { padding: 32px 24px; }
        .form-grid-2 { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
        .page-section { padding: 32px 16px 60px; }
    }

</style>

<section class="page-section">
    <div class="page-inner">
        <div class="form-page-header">
            <div class="form-page-logo">I<span class="hl">code</span>U</div>
            <h1 class="form-page-title">전문가 정보 입력</h1>
            <p class="form-page-desc">제출 후 관리자 승인을 거쳐 활동할 수 있어요.</p>
        </div>

        <div class="glass-card">
            <div class="notice-box">ⓘ 전문가 가입은 <b>관리자 승인 후</b> 로그인할 수 있습니다. 승인 전까지는 로그인이 제한됩니다.</div>

            <form action="/social-expert-join" method="POST" id="expertForm">

                <div class="section-label">기본 정보</div>

                <div class="form-group">
                    <label class="form-label">이름 <span class="required">*</span></label>
                    <input type="text" name="name" class="form-input" value="{{name}}"/>
                </div>

                {{#emailReadonly}}
                    <div class="form-group">
                        <label class="form-label">이메일 <span class="required">*</span></label>
                        <input type="email" name="email" class="form-input" value="{{email}}" readonly/>
                        <span class="form-hint">소셜 계정에서 가져온 이메일이에요.</span>
                    </div>
                {{/emailReadonly}}
                {{^emailReadonly}}<input type="hidden" name="email" value=""/>{{/emailReadonly}}

                <div class="f-divider"></div>
                <div class="section-label">전문가 정보</div>

                <div class="form-group">
                    <label class="form-label">한 줄 소개 <span class="required">*</span></label>
                    <input type="text" name="intro" class="form-input" placeholder="예) 5년차 React 개발자입니다"/>
                </div>
                <div class="form-group">
                    <label class="form-label">경력 <span class="required">*</span></label>
                    <textarea name="career" class="form-textarea" placeholder="예) OO기업 백엔드 개발 3년&#10;프리랜서 외주 개발 2년"></textarea>
                    <span class="form-hint">주요 경력을 자유롭게 작성해 주세요.</span>
                </div>
                <div class="form-group">
                    <label class="form-label">GitHub 주소 <span class="opt">(선택)</span></label>
                    <input type="text" name="githubUrl" class="form-input" placeholder="https://github.com/username"/>
                </div>
                <div class="form-group">
                    <label class="form-label">기술 스택 <span class="required">*</span></label>
                    <select id="categorySelect" class="form-input" style="margin-bottom:10px;" onchange="renderChips()">
                        <option value="0">언어</option><option value="1">백엔드</option><option value="2">프론트엔드</option>
                        <option value="3">모바일</option><option value="4">DB/인프라</option><option value="5">디자인</option>
                        <option value="6">데이터/AI</option><option value="7">영상</option><option value="8">기타</option>
                    </select>
                    <div id="spBody"></div>
                    <div style="margin-top:10px;">
                        <div style="font-size:12px;color:#4a6fa5;margin-bottom:8px;">선택된 기술</div>
                        <div class="skill-tags" id="skillTags"><span class="skill-empty">선택된 기술이 없습니다.</span></div>
                    </div>
                    <span class="form-hint" style="margin-top:6px;">ⓘ 여러 기술을 중복 선택할 수 있습니다.</span>
                    <input type="hidden" name="speciality" id="specialityHidden"/>
                </div>

                <div class="f-divider"></div>
                <div class="section-label">약관 동의</div>
                <div class="terms-box">
                    <div class="terms-item"><input type="checkbox" id="term1" class="term-check"/><label for="term1">[필수] 전문가 서비스 이용약관에 동의합니다</label></div>
                    <div class="terms-item"><input type="checkbox" id="term2" class="term-check"/><label for="term2">[필수] 수수료 정책에 동의합니다</label></div>
                    <div class="terms-item"><input type="checkbox" id="term3" class="term-check"/><label for="term3">[필수] 개인정보 처리방침에 동의합니다</label></div>
                </div>

                <button type="submit" class="submit-btn" style="margin-top:12px;">제출하고 승인 요청</button>
            </form>
        </div>
    </div>
</section>

<script>

    const SKILL_CATEGORIES = [
        { label: '언어', skills: ['Java','Python','JavaScript','TypeScript','Swift','Kotlin','Dart','R','C','C++','C#','Go','Rust','PHP'] },
        { label: '백엔드', skills: ['Spring Boot','Django','FastAPI','Node.js','Express','NestJS','Flask','Laravel','Ruby on Rails'] },
        { label: '프론트엔드', skills: ['React','Vue','Angular','Next.js','Nuxt.js','HTML/CSS','Tailwind CSS','SCSS','Webpack','Vite','jQuery','Svelte'] },
        { label: '모바일', skills: ['Flutter','React Native','Android','iOS','Kotlin Multiplatform'] },
        { label: 'DB/인프라', skills: ['MySQL','PostgreSQL','MongoDB','Redis','Firebase','Docker','AWS','GCP','Azure','Nginx','Jenkins','Kubernetes','Linux','Elasticsearch'] },
        { label: '디자인', skills: ['Figma','Adobe XD','Sketch','Zeplin','Photoshop','Illustrator','InDesign','Canva'] },
        { label: '데이터/AI', skills: ['Pandas','NumPy','TensorFlow','PyTorch','SQL','Spark','Tableau','Power BI','Scikit-learn','OpenCV','LangChain'] },
        { label: '영상', skills: ['Premiere Pro','After Effects','DaVinci Resolve','Final Cut Pro','CapCut','Blender','Cinema 4D'] },
        { label: '기타', skills: ['Git','WordPress','Shopify','Notion API','REST API','GraphQL','WebSocket','Unity','Unreal Engine'] }
    ];
    let selectedSkills = [];
    function renderChips() {
        const idx = parseInt(document.getElementById('categorySelect').value);
        document.getElementById('spBody').innerHTML = SKILL_CATEGORIES[idx].skills.map(s =>
            `<button type="button" class="sp-chip ${selectedSkills.includes(s)?'selected':''}" onclick="toggleSkill('${s}')">${s}</button>`
        ).join('');
    }
    function renderSelectedTags() {
        const area = document.getElementById('skillTags');
        area.innerHTML = selectedSkills.length === 0
            ? '<span class="skill-empty">선택된 기술이 없습니다.</span>'
            : selectedSkills.map(s => `<span class="skill-tag">${s}<button type="button" onclick="removeSkill('${s}')">×</button></span>`).join('');
        document.getElementById('specialityHidden').value = selectedSkills.join(',');
    }
    function toggleSkill(s) { selectedSkills = selectedSkills.includes(s) ? selectedSkills.filter(x=>x!==s) : [...selectedSkills, s]; renderChips(); renderSelectedTags(); }
    function removeSkill(s) { selectedSkills = selectedSkills.filter(x=>x!==s); renderChips(); renderSelectedTags(); }
    renderChips(); renderSelectedTags();

    document.getElementById('expertForm').addEventListener('submit',function(e){
        if(selectedSkills.length===0){e.preventDefault();alert('기술 스택을 최소 1개 이상 선택해 주세요.');return;}
        if(![...document.querySelectorAll('.term-check')].every(c=>c.checked)){e.preventDefault();alert('전문가 가입을 위해 필수 약관에 모두 동의해 주세요.');}
    });
</script>
{{> layout/footer}}
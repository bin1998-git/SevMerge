{{> layout/header}}

<style>
    .ej-section { padding: 60px 28px 80px; }
    .ej-inner { max-width: 560px; margin: 0 auto; }
    .ej-header { text-align: center; margin-bottom: 32px; }
    .ej-title { font-size: 24px; font-weight: 900; color: #1c1e26; margin-bottom: 8px; letter-spacing: -0.5px; }
    .ej-desc { font-size: 14px; color: #9ca3af; line-height: 1.6; }
    .ej-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 18px; padding: 36px; }
    .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: 20px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-label .opt { color: #c4c9d9; font-weight: 500; margin-left: 4px; }
    .form-input, .form-textarea { padding: 13px 15px; background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input:focus, .form-textarea:focus { border-color: #2563eb; background: #fff; }
    .form-input:disabled { color: #9ca3af; background: #f3f4f6; cursor: not-allowed; }
    .form-textarea { resize: vertical; min-height: 90px; line-height: 1.6; }
    .form-hint { font-size: 12px; color: #c4c9d9; margin-top: 2px; }
    .section-divider { border: none; border-top: 1.5px solid #f3f4f8; margin: 8px 0 24px; }
    .section-label { font-size: 12px; font-weight: 700; color: #c4c9d9; letter-spacing: .5px; margin-bottom: 16px; }
    .submit-btn { width: 100%; padding: 15px; background: #2563eb; color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .submit-btn:hover { background: #1d4ed8; }
    .notice-box { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px 16px; font-size: 13px; color: #b45309; line-height: 1.6; margin-bottom: 24px; }
    /* 기술스택 선택기 */
.skill-picker { border: 1.5px solid #e2e5ef; border-radius: 12px; overflow: hidden; }
.skill-picker-tabs {
    display: flex;
    overflow-x: auto;
    background: #f8f9fc;
    border-bottom: 1px solid #e2e5ef;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
}
.skill-picker-tabs::-webkit-scrollbar { display: none; }

.sp-tab {
    padding: 9px 12px;
    font-size: 11px;
    font-weight: 700;
    color: #9ca3af;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
    border-bottom: 2px solid transparent;
    transition: all .12s;
    flex-shrink: 0;
}
.sp-tab.active { color: #2563eb; border-bottom-color: #2563eb; background: #fff; }
.skill-picker-body { padding: 14px 16px; display: flex; flex-wrap: wrap; gap: 8px; min-height: 72px; }
.sp-chip { padding: 6px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
    cursor: pointer; border: 1.5px solid #e2e5ef; background: #fff; color: #4b5563;
    font-family: inherit; transition: all .12s; user-select: none; }
.sp-chip:hover { border-color: #2563eb; color: #2563eb; }
.sp-chip.selected { background: #2563eb; border-color: #2563eb; color: #fff; }
.skill-selected-area { margin-top: 12px; }
.skill-selected-label { font-size: 12px; color: #9ca3af; margin-bottom: 8px; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 8px; min-height: 28px; }
.skill-tag { display: inline-flex; align-items: center; gap: 5px; padding: 5px 11px;
    background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe;
    border-radius: 20px; font-size: 12px; font-weight: 600; }
.skill-tag button { background: none; border: none; color: #93c5fd; cursor: pointer;
    font-size: 13px; line-height: 1; padding: 0; }
.skill-tag button:hover { color: #ef4444; }
.skill-empty { font-size: 12px; color: #c4c9d9; }
    /* 약관 (일반 가입과 동일 톤) */
    .terms-box { display: flex; flex-direction: column; gap: 10px; background: #f8f9fc; border-radius: 10px; padding: 16px; margin-bottom: 24px; }
    .terms-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #374151; }
    .terms-item input { width: 16px; height: 16px; accent-color: #2563eb; cursor: pointer; }
    .terms-item label { cursor: pointer; }
</style>

<section class="ej-section">
    <div class="ej-inner">
        <div class="ej-header">
            <h1 class="ej-title">전문가 정보 입력</h1>
            <p class="ej-desc">전문가 활동을 위해 정보를 입력해 주세요.<br>제출 후 관리자 승인을 거쳐 활동할 수 있어요.</p>
        </div>

        <div class="notice-box">
            ⓘ 전문가 가입은 <b>관리자 승인 후</b> 로그인할 수 있습니다. 승인 전까지는 로그인이 제한됩니다.
        </div>

        <form class="ej-card" action="/social-expert-join" method="POST" id="expertForm">

            <div class="section-label">기본 정보</div>

            <div class="form-group">
                <label class="form-label">이름 <span class="required">*</span></label>
                <input type="text" name="name" class="form-input" value="{{name}}" />
            </div>



            {{#emailReadonly}}
                <div class="form-group">
                    <label class="form-label">이메일 <span class="required">*</span></label>
                    <input type="email" name="email" class="form-input" value="{{email}}" readonly />
                    <span class="form-hint">소셜 계정에서 가져온 이메일이에요.</span>
                </div>
            {{/emailReadonly}}

            {{^emailReadonly}}
                <input type="hidden" name="email" value="" />
            {{/emailReadonly}}


            <hr class="section-divider" />
            <div class="section-label">전문가 정보</div>

            <div class="form-group">
                <label class="form-label">한 줄 소개 <span class="required">*</span></label>
                <input type="text" name="intro" class="form-input"
                       placeholder="예) 5년차 React 개발자입니다" />
            </div>

            <div class="form-group">
                <label class="form-label">경력 <span class="required">*</span></label>
                <textarea name="career" class="form-textarea"
                          placeholder="예)  OO기업 백엔드 개발 3년&#10;프리랜서 외주 개발 2년"></textarea>
                <span class="form-hint">주요 경력을 자유롭게 작성해 주세요.</span>
            </div>

            <div class="form-group">
                <label class="form-label">GitHub 주소<span class="opt">(선택)</span></label>
                <input type="text" name="githubUrl" class="form-input"
                       placeholder="https://github.com/username" />
            </div>

            <div class="form-group">
                <label class="form-label">기술 스택 <span class="required">*</span></label>
                <div class="skill-picker">
                    <div class="skill-picker-tabs" id="spTabs"></div>
                    <div class="skill-picker-body" id="spBody"></div>
                </div>
                <div class="skill-selected-area">
                    <div class="skill-selected-label">선택된 기술</div>
                    <div class="skill-tags" id="skillTags">
                        <span class="skill-empty">선택된 기술이 없습니다.</span>
                    </div>
                </div>
                <span class="form-hint">ⓘ 여러 기술을 중복 선택할 수 있습니다.</span>
                <input type="hidden" name="speciality" id="specialityHidden" />
            </div>

            <hr class="section-divider" />
            <div class="section-label">약관 동의</div>
            <div class="terms-box">
                <div class="terms-item">
                    <input type="checkbox" id="term1" class="term-check" />
                    <label for="term1">[필수] 전문가 서비스 이용약관에 동의합니다</label>
                </div>
                <div class="terms-item">
                    <input type="checkbox" id="term2" class="term-check" />
                    <label for="term2">[필수] 수수료 정책에 동의합니다</label>
                </div>
                <div class="terms-item">
                    <input type="checkbox" id="term3" class="term-check" />
                    <label for="term3">[필수] 개인정보 처리방침에 동의합니다</label>
                </div>
            </div>

            <button type="submit" class="submit-btn">제출하고 승인 요청</button>
        </form>
    </div>
</section>

<script>
    // ===== 기술스택 선택기 =====
 const SKILL_CATEGORIES = [
     { label: '언어', skills: ['Java','Python','JavaScript','TypeScript','Swift','Kotlin','Dart','R','C','C++','C#','Go','Rust','PHP'] },
     { label: '백엔드', skills: ['Spring Boot','Django','FastAPI','Node.js','Express','NestJS','Flask','Laravel','Ruby on Rails'] },
     { label: '프론트엔드', skills: ['React','Vue','Angular','Next.js','Nuxt.js','HTML/CSS','Tailwind CSS','SCSS','Webpack','Vite','jQuery','Svelte'] },
     { label: '모바일', skills: ['Flutter','React Native','Android','iOS','Kotlin Multiplatform'] },
     { label: 'DB/인프라', skills: ['MySQL','PostgreSQL','MongoDB','Redis','Firebase','Docker','AWS','GCP','Azure','Nginx','Jenkins','Kubernetes','Linux','Elasticsearch'] },
     { label: '디자인', skills: ['Figma','Adobe XD','Sketch','Zeplin','Photoshop','Illustrator','InDesign','Canva'] },
     { label: '데이터/AI', skills: ['Pandas','NumPy','TensorFlow','PyTorch','SQL','Spark','Tableau','Power BI','Scikit-learn','OpenCV','LangChain'] },
     { label: '영상', skills: ['Premiere Pro','After Effects','DaVinci Resolve','Final Cut Pro','CapCut','Blender','Cinema 4D'] },
     { label: '기타', skills: ['Git','WordPress','Shopify','Notion API','REST API','GraphQL','WebSocket','Unity','Unreal Engine'] }
 ];

 let selectedSkills = [];
 let activeCategory = 0;

 function renderTabs() {
     const tabs = document.getElementById('spTabs');
     tabs.innerHTML = SKILL_CATEGORIES.map((cat, i) =>
         `<button type="button" class="sp-tab ${i === activeCategory ? 'active' : ''}"
             onclick="switchCategory(${i})">${cat.label}</button>`
     ).join('');
 }

 function renderChips() {
     const body = document.getElementById('spBody');
     body.innerHTML = SKILL_CATEGORIES[activeCategory].skills.map(skill =>
         `<button type="button" class="sp-chip ${selectedSkills.includes(skill) ? 'selected' : ''}"
             onclick="toggleSkill('${skill}')">${skill}</button>`
     ).join('');
 }

 function renderSelectedTags() {
     const area = document.getElementById('skillTags');
     if (selectedSkills.length === 0) {
         area.innerHTML = '<span class="skill-empty">선택된 기술이 없습니다.</span>';
     } else {
         area.innerHTML = selectedSkills.map(skill =>
             `<span class="skill-tag">${skill}
                 <button type="button" onclick="removeSkill('${skill}')">×</button>
             </span>`
         ).join('');
     }
     document.getElementById('specialityHidden').value = selectedSkills.join(',');
 }

 function switchCategory(idx) {
     activeCategory = idx;
     renderTabs();
     renderChips();
 }

 function toggleSkill(skill) {
     if (selectedSkills.includes(skill)) {
         selectedSkills = selectedSkills.filter(s => s !== skill);
     } else {
         selectedSkills.push(skill);
     }
     renderChips();
     renderSelectedTags();
 }

 function removeSkill(skill) {
     selectedSkills = selectedSkills.filter(s => s !== skill);
     renderChips();
     renderSelectedTags();
 }

 // 초기화
 renderTabs();
 renderChips();
 renderSelectedTags();

     // 약관 필수 동의 + 기술 스택 검증
 document.getElementById("expertForm").addEventListener("submit", function (e) {
     // 기술 스택 최소 1개
     if (skills.length === 0) {
         e.preventDefault();
         alert("기술 스택을 최소 1개 이상 입력해 주세요.");
         return;
     }
     // 약관 동의
     const allChecked = [...document.querySelectorAll(".term-check")].every(c => c.checked);
     if (!allChecked) {
         e.preventDefault();
         alert("전문가 가입을 위해 필수 약관에 모두 동의해 주세요.");
     }
 });

</script>

{{> layout/footer}}
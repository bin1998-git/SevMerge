{{> layout/header}}

<style>
    .start-section {
        min-height: calc(100vh - 64px);
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        display: flex; align-items: center; justify-content: center;
        padding: 48px 28px; position: relative; overflow: hidden;
    }
    .start-section::before {
        content: ''; position: absolute;
        width: 500px; height: 500px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.55) 0%, transparent 70%);
        top: -120px; left: -120px; pointer-events: none;
    }
    .start-section::after {
        content: ''; position: absolute;
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%);
        bottom: -80px; right: -80px; pointer-events: none;
    }

    .start-inner { width: 100%; max-width: 420px; position: relative; z-index: 1; }

    .start-header { text-align: center; margin-bottom: 28px; }
    .start-logo { font-size: 26px; font-weight: 900; color: #1e3a6e; margin-bottom: 14px; letter-spacing: -1px; }
    .start-logo .hl { color: var(--blue); }
    .start-title { font-size: 22px; font-weight: 900; color: #1e3a6e; line-height: 1.4; letter-spacing: -0.5px; margin-bottom: 6px; }
    .start-desc { font-size: 13px; color: #4a6fa5; }

    .start-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 24px; padding: 36px;
        display: flex; flex-direction: column; gap: 12px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .start-card::before {
        content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }

    .start-btn {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        width: 100%; padding: 14px; border-radius: 25px;
        font-size: 14px; font-weight: 700; text-decoration: none;
        font-family: inherit; cursor: pointer; border: none; transition: all .2s;
        position: relative; overflow: hidden;
    }
    .start-btn::after {
        content: ''; position: absolute; inset: 0; border-radius: 25px;
        background: linear-gradient(180deg, rgba(255,255,255,.15) 0%, transparent 50%);
        pointer-events: none;
    }
    .btn-kakao { background: #FEE500; color: #191600; box-shadow: 0 4px 14px rgba(254,229,0,.35); }
    .btn-kakao:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(254,229,0,.45); }
    .btn-google { backdrop-filter: blur(8px); background: rgba(255,255,255,.8); color: #374151; border: 1.5px solid rgba(255,255,255,.9); box-shadow: 0 4px 14px rgba(0,0,0,.05); }
    .btn-google:hover { transform: translateY(-2px); background: rgba(255,255,255,.95); box-shadow: 0 8px 20px rgba(0,0,0,.08); }
    .btn-email { background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,.3); }
    .btn-email:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(37,99,235,.4); }

    .start-divider {
        display: flex; align-items: center; gap: 12px;
        margin: 4px 0; color: #4a6fa5; font-size: 12px; font-weight: 500;
    }
    .start-divider::before, .start-divider::after { content: ""; flex: 1; height: 1px; background: rgba(37,99,235,.15); }

    .start-footer { text-align: center; margin-top: 20px; font-size: 14px; color: #4a6fa5; }
    .start-footer a { color: #1e3a8a; font-weight: 700; text-decoration: none; }
    .start-footer a:hover { text-decoration: underline; }
</style>

<section class="start-section">
    <div class="start-inner">
        <div class="start-header">
            <div class="start-logo">I<span class="hl">code</span>U</div>
            <h1 class="start-title">코드요와 함께<br>시작해 보세요!</h1>
            <p class="start-desc">가입하고 IT 프리랜서 매칭을 경험해보세요.</p>
        </div>

        <div class="start-card">
            <a href="https://kauth.kakao.com/oauth/authorize?client_id=af204550b1d40839b55edce162cf4123&redirect_uri=http://localhost:8080/kakao-redirect&response_type=code"
               class="start-btn btn-kakao">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#191600">
                    <path d="M12 3C6.477 3 2 6.477 2 10.8c0 2.7 1.636 5.076 4.1 6.514L5.1 21l4.373-2.329C10.243 18.88 11.11 19 12 19c5.523 0 10-3.477 10-7.8S17.523 3 12 3z"/>
                </svg>
                카카오로 시작하기
            </a>

            <a href="https://accounts.google.com/o/oauth2/v2/auth?client_id={{googleClientId}}&redirect_uri=http://localhost:8080/google-redirect&response_type=code&scope=email%20profile"
            class="start-btn btn-google">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="20" alt="Google"/>
            Google로 시작하기
            </a>

            <div class="start-divider">또는</div>

            <a href="/join-role" class="start-btn btn-email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                이메일로 시작하기
            </a>
        </div>

        <div class="start-footer">
            이미 계정이 있으신가요? <a href="/login">로그인</a>
        </div>
    </div>
</section>

{{> layout/footer}}
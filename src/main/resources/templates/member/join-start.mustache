                    <div><div class="trust-val">1,200<em>+</em></div><div class="trust-label">등록 전문가</div></div>
                </div>
                <div class="trust-item">
                    <div class="trust-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 22H5v-2h14v2ZM5 20H3V10h2v10Zm16 0h-2V10h2v10ZM9 8h10v2H5V8h2V4h2v4Zm8-2h-2V4h2v2Zm-2-2H9V2h6v2Z"/></svg></div>
                    <div><div class="trust-val">98<em>%</em></div><div class="trust-label">의뢰인 만족도</div></div>
                </div>
            </div>

            <div class="network">
                <div class="network-center">
                    <div style="color:#00c8e0;"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M4 13h8v6h2v2h-2v2h-2v-8H2v-4h2v2Zm12 6h-2v-2h2v2Zm2-2h-2v-2h2v2Zm2-2h-2v-2h2v2Zm-6-6h8v4h-2v-2h-8V5h-2V3h2V1h2v8Zm-8 2H4V9h2v2Zm2-2H6V7h2v2Zm2-2H8V5h2v2Z"/></svg></div>
                    <span>프로젝트</span>
                </div>
                <div class="network-card n-dev"><span class="n-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M2 22H0v-4h2v4Zm14 0h-2v-4h2v4Zm8 0h-2v-4h2v4ZM4 18H2v-2h2v2Zm10 0h-2v-2h2v2Zm8 0h-2v-2h2v2Zm-10-2H4v-2h8v2Zm8 0h-4v-2h4v2Zm-9-4H5v-2h6v2Zm8 0h-4v-2h4v2ZM5 10H3V4h2v6Zm8 0h-2V4h2v6Zm8 0h-2V4h2v6ZM11 4H5V2h6v2Zm8 0h-4V2h4v2Z"/></svg></span> 개발자</div>
                <div class="network-card n-design"><span class="n-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5h2v2H8V5ZM6 7h2v2H6V7ZM4 9h2v2H4V9Zm-2 2h2v2H2v-2Zm2 2h2v2H4v-2Zm2 2h2v2H6v-2Zm2 2h2v2H8v-2Zm8-12h-2v2h2V5Zm2 2h-2v2h2V7Zm2 2h-2v2h2V9Zm2 2h-2v2h2v-2Zm-2 2h-2v2h2v-2Zm-2 2h-2v2h2v-2Zm-2 2h-2v2h2v-2Z"/></svg></span> 디자이너</div>
                <div class="network-card n-pm"><span class="n-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 23H4v-2h16v2ZM4 21H2v-6h2v6Zm18 0h-2v-6h2v6ZM8 19H6v-2h2v2Zm10 0h-8v-2h8v2Zm-8-8v2h4v-2h-4ZM6 9H4V3h2v6Zm14 0h-2V3h2v6Zm-2-6H6V1h12v2Zm-2 10h4v2H4v-2h4v-2H6V9h12v2h-2v2Z"/></svg></span> 기획자</div>

{{> layout/header}}

<style>
    .start-section {
        min-height: calc(100vh - 64px);
        background: #f0f4fa;
        display: flex; align-items: center; justify-content: center;
        padding: 48px 28px;
    }
    .start-inner { width: 100%; max-width: 440px; }

    .start-header { text-align: center; margin-bottom: 32px; }
    .start-logo {
        font-size: 24px; font-weight: 900; color: #0f172a;
        margin-bottom: 12px; letter-spacing: -1px;
    }
    .start-logo .hl { color: var(--blue); }
    .start-title {
        font-size: 22px; font-weight: 900; color: #0f172a;
        line-height: 1.4; letter-spacing: -0.5px;
    }
    .start-desc { font-size: 14px; color: var(--gray-lt); margin-top: 6px; }

    .start-card {
        background: #fff; border: 1.5px solid var(--border);
        border-radius: 20px; padding: 36px;
        display: flex; flex-direction: column; gap: 12px;
        box-shadow: 0 4px 24px rgba(37,99,235,.06);
    }

    .start-btn {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        width: 100%; padding: 14px; border-radius: 25px;
        font-size: 14px; font-weight: 700; text-decoration: none;
        font-family: inherit; cursor: pointer; border: none;
        transition: opacity .15s, transform .15s;
    }
    .start-btn:hover { opacity: .88; transform: translateY(-1px); }

    .btn-kakao { background: #FEE500; color: #191600; }
    .btn-google { background: #fff; border: 1.5px solid var(--border); color: #374151; }
    .btn-email { background: var(--blue); color: #fff; }
    .btn-email:hover { opacity: 1; background: var(--blue-dark); }

    .start-divider {
        display: flex; align-items: center; gap: 12px;
        margin: 4px 0; color: var(--gray-lt); font-size: 12px; font-weight: 500;
    }
    .start-divider::before, .start-divider::after {
        content: ""; flex: 1; height: 1px; background: var(--border);
    }

    .start-footer {
        text-align: center; margin-top: 20px;
        font-size: 14px; color: var(--gray-lt);
    }
    .start-footer a { color: var(--blue); font-weight: 700; text-decoration: none; }
    .start-footer a:hover { text-decoration: underline; }
</style>

<section class="start-section">
    <div class="start-inner">

        <div class="start-header">
            <div class="start-logo">I<span class="hl">code</span>U</div>
            <h1 class="start-title">코드요와 함께<br>시작해 보세요!</h1>
            <p class="start-desc">가입하고 IT 프리랜서 매칭을 경험해보세요.</p>
        </div>

        <div class="start-card">
            <!-- 카카오 -->
            <a href="https://kauth.kakao.com/oauth/authorize?client_id=af204550b1d40839b55edce162cf4123&redirect_uri=http://localhost:8080/kakao-redirect&response_type=code"
               class="start-btn btn-kakao">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#191600">
                    <path d="M12 3C6.477 3 2 6.477 2 10.8c0 2.7 1.636 5.076 4.1 6.514L5.1 21l4.373-2.329C10.243 18.88 11.11 19 12 19c5.523 0 10-3.477 10-7.8S17.523 3 12 3z"/>
                </svg>
                카카오로 시작하기
            </a>

            <!-- 구글 -->
            <a href="https://accounts.google.com/o/oauth2/v2/auth?client_id={{googleClientId}}&redirect_uri=http://localhost:8080/google-redirect&response_type=code&scope=email%20profile"
            class="start-btn btn-google">
            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" width="20" alt="Google"/>
            Google로 시작하기
            </a>

            <div class="start-divider">또는</div>

            <!-- 이메일 -->
            <a href="/join-role" class="start-btn btn-email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                이메일로 시작하기
            </a>
        </div>

        <div class="start-footer">
            이미 계정이 있으신가요? <a href="/login">로그인</a>
        </div>

    </div>
</section>

{{> layout/footer}}
{{> layout/header}}

<style>
    :root{
    --blue:#2563eb;
    --blue-dark:#1d4ed8;
    --navy:#172554;
    --text:#1e293b;
    --sub:#64748b;
}

/* ==========================
   LAYOUT
========================== */

.start-section{
    min-height:calc(100vh - 64px);

    background:
        radial-gradient(
            circle at 10% 10%,
            rgba(255,255,255,.6),
            transparent 25%
        ),
        radial-gradient(
            circle at 90% 90%,
            rgba(37,99,235,.15),
            transparent 30%
        ),
        linear-gradient(
            135deg,
            #dbeafe 0%,
            #bfdbfe 100%
        );

    position:relative;
    overflow:hidden;

    display:flex;
    align-items:center;
    justify-content:center;

    padding:60px;
}

.start-section::before{
    content:'';

    position:absolute;
    inset:0;

    background-image:
        linear-gradient(
            rgba(255,255,255,.12) 1px,
            transparent 1px
        ),
        linear-gradient(
            90deg,
            rgba(255,255,255,.12) 1px,
            transparent 1px
        );

    background-size:40px 40px;

    opacity:.35;
}

.start-inner{
    width:100%;
    max-width:1280px;

    display:grid;
    grid-template-columns:1fr 460px;

    gap:100px;

    align-items:center;

    position:relative;
    z-index:2;
}

/* ==========================
   LEFT SIDE
========================== */

.hero-side{
    padding-right:20px;
}

.start-logo{
    font-size:36px;
    font-weight:900;

    color:#1e3a8a;

    margin-bottom:40px;

    letter-spacing:-1px;
}

.start-logo span{
    color:var(--blue);
}

.hero-main-title{
    font-size:64px;
    line-height:1.1;
    font-weight:900;

    letter-spacing:-2px;

    color:var(--navy);

    margin-bottom:24px;
}

.hero-main-desc{
    font-size:20px;

    color:#4a6fa5;

    line-height:1.8;

    margin-bottom:60px;
}

/* ==========================
   NETWORK VISUAL
========================== */

.network{
    position:relative;

    width:100%;
    height:420px;
}

.network-center{

    position:absolute;

    left:50%;
    top:50%;

    transform:translate(-50%,-50%);

    width:220px;
    height:220px;

    border-radius:42px;

    background:
        linear-gradient(
            135deg,
            #2563eb,
            #3b82f6
        );

    color:white;

    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;

    gap:10px;

    font-size:22px;
    font-weight:800;

    box-shadow:
        0 25px 60px rgba(37,99,235,.25);
}

.network-center span{
    font-size:20px;
}

.network-card{
    position:absolute;

    display:flex;
    align-items:center;
    gap:10px;

    padding:18px 24px;

    background:
        rgba(255,255,255,.75);

    backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px);

    border:1px solid rgba(255,255,255,.8);

    border-radius:20px;

    font-size:15px;
    font-weight:700;

    color:#1e3a8a;

    box-shadow:
        0 12px 30px rgba(37,99,235,.08);
}

.dev{
    left:0;
    top:20px;
}

.design{
    right:0;
    top:20px;
}

.pm{
    left:40px;
    bottom:20px;
}

.client{
    right:40px;
    bottom:20px;
}

/* 연결선 */

.network::before{
    content:'';

    position:absolute;

    left:50%;
    top:50%;

    width:480px;
    height:480px;

    transform:translate(-50%,-50%);

    border:2px dashed rgba(37,99,235,.12);

    border-radius:50%;
}

/* ==========================
   AUTH CARD
========================== */

.start-card{

    backdrop-filter:blur(30px);
    -webkit-backdrop-filter:blur(30px);

    background:
        rgba(255,255,255,.55);

    border:
        1.5px solid rgba(255,255,255,.85);

    border-radius:32px;

    padding:42px;

    box-shadow:
        0 20px 60px rgba(37,99,235,.12),
        inset 0 1px 0 rgba(255,255,255,.9);

    position:relative;
}

.start-card::before{
    content:'';

    position:absolute;

    left:10%;
    right:10%;
    top:0;

    height:1px;

    background:
        linear-gradient(
            90deg,
            transparent,
            rgba(255,255,255,.9),
            transparent
        );
}

.card-header{
    text-align:center;
    margin-bottom:32px;
}

.card-header h2{
    font-size:30px;
    font-weight:900;

    color:var(--navy);

    margin-bottom:10px;
}

.card-header p{
    color:var(--sub);
    font-size:15px;
}

/* ==========================
   BUTTONS
========================== */

.start-btn{

    width:100%;

    display:flex;
    align-items:center;

    gap:14px;

    padding:18px 20px;

    border-radius:18px;

    text-decoration:none;

    font-weight:700;

    transition:.25s ease;

    margin-bottom:14px;

    position:relative;

    overflow:hidden;
}

.start-btn:hover{
    transform:translateY(-2px);
}

.start-btn::after{
    content:'';

    position:absolute;

    inset:0;

    background:
        linear-gradient(
            180deg,
            rgba(255,255,255,.15),
            transparent
        );

    pointer-events:none;
}

.btn-kakao{
    background:#FEE500;
    color:#191600;

    box-shadow:
        0 8px 20px rgba(254,229,0,.35);
}

.btn-google{

    background:
        rgba(255,255,255,.85);

    border:
        1px solid rgba(255,255,255,.9);

    color:#374151;
}

.btn-email{

    background:
        linear-gradient(
            135deg,
            #2563eb,
            #1d4ed8
        );

    color:white;
}

/* ==========================
   DIVIDER
========================== */

.start-divider{

    display:flex;
    align-items:center;

    gap:14px;

    margin:22px 0;

    color:#64748b;

    font-size:13px;
}

.start-divider::before,
.start-divider::after{

    content:'';

    flex:1;

    height:1px;

    background:
        rgba(37,99,235,.12);
}

/* ==========================
   LOGIN LINK
========================== */

.login-link{

    text-align:center;

    margin-top:22px;

    color:#64748b;

    font-size:14px;
}

.login-link a{
    color:#2563eb;
    font-weight:700;
    text-decoration:none;
}

/* ==========================
   RESPONSIVE
========================== */

@media(max-width:1024px){

    .start-inner{

        grid-template-columns:1fr;
        gap:50px;
    }

    .hero-side{
        text-align:center;
        padding-right:0;
    }

    .hero-main-title{
        font-size:46px;
    }

    .hero-main-desc{
        font-size:18px;
    }

    .network{
        display:none;
    }

    .start-card{
        max-width:500px;
        margin:auto;
    }
}

@media(max-width:640px){

    .start-section{
        padding:32px 20px;
    }

    .hero-main-title{
        font-size:36px;
    }

    .start-card{
        padding:32px;
    }
}
</style>
<section class="start-section">

    <div class="start-inner">

        <!-- LEFT -->
        <div class="hero-side">

            <h1 class="hero-main-title">
                검증된 IT 전문가와<br>
                프로젝트를 연결하세요
            </h1>

            <p class="hero-main-desc">
                개발자 · 디자이너 · 기획자를 빠르게 매칭하고<br>
                프로젝트를 성공적으로 시작해보세요.
            </p>

            <div class="network">

                <div class="network-center">
                    <div class="rocket">🚀</div>
                    <span>프로젝트</span>
                </div>

                <div class="network-card dev">
                    <span>👨‍💻</span>
                    개발자
                </div>

                <div class="network-card design">
                    <span>🎨</span>
                    디자이너
                </div>

                <div class="network-card pm">
                    <span>📊</span>
                    기획자
                </div>

                <div class="network-card client">
                    <span>💼</span>
                    클라이언트
                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="start-card">

            <div class="card-header">
                <h2>시작하기</h2>
                <p>원하는 방식으로 회원가입하세요</p>
            </div>

            <!-- 카카오 -->

            <a
                    href="https://kauth.kakao.com/oauth/authorize?client_id=af204550b1d40839b55edce162cf4123&redirect_uri=http://localhost:8080/kakao-redirect&response_type=code"
                    class="start-btn btn-kakao">

                <svg width="20" height="20" viewBox="0 0 24 24" fill="#191600">
                    <path d="M12 3C6.477 3 2 6.477 2 10.8c0 2.7 1.636 5.076 4.1 6.514L5.1 21l4.373-2.329C10.243 18.88 11.11 19 12 19c5.523 0 10-3.477 10-7.8S17.523 3 12 3z"/>
                </svg>

                <div>
                    <strong>카카오로 계속하기</strong>
                    <small>3초 만에 회원가입</small>
                </div>

            </a>

            <!-- 구글 -->

            <a
                    href="https://accounts.google.com/o/oauth2/v2/auth?client_id={{googleClientId}}&redirect_uri=http://localhost:8080/google-redirect&response_type=code&scope=email%20profile"
            class="start-btn btn-google">

            <img
                    src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                    width="20"
                    alt="Google">

            <div>
                <strong>Google로 계속하기</strong>
                <small>3초 만에 회원가입</small>
            </div>

            </a>

            <div class="start-divider">
                또는
            </div>

            <!-- 이메일 -->

            <a href="/join-role" class="start-btn btn-email">

                <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2">

                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>

                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>

                </svg>

                <div>
                    <strong>이메일로 시작하기</strong>
                    <small>직접 회원가입</small>
                </div>

            </a>

            <div class="login-link">
                이미 계정이 있으신가요?
                <a href="/login">로그인</a>
            </div>

        </div>

    </div>

</section>

{{> layout/footer}}
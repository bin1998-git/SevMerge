{{> layout/header}}

<style>
    :root { --blue: #2563eb; --blue-dark: #1d4ed8; --navy: #172554; }

    .fa-section {
        min-height: calc(100vh - 64px);
        background:
            radial-gradient(circle at 10% 10%, rgba(255,255,255,.6), transparent 25%),
            radial-gradient(circle at 90% 90%, rgba(37,99,235,.15), transparent 30%),
            linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
        position: relative; overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        padding: 60px 28px;
    }
    .fa-section::before {
        content: ''; position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(255,255,255,.12) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,.12) 1px, transparent 1px);
        background-size: 40px 40px; opacity: .35; pointer-events: none;
    }

    .fa-inner { width: 100%; max-width: 460px; position: relative; z-index: 2; }

    .fa-header { text-align: center; margin-bottom: 28px; }
    .fa-logo { font-size: 24px; font-weight: 900; color: #1e3a8a; margin-bottom: 10px; letter-spacing: -1px; }
    .fa-logo .hl { color: var(--blue); }
    .fa-title { font-size: 22px; font-weight: 900; color: var(--navy); letter-spacing: -.5px; margin-bottom: 6px; }
    .fa-desc { font-size: 14px; color: #4a6fa5; }

    /* 탭 */
    .fa-tabs {
        display: flex; margin-bottom: 24px;
        backdrop-filter: blur(12px);
        background: rgba(255,255,255,.4); border: 1.5px solid rgba(255,255,255,.7);
        border-radius: 14px; padding: 4px; gap: 4px;
    }
    .fa-tab {
        flex: 1; padding: 10px 0; text-align: center; font-size: 14px; font-weight: 700;
        color: #4a6fa5; cursor: pointer; border-radius: 10px;
        transition: all .15s; background: none; border: none; font-family: inherit;
    }
    .fa-tab.active {
        background: rgba(255,255,255,.85); color: var(--blue);
        box-shadow: 0 2px 8px rgba(37,99,235,.1);
    }

    /* 글래스 카드 */
    .fa-card {
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.58);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 28px; padding: 36px 40px;
        display: flex; flex-direction: column; gap: 18px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .fa-card::before {
        content: ''; position: absolute; left: 10%; right: 10%; top: 0; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }

    .form-group { display: flex; flex-direction: column; gap: 7px; }
    .form-label { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-input {
        padding: 13px 16px; background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(37,99,235,.15); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .15s;
    }
    .form-input::placeholder { color: #93aecf; }
    .form-input:focus { border-color: var(--blue); background: rgba(255,255,255,.95); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .form-hint { font-size: 12px; color: #4a6fa5; }

    .phone-row { display: flex; gap: 8px; }
    .phone-row .form-input { flex: 1; }
    .send-btn {
        padding: 0 18px; background: #1e3a6e; color: #fff;
        border: none; border-radius: 12px; font-size: 13px; font-weight: 700;
        cursor: pointer; font-family: inherit; white-space: nowrap; transition: all .15s;
    }
    .send-btn:hover { background: var(--blue); }
    .send-btn:disabled { background: #93aecf; cursor: not-allowed; }

    .submit-btn {
        width: 100%; padding: 15px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        border: none; border-radius: 25px; font-size: 15px; font-weight: 800;
        cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .submit-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    .divider { height: 1px; background: rgba(37,99,235,.1); }

    .result-box { border-radius: 14px; padding: 18px 20px; font-size: 14px; line-height: 1.7; display: none; }
    .result-box.success { background: rgba(236,253,245,.8); border: 1px solid #a7f3d0; color: #065f46; }
    .result-box.error   { background: rgba(255,243,243,.8); border: 1px solid #fecaca; color: #ef4444; }
    .result-label { font-size: 11px; font-weight: 700; letter-spacing: .5px; margin-bottom: 6px; color: #4a6fa5; text-transform: uppercase; }
    .result-value { font-size: 20px; font-weight: 900; color: #1e3a6e; }

    .tab-panel { display: none; flex-direction: column; gap: 18px; }
    .tab-panel.active { display: flex; }

    .fa-footer { text-align: center; margin-top: 20px; font-size: 14px; color: #4a6fa5; }
    .fa-footer a { color: var(--blue); font-weight: 700; text-decoration: none; }
    .fa-footer a:hover { text-decoration: underline; }
</style>

<section class="fa-section">
    <div class="fa-inner">
        <div class="fa-header">
            <div class="fa-logo">I<span class="hl">code</span>U</div>
            <h1 class="fa-title">계정 찾기</h1>
            <p class="fa-desc">이름과 휴대폰 번호로 계정 정보를 찾아드려요.</p>
        </div>

        <div class="fa-tabs">
            <button class="fa-tab active" onclick="switchTab('email')">이메일 찾기</button>
            <button class="fa-tab" onclick="switchTab('password')">비밀번호 찾기</button>
        </div>

        <div class="fa-card">

            <!-- 이메일 찾기 -->
            <div id="tab-email" class="tab-panel active">
                <div class="form-group">
                    <label class="form-label">이름</label>
                    <input type="text" id="email-name" class="form-input" placeholder="가입 시 입력한 이름"/>
                </div>
                <div class="form-group">
                    <label class="form-label">휴대폰 번호</label>
                    <div class="phone-row">
                        <input type="tel" id="email-phone" class="form-input" placeholder="010-0000-0000"/>
                        <button type="button" class="send-btn" onclick="sendSms('email')">인증</button>
                    </div>
                </div>
                <div class="form-group" id="email-sms-group" style="display:none;">
                    <label class="form-label">인증번호</label>
                    <div class="phone-row">
                        <input type="text" id="email-sms-code" class="form-input" placeholder="인증번호 6자리" maxlength="6"/>
                        <button type="button" class="send-btn" onclick="verifySms('email')">확인</button>
                    </div>
                    <span id="email-sms-hint" class="form-hint"></span>
                </div>
                <div class="divider"></div>
                <button type="button" class="submit-btn" onclick="findEmail()">이메일 찾기</button>
                <div id="email-result" class="result-box"></div>
            </div>

            <!-- 비밀번호 찾기 -->
            <div id="tab-password" class="tab-panel">
                <div class="form-group">
                    <label class="form-label">이름</label>
                    <input type="text" id="pw-name" class="form-input" placeholder="가입 시 입력한 이름"/>
                </div>
                <div class="form-group">
                    <label class="form-label">휴대폰 번호</label>
                    <div class="phone-row">
                        <input type="tel" id="pw-phone" class="form-input" placeholder="010-0000-0000"/>
                        <button type="button" class="send-btn" onclick="sendSms('password')">인증</button>
                    </div>
                </div>
                <div class="form-group" id="pw-sms-group" style="display:none;">
                    <label class="form-label">인증번호</label>
                    <div class="phone-row">
                        <input type="text" id="pw-sms-code" class="form-input" placeholder="인증번호 6자리" maxlength="6"/>
                        <button type="button" class="send-btn" onclick="verifySms('password')">확인</button>
                    </div>
                    <span id="pw-sms-hint" class="form-hint"></span>
                </div>
                <div class="divider"></div>
                <button type="button" class="submit-btn" onclick="resetPassword()">임시 비밀번호 받기</button>
                <div id="pw-result" class="result-box"></div>
            </div>

        </div>

        <div class="fa-footer">
            <a href="/login">← 로그인으로 돌아가기</a>
        </div>
    </div>
</section>

<script>
    let emailVerified = false;
    let pwVerified = false;

    function switchTab(tab) {
        document.querySelectorAll('.fa-tab').forEach((el, i) => {
            el.classList.toggle('active', (tab === 'email' && i === 0) || (tab === 'password' && i === 1));
        });
        document.getElementById('tab-email').classList.toggle('active', tab === 'email');
        document.getElementById('tab-password').classList.toggle('active', tab === 'password');
    }

    ['email-phone', 'pw-phone'].forEach(id => {
        const el = document.getElementById(id);
        el.addEventListener('input', function() {
            let v = el.value.replace(/[^0-9]/g, '');
            if (v.length > 11) v = v.slice(0, 11);
            if (v.length < 4) el.value = v;
            else if (v.length < 8) el.value = v.slice(0,3) + '-' + v.slice(3);
            else el.value = v.slice(0,3) + '-' + v.slice(3,7) + '-' + v.slice(7);
        });
    });

    async function sendSms(type) {
        const phone = document.getElementById(type === 'email' ? 'email-phone' : 'pw-phone').value.trim();
        if (!phone) { alert('휴대폰 번호를 입력해주세요.'); return; }
        const res = await fetch('/api/sms/send', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone })
        });
        if (res.ok) {
            const groupId = type === 'email' ? 'email-sms-group' : 'pw-sms-group';
            document.getElementById(groupId).style.display = 'flex';
            document.getElementById(groupId).style.flexDirection = 'column';
            alert('인증번호가 발송되었습니다.');
        } else { alert('발송에 실패했습니다.'); }
    }

    async function verifySms(type) {
        const phone = document.getElementById(type === 'email' ? 'email-phone' : 'pw-phone').value.trim();
        const code  = document.getElementById(type === 'email' ? 'email-sms-code' : 'pw-sms-code').value.trim();
        const hint  = document.getElementById(type === 'email' ? 'email-sms-hint' : 'pw-sms-hint');
        if (!code) { alert('인증번호를 입력해주세요.'); return; }
        const res = await fetch('/api/sms/verify', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ phone, code })
        });
        if (res.ok) {
            if (type === 'email') emailVerified = true;
            else pwVerified = true;
            hint.textContent = '✓ 인증되었습니다.'; hint.style.color = '#10b981';
        } else {
            hint.textContent = '✗ 인증번호가 일치하지 않습니다.'; hint.style.color = '#ef4444';
        }
    }

    async function findEmail() {
        const name  = document.getElementById('email-name').value.trim();
        const phone = document.getElementById('email-phone').value.trim();
        const result = document.getElementById('email-result');
        if (!name || !phone) { alert('이름과 휴대폰 번호를 입력해주세요.'); return; }
        if (!emailVerified) { alert('휴대폰 인증을 완료해주세요.'); return; }
        const res = await fetch('/api/member/find-email', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, phone })
        });
        const data = await res.json();
        result.style.display = 'block';
        if (res.ok) {
            result.className = 'result-box success';
            result.innerHTML = '<div class="result-label">가입된 이메일</div><div class="result-value">' + data.email + '</div>';
        } else {
            result.className = 'result-box error';
            result.textContent = data.message;
        }
    }

    async function resetPassword() {
        const name  = document.getElementById('pw-name').value.trim();
        const phone = document.getElementById('pw-phone').value.trim();
        const result = document.getElementById('pw-result');
        if (!name || !phone) { alert('이름과 휴대폰 번호를 입력해주세요.'); return; }
        if (!pwVerified) { alert('휴대폰 인증을 완료해주세요.'); return; }
        const res = await fetch('/api/member/reset-password', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, phone })
        });
        const data = await res.json();
        result.style.display = 'block';
        if (res.ok) {
            result.className = 'result-box success';
            result.innerHTML = '✓ ' + data.message + '<br><span style="font-size:12px;color:#065f46;">로그인 후 반드시 비밀번호를 변경해 주세요.</span>';
        } else {
            result.className = 'result-box error';
            result.textContent = data.message;
        }
    }
</script>

{{> layout/footer}}
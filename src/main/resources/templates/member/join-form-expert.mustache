{{> layout/header}}

<style>
    .auth-section { padding: 72px 28px 80px; }
    .auth-inner { max-width: 480px; margin: 0 auto; }
    .auth-header { text-align: center; margin-bottom: 36px; }
    .auth-logo { font-size: 22px; font-weight: 900; color: #1c1e26; margin-bottom: 10px; }
    .auth-logo span { color: #2563eb; }
    .auth-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .auth-desc { font-size: 14px; color: #9ca3af; }
    .auth-form { background: #fff; border: 1.5px solid #eaecf4; border-radius: 18px; padding: 36px; display: flex; flex-direction: column; gap: 18px; }
    .form-group { display: flex; flex-direction: column; gap: 7px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-label .opt { color: #c4c9d9; font-weight: 500; margin-left: 4px; }
    .form-input, .form-textarea { padding: 13px 16px; background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input::placeholder, .form-textarea::placeholder { color: #c4c9d9; }
    .form-input:focus, .form-textarea:focus { border-color: #2563eb; background: #fff; }
    .form-textarea { resize: vertical; min-height: 84px; line-height: 1.6; }
    .form-hint { font-size: 12px; color: #9ca3af; }
    .divider { height: 1px; background: #f3f4f8; margin: 4px 0; }
    .submit-btn { padding: 15px; background: #2563eb; color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit; margin-top: 4px; }
    .submit-btn:hover { background: #1d4ed8; }
    .auth-footer { text-align: center; margin-top: 20px; font-size: 14px; color: #9ca3af; }
    .auth-footer a { color: #2563eb; font-weight: 600; text-decoration: none; }
    .auth-footer a:hover { text-decoration: underline; }
    .email-verify-wrap { display: flex; gap: 8px; }
    .email-verify-wrap .form-input { flex: 1; }
    .verify-btn { padding: 0 18px; background: #1c1e26; color: #fff; border: none; border-radius: 10px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; white-space: nowrap; }
    .verify-btn:hover { background: #2563eb; }
    .verify-btn:disabled { background: #c4c9d9; cursor: not-allowed; }
    .form-input:disabled { background: #f0f1f5; color: #9ca3af; cursor: not-allowed; }
    .role-tag { display:inline-block; font-size:12px; font-weight:700; color:#2563eb; background:#eff6ff; border:1px solid #bfdbfe; padding:4px 12px; border-radius:20px; }
    .section-label { font-size: 12px; font-weight: 700; color: #2563eb; letter-spacing: .5px; margin-top: 4px; }
    .notice-box { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px 16px; font-size: 13px; color: #b45309; line-height: 1.6; }
    .terms-box { display: flex; flex-direction: column; gap: 10px; background: #f8f9fc; border-radius: 10px; padding: 16px; }
    .terms-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #374151; }
    .terms-item input { width: 16px; height: 16px; accent-color: #2563eb; cursor: pointer; }
    .terms-item label { cursor: pointer; }
    /* 기술스택 선택기 */
.skill-picker { border: 1.5px solid #e2e5ef; border-radius: 12px; overflow: hidden; }
.skill-picker-tabs {
    display: flex;
    overflow-x: auto;
    background: #f8f9fc;
    border-bottom: 1px solid #e2e5ef;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
}
.skill-picker-tabs::-webkit-scrollbar { display: none; }

.sp-tab {
    padding: 9px 12px;
    font-size: 11px;
    font-weight: 700;
    color: #9ca3af;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    background: none;
    font-family: inherit;
    border-bottom: 2px solid transparent;
    transition: all .12s;
    flex-shrink: 0;
}
.sp-tab.active { color: #2563eb; border-bottom-color: #2563eb; background: #fff; }
.skill-picker-body { padding: 14px 16px; display: flex; flex-wrap: wrap; gap: 8px; min-height: 72px; }
.sp-chip { padding: 6px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
    cursor: pointer; border: 1.5px solid #e2e5ef; background: #fff; color: #4b5563;
    font-family: inherit; transition: all .12s; user-select: none; }
.sp-chip:hover { border-color: #2563eb; color: #2563eb; }
.sp-chip.selected { background: #2563eb; border-color: #2563eb; color: #fff; }
.skill-selected-area { margin-top: 12px; }
.skill-selected-label { font-size: 12px; color: #9ca3af; margin-bottom: 8px; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 8px; min-height: 28px; }
.skill-tag { display: inline-flex; align-items: center; gap: 5px; padding: 5px 11px;
    background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe;
    border-radius: 20px; font-size: 12px; font-weight: 600; }
.skill-tag button { background: none; border: none; color: #93c5fd; cursor: pointer;
    font-size: 13px; line-height: 1; padding: 0; }
.skill-tag button:hover { color: #ef4444; }
.skill-empty { font-size: 12px; color: #c4c9d9; }
</style>

<section class="auth-section">
    <div class="auth-inner">

        <div class="auth-header">
            <div class="auth-logo">Sev<span>Merge</span></div>
            <h1 class="auth-title">전문가 회원가입</h1>
            <p class="auth-desc"><span class="role-tag">👨‍💻 전문가</span></p>
        </div>

        <form class="auth-form" action="/join" method="POST" id="joinForm" enctype="multipart/form-data">
            <input type="hidden" name="role" value="EXPERT" />

            <div class="notice-box">
                ⓘ 전문가 가입은 <b>관리자 승인 후</b> 로그인할 수 있습니다. 승인 전까지는 로그인이 제한됩니다.
            </div>

            <div class="section-label">기본 정보</div>

            <div class="form-group" style="align-items:center; margin-bottom:8px;">
                <!-- 원형 미리보기 (크게, 가운데) -->
                <div id="preview" style="width:110px; height:110px; border-radius:50%; background:#f0f1f5; border:2px solid #e2e5ef; background-size:cover; background-position:center; display:flex; align-items:center; justify-content:center; font-size:44px; color:#c4c9d9; margin-bottom:14px;">👤</div>

                <!-- 파일 선택 (숨기고 라벨을 버튼처럼) -->
                <input type="file" name="profileImageFile" id="profileImageFile" accept="image/*" style="display:none;" />
                <label for="profileImageFile" class="upload-btn" style="display:inline-block; padding:10px 22px; background:#fff; border:1.5px solid #2563eb; color:#2563eb; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">프로필 이미지 선택</label>
                <span class="form-hint" id="fileName" style="margin-top:6px;">선택 사항이에요</span>
            </div>

            <div class="form-group">
                <label class="form-label">이름 <span class="required">*</span></label>
                <input type="text" name="name" class="form-input"value="테스트용" placeholder="이름을 입력하세요" maxlength="20" />
            </div>

            <div class="form-group">
                <label class="form-label">이메일 <span class="required">*</span></label>
                <div class="email-verify-wrap">
                    <input type="email" name="email" id="emailInput" value="test@test" class="form-input" placeholder="이메일을 입력하세요" />
                    <button type="button" id="sendCodeBtn" class="verify-btn">인증</button>
                </div>
            </div>

            <div class="form-group" id="codeGroup" style="display:none;">
                <label class="form-label">인증 코드 <span class="required">*</span></label>
                <div class="email-verify-wrap">
                    <input type="text" name="authCode" id="codeInput" class="form-input" placeholder="인증 코드 6자리" maxlength="6" />
                    <button type="button" id="verifyCodeBtn" class="verify-btn">확인</button>
                </div>
                <span class="form-hint" id="codeHint"></span>
            </div>

            <div class="form-group">
                <label class="form-label">비밀번호 <span class="required">*</span></label>
                <input type="password" name="password" id="pwInput" value="test123!" class="form-input" placeholder="비밀번호를 입력하세요" />
                <span class="form-hint">영문, 숫자, 특수문자 포함 8자 이상</span>
            </div>

            <div class="form-group">
                <label class="form-label">비밀번호 확인 <span class="required">*</span></label>
                <input type="password" name="passwordConfirm" id="pwConfirmInput"value="test123!" class="form-input" placeholder="비밀번호를 다시 입력하세요" />
                <span class="form-hint" id="pwMatchHint"></span>
            </div>

            <div class="form-group">
                <label class="form-label">휴대폰 번호 <span class="required">*</span></label>
                <div class="email-verify-wrap">
                    <input type="tel" name="phone" id="phoneInput"value="010-0101-0101" class="form-input" placeholder="010-0000-0000" />
                    <button type="button" id="sendSmsBtn" class="verify-btn">인증</button>
                </div>
            </div>

            <div class="form-group" id="smsCodeGroup" style="display:none;">
                <label class="form-label">인증 코드 <span class="required">*</span></label>
                <div class="email-verify-wrap">
                    <input type="text" id="smsCodeInput" class="form-input" placeholder="인증번호 6자리" maxlength="6" />
                    <button type="button" id="verifySmsBtn" class="verify-btn">확인</button>
                </div>
                <span class="form-hint" id="smsHint"></span>
            </div>

            <div class="divider"></div>
            <div class="section-label">전문가 정보</div>

            <div class="form-group">
                <label class="form-label">한 줄 소개 <span class="required">*</span></label>
                <input type="text" name="intro" class="form-input"value="예) 5년차 React 개발자입니다123" placeholder="예) 5년차 React 개발자입니다" />
            </div>

            <div class="form-group">
                <label class="form-label">경력 <span class="required">*</span></label>
                <textarea name="career" class="form-textarea" placeholder="예) OO기업 백엔드 개발 3년&#10;프리랜서 외주 개발 2년"></textarea>
                <span class="form-hint">주요 경력을 자유롭게 작성해 주세요.</span>
            </div>

            <div class="form-group">
                <label class="form-label">GitHub 주소 <span class="opt">(선택)</span></label>
                <input type="text" name="githubUrl" class="form-input" placeholder="https://github.com/username" />
            </div>

            <div class="form-group">
                <label class="form-label">기술 스택 <span class="required">*</span></label>
                <div class="skill-picker">
                    <div class="skill-picker-tabs" id="spTabs"></div>
                    <div class="skill-picker-body" id="spBody"></div>
                </div>
                <div class="skill-selected-area">
                    <div class="skill-selected-label">선택된 기술</div>
                    <div class="skill-tags" id="skillTags">
                        <span class="skill-empty">선택된 기술이 없습니다.</span>
                    </div>
                </div>
                <span class="form-hint">ⓘ 여러 기술을 중복 선택할 수 있습니다.</span>
                <input type="hidden" name="speciality" id="specialityHidden" />
            </div>

            <div class="divider"></div>
            <div class="section-label">약관 동의</div>
            <div class="terms-box">
                <div class="terms-item">
                    <input type="checkbox" id="term1" class="term-check" />
                    <label for="term1">[필수] 전문가 서비스 이용약관에 동의합니다</label>
                </div>
                <div class="terms-item">
                    <input type="checkbox" id="term2" class="term-check" />
                    <label for="term2">[필수] 수수료 정책에 동의합니다</label>
                </div>
                <div class="terms-item">
                    <input type="checkbox" id="term3" class="term-check" />
                    <label for="term3">[필수] 개인정보 처리방침에 동의합니다</label>
                </div>
            </div>

            {{#errorMessage}}
                <div style="background:#fff3f3; border:1px solid #fecaca; border-radius:8px; padding:12px 14px; font-size:13px; color:#ef4444; font-weight:600;">
                    {{errorMessage}}
                </div>
            {{/errorMessage}}

            <div class="divider"></div>
            <button type="submit" class="submit-btn">제출하고 승인 요청</button>
        </form>

        <div class="auth-footer">
            의뢰인으로 가입하시나요? <a href="/join-start">의뢰인 회원가입</a><br>
            이미 계정이 있으신가요? <a href="/login">로그인</a>
        </div>

    </div>
</section>

<script>
    const form = document.getElementById("joinForm");
    const emailInput    = document.getElementById("emailInput");
    const sendCodeBtn   = document.getElementById("sendCodeBtn");
    const codeGroup     = document.getElementById("codeGroup");
    const codeInput     = document.getElementById("codeInput");
    const verifyCodeBtn = document.getElementById("verifyCodeBtn");
    const codeHint      = document.getElementById("codeHint");
    const pwInput        = document.getElementById("pwInput");
    const pwConfirmInput = document.getElementById("pwConfirmInput");
    const pwMatchHint    = document.getElementById("pwMatchHint");

    // 비밀번호 일치 실시간 확인
    function checkPwMatch() {
        if (pwConfirmInput.value === "") {
            pwConfirmInput.style.borderColor = "#e2e5ef";
            pwMatchHint.textContent = "";
            return;
        }
        if (pwInput.value === pwConfirmInput.value) {
            pwConfirmInput.style.borderColor = "#10b981";
            pwMatchHint.textContent = "✓ 비밀번호가 일치합니다.";
            pwMatchHint.style.color = "#10b981";
        } else {
            pwConfirmInput.style.borderColor = "#ef4444";
            pwMatchHint.textContent = "✗ 비밀번호가 일치하지 않습니다.";
            pwMatchHint.style.color = "#ef4444";
        }
    }
    pwInput.addEventListener("input", checkPwMatch);
    pwConfirmInput.addEventListener("input", checkPwMatch);

// ===== 기술스택 선택기 =====
const SKILL_CATEGORIES = [
    { label: '언어', skills: ['Java','Python','JavaScript','TypeScript','Swift','Kotlin','Dart','R','C','C++','C#','Go','Rust','PHP'] },
    { label: '백엔드', skills: ['Spring Boot','Django','FastAPI','Node.js','Express','NestJS','Flask','Laravel','Ruby on Rails'] },
    { label: '프론트엔드', skills: ['React','Vue','Angular','Next.js','Nuxt.js','HTML/CSS','Tailwind CSS','SCSS','Webpack','Vite','jQuery','Svelte'] },
    { label: '모바일', skills: ['Flutter','React Native','Android','iOS','Kotlin Multiplatform'] },
    { label: 'DB/인프라', skills: ['MySQL','PostgreSQL','MongoDB','Redis','Firebase','Docker','AWS','GCP','Azure','Nginx','Jenkins','Kubernetes','Linux','Elasticsearch'] },
    { label: '디자인', skills: ['Figma','Adobe XD','Sketch','Zeplin','Photoshop','Illustrator','InDesign','Canva'] },
    { label: '데이터/AI', skills: ['Pandas','NumPy','TensorFlow','PyTorch','SQL','Spark','Tableau','Power BI','Scikit-learn','OpenCV','LangChain'] },
    { label: '영상', skills: ['Premiere Pro','After Effects','DaVinci Resolve','Final Cut Pro','CapCut','Blender','Cinema 4D'] },
    { label: '기타', skills: ['Git','WordPress','Shopify','Notion API','REST API','GraphQL','WebSocket','Unity','Unreal Engine'] }
];

let selectedSkills = [];
let activeCategory = 0;

function renderTabs() {
    const tabs = document.getElementById('spTabs');
    tabs.innerHTML = SKILL_CATEGORIES.map((cat, i) =>
        `<button type="button" class="sp-tab ${i === activeCategory ? 'active' : ''}"
            onclick="switchCategory(${i})">${cat.label}</button>`
    ).join('');
}

function renderChips() {
    const body = document.getElementById('spBody');
    body.innerHTML = SKILL_CATEGORIES[activeCategory].skills.map(skill =>
        `<button type="button" class="sp-chip ${selectedSkills.includes(skill) ? 'selected' : ''}"
            onclick="toggleSkill('${skill}')">${skill}</button>`
    ).join('');
}

function renderSelectedTags() {
    const area = document.getElementById('skillTags');
    if (selectedSkills.length === 0) {
        area.innerHTML = '<span class="skill-empty">선택된 기술이 없습니다.</span>';
    } else {
        area.innerHTML = selectedSkills.map(skill =>
            `<span class="skill-tag">${skill}
                <button type="button" onclick="removeSkill('${skill}')">×</button>
            </span>`
        ).join('');
    }
    document.getElementById('specialityHidden').value = selectedSkills.join(',');
}

function switchCategory(idx) {
    activeCategory = idx;
    renderTabs();
    renderChips();
}

function toggleSkill(skill) {
    if (selectedSkills.includes(skill)) {
        selectedSkills = selectedSkills.filter(s => s !== skill);
    } else {
        selectedSkills.push(skill);
    }
    renderChips();
    renderSelectedTags();
}

function removeSkill(skill) {
    selectedSkills = selectedSkills.filter(s => s !== skill);
    renderChips();
    renderSelectedTags();
}

// 초기화
renderTabs();
renderChips();
renderSelectedTags();

    // 제출 시 필수값 + 비밀번호 + 기술스택 + 약관 검증
form.addEventListener("submit", function (e) {
    const name = form.name.value.trim();
    const email = form.email.value.trim();
    const pw = pwInput.value;
    const pwConfirm = pwConfirmInput.value;
    const phone = form.phone.value.trim();
    const intro = form.intro.value.trim();
    const career = form.career.value.trim();

    if (!name || !email || !pw || !pwConfirm || !phone || !intro || !career) {
        e.preventDefault();
        alert("필수 항목을 모두 입력해 주세요.");
        return;
    }
    const pwRegex = /^(?=.*[A-Za-z])(?=.*\d)(?=.*[!@#$%^&*(),.?":{}|<>]).{8,}$/;
    if (!pwRegex.test(pw)) {
        e.preventDefault();
        alert("비밀번호는 영문, 숫자, 특수문자를 포함해 8자 이상이어야 합니다.");
        return;
    }
    if (pw !== pwConfirm) {
        e.preventDefault();
        alert("비밀번호가 일치하지 않습니다.");
        return;
    }
    // 기술 스택 최소 1개
    if (skills.length === 0) {
        e.preventDefault();
        alert("기술 스택을 최소 1개 이상 입력해 주세요.");
        return;
    }
    const allChecked = [...document.querySelectorAll(".term-check")].every(c => c.checked);
    if (!allChecked) {
        e.preventDefault();
        alert("전문가 가입을 위해 필수 약관에 모두 동의해 주세요.");
        return;
    }
});

    // 전화번호 하이픈 자동 입력
    const phoneInput = form.phone;
    phoneInput.addEventListener("input", function () {
        let v = phoneInput.value.replace(/[^0-9]/g, "");  // 숫자만 남김
        if (v.length > 11) v = v.slice(0, 11);            // 최대 11자리
        if (v.length < 4) {
            phoneInput.value = v;
        } else if (v.length < 8) {
            phoneInput.value = v.slice(0, 3) + "-" + v.slice(3);
        } else {
            phoneInput.value = v.slice(0, 3) + "-" + v.slice(3, 7) + "-" + v.slice(7);
        }
    });

    // ===== 이메일 인증 =====
    sendCodeBtn.addEventListener("click", async function () {
    const email = emailInput.value.trim();
    if (!email) { alert("이메일을 입력해주세요."); return; }

    // 중복 체크 먼저
    const dupRes = await fetch("/api/member/check-email", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email })
    });
    const dupData = await dupRes.json();
    if (!dupData.available) {
        alert(dupData.message);
        emailInput.style.borderColor = "#ef4444";
        return;
    }
    emailInput.style.borderColor = "#10b981";

    // 중복 아니면 인증코드 발송
    sendCodeBtn.disabled = true;
    showSendingToast("이메일 발송중입니다");
    try {
        const res = await fetch("/api/email/send", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email })
        });
        if (res.ok) {
            alert("인증 코드가 발송되었습니다.");
            codeGroup.style.display = "flex";
            codeGroup.style.flexDirection = "column";
        } else { alert("발송에 실패했습니다. 다시 시도해주세요."); }
    } catch (e) {
        alert("발송에 실패했습니다. 다시 시도해주세요.");
    } finally {
        hideSendingToast();
        sendCodeBtn.disabled = false;
    }
});

    // 이메일 발송중 오버레이 (중앙 원형 점 스피너)
    function showSendingToast(message) {
        let overlay = document.getElementById("sendingOverlay");
        if (!overlay) {
            // 스피너 점 8개를 원형으로 배치
            let dots = "";
            const total = 8;
            for (let i = 0; i < total; i++) {
                const angle = i * (360 / total);
                const opacity = 0.15 + (0.85 * i / (total - 1)); // 연함→진함
                dots +=
                    '<span style="position:absolute;top:50%;left:50%;width:15px;height:15px;margin:-7.5px;' +
                    'border-radius:50%;background:#2563eb;opacity:' + opacity.toFixed(2) + ';' +
                    'transform:rotate(' + angle + 'deg) translateY(-32px);"></span>';
            }

            overlay = document.createElement("div");
            overlay.id = "sendingOverlay";
            overlay.style.cssText =
                "position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;" +
                "align-items:center;justify-content:center;gap:26px;" +
                "background:rgba(245,246,250,.78);backdrop-filter:blur(2px);font-family:inherit;";
            overlay.innerHTML =
                '<div style="position:relative;width:80px;height:80px;animation:sendingSpin .8s steps(8) infinite;">' +
                dots +
                '</div>' +
                '<div style="font-size:16px;font-weight:700;color:#1c1e26;letter-spacing:-0.3px;">' +
                '<span id="sendingOverlayMsg"></span>' +
                '<span id="sendingOverlayDots" style="display:inline-block;width:1.2em;text-align:left;"></span>' +
                '</div>';
            document.body.appendChild(overlay);

            const style = document.createElement("style");
            style.textContent = "@keyframes sendingSpin{to{transform:rotate(360deg)}}";
            document.head.appendChild(style);
        }
        // 메시지는 고정, 점만 칸 안에서 늘어남 (. → .. → ...)
        document.getElementById("sendingOverlayMsg").textContent = message;
        const dotEl = document.getElementById("sendingOverlayDots");
        let step = 1;
        dotEl.textContent = ".";
        clearInterval(window._sendingDotTimer);
        window._sendingDotTimer = setInterval(function () {
            step = (step % 3) + 1;
            dotEl.textContent = ".".repeat(step);
        }, 400);

        overlay.style.display = "flex";
    }

    function hideSendingToast() {
        clearInterval(window._sendingDotTimer);
        const overlay = document.getElementById("sendingOverlay");
        if (overlay) overlay.style.display = "none";
    }

    verifyCodeBtn.addEventListener("click", async function () {
        const email = emailInput.value.trim();
        const code  = codeInput.value.trim();
        if (!code) { alert("인증 코드를 입력해주세요."); return; }
        const res = await fetch("/api/email/verify", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email: email, code: code })
        });
        if (res.ok) {
            codeHint.textContent = "✓ 인증이 완료되었습니다.";
            codeHint.style.color = "#10b981";
            emailInput.readOnly = true;
            sendCodeBtn.disabled = true;
            codeInput.disabled = true;
            verifyCodeBtn.disabled = true;
        } else {
            codeHint.textContent = "✗ 인증 코드가 일치하지 않습니다.";
            codeHint.style.color = "#ef4444";
        }
    });

    // ===== 휴대폰 SMS 인증 =====
    const sendSmsBtn   = document.getElementById("sendSmsBtn");
    const smsCodeGroup = document.getElementById("smsCodeGroup");
    const smsCodeInput = document.getElementById("smsCodeInput");
    const verifySmsBtn = document.getElementById("verifySmsBtn");
    const smsHint      = document.getElementById("smsHint");

    sendSmsBtn.addEventListener("click", async function () {
        const phone = document.getElementById("phoneInput").value.trim();
        if (!phone) { alert("휴대폰 번호를 입력해주세요."); return; }
        const res = await fetch("/api/sms/send", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone: phone })
        });
        if (res.ok) {
            alert("인증번호가 발송되었습니다.");
            smsCodeGroup.style.display = "flex";
            smsCodeGroup.style.flexDirection = "column";
        } else { alert("발송에 실패했습니다. 다시 시도해주세요."); }
    });

    verifySmsBtn.addEventListener("click", async function () {
        const phone = document.getElementById("phoneInput").value.trim();
        const code  = smsCodeInput.value.trim();
        if (!code) { alert("인증번호를 입력해주세요."); return; }
        const res = await fetch("/api/sms/verify", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ phone: phone, code: code })
        });
        if (res.ok) {
            smsHint.textContent = "✓ 인증이 완료되었습니다.";
            smsHint.style.color = "#10b981";
            document.getElementById("phoneInput").readOnly = true;
            sendSmsBtn.disabled = true;
            smsCodeInput.disabled = true;
            verifySmsBtn.disabled = true;
        } else {
            smsHint.textContent = "✗ 인증번호가 일치하지 않습니다.";
            smsHint.style.color = "#ef4444";
        }
    });

    // 프로필 미리보기
    const profileImageFile = document.getElementById("profileImageFile");
    const preview = document.getElementById("preview");
    const fileName = document.getElementById("fileName");
    profileImageFile.addEventListener("change", function () {
        const file = profileImageFile.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.style.backgroundImage = "url(" + e.target.result + ")";
                preview.textContent = "";
            };
            reader.readAsDataURL(file);
            fileName.textContent = file.name;
        } else {
            preview.style.backgroundImage = "";
            preview.textContent = "👤";
            fileName.textContent = "선택 사항이에요";
        }
    });


</script>

{{> layout/footer}}
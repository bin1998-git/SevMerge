{{> layout/header}}

<style>
    /* ── 배경 ── */
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .cm-wrap { max-width: 1100px; margin: 0 auto; padding: 28px 28px 80px; position: relative; z-index: 1; }

    /* 상단 배너 */
    .cm-banner { background: linear-gradient(135deg, #1846C9 0%, #2563eb 55%, #5b8fff 100%); border-radius: 20px; padding: 26px 32px; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; gap: 24px; position: relative; overflow: hidden; min-height: 104px; box-shadow: 0 8px 32px rgba(37,99,235,.2); }
    .cm-banner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 85% 50%, rgba(255,255,255,.12) 0%, transparent 55%); pointer-events: none; }
    .cm-banner-left { display: flex; flex-direction: column; gap: 7px; z-index: 1; }
    .cm-banner-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.18); border-radius: 20px; padding: 3px 11px; width: fit-content; font-size: 11px; font-weight: 700; letter-spacing: .08em; color: #fff; }
    .cm-banner-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; }
    .cm-banner-title { font-size: 20px; font-weight: 800; color: #fff; letter-spacing: -.02em; line-height: 1.3; }
    .cm-banner-title span { opacity: .8; font-size: 13px; font-weight: 400; }
    .cm-banner-cta { padding: 11px 22px; background: #fff; color: #2563eb; border: none; border-radius: 25px; font-size: 14px; font-weight: 800; cursor: pointer; font-family: inherit; white-space: nowrap; z-index: 1; text-decoration: none; box-shadow: 0 4px 14px rgba(0,0,0,.1); transition: all .15s; }
    .cm-banner-cta:hover { background: #eff6ff; transform: translateY(-1px); }

    .cm-body { display: grid; grid-template-columns: 240px 1fr; gap: 20px; align-items: start; }

    /* 왼쪽 사이드 - 글래스 */
    .cm-side { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8); border-radius: 20px; overflow: hidden; box-shadow: 0 8px 32px rgba(37,99,235,.08); }
    .cm-profile { padding: 28px 24px; text-align: center; border-bottom: 1px solid rgba(37,99,235,.08); }
    .cm-avatar { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); border: 3px solid rgba(255,255,255,.9); margin: 0 auto 14px; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 900; color: #fff; background-size: cover; background-position: center; box-shadow: 0 4px 16px rgba(37,99,235,.2); }
    .cm-name { font-size: 16px; font-weight: 800; color: #1e3a6e; }
    .cm-role { display: inline-block; margin-top: 6px; font-size: 11px; font-weight: 700; color: #2563eb; background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2); padding: 3px 12px; border-radius: 20px; }
    .cm-menu { padding: 10px 0; }
    .cm-group { font-size: 11px; font-weight: 700; color: #93aecf; letter-spacing: 1px; padding: 12px 22px 6px; }
    .cm-link { display: flex; align-items: center; gap: 10px; padding: 11px 22px; font-size: 13px; font-weight: 600; color: #4a6fa5; text-decoration: none; border-left: 3px solid transparent; cursor: pointer; transition: all .12s; }
    .cm-link:hover { background: rgba(37,99,235,.06); color: #2563eb; }
    .cm-link.active { background: rgba(37,99,235,.08); color: #2563eb; border-left-color: #2563eb; }
    .cm-link.danger { color: #ef4444; }
    .cm-link.danger:hover { background: rgba(239,68,68,.06); }
    .cm-icon { width: 18px; text-align: center; display: flex; align-items: center; }
    .cm-soon { font-size: 10px; color: #93aecf; margin-left: auto; }

    /* 오른쪽 */
    .cm-main { display: flex; flex-direction: column; gap: 20px; }
    .cm-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }
    .cm-stat { backdrop-filter: blur(12px); background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8); border-radius: 16px; padding: 18px; display: flex; align-items: center; gap: 12px; transition: all .2s; text-decoration: none; color: inherit; box-shadow: 0 4px 16px rgba(37,99,235,.06); }
    .cm-stat:hover { border-color: rgba(37,99,235,.3); box-shadow: 0 8px 24px rgba(37,99,235,.1); transform: translateY(-2px); background: rgba(255,255,255,.75); }
    .cm-stat-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 19px; flex-shrink: 0; }
    .ic-blue { background: rgba(37,99,235,.1); } .ic-green { background: rgba(16,185,129,.1); } .ic-amber { background: rgba(245,158,11,.1); } .ic-violet { background: rgba(124,58,237,.1); }
    .cm-stat-val { font-size: 20px; font-weight: 900; line-height: 1; color: #1e3a6e; }
    .cm-stat-lbl { font-size: 12px; color: #4a6fa5; margin-top: 5px; }

    .cm-content { backdrop-filter: blur(16px); background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8); border-radius: 20px; padding: 28px 30px; min-height: 420px; box-shadow: 0 8px 32px rgba(37,99,235,.07); }
    .cm-content-head { margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(37,99,235,.08); }
    .cm-content-title { font-size: 18px; font-weight: 900; color: #1e3a6e; }
    .cm-content-sub { font-size: 13px; color: #4a6fa5; margin-top: 3px; }

    .cm-item { backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); border-radius: 14px; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; text-decoration: none; color: inherit; transition: all .2s; }
    .cm-item:hover { border-color: rgba(37,99,235,.3); box-shadow: 0 6px 20px rgba(37,99,235,.08); background: rgba(255,255,255,.85); }
    .cm-item-body { flex: 1; }
    .cm-item-cat { font-size: 11px; font-weight: 700; color: #2563eb; background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.15); padding: 3px 9px; border-radius: 6px; display: inline-block; margin-bottom: 6px; }
    .cm-item-title { font-size: 15px; font-weight: 700; color: #1e3a6e; margin-bottom: 4px; }
    .cm-item-meta { font-size: 12px; color: #4a6fa5; }
    .cm-item-right { text-align: right; flex-shrink: 0; margin-left: 16px; }
    .cm-item-price { font-size: 15px; font-weight: 900; color: #1e3a6e; }
    .cm-item-status { font-size: 11px; margin-top: 6px; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .st-open { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .st-closed { background: rgba(156,163,175,.1); color: #9ca3af; }
    .st-done { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .cm-empty { text-align: center; padding: 60px 0; font-size: 15px; color: #93aecf; }

    .cm-btn { display: inline-block; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; cursor: pointer; border: none; font-family: inherit; text-decoration: none; margin-top: 8px; transition: all .15s; }
    .cm-btn-primary { background: #2563eb; color: #fff; box-shadow: 0 2px 8px rgba(37,99,235,.25); }
    .cm-btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); }

    /* 정보수정 폼 */
    .cm-form { display: flex; flex-direction: column; gap: 18px; max-width: 480px; }
    .cm-fg { display: flex; flex-direction: column; gap: 7px; }
    .cm-flabel { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .cm-finput { padding: 12px 16px; background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.15); border-radius: 10px; font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .15s; }
    .cm-finput:focus { border-color: #2563eb; background: rgba(255,255,255,.95); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .cm-finput:disabled { color: #93aecf; background: rgba(240,244,250,.6); }
    .cm-form-btns { display: flex; justify-content: flex-end; }

    /* 준비중 */
    .cm-soon-box { text-align: center; padding: 70px 0; }
    .cm-soon-icon { font-size: 44px; margin-bottom: 14px; }
    .cm-soon-title { font-size: 17px; font-weight: 800; color: #1e3a6e; margin-bottom: 6px; }
    .cm-soon-desc { font-size: 14px; color: #4a6fa5; }

    /* 페이지네이션 */
    .cm-paging { display: flex; justify-content: center; gap: 6px; margin-top: 22px; }
    .cm-page { padding: 9px 14px; border-radius: 8px; backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1px solid rgba(255,255,255,.8); font-size: 13px; font-weight: 600; color: #4a6fa5; cursor: pointer; text-decoration: none; transition: all .15s; }
    .cm-page:hover { border-color: rgba(37,99,235,.3); color: #2563eb; }
    .cm-page.active { background: #2563eb; border-color: #2563eb; color: #fff; }

    /* 모달 */
    .ar-modal-bg { display: none; position: fixed; inset: 0; background: rgba(13,27,46,.5); z-index: 9999; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .ar-modal-bg.open { display: flex; }
    .ar-modal { backdrop-filter: blur(20px); background: rgba(255,255,255,.85); border: 1.5px solid rgba(255,255,255,.9); border-radius: 20px; padding: 28px; max-width: 420px; width: 90%; box-shadow: 0 20px 60px rgba(37,99,235,.15); }
    .ar-modal-title { font-size: 17px; font-weight: 900; margin-bottom: 6px; color: #1e3a6e; }
    .ar-modal-sub { font-size: 13px; color: #4a6fa5; margin-bottom: 16px; }
    .ar-modal-textarea { width: 100%; box-sizing: border-box; padding: 12px 14px; background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.15); border-radius: 10px; font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; }
    .ar-modal-textarea:focus { border-color: #2563eb; background: rgba(255,255,255,.95); }
    .ar-modal-btns { display: flex; justify-content: flex-end; gap: 8px; margin-top: 16px; }
    .ar-modal-cancel { padding: 9px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; background: rgba(243,244,248,.8); color: #4b5563; border: none; cursor: pointer; font-family: inherit; }
    .ar-modal-confirm { padding: 9px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; border: none; cursor: pointer; font-family: inherit; color: #fff; }
</style>

<div class="cm-wrap">

    <!-- 상단 배너 (광고/이벤트 자리) -->
    <div class="cm-banner">
        <div class="cm-banner-left">
            <div class="cm-banner-badge"><span class="cm-banner-dot"></span> 이번 주 한정 이벤트</div>
            <div class="cm-banner-title">첫 프로젝트 수수료 0% 🎉<br><span>지금 프로젝트를 등록하고 전문가를 만나보세요</span></div>
        </div>
        <a href="/projects/save-form" class="cm-banner-cta">프로젝트 등록하기 →</a>
    </div>

    <div class="cm-body">

        <!-- 왼쪽: 프로필 + 사이드바 -->
        <aside class="cm-side">
            <div class="cm-profile">
                {{#member.profileImage}}
                    <div class="cm-avatar" style="background-image:url('{{member.profileImageUrl}}'); font-size:0;"></div>
                {{/member.profileImage}}
                {{^member.profileImage}}
                    <div class="cm-avatar" id="sideAvatar">{{member.name}}</div>
                {{/member.profileImage}}
                <div class="cm-name">{{member.name}}</div>
                <img src="/client.png" style="width:114px; height:48px; object-fit:contain;"/>
            </div>
            <nav class="cm-menu">
                <div class="cm-group">내 활동</div>
                <a href="/my-pages?tab=projects" class="cm-link {{#isProjects}}active{{/isProjects}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 22H4v-2h16v2ZM4 20H2V4h2v16Zm18 0h-2V4h2v16Zm-11-4H9v-2h2v2Zm-2-2H7v-2h2v2Zm4 0h-2v-2h2v2Zm2-2h-2v-2h2v2Zm2-2h-2V8h2v2Zm3-6H4V2h16v2Z"/></svg></span>내 프로젝트</a>
                <a href="/my-pages?tab=messages" class="cm-link {{#isMessages}}active{{/isMessages}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4v2H2v14h2v2h4v2h2v-2h2v2h2v-2h6v-2h2V4h-2V2zm0 14H4V4h16v12z"/><path d="M6 7h12v2H6zm0 4h8v2H6z"/></svg></span>쪽지함 {{#messageCount}}<span style="background:#ef4444;color:#fff;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;margin-left:4px;">{{messageCount}}</span>{{/messageCount}}</a>
                <a href="/my-pages?tab=chats" class="cm-link {{#isChats}}active{{/isChats}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4v2H2v12h2v2h2v2h2v-2h2v2h2v-2h8v-2h2V4h-2V2zm0 14H4V4h16v12z"/><path d="M6 7h12v2H6zm0 4h6v2H6z"/></svg></span>1:1 채팅</a>
                <a href="/my-pages?tab=boards" class="cm-link {{#isBoards}}active{{/isBoards}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4v2H2v18h2v-2h16v2h2V4h-2V2zm0 16H4V4h16v14zM6 7h12v2H6zm0 4h12v2H6zm0 4h8v2H6z"/></svg></span>내 게시글</a>
                <a href="/my-pages?tab=reviews" class="cm-link {{#isReviews}}active{{/isReviews}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 23h-2v-4h2v4Zm-2-4H9v-4h2v4Zm4 0h-2v-4h2v4Zm-6-4H5v-2h4v2Zm10-2v2h-4v-2h4ZM5 13H1v-2h4v2Zm18 0h-4v-2h4v2ZM9 11H5V9h4v2Zm10 0h-4V9h4v2Zm-8-2H9V5h2v4Zm4 0h-2V5h2v4Zm-2-4h-2V1h2v4Z"/></svg></span>리뷰</a>
                <a href="/my-pages?tab=bookmarks" class="cm-link {{#isBookmarks}}active{{/isBookmarks}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 23h-2v-4h2v4Zm-2-4H9v-4h2v4Zm4 0h-2v-4h2v4Zm-6-4H5v-2h4v2Zm10-2v2h-4v-2h4ZM5 13H1v-2h4v2Zm18 0h-4v-2h4v2ZM9 11H5V9h4v2Zm10 0h-4V9h4v2Zm-8-2H9V5h2v4Zm4 0h-2V5h2v4Zm-2-4h-2V1h2v4Z"/></svg></span>북마크</a>
                <a href="/my-pages?tab=wishlist" class="cm-link {{#isWishlist}}active{{/isWishlist}}">
                    <span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21H10v-2H8v-2H6v-2H4v-2H2V9h2V7h2V5h4V3h4v2h4v2h2v2h2v4h-2v2h-2v2h-2v2h-2v2z"/></svg></span>찜한 전문가
                </a>

                <div class="cm-group">포인트 / 결제</div>
                <a href="/charge/form" class="cm-link"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5h18v2H3zM1 7h2v10H1zm2 10h18v2H3zM21 7h2v10h-2zM11 9h2v2h-2zm-2 2h2v2H9zm2 2h2v2h-2zm2-2h2v2h-2zm4 0h2v2h-2zM5 11h2v2H5z"/></svg></span>포인트 충전</a>
                <a href="/my-pages?tab=chargeHistory" class="cm-link {{#isChargeHistory}}active{{/isChargeHistory}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6v2H4v18h2v-2h12v2h2V4h-2V2zm0 16H6V4h12v14zM8 7h8v2H8zm0 4h8v2H8zm0 4h5v2H8z"/></svg></span>충전 내역</a>
                <a href="/my-pages?tab=refundHistory" class="cm-link {{#isRefundHistory}}active{{/isRefundHistory}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 5H7V3H5v2H3v2h2v2h2V7h2V5zm8 4h-2V7h-4V5h6v2h2v6h-2V9zm-4 4H7v-2H5v2H3v6h2v-2h2v2h8v-2h2v-4h-2v2h-2v2H7v-2H5v-2h2v-2h6v2h2v-2h-2z"/></svg></span>환불 내역</a>
                <a href="/my-pages?tab=payments" class="cm-link {{#isPayments}}active{{/isPayments}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4v2H2v18h2v-2h2v2h2v-2h2v2h2v-2h2v2h2v-2h2v2h2V4h-2V2zm0 16H4V4h16v14zM8 7h8v2H8zm0 4h8v2H8zm0 4h5v2H8z"/></svg></span>결제 내역</a>

                <div class="cm-group">계정</div>
                <a href="/my-pages?tab=edit" class="cm-link {{#isEdit}}active{{/isEdit}}"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 2h4v2h2v2h2v2h-2v2h2v2h-2v2h2v2h-2v2h-2v2h-4v-2H8v-2H6v-2h2v-2H6v-2h2V9H6V7h2V5h2V3h-2V1zm4 2h-4v2H8v2H6v2h2v4H6v2h2v2h2v2h4v-2h2v-2h2v-2h-2v-4h2V7h-2V5h-2V3z"/><path d="M10 9h4v6h-4z"/></svg></span>계정 / 정보 수정</a>
                <a href="#" onclick="withdrawMember(event)" class="cm-link danger"><span class="cm-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H8v2H6v18h2v-2h12V4h-2V2zm0 16H8V4h12v14zM13 11h2v2h-2z"/></svg></span>회원 탈퇴</a>
            </nav>
        </aside>

        <!-- 오른쪽: 통계 + 콘텐츠 -->
        <div class="cm-main">

            <!-- 통계 -->
            <div class="cm-stats">
                <a href="/my-pages?tab=projects" class="cm-stat" style="text-decoration:none;color:inherit;cursor:pointer;">
                    <div class="cm-stat-icon ic-blue"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 22H4v-2h16v2ZM4 20H2V4h2v16Zm18 0h-2V4h2v16Zm-11-4H9v-2h2v2Zm-2-2H7v-2h2v2Zm4 0h-2v-2h2v2Zm2-2h-2v-2h2v2Zm2-2h-2V8h2v2Zm3-6H4V2h16v2Z"/></svg></div><div><div class="cm-stat-val">{{projectCount}}</div><div class="cm-stat-lbl">등록 프로젝트</div></div>
                </a>
                <a href="/my-pages?tab=projects" class="cm-stat" style="text-decoration:none;color:inherit;cursor:pointer;">
                    <div class="cm-stat-icon ic-green"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M10 18H8v-2h2v2Zm-2-2H6v-2h2v2Zm4-2v2h-2v-2h2Zm-6 0H4v-2h2v2Zm8 0h-2v-2h2v2Zm2-2h-2v-2h2v2Zm2-2h-2V8h2v2Zm2-2h-2V6h2v2Z"/></svg></div><div><div class="cm-stat-val">{{completedCount}}</div><div class="cm-stat-lbl">완료 프로젝트</div></div>
                </a>
                <a href="/my-pages?tab=messages" class="cm-stat" style="text-decoration:none;color:inherit;cursor:pointer;">
                    <div class="cm-stat-icon ic-amber"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4v2H2v14h2v2h4v2h2v-2h2v2h2v-2h6v-2h2V4h-2V2zm0 14H4V4h16v12z"/><path d="M6 7h12v2H6zm0 4h8v2H6z"/></svg></div><div><div class="cm-stat-val">{{messageCount}}</div><div class="cm-stat-lbl">새 메시지</div></div>
                </a>
                <a href="/my-pages?tab=chargeHistory" class="cm-stat" style="text-decoration:none;color:inherit;cursor:pointer;">
                    <div class="cm-stat-icon ic-violet"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5h18v2H3zM1 7h2v10H1zm2 10h18v2H3zM21 7h2v10h-2zM11 9h2v2h-2zm-2 2h2v2H9zm2 2h2v2h-2zm2-2h2v2h-2zm4 0h2v2h-2zM5 11h2v2H5z"/></svg></div><div><div class="cm-stat-val">{{member.displayBalance}}</div><div class="cm-stat-lbl">보유 포인트</div></div>
                </a>
            </div>
            <!-- 콘텐츠 -->
            <section class="cm-content">


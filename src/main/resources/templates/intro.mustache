{{> layout/header}}

<!-- ══ 히어로 ══ -->
<div class="hero">

    <!-- 왼쪽: 다크 패널 -->
    <div class="hero-dark">
        <img src="/codeImage.jpg" alt="코드 이미지" class="hero-code-img" />
        <div class="hero-badge-dark">🚀 IT 프리랜서 매칭 플랫폼</div>
        <h1 class="hero-title-dark">
            당신의 아이디어를<br>
            <span class="hl">[코드]</span>로, 현실로.
        </h1>
        <p class="hero-desc-dark">
            당신의 아이디어를 영실하기뜨리,<br>
            코드로로 현실을 수 있습니다.
        </p>
        <div class="hero-btns-dark">
            <a href="/join-start" class="btn btn-cyan">지금 무료로 시작 →</a>
            <a href="/projects" class="btn btn-outline-dark">프로젝트 둘러보기</a>
        </div>
    </div>

    <!-- 오른쪽: 밝은 카드 -->
    <div class="hero-light">
        <img src="/personIcon.png" alt="전문가 아이콘" class="hero-person-img" />
        <div class="hero-badge-light">🚀 IT 프리랜서 매칭 플랫폼</div>
        <h2 class="hero-title-light">
            코딩, 디자인,<br>
            무엇이든 <span class="hl">코앞에서.</span>
        </h2>
        <div class="mini-cards">
            <div class="mini-card">
                <div class="mini-card-ico">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 9L4 12L8 15" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M16 9L20 12L16 15" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="18" cy="18" r="5" fill="#22c55e"/>
                        <path d="M15.5 18L17 19.5L20.5 16" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="mini-card-eyebrow">Project</div>
                <div class="mini-card-title">프로젝트 매칭</div>
            </div>
            <div class="mini-card">
                <div class="mini-card-ico">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="3" width="18" height="18" rx="3" stroke="#2563eb" stroke-width="2"/>
                        <circle cx="12" cy="12" r="3" stroke="#2563eb" stroke-width="2"/>
                        <path d="M12 3V6M12 18V21M3 12H6M18 12H21" stroke="#2563eb" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="19" cy="5" r="4" fill="#f59e0b"/>
                        <path d="M17.5 5L18.5 6L21 3.5" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="mini-card-eyebrow">Project</div>
                <div class="mini-card-title">프로젝트 가용</div>
            </div>
        </div>
        <div class="hero-btns-light">
            <a href="/join-start" class="btn btn-blue-light">의뢰인으로 시작</a>
            <a href="/join-start" class="btn btn-outline-light">전문가로 등록</a>
        </div>
    </div>
</div>

<!-- 통계 바 -->
<div class="stats-bar">
    <div class="stat"><span class="stat-num">1,200<em>+</em></span><div class="stat-label">등록 전문가</div></div>
    <div class="stat"><span class="stat-num">3,800<em>+</em></span><div class="stat-label">완료 프로젝트</div></div>
    <div class="stat"><span class="stat-num">98<em>%</em></span><div class="stat-label">의뢰인 만족도</div></div>
    <div class="stat"><span class="stat-num">100<em>%</em></span><div class="stat-label">에스크로 안전 결제</div></div>
</div>

<!-- ══ 서비스 소개 ══ -->
<section class="features" id="features">
    <div class="section-inner">
        <div class="section-header">
            <p class="eyebrow">서비스 소개</p>
            <h2 class="sec-title">서비스 소개</h2>
            <p class="sec-desc">단순한 매칭을 넘어, 프로젝트 완료까지 안전하게 함께합니다.</p>
        </div>
        <div class="feature-grid">
            <div class="feature-card"><div class="feature-icon">🎯</div><div class="feature-name">정확한 전문가 매칭</div><p class="feature-desc">웹·앱·디자인·데이터·영상 등 분야별 인증 전문가 풀에서 프로젝트에 딱 맞는 사람을 찾을 수 있습니다.</p></div>
            <div class="feature-card"><div class="feature-icon">🔒</div><div class="feature-name">에스크로 안전 결제</div><p class="feature-desc">의뢰인이 먼저 금액을 예치하고, 작업 완료 후 전문가에게 지급됩니다. 먹튀·미지급 걱정 없이 진행하세요.</p></div>
            <div class="feature-card"><div class="feature-icon">💬</div><div class="feature-name">쪽지로 직접 소통</div><p class="feature-desc">플랫폼 내 쪽지 기능으로 의뢰인과 전문가가 자유롭게 소통하고 요구사항을 조율할 수 있습니다.</p></div>
            <div class="feature-card"><div class="feature-icon">📋</div><div class="feature-name">투명한 제안서 시스템</div><p class="feature-desc">전문가가 프로젝트에 제안서를 제출하면 의뢰인이 금액·경력·포트폴리오를 비교해 낙찰할 수 있습니다.</p></div>
            <div class="feature-card"><div class="feature-icon">⭐</div><div class="feature-name">검증된 리뷰 시스템</div><p class="feature-desc">완료된 프로젝트에 대한 실제 리뷰만 작성 가능합니다. 진짜 후기로 신뢰할 수 있는 전문가를 선택하세요.</p></div>
            <div class="feature-card"><div class="feature-icon">🏅</div><div class="feature-name">인증 전문가 뱃지</div><p class="feature-desc">관리자 심사를 통과한 전문가에게 인증 뱃지가 부여됩니다. 높은 퀄리티의 전문가를 한눈에 확인하세요.</p></div>
        </div>
    </div>
</section>

<!-- ══ 이용 방법 ══ -->
<section class="how" id="how">
    <div class="section-inner">
        <p class="eyebrow">How It Works</p>
        <h2 class="sec-title">이렇게 사용하세요</h2>
        <div class="how-steps-row">
            <div class="how-col">
                <p class="how-col-label client">💼 의뢰인이라면</p>
                <div class="steps">
                    <div class="step"><div class="step-num blue">1</div><div><div class="step-title">프로젝트 등록</div><p class="step-desc">원하는 작업 내용, 예산, 기간을 입력하고 프로젝트를 등록합니다. 카테고리별로 적합한 전문가에게 노출됩니다.</p></div></div>
                    <div class="step"><div class="step-num blue">2</div><div><div class="step-title">제안서 검토 & 낙찰</div><p class="step-desc">전문가들이 보낸 제안서를 비교하고, 가장 마음에 드는 전문가를 낙찰합니다.</p></div></div>
                    <div class="step"><div class="step-num blue">3</div><div><div class="step-title">에스크로 결제 & 완료 승인</div><p class="step-desc">잔액으로 에스크로를 생성하고, 작업 완료 후 최종 승인하면 전문가에게 자동 정산됩니다.</p></div></div>
                </div>
            </div>
            <div class="how-col">
                <p class="how-col-label expert">🧑‍💻 전문가라면</p>
                <div class="steps">
                    <div class="step"><div class="step-num purple">1</div><div><div class="step-title">프로필 등록 & 인증 신청</div><p class="step-desc">기술 스택, 경력, 포트폴리오를 입력하고 인증 전문가 심사를 신청합니다.</p><br></div></div>
                    <div class="step"><div class="step-num purple">2</div><div><div class="step-title">프로젝트 탐색 & 제안서 제출</div><p class="step-desc">원하는 프로젝트에 제안 금액과 예상 기간을 담아 제안서를 제출합니다.</p></div></div>
                    <div class="step"><div class="step-num purple">3</div><div><div class="step-title">작업 완료 & 수익 정산</div><p class="step-desc">낙찰 후 작업을 완료하고 의뢰인의 승인을 받으면 수익이 잔액으로 정산됩니다.</p></div></div>
                </div>
            </div>
        </div>
        <div class="how-mock">
            <p class="how-mock-label">LIVE PROJECT</p>
            <div class="mock-cards-row">
                <div class="mock-card"><div class="mock-title">React + Spring Boot 쇼핑몰 풀스택 개발</div><div class="mock-tags"><span class="mock-tag tag-blue">WEB</span><span class="mock-tag tag-blue">풀스택</span><span class="mock-tag tag-green">모집중</span></div><div class="mock-price">예산 300만원 · 30일</div></div>
                <div class="mock-card"><div class="mock-title">iOS 헬스케어 앱 UI/UX + 개발</div><div class="mock-tags"><span class="mock-tag tag-blue">APP</span><span class="mock-tag tag-blue">iOS</span><span class="mock-tag tag-purple">낙찰완료</span></div><div class="mock-price">예산 500만원 · 60일</div></div>
                <div class="mock-card"><div class="mock-title">브랜드 유튜브 채널 영상 편집 월정기</div><div class="mock-tags"><span class="mock-tag tag-amber">영상</span><span class="mock-tag tag-green">모집중</span></div><div class="mock-price">예산 80만원 · 매월</div></div>
            </div>
        </div>
    </div>
</section>

<!-- ══ 분야 ══ -->
<section class="categories" id="categories">
    <div class="section-inner">
        <p class="eyebrow">Categories</p>
        <h2 class="sec-title">어떤 분야든 찾을 수 있어요</h2>
        <p class="sec-desc">웹 개발부터 영상 편집까지, 다양한 분야의 전문가가 기다리고 있습니다.</p>
        <div class="cat-grid">
            <div class="cat-card"><span class="cat-emoji">🌐</span><div class="cat-name">웹 개발</div><div class="cat-sub">React · Vue · Spring · Node</div></div>
            <div class="cat-card"><span class="cat-emoji">📱</span><div class="cat-name">앱 개발</div><div class="cat-sub">iOS · Android · Flutter</div></div>
            <div class="cat-card"><span class="cat-emoji">🎨</span><div class="cat-name">UI/UX 디자인</div><div class="cat-sub">Figma · XD · 프로토타입</div></div>
            <div class="cat-card"><span class="cat-emoji">📊</span><div class="cat-name">데이터 · AI</div><div class="cat-sub">Python · ML · 분석 대시보드</div></div>
            <div class="cat-card"><span class="cat-emoji">🎬</span><div class="cat-name">영상 편집</div><div class="cat-sub">Premiere · After Effects</div></div>
            <div class="cat-card"><span class="cat-emoji">🔧</span><div class="cat-name">DevOps · 인프라</div><div class="cat-sub">AWS · Docker · CI/CD</div></div>
            <div class="cat-card"><span class="cat-emoji">🛡️</span><div class="cat-name">보안 · QA</div><div class="cat-sub">테스트 · 취약점 분석</div></div>
            <div class="cat-card"><span class="cat-emoji">✏️</span><div class="cat-name">기타</div><div class="cat-sub">워드프레스 · SEO · 크롤링</div></div>
        </div>
    </div>
</section>

<!-- ══ 안전 결제 ══ -->
<section class="trust" id="trust">
    <div class="section-inner">
        <p class="eyebrow">Trust & Safety</p>
        <h2 class="sec-title">안심하고 거래하세요</h2>
        <p class="sec-desc">코드요는 의뢰인과 전문가 모두를 보호하는 안전한 거래 환경을 제공합니다.</p>
        <div class="trust-grid">
            <div class="trust-card"><span class="trust-icon">🏦</span><div class="trust-name">에스크로 결제 시스템</div><p class="trust-desc">의뢰인이 예치한 금액은 작업 완료 승인 전까지 안전하게 보관됩니다. 일방적인 미지급은 불가능합니다.</p></div>
            <div class="trust-card"><span class="trust-icon">🔁</span><div class="trust-name">환불 보장</div><p class="trust-desc">작업 결과물이 마음에 들지 않으면 의뢰인이 직접 환불을 요청할 수 있습니다. 분쟁 발생 시 관리자가 개입합니다.</p></div>
            <div class="trust-card"><span class="trust-icon">✅</span><div class="trust-name">인증 전문가 심사</div><p class="trust-desc">전문가는 관리자의 심사를 통과해야 인증 뱃지를 받습니다. 검증된 전문가만이 인증 마크를 달 수 있습니다.</p></div>
        </div>
    </div>
</section>

<!-- ══ CTA 배너 ══ -->
<section class="cta-banner">
    <div class="cta-inner">
        <h2 class="cta-title">지금 바로 <span class="hl">시작</span>해보세요</h2>
        <p class="cta-desc">무료로 가입하고 프로젝트를 등록하거나, 전문가로 활동을 시작하세요.</p>
        <div class="cta-btns">
            <a href="/join-start" class="btn btn-cta-cyan">의뢰인으로 시작</a>
            <a href="/join-start" class="btn btn-cta-ghost">전문가로 등록</a>
        </div>
    </div>
</section>

<!-- ══ 푸터 ══ -->
{{> layout/footer}}

</body>
</html>

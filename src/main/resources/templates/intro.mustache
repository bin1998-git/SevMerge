{{> layout/header}}

<style>
    body {
        background: #f0f4fa;
        color: #1e293b;
        line-height: 1.6;
    }

    a { text-decoration: none; color: inherit; }

    /* ══ 히어로 ══ */
    .hero {
        padding: 28px 28px 32px;
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
        max-width: 1300px; margin: 0 auto;
    }
    .hero-dark {
        background: linear-gradient(140deg, rgba(13,27,46,.82) 0%, rgba(14,42,74,.75) 60%, rgba(13,32,64,.85) 100%),
        url('/mainBackground.jpg') center/cover no-repeat;
        border-radius: 24px; padding: 48px 44px 44px;
        position: relative; overflow: hidden; min-height: 440px;
        display: flex; flex-direction: column; justify-content: flex-end;
    }
    .hero-dark::before {
        content: ''; position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(0,200,224,.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,200,224,.06) 1px, transparent 1px);
        background-size: 40px 40px; pointer-events: none;
    }
    .hero-code-img {
        position: absolute; top: 24px; right: 24px;
        width: 200px; height: 375px; border-radius: 16px; object-fit: cover; opacity: .92;
    }
    .hero-badge-dark {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(0,200,224,.12); border: 1px solid rgba(0,200,224,.3);
        border-radius: 999px; padding: 4px 14px;
        font-size: 11px; font-weight: 700; color: var(--cyan);
        margin-bottom: 20px; letter-spacing: .3px; width: fit-content;
    }
    .hero-title-dark {
        font-size: clamp(24px, 2.8vw, 38px); font-weight: 900; color: #fff;
        line-height: 1.2; letter-spacing: -1.5px; margin-bottom: 14px;
        max-width: calc(100% - 220px);
    }
    .hero-title-dark .hl { color: var(--cyan); }
    .hero-desc-dark {
        font-size: 14px; color: rgba(255,255,255,.55);
        line-height: 1.75; margin-bottom: 24px; max-width: calc(100% - 220px);
    }
    .hero-btns-dark { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
    .btn-cyan {
        background: var(--cyan); color: var(--navy);
        border-radius: 30px; padding: 12px 26px; font-size: 14px; font-weight: 800;
        text-decoration: none; display: inline-block;
    }
    .btn-cyan:hover { background: var(--cyan-dark); }
    .btn-outline-dark {
        background: transparent; color: #fff;
        border: 1.5px solid rgba(255,255,255,.35);
        border-radius: 30px; padding: 12px 26px; font-size: 14px; font-weight: 700;
        text-decoration: none; display: inline-block;
    }
    .btn-outline-dark:hover { border-color: rgba(255,255,255,.7); }

    /* 히어로 스텝 */
    .hero-steps {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .hero-step {
        display: flex; align-items: center; gap: 7px;
        background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
        border-radius: 10px; padding: 7px 12px;
    }
    .hero-step-num {
        width: 20px; height: 20px; border-radius: 50%;
        background: var(--cyan); color: var(--navy);
        font-size: 10px; font-weight: 900;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .hero-step-txt { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.75); white-space: nowrap; }
    .hero-step-arrow { font-size: 12px; color: rgba(255,255,255,.3); }

    /* 라이트 히어로 */
    .hero-light {
        background: #fff; border-radius: 24px; padding: 32px 32px 28px;
        display: flex; flex-direction: column; justify-content: flex-start; gap: 18px;
        position: relative; overflow: hidden; min-height: 440px;
    }
    .hero-person-img {
        position: absolute; bottom: 0; right: -10px;
        width: 260px; height: auto; object-fit: contain; pointer-events: none; z-index: 2;
    }
    .hero-badge-light {
        display: inline-flex; align-items: center; gap: 6px;
        background: #eff6ff; border: 1px solid #bfdbfe;
        border-radius: 999px; padding: 4px 14px;
        font-size: 11px; font-weight: 700; color: var(--blue);
        letter-spacing: .3px; width: fit-content;
    }
    .hero-title-light {
        font-size: clamp(24px, 3vw, 38px); font-weight: 900; color: #0f172a;
        line-height: 1.2; letter-spacing: -1.5px; max-width: 62%;
    }
    .hero-title-light .hl { color: var(--blue); }
    .mini-cards {
        display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
        max-width: 62%; position: relative; z-index: 3;
    }
    .mini-card {
        background: #f8faff; border: 1.5px solid var(--border);
        border-radius: 16px; padding: 20px 14px; transition: border-color .2s, background .2s;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        text-align: center; aspect-ratio: 1 / 1; text-decoration: none; color: inherit;
        cursor: pointer;
    }
    .mini-card:hover { border-color: #93c5fd; background: #fff; }
    .mini-card-ico {
        width: 52px; height: 52px; border-radius: 14px;
        background: #fff; margin-bottom: 12px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 8px rgba(37,99,235,.1);
    }
    .mini-card-ico svg { width: 28px; height: 28px; }
    .mini-card-eyebrow { font-size: 10px; color: var(--gray-lt); font-weight: 600; margin-bottom: 4px; letter-spacing: .3px; }
    .mini-card-title { font-size: 13px; font-weight: 800; color: #0f172a; }
    .hero-btns-light {
        display: flex; gap: 8px; flex-wrap: wrap;
        max-width: 62%; position: relative; z-index: 3;
    }
    .btn-blue-light {
        background: var(--blue); color: #fff; border-radius: 30px; padding: 11px 20px;
        font-size: 13px; font-weight: 800; flex: 1; text-align: center;
        text-decoration: none; display: inline-block;
    }
    .btn-blue-light:hover { background: var(--blue-dark); }
    .btn-outline-light {
        background: #fff; color: #1e293b;
        border: 1.5px solid var(--border); border-radius: 30px; padding: 11px 20px;
        font-size: 13px; font-weight: 700; flex: 1; text-align: center;
        text-decoration: none; display: inline-block;
    }
    .btn-outline-light:hover { border-color: var(--blue); color: var(--blue); }

    /* ══ 통계 바 ══ */
    .stats-bar {
        max-width: 1300px; margin: 0 auto; padding: 20px 28px;
        display: flex; justify-content: space-around; flex-wrap: wrap; gap: 16px;
    }
    .stat { text-align: center; }
    .stat-num { font-size: 28px; font-weight: 900; color: #0f172a; display: block; letter-spacing: -1px; }
    .stat-num em { color: var(--blue); font-style: normal; }
    .stat-label { font-size: 12px; color: var(--gray-lt); font-weight: 500; margin-top: 2px; }

    /* ══ 공통 섹션 ══ */
    section { padding: 80px 28px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
    .sec-title { font-size: clamp(26px, 4vw, 38px); font-weight: 900; letter-spacing: -1.5px; color: #0f172a; margin-bottom: 12px; }
    .sec-desc { font-size: 15px; color: var(--gray); max-width: 550px; line-height: 1.8; }
    .section-header { margin-bottom: 52px; }

    /* ══ 서비스 소개 ══ */
    .features { background: #fff; }
    .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .feature-card {
        background: #f8faff; border: 1.5px solid var(--border);
        border-radius: 18px; padding: 30px 26px; transition: border-color .2s, box-shadow .2s;
    }
    .feature-card:hover { border-color: #93c5fd; box-shadow: 0 6px 24px rgba(37,99,235,.08); }
    .feature-icon {
        width: 50px; height: 50px; border-radius: 14px; background: #eff6ff;
        display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 16px;
    }
    .feature-name { font-size: 16px; font-weight: 800; color: #0f172a; margin-bottom: 8px; letter-spacing: -.3px; }
    .feature-desc { font-size: 13px; color: var(--gray); line-height: 1.75; }

    /* ══ 이용 방법 ══ */
    .how { background: #f0f4fa; }
    .how-steps-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 52px; align-items: start; }
    .how-col { background: #fff; border: 1.5px solid var(--border); border-radius: 20px; padding: 28px 28px 32px; height: 100%; }
    .how-col-label { font-size: 13px; font-weight: 700; margin-bottom: 24px; }
    .how-col-label.client { color: var(--blue); }
    .how-col-label.expert { color: #7c3aed; }
    .steps { display: flex; flex-direction: column; gap: 22px; }
    .step { display: flex; gap: 16px; align-items: flex-start; }
    .step-num {
        width: 32px; height: 32px; border-radius: 8px; color: #fff;
        font-size: 13px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .step-num.blue { background: var(--blue); }
    .step-num.purple { background: #7c3aed; }
    .step-title { font-size: 14px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
    .step-desc { font-size: 13px; color: var(--gray); line-height: 1.7; }
    .how-mock { margin-top: 32px; background: #fff; border: 1.5px solid var(--border); border-radius: 20px; padding: 24px 28px; }
    .how-mock-label { font-size: 11px; font-weight: 700; color: var(--gray-lt); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
    .mock-cards-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .mock-card { background: #f8faff; border-radius: 14px; padding: 16px 18px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 8px; }
    .mock-title { font-size: 13px; font-weight: 700; color: #0f172a; line-height: 1.4; }
    .mock-tags { display: flex; gap: 5px; flex-wrap: wrap; }
    .mock-tag { font-size: 10px; font-weight: 700; border-radius: 6px; padding: 2px 8px; }
    .tag-blue { background: #dbeafe; color: #1e40af; }
    .tag-green { background: #d1fae5; color: #065f46; }
    .tag-purple { background: #ede9fe; color: #5b21b6; }
    .tag-amber { background: #fef3c7; color: #92400e; }
    .mock-price { font-size: 13px; font-weight: 900; color: var(--blue); margin-top: auto; }

    /* ══ 분야 ══ */
    .categories { background: var(--navy); }
    .categories .eyebrow { color: #67e8f9; }
    .categories .sec-title { color: #fff; }
    .categories .sec-desc { color: rgba(255,255,255,.45); }
    .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 40px; }
    .cat-card {
        background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.09);
        border-radius: 14px; padding: 22px 16px; text-align: center;
        transition: background .2s, border-color .2s; cursor: default;
    }
    .cat-card:hover { background: rgba(0,200,224,.15); border-color: rgba(0,200,224,.4); }
    .cat-emoji { font-size: 26px; margin-bottom: 10px; display: block; }
    .cat-name { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 3px; }
    .cat-sub { font-size: 11px; color: rgba(255,255,255,.35); }

    /* ══ 신뢰 ══ */
    .trust { background: #fff; }
    .trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 52px; }
    .trust-card { border: 1.5px solid var(--border); border-radius: 18px; padding: 30px 26px; text-align: center; transition: border-color .2s; }
    .trust-card:hover { border-color: #93c5fd; }
    .trust-icon { font-size: 34px; margin-bottom: 14px; display: block; }
    .trust-name { font-size: 15px; font-weight: 800; color: #0f172a; margin-bottom: 8px; }
    .trust-desc { font-size: 13px; color: var(--gray); line-height: 1.75; }

    /* ══ CTA ══ */
    .cta-banner { background: linear-gradient(180deg, #1a3a8f 0%, #131d3b 60%, #0d1b2e 100%); padding: 88px 28px; text-align: center; }
    .cta-inner { max-width: 620px; margin: 0 auto; }
    .cta-title { font-size: clamp(28px, 5vw, 46px); font-weight: 900; color: #fff; letter-spacing: -2px; margin-bottom: 14px; }
    .cta-title .hl { color: var(--cyan); }
    .cta-desc { font-size: 16px; color: rgba(255,255,255,.6); margin-bottom: 38px; line-height: 1.8; }
    .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-cta-cyan { background: var(--cyan); color: var(--navy); border-radius: 30px; padding: 14px 32px; font-size: 15px; font-weight: 800; text-decoration: none; }
    .btn-cta-cyan:hover { background: var(--cyan-dark); }
    .btn-cta-ghost { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.3); border-radius: 30px; padding: 14px 32px; font-size: 15px; font-weight: 700; text-decoration: none; }
    .btn-cta-ghost:hover { border-color: rgba(255,255,255,.7); }

    /* ══ 반응형 ══ */
    @media (max-width: 960px) {
        .hero { grid-template-columns: 1fr; padding: 12px; }
        .hero-dark { min-height: 360px; padding: 32px 24px 28px; }
        .hero-light { min-height: auto; }
        .feature-grid { grid-template-columns: 1fr; }
        .how-steps-row { grid-template-columns: 1fr; }
        .mock-cards-row { grid-template-columns: 1fr; }
        .cat-grid { grid-template-columns: repeat(2, 1fr); }
        .trust-grid { grid-template-columns: 1fr; }
        section { padding: 60px 16px; }
    }
    @media (max-width: 480px) {
        .hero-person-img { width: 180px; }
        .hero-code-img { width: 140px; height: 260px; }
        .mini-cards { max-width: 58%; }
        .hero-btns-light { max-width: 58%; }
        .hero-title-light { max-width: 58%; }
        .hero-steps { display: none; }
    }
</style>

<!-- ══ 히어로 ══ -->
<section class="hero">

    <!-- 좌: 다크 - 의뢰인 메인 CTA -->
    <div class="hero-dark">
        <img src="/codeImage.jpg" alt="" class="hero-code-img"/>
        <span class="hero-badge-dark">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;">
                <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
            </svg>
            IT 프로젝트, 전문가에게 맡기세요
        </span>
        <h1 class="hero-title-dark">
            아이디어만 있으면<br>
            충분합니다.<br>
            <span class="hl">[코드요]</span>가 연결합니다.
        </h1>
        <p class="hero-desc-dark">
            프로젝트를 등록하면 평균 <strong style="color:var(--cyan);">24시간 내</strong> 검증된 전문가가 제안서를 보내옵니다.<br>
            복잡한 개발, 디자인, AI까지 — 한 번의 등록으로 시작하세요.
        </p>
        <div class="hero-btns-dark">
            <a href="/projects/form" class="btn-cyan" style="display: inline-flex; align-items: center; gap: 6px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                </svg>
                프로젝트 등록하기
            </a>
            <a href="/experts" class="btn-outline-dark">전문가 둘러보기</a>
        </div>
        <div class="hero-steps">
            <div class="hero-step">
                <span class="hero-step-num">1</span>
                <span class="hero-step-txt">프로젝트 등록</span>
            </div>
            <span class="hero-step-arrow">→</span>
            <div class="hero-step">
                <span class="hero-step-num">2</span>
                <span class="hero-step-txt">전문가 제안 수신</span>
            </div>
            <span class="hero-step-arrow">→</span>
            <div class="hero-step">
                <span class="hero-step-num">3</span>
                <span class="hero-step-txt">안전 결제 &amp; 완료</span>
            </div>
        </div>
    </div>

    <!-- 우: 라이트 - 카테고리 빠른 진입 -->
    <div class="hero-light">
        <img src="/personIcon.png" alt="" class="hero-person-img"/>
        <span class="hero-badge-light" style="display: inline-flex; align-items: center; gap: 6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            오늘도 새 프로젝트가 등록되었어요
        </span>
        <h2 class="hero-title-light">
            어떤 프로젝트를<br>
            <span class="hl">맡기고</span><br>
            싶으신가요?
        </h2>
        <div class="mini-cards">
            <a href="/projects/form?category=web" class="mini-card">
                <div class="mini-card-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="16 18 22 12 16 6"></polyline>
                        <polyline points="8 6 2 12 8 18"></polyline>
                    </svg>
                </div>
                <div class="mini-card-eyebrow">Web / App</div>
                <div class="mini-card-title">웹 · 앱 개발</div>
            </a>
            <a href="/projects/form?category=design" class="mini-card">
                <div class="mini-card-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <circle cx="12" cy="12" r="4"></circle>
                        <line x1="4.93" y1="4.93" x2="9.17" y2="9.17"></line>
                        <line x1="14.83" y1="14.83" x2="19.07" y2="19.07"></line>
                        <line x1="14.83" y1="9.17" x2="19.07" y2="4.93"></line>
                        <line x1="4.93" y1="19.07" x2="9.17" y2="14.83"></line>
                    </svg>
                </div>
                <div class="mini-card-eyebrow">Design</div>
                <div class="mini-card-title">UI/UX 디자인</div>
            </a>
        </div>
        <div class="hero-btns-light">
            <a href="/join-start" class="btn-blue-light">무료로 시작하기</a>
            <a href="/projects" class="btn-outline-light">등록된 프로젝트</a>
        </div>
    </div>

</section>

<!-- ══ 통계 바 ══ -->
<div class="stats-bar">
    <div class="stat"><span class="stat-num">1,200<em>+</em></span><div class="stat-label">등록 전문가</div></div>
    <div class="stat"><span class="stat-num">3,800<em>+</em></span><div class="stat-label">완료 프로젝트</div></div>
    <div class="stat"><span class="stat-num">98<em>%</em></span><div class="stat-label">의뢰인 만족도</div></div>
    <div class="stat"><span class="stat-num">100<em>%</em></span><div class="stat-label">에스크로 안전 결제</div></div>
</div>

<!-- ══ 서비스 소개 ══ -->
<section class="features" id="features">
    <div class="section-inner">
        <div class="section-header">
            <p class="eyebrow">WHY ICODEU</p>
            <h2 class="sec-title">왜 코드요인가요?</h2>
            <p class="sec-desc">검증된 전문가, 안전한 결제, 빠른 매칭까지 — IT 프리랜싱의 모든 것을 한 곳에서.</p>
        </div>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="feature-icon" style="display: flex; align-items: center; justify-content: center; color: var(--blue);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                        <polyline points="22 4 12 14.01 9 11.01"></polyline>
                    </svg>
                </div>
                <div class="feature-name">검증된 전문가</div>
                <p class="feature-desc">포트폴리오·경력·리뷰 기반으로 엄선된 전문가와만 연결됩니다. [cite: 141] 실력을 직접 확인하고 선택하세요. [cite: 141]</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon" style="display: flex; align-items: center; justify-content: center; color: var(--blue);">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <div class="feature-name">에스크로 안전 결제</div>

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ICodeU — IT 전문가 매칭 플랫폼</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@600&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: #f8fafc;
            color: #0f172a;
            line-height: 1.6;
        }
        a { text-decoration: none; color: inherit; }

        /* ── HEADER ── */
        .header {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 32px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
        }
        .logo {
            font-size: 18px;
            font-weight: 700;
            color: #0f172a;
            letter-spacing: -0.5px;
            white-space: nowrap;
            flex-shrink: 0;
        }
        .logo-code {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            color: #2563eb;
            background: #eff6ff;
            padding: 1px 6px;
            border-radius: 5px;
            font-size: 16px;
            border: 1px solid #bfdbfe;
        }
        .header-nav { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .btn-login {
            padding: 7px 18px;
            border: 1.5px solid #e2e8f0;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            color: #475569;
            background: #fff;
            cursor: pointer;
            transition: all .15s;
            font-family: inherit;
        }
        .btn-login:hover { border-color: #2563eb; color: #2563eb; }
        .btn-signup {
            padding: 7px 18px;
            background: #2563eb;
            color: #fff;
            border: 1.5px solid #2563eb;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }
        .btn-signup:hover { background: #1d4ed8; border-color: #1d4ed8; }
        .btn-dashboard {
            padding: 7px 18px;
            background: #f1f5f9;
            color: #334155;
            border: 1.5px solid #e2e8f0;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            transition: all .15s;
        }
        .btn-dashboard:hover { background: #e2e8f0; }
        .header-user {
            font-size: 13px;
            color: #64748b;
            font-weight: 500;
            padding: 0 4px;
        }
        .btn-logout {
            padding: 7px 14px;
            border: 1.5px solid #e2e8f0;
            border-radius: 7px;
            font-size: 12px;
            font-weight: 600;
            color: #94a3b8;
            background: #fff;
            cursor: pointer;
            transition: all .15s;
        }
        .btn-logout:hover { border-color: #ef4444; color: #ef4444; }

        /* ── SEARCH HERO ── */
        .search-hero {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 48px 32px 36px;
        }
        .search-hero-inner {
            max-width: 700px;
            margin: 0 auto;
        }
        .search-hero-logo {
            font-size: 13px;
            font-weight: 700;
            color: #94a3b8;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 12px;
            text-align: center;
        }
        .search-hero-title {
            font-size: 32px;
            font-weight: 900;
            color: #0f172a;
            letter-spacing: -1px;
            text-align: center;
            margin-bottom: 28px;
            line-height: 1.2;
        }
        .search-hero-title em { color: #2563eb; font-style: normal; }
        .search-row {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }
        .search-input {
            flex: 1;
            padding: 12px 18px;
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-radius: 9px;
            font-size: 14px;
            font-family: inherit;
            color: #0f172a;
            outline: none;
            transition: border-color .15s, background .15s;
        }
        .search-input::placeholder { color: #94a3b8; }
        .search-input:focus { border-color: #2563eb; background: #fff; }
        .search-submit {
            padding: 12px 24px;
            background: #0f172a;
            color: #fff;
            border: none;
            border-radius: 9px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            white-space: nowrap;
            transition: background .15s;
        }
        .search-submit:hover { background: #1e293b; }
        .search-keywords {
            display: flex;
            gap: 7px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .search-kw {
            padding: 5px 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            color: #64748b;
            transition: all .15s;
        }
        .search-kw:hover { background: #eff6ff; border-color: #93c5fd; color: #2563eb; }

        /* ── CATEGORY RAIL ── */
        .cat-rail {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 60px;
            z-index: 90;
        }
        .cat-rail-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 32px;
            display: flex;
            overflow-x: auto;
            scrollbar-width: none;
        }
        .cat-rail-inner::-webkit-scrollbar { display: none; }
        .cat-item {
            padding: 0 18px;
            height: 46px;
            display: flex;
            align-items: center;
            font-size: 13px;
            font-weight: 600;
            color: #64748b;
            white-space: nowrap;
            border-bottom: 2px solid transparent;
            cursor: pointer;
            transition: color .15s, border-color .15s;
        }
        .cat-item:hover { color: #0f172a; }
        .cat-item.active { color: #2563eb; border-color: #2563eb; }

        /* ── 메인 콘텐츠 ── */
        .main-content { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

        /* ── 전문가 섹션 ── */
        .expert-block { padding: 44px 0 0; }
        .expert-block + .expert-block { border-top: 1px solid #e2e8f0; }
        .expert-block:last-of-type { padding-bottom: 56px; }

        .block-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }
        .block-head-left { display: flex; align-items: baseline; gap: 12px; }
        .block-tag {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 3px 9px;
            border-radius: 4px;
        }
        .tag-blue  { background: #eff6ff; color: #1d4ed8; }
        .tag-amber { background: #fefce8; color: #a16207; }
        .tag-green { background: #f0fdf4; color: #166534; }

        .block-title {
            font-size: 19px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
        }
        .block-desc {
            font-size: 13px;
            color: #94a3b8;
            font-weight: 400;
        }
        .block-more {
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            white-space: nowrap;
        }
        .block-more:hover { text-decoration: underline; }

        /* ── 전문가 카드 ── */
        .expert-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
        }
        .expert-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            transition: border-color .2s, box-shadow .2s, transform .15s;
            display: block;
        }
        .expert-card:hover {
            border-color: #93c5fd;
            box-shadow: 0 4px 20px rgba(37,99,235,.08);
            transform: translateY(-2px);
        }
        .card-top {
            padding: 18px 18px 12px;
            display: flex;
            align-items: center;
            gap: 11px;
        }
        .card-avatar {
            width: 44px;
            height: 44px;
            border-radius: 11px;
            background: #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
            border: 1px solid #e2e8f0;
        }
        .card-meta { min-width: 0; }
        .card-name {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 5px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .verified {
            width: 14px;
            height: 14px;
            background: #2563eb;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 8px;
            color: #fff;
            flex-shrink: 0;
        }
        .card-role {
            font-size: 11px;
            color: #94a3b8;
            font-weight: 400;
            margin-top: 1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .card-tags {
            padding: 0 18px 12px;
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }
        .ctag {
            font-size: 10px;
            font-weight: 600;
            background: #f8fafc;
            color: #475569;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            padding: 2px 7px;
        }
        .card-footer {
            padding: 10px 18px 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #f1f5f9;
        }
        .card-price {
            font-size: 14px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.3px;
        }
        .card-price small { font-size: 11px; font-weight: 400; color: #94a3b8; }
        .card-rating {
            display: flex;
            align-items: center;
            gap: 3px;
            font-size: 12px;
            font-weight: 700;
            color: #f59e0b;
        }
        .card-rating span { color: #94a3b8; font-weight: 400; font-size: 11px; }

        /* ── 리뷰 섹션 ── */
        .review-section {
            background: #0f172a;
            padding: 64px 32px;
            margin-top: 56px;
        }
        .review-inner { max-width: 1200px; margin: 0 auto; }
        .review-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #475569;
            margin-bottom: 8px;
        }
        .review-title {
            font-size: 24px;
            font-weight: 900;
            color: #f8fafc;
            letter-spacing: -0.5px;
            margin-bottom: 32px;
        }
        .review-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }
        .review-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 24px;
        }
        .review-stars { color: #f59e0b; font-size: 12px; letter-spacing: 2px; margin-bottom: 14px; }
        .review-text {
            font-size: 13px;
            color: #cbd5e1;
            line-height: 1.8;
            margin-bottom: 20px;
            font-weight: 400;
        }
        .review-author {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-top: 16px;
            border-top: 1px solid #334155;
        }
        .review-ava {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: #2563eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }
        .review-name { font-size: 13px; font-weight: 700; color: #f1f5f9; }
        .review-sub { font-size: 11px; color: #64748b; margin-top: 1px; }

        /* ── FOOTER ── */
        .footer {
            background: #0f172a;
            border-top: 1px solid #1e293b;
            padding: 28px 32px;
        }
        .footer-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .footer-logo { font-size: 15px; font-weight: 700; color: #475569; }
        .footer-logo .logo-code { font-size: 13px; }
        .footer-copy { font-size: 12px; color: #334155; }
    </style>
</head>
<body>

<!-- HEADER -->
<header class="header">
    <div class="header-inner">
        <a href="/exmain" class="logo">I<span class="logo-code">&lt;Code&gt;</span>U</a>
        <nav class="header-nav">
            {{#isLoggedIn}}
                <a href="{{#isExpert}}/experts/dashboard{{/isExpert}}{{^isExpert}}/my-pages{{/isExpert}}" class="btn-dashboard">대시보드</a>
                <span class="header-user">{{sessionUser.name}}님</span>
                <a href="/logout" class="btn-logout">로그아웃</a>
            {{/isLoggedIn}}
            {{^isLoggedIn}}
                <a href="/login" class="btn-login">로그인</a>
                <a href="/join-start" class="btn-signup">회원가입</a>
            {{/isLoggedIn}}
        </nav>
    </div>
</header>

<!-- SEARCH HERO -->
<section class="search-hero">
    <div class="search-hero-inner">
        <div class="search-hero-logo">IT 전문가 매칭 플랫폼</div>
        <h1 class="search-hero-title">원하는 전문가를<br><em>지금 바로</em> 찾아보세요</h1>
        <div class="search-row">
            <input type="text" class="search-input" placeholder="React 개발, 앱 UI 디자인, 로고 제작 …">
            <button class="search-submit">검색</button>
        </div>
        <div class="search-keywords">
            <a href="/experts?category=UI" class="search-kw">UI/UX 디자인</a>
            <a href="/experts?category=LOGO" class="search-kw">로고 · 브랜딩</a>
            <a href="/experts?category=WEB" class="search-kw">웹 개발</a>
            <a href="/experts?category=APP" class="search-kw">앱 개발</a>
            <a href="/experts?category=VIDEO" class="search-kw">영상편집</a>
            <a href="/experts?category=DATA" class="search-kw">데이터 · AI</a>
            <a href="/experts?category=DEVOPS" class="search-kw">DevOps</a>
        </div>
    </div>
</section>

<!-- CATEGORY RAIL -->
<nav class="cat-rail">
    <div class="cat-rail-inner">
        <a href="#" class="cat-item active">전체</a>
        <a href="#" class="cat-item">UI/UX</a>
        <a href="#" class="cat-item">로고 · 브랜딩</a>
        <a href="#" class="cat-item">웹 개발</a>
        <a href="#" class="cat-item">앱 개발</a>
        <a href="#" class="cat-item">영상편집</a>
        <a href="#" class="cat-item">데이터 · AI</a>
        <a href="#" class="cat-item">DevOps</a>
        <a href="#" class="cat-item">보안 · QA</a>
        <a href="#" class="cat-item">기타</a>
    </div>
</nav>

<!-- MAIN -->
<div class="main-content">

    <!-- ① 오분대기조 -->
    <div class="expert-block">
        <div class="block-head">
            <div class="block-head-left">
                <span class="block-tag tag-blue">빠른 시작</span>
                <span class="block-title">오분대기조</span>
                <span class="block-desc">작업 기한이 빠른 전문가</span>
            </div>
            <a href="/experts" class="block-more">전체 보기 →</a>
        </div>
        <div class="expert-grid">
            <a href="/experts/1" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">🧑‍💻</div>
                    <div class="card-meta">
                        <div class="card-name">김민준 <span class="verified">✓</span></div>
                        <div class="card-role">React · Next.js 개발자</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">React</span><span class="ctag">TypeScript</span><span class="ctag">Next.js</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">50,000<small>원~</small></div>
                    <div class="card-rating">★ 4.9 <span>(32)</span></div>
                </div>
            </a>
            <a href="/experts/2" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">👩‍🎨</div>
                    <div class="card-meta">
                        <div class="card-name">이서연 <span class="verified">✓</span></div>
                        <div class="card-role">UI/UX 디자이너</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Figma</span><span class="ctag">Webflow</span><span class="ctag">Framer</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">80,000<small>원~</small></div>
                    <div class="card-rating">★ 5.0 <span>(18)</span></div>
                </div>
            </a>
            <a href="/experts/3" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">🧑‍🔧</div>
                    <div class="card-meta">
                        <div class="card-name">박도윤</div>
                        <div class="card-role">Flutter · 앱 개발</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Flutter</span><span class="ctag">Dart</span><span class="ctag">Firebase</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">120,000<small>원~</small></div>
                    <div class="card-rating">★ 4.8 <span>(47)</span></div>
                </div>
            </a>
            <a href="/experts/4" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">🎬</div>
                    <div class="card-meta">
                        <div class="card-name">최예린 <span class="verified">✓</span></div>
                        <div class="card-role">영상편집 · 모션그래픽</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Premiere</span><span class="ctag">After Effects</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">40,000<small>원~</small></div>
                    <div class="card-rating">★ 4.7 <span>(61)</span></div>
                </div>
            </a>
        </div>
    </div>

    <!-- ② 바가지 수사대 -->
    <div class="expert-block">
        <div class="block-head">
            <div class="block-head-left">
                <span class="block-tag tag-amber">가성비</span>
                <span class="block-title">바가지 수사대</span>
                <span class="block-desc">합리적인 가격의 전문가</span>
            </div>
            <a href="/experts" class="block-more">전체 보기 →</a>
        </div>
        <div class="expert-grid">
            <a href="/experts/5" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">🎯</div>
                    <div class="card-meta">
                        <div class="card-name">정하늘</div>
                        <div class="card-role">로고 · 브랜딩 디자인</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Illustrator</span><span class="ctag">Photoshop</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">20,000<small>원~</small></div>
                    <div class="card-rating">★ 4.6 <span>(29)</span></div>
                </div>
            </a>
            <a href="/experts/6" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">💻</div>
                    <div class="card-meta">
                        <div class="card-name">윤재원 <span class="verified">✓</span></div>
                        <div class="card-role">Spring Boot · Java 백엔드</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Spring</span><span class="ctag">MySQL</span><span class="ctag">AWS</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">60,000<small>원~</small></div>
                    <div class="card-rating">★ 4.8 <span>(14)</span></div>
                </div>
            </a>
            <a href="/experts/7" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">📊</div>
                    <div class="card-meta">
                        <div class="card-name">한소율</div>
                        <div class="card-role">데이터 분석 · Python</div>
                    </div>
                </div>
                <div class="card-tags">
                    <span class="ctag">Python</span><span class="ctag">Pandas</span><span class="ctag">Tableau</span>
                </div>
                <div class="card-footer">
                    <div class="card-price">35,000<small>원~</small></div>
                    <div class="card-rating">★ 4.5 <span>(22)</span></div>
                </div>
            </a>
            <a href="/experts/8" class="expert-card">
                <div class="card-top">
                    <div class="card-avatar">🌐</div>
                    <div class="card-meta">
                        <div class="card-name">오지훈</div>
                        <div class="card-role">웹 퍼블리싱 · HTML/CSS</div>
                    </div>
                </div>

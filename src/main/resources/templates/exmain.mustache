{{> layout/header}}
    <style>
        :root {
            --brand-blue:      #2D6BFF;
            --brand-blue-deep: #1846C9;
            --brand-sky:       #6BA0FF;
            --brand-ink:       #0C1424;
            --brand-slate:     #33415C;
            --brand-muted:     #5A6B85;
            --brand-mist:      #EBEEF4;
            --brand-line:      #E2E7F0;
            --brand-white:     #FFFFFF;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--brand-mist);
            color: var(--brand-ink);
            line-height: 1.6;
        }
        a { text-decoration: none; color: inherit; }

        /* [삭제 완료] 기존 .header, .header-inner, .nav-logo, .header-nav, .btn-h 관련 스타일 정의 제거 */

        /* ── SEARCH HERO ── */
        .search-hero { background: var(--brand-white); border-bottom: 1px solid var(--brand-line); padding: 52px 32px 40px; }
        .search-hero-inner { max-width: 680px; margin: 0 auto; }
        .sh-eyebrow {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .2em; text-transform: uppercase; color: var(--brand-muted);
            margin-bottom: 14px; text-align: center;
        }
        .sh-title {
            font-size: 34px; font-weight: 700; color: var(--brand-ink);
            letter-spacing: -.02em; text-align: center; margin-bottom: 28px; line-height: 1.2;
        }
        .sh-title em { color: var(--brand-blue); font-style: normal; }
        .sh-row { display: flex; gap: 8px; }
        .sh-input {
            flex: 1; padding: 12px 18px; background: var(--brand-mist);
            border: 1.5px solid var(--brand-line); border-radius: 8px;
            font-size: 14px; font-family: 'Space Grotesk', sans-serif; color: var(--brand-ink);
            outline: none; transition: border-color .15s, background .15s;
        }
        .sh-input::placeholder { color: var(--brand-muted); }
        .sh-input:focus { border-color: var(--brand-blue); background: var(--brand-white); }
        .sh-btn {
            padding: 12px 24px; background: var(--brand-ink); color: var(--brand-white);
            border: none; border-radius: 8px; font-size: 14px; font-weight: 600;
            cursor: pointer; font-family: inherit; white-space: nowrap; transition: background .15s;
        }
        .sh-btn:hover { background: var(--brand-slate); }

        /* ── MAIN CONTENT ── */
        .main-wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

        /* 메인 배너 광고 카드 */
        .ad-main-card {
            flex: 0 0 calc((100% - 32px) / 3); background: #fff; border: 1.5px solid #fde68a;
            border-radius: 14px; overflow: hidden; display: flex; flex-direction: column;
            transition: transform .2s, box-shadow .2s; text-decoration: none; color: inherit;
        }
        .ad-main-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(217,119,6,.16); }
        .ad-main-thumb { position: relative; width: 100%; padding-top: 60%; background-color: #f5f5f0; flex-shrink: 0; }
        .ad-main-thumb-img { position: absolute; inset: 0; background-size: cover; background-position: center; }
        .ad-main-badge {
            position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,.95); color: #92400e;
            font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 800;
            letter-spacing: .1em; padding: 2px 7px; border-radius: 4px; z-index: 1;
        }
        .ad-main-body { padding: 14px 16px 16px; display: flex; flex-direction: column; gap: 4px; }
        .ad-main-name { font-size: 14px; font-weight: 800; color: var(--brand-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .ad-main-spec { font-size: 11px; color: var(--brand-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .ad-main-msg {
            font-size: 12px; color: #78716c; line-height: 1.5; margin-top: 4px;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        }

        /* 캐러셀 미니 광고 카드 */
        .ad-mini-card { position: relative; background-color: #1c1209; overflow: hidden; min-height: 240px; }
        .ad-mini-thumb { position: absolute; inset: 0; background-size: cover; background-position: center; border-radius: 16px; }
        .ad-mini-badge {
            position: absolute; top: 12px; right: 12px; z-index: 2; background: rgba(255,255,255,.95); color: #92400e;
            font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 800; letter-spacing: .1em; padding: 3px 8px; border-radius: 5px;
        }

        /* ── EXPERT BLOCK ── */
        .expert-block { padding: 48px 0 0; }
        .expert-block + .expert-block { border-top: 1px solid var(--brand-line); }
        .expert-block:last-of-type { padding-bottom: 64px; }
        .block-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .block-head-left { display: flex; align-items: baseline; gap: 12px; }
        .block-kw {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .15em; text-transform: uppercase; padding: 3px 9px; border-radius: 4px;
        }
        .kw-blue  { background: #dde8ff; color: var(--brand-blue); }
        .kw-amber { background: #fef9c3; color: #92400e; }
        .kw-green { background: #dcfce7; color: #166534; }
        .block-sub { font-size: 20px; font-weight: 700; color: var(--brand-ink); letter-spacing: -.02em; }
        .block-more { font-size: 12px; font-weight: 600; color: var(--brand-blue); font-family: 'JetBrains Mono', monospace; letter-spacing: .02em; }
        .block-more:hover { text-decoration: underline; }

        /* ── CAROUSEL ── */
        .carousel-section { position: relative; }
        .c-viewport { overflow: hidden; }
        .c-track { display: flex; gap: 16px; will-change: transform; }

        /* ── BUSINESS CARD (명함 스타일에 따른 본문 레이아웃) ── */
        .biz-card {
            flex: 0 0 calc((100% - 32px) / 3); min-height: 240px; background: #0d1728;
            border: 1px solid rgba(255,255,255,.07); border-radius: 16px; overflow: hidden;
            transition: border-color .25s, box-shadow .25s, transform .2s; cursor: pointer; display: block;
        }
        .biz-card:hover { border-color: rgba(45,107,255,.45); box-shadow: 0 8px 32px rgba(45,107,255,.18); transform: translateY(-2px); }
        .biz-inner { padding: 24px; min-height: 240px; display: flex; flex-direction: column; justify-content: space-between; }
        .biz-brand { display: flex; align-items: center; gap: 12px; }
        .biz-app-icon { width: 52px; height: 52px; border-radius: 12px; display: block; flex-shrink: 0; }
        .biz-wordmark { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 700; letter-spacing: .12em; color: rgba(255,255,255,.80); }
        .bwm-iu { color: var(--brand-sky); }
        .biz-name-line { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
        .biz-name {
            font-size: 16px; font-weight: 700; color: #ffffff; letter-spacing: -.02em; line-height: 1.35;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        }
        .biz-role { font-family: 'Space Grotesk', sans-serif; font-size: 12px; font-weight: 500; color: var(--brand-sky); white-space: nowrap; }
        .biz-contacts { display: flex; flex-direction: column; gap: 5px; }
        .biz-ct {
            font-family: 'JetBrains Mono', monospace; font-size: 11px; color: rgba(255,255,255,.40);
            display: flex; align-items: center; gap: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .biz-ct-dot { color: var(--brand-blue); font-size: 9px; flex-shrink: 0; }
        .biz-ct a { color: var(--brand-sky); text-decoration: none; }
        .biz-ct a:hover { text-decoration: underline; }

        /* ── TRUST BAR ── */
        .trust-bar { background: var(--brand-white); border-bottom: 1px solid var(--brand-line); padding: 0 32px; }
        .trust-bar-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 0; height: 44px; }
        .trust-item { display: flex; align-items: center; gap: 7px; font-size: 12px; font-weight: 500; color: var(--brand-muted); padding: 0 28px; }
        .trust-item + .trust-item { border-left: 1px solid var(--brand-line); }
        .trust-item svg { flex-shrink: 0; }
        .trust-item strong { color: var(--brand-ink); font-weight: 700; }

        /* ── BIZ CARD OVERLAY ── */
        .biz-overlay {
            position: absolute; bottom: 0; left: 0; right: 0;
            background: linear-gradient(to bottom, rgba(13,23,40,0) 0%, rgba(13,23,40,.96) 28%, #0a1222 100%);
            border-radius: 0 0 16px 16px; padding: 32px 24px 24px; transform: translateY(100%);
            transition: transform .32s cubic-bezier(0.4,0,0.2,1); display: flex; flex-direction: column; gap: 14px;
        }
        .biz-card:hover .biz-overlay { transform: translateY(0); }
        .ov-stats { display: flex; gap: 16px; }
        .ov-stat { display: flex; flex-direction: column; gap: 2px; }
        .ov-stat-val { font-family: 'JetBrains Mono', monospace; font-size: 15px; font-weight: 700; color: #ffffff; }
        .ov-stat-val .ov-stars { color: #f59e0b; letter-spacing: 1px; font-size: 12px; }
        .ov-stat-label { font-size: 10px; color: rgba(255,255,255,.38); font-family: 'JetBrains Mono', monospace; letter-spacing: .05em; }
        .ov-divider { width: 1px; background: rgba(255,255,255,.08); align-self: stretch; flex-shrink: 0; }
        .ov-cta {
            display: block; width: 100%; padding: 10px 0; background: var(--brand-blue); color: #fff;
            border: none; border-radius: 8px; font-size: 13px; font-weight: 700; font-family: inherit;
            cursor: pointer; text-align: center; transition: background .15s;
        }
        .ov-cta:hover { background: var(--brand-blue-deep); color: #fff; }

        /* ── CAROUSEL ARROWS ── */
        .c-arrow {
            position: absolute; top: 0; bottom: 0; width: 80px; display: flex; align-items: center;
            border: none; cursor: pointer; z-index: 10; font-size: 28px; font-weight: 300;
            color: rgba(255,255,255,.6); transition: color .15s; padding: 0;
        }
        .c-arrow:hover { color: var(--brand-sky); }
        .c-arrow-right { right: 0; background: linear-gradient(to right, transparent 0%, var(--brand-mist) 60%); justify-content: flex-end; padding-right: 14px; }
        .c-arrow-left { left: 0; background: linear-gradient(to left, transparent 0%, var(--brand-mist) 60%); justify-content: flex-start; padding-left: 14px; }

        /* ── BANNER #5: 프로모션 카운트다운 ── */
        .promo-banner {
            background: linear-gradient(135deg, #1846C9 0%, #2D6BFF 50%, #5b8fff 100%); border-radius: 16px;
            padding: 28px 36px; margin: 48px 0 0; display: flex; align-items: center; justify-content: space-between;
            gap: 24px; position: relative; overflow: hidden;
        }
        .promo-banner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 80% 50%, rgba(255,255,255,.08) 0%, transparent 60%); pointer-events: none; }
        .promo-left { display: flex; flex-direction: column; gap: 6px; }
        .promo-badge {
            display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.18);
            border-radius: 20px; padding: 3px 10px; width: fit-content; font-family: 'JetBrains Mono', monospace;
            font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #fff;
        }
        .promo-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: blink 1.4s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
        .promo-title { font-size: 22px; font-weight: 700; color: #fff; letter-spacing: -.02em; line-height: 1.2; }
        .promo-title span { opacity: .75; font-size: 14px; font-weight: 400; }
        .promo-right { display: flex; align-items: center; gap: 20px; flex-shrink: 0; }
        .promo-timer { display: flex; align-items: center; gap: 8px; }
        .promo-unit { display: flex; flex-direction: column; align-items: center; gap: 2px; }
        .promo-num {
            font-family: 'JetBrains Mono', monospace; font-size: 28px; font-weight: 700; color: #fff;
            background: rgba(0,0,0,.15); padding: 4px 10px; border-radius: 8px; min-width: 48px; text-align: center;
        }
        .promo-colon { font-family: 'JetBrains Mono', monospace; font-size: 22px; font-weight: 500; color: rgba(255,255,255,.5); padding-bottom: 16px; }
        .promo-label { font-size: 9px; font-weight: 600; color: rgba(255,255,255,.5); letter-spacing: .05em; text-transform: uppercase; }
        .promo-btn {
            background: #fff; color: var(--brand-blue); font-size: 13px; font-weight: 700;
            padding: 12px 24px; border-radius: 30px; box-shadow: 0 4px 14px rgba(24,70,201,.2);
            transition: transform .15s, box-shadow .15s;
        }
        .promo-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(24,70,201,.3); }

        /* ── SECTION REVIEWS ── */
        .review-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .review-card { background: var(--brand-white); border: 1px solid var(--brand-line); border-radius: 14px; padding: 20px; }
        .rev-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
        .rev-project { font-size: 14px; font-weight: 700; color: var(--brand-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%; }
        .rev-stars { color: #f59e0b; font-size: 12px; letter-spacing: 1px; }
        .rev-comment { font-size: 13px; color: var(--brand-slate); line-height: 1.5; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
        .rev-meta { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--brand-muted); display: flex; gap: 8px; }
        .rev-author { font-weight: 600; color: var(--brand-slate); }

        /* ── SECTION STATS ── */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding-bottom: 48px; }
        .stat-card { background: var(--brand-white); border: 1px solid var(--brand-line); border-radius: 14px; padding: 24px; text-align: center; }
        .st-val { font-family: 'JetBrains Mono', monospace; font-size: 32px; font-weight: 700; color: var(--brand-blue); letter-spacing: -.02em; margin-bottom: 4px; }
        .st-label { font-size: 12px; font-weight: 600; color: var(--brand-muted); }

        /* ── FOOTER ── */
        .footer { background: var(--brand-white); border-top: 1px solid var(--brand-line); padding: 40px 32px; color: var(--brand-muted); font-size: 12px; }
        .footer-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: flex-start; gap: 40px; }
        .footer-left { display: flex; flex-direction: column; gap: 12px; }
        .footer-logo { font-family: 'JetBrains Mono', monospace; font-size: 18px; font-weight: 700; letter-spacing: .1em; color: var(--brand-ink); }
        .footer-logo span { color: var(--brand-blue); }
        .footer-links { display: flex; gap: 20px; margin-bottom: 4px; }
        .footer-links a { font-weight: 600; color: var(--brand-slate); }
        .footer-links a:hover { color: var(--brand-blue); text-decoration: underline; }
        .footer-right { font-family: 'JetBrains Mono', monospace; text-align: right; font-size: 11px; }

        @media(max-width: 960px) {
            .ad-main-card, .biz-card { flex: 0 0 calc((100% - 16px) / 2); }
            .review-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .promo-banner { flex-direction: column; align-items: flex-start; padding: 24px; }
            .promo-right { width: 100%; justify-content: space-between; }
            .footer-inner { flex-direction: column; gap: 24px; }
            .footer-right { text-align: left; }
        }
        @media(max-width: 560px) {
            .ad-main-card, .biz-card { flex: 0 0 100%; }
            .stats-grid { grid-template-columns: 1fr; }
            .sh-title { font-size: 26px; }
            .sh-row { flex-direction: column; }
            .sh-btn { width: 100%; text-align: center; }
        }
    </style>
</head>
<body>

<section class="search-hero">
    <div class="search-hero-inner">
        <div class="sh-eyebrow">Expert Workspace / Center</div>
        <h2 class="sh-title">전문가님, 반갑습니다.<br>오늘도 <em>최고의 코드</em>를 공유해보세요.</h2>
        <form class="sh-row" action="/projects" method="GET">
            <input class="sh-input" type="text" name="kw" placeholder="관심 있는 프로젝트 검색어 또는 기술 스택을 입력하세요..."/>
            <button class="sh-btn" type="submit">의뢰 검색</button>
        </form>
    </div>
</section>

<div class="trust-bar">
    <div class="trust-bar-inner">
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>누적 완료 의뢰 <strong>14,209건</strong></span>
        </div>
        <div class="trust-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            <span>안전한 에스크로 거래 대금 보호</span>
        </div>
    </div>
</div>

<div class="main-wrap">

    <section class="expert-block">
        <div class="block-head">
            <div class="block-head-left">
                <span class="block-kw kw-amber">AD / Premium</span>
                <h3 class="block-sub">추천 상단 광고 전문가</h3>
            </div>
        </div>

        <div style="display:flex; gap:16px; flex-wrap:wrap;">
            {{#adExperts}}
                <a class="ad-main-card" href="/experts/{{id}}">
                    <div class="ad-main-thumb">
                        <div class="ad-main-thumb-img" style="background-image: url('{{#bannerImage}}{{bannerImageUrl}}{{/bannerImage}}{{^bannerImage}}/default-banner.jpg{{/bannerImage}}');"></div>
                        <div class="ad-main-badge">PREMIUM</div>
                    </div>
                    <div class="ad-main-body">
                        <div class="ad-main-name">{{user.name}} 전문가</div>
                        <div class="ad-main-spec">{{techStack}} · 경력 {{careerYear}}년</div>
                        <div class="ad-main-msg">{{introduction}}</div>
                    </div>
                </a>
            {{/adExperts}}
            {{^adExperts}}
                <div style="flex:1; background:#fff; border:1px dashed var(--brand-line); border-radius:14px; padding:40px; text-align:center; font-size:13px; color:var(--brand-muted);">
                    현재 활성화된 프리미엄 상단 광고 전문가가 없습니다.
                </div>
            {{/adExperts}}
        </div>
    </section>

    <section class="expert-block">
        <div class="block-head">
            <div class="block-head-left">
                <span class="block-kw kw-blue">LIVE BIDDING</span>
                <h3 class="block-sub">실시간 지원 대기중인 프로젝트</h3>
            </div>
            <a class="block-more" href="/projects">ALL PROJECTS →</a>
        </div>

        <div class="carousel-section" id="c1">
            <button class="c-arrow c-arrow-left" aria-label="이전">&#8249;</button>
            <div class="c-viewport">
                <div class="c-track">
                    {{#recentProjects}}
                        <div class="biz-card" data-project-id="{{id}}" data-dday="D-{{dday}}" data-budget="{{budget}}원" href="/projects/{{id}}">
                            <div class="biz-inner">
                                <div class="biz-brand">
                                    <img class="biz-app-icon" src="/project-icon.svg" alt="App"/>
                                    <div class="biz-wordmark">PRJ<span class="bwm-iu">.{{id}}</span></div>
                                </div>
                                <div class="biz-body">
                                    <div class="biz-name-line">
                                        <h4 class="biz-name">{{title}}</h4>
                                        <div class="biz-role">{{category}}</div>
                                    </div>
                                    <div class="biz-contacts">
                                        <div class="biz-ct"><span class="biz-ct-dot">■</span>스택: {{requiredSkills}}</div>
                                        <div class="biz-ct"><span class="biz-ct-dot">■</span>마감일: {{endDate}}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {{/recentProjects}}
                    {{^recentProjects}}
                        <div style="flex:1; background:#fff; border:1px dashed var(--brand-line); border-radius:16px; padding:60px; text-align:center; font-size:14px; color:var(--brand-muted);">
                            현재 등록된 신규 프로젝트 의뢰가 존재하지 않습니다.
                        </div>
                    {{/recentProjects}}
                </div>
            </div>
            <button class="c-arrow c-arrow-right" aria-label="다음">&#8250;</button>
        </div>
    </section>

    <section class="expert-block">
        <div class="block-head">
            <div class="block-head-left">
                <span class="block-kw kw-green">MASTER RANK</span>
                <h3 class="block-sub">아이코드유 공인 최고 등급 마스터</h3>
            </div>
            <a class="block-more" href="/experts">ALL EXPERTS →</a>
        </div>

        <div class="carousel-section" id="c2">
            <button class="c-arrow c-arrow-left" aria-label="이전">&#8249;</button>
            <div class="c-viewport">
                <div class="c-track">
                    {{#masterExperts}}
                        <div class="biz-card" data-project-id="EX-{{id}}" data-dday="★ {{grade}}" data-budget="리뷰 {{reviewCount}}개" href="/experts/{{id}}">
                            <div class="biz-inner">
                                <div class="biz-brand">
                                    <img class="biz-app-icon" src="/expert-icon.svg" alt="Expert"/>
                                    <div class="biz-wordmark">EXP<span class="bwm-iu">.{{id}}</span></div>
                                </div>

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>IcodeU — IT 전문가 매칭 플랫폼</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
    <style>
        :root {
            --brand-blue:      #2D6BFF;
            --brand-blue-deep: #1846C9;
            --brand-sky:       #6BA0FF;
            --brand-ink:       #0C1424;
            --brand-slate:     #33415C;
            --brand-muted:     #5A6B85;
            --brand-mist:      #EBEEF4;
            --brand-line:      #E2E7F0;
            --brand-white:     #FFFFFF;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Space Grotesk', sans-serif;
            background: var(--brand-mist);
            color: var(--brand-ink);
            line-height: 1.6;
        }
        a { text-decoration: none; color: inherit; }

        /* ── HEADER ── */
        .header {
            background: var(--brand-white);
            border-bottom: 1px solid var(--brand-line);
            position: sticky; top: 0; z-index: 100;
        }
        .header-inner {
            max-width: 1200px; margin: 0 auto; padding: 0 32px;
            height: 60px; display: flex; align-items: center;
            justify-content: space-between; gap: 24px;
        }
        .nav-logo img { display: block; height: 32px; width: auto; }
        .header-nav { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
        .btn-h {
            padding: 7px 18px; border-radius: 7px; font-size: 13px; font-weight: 600;
            font-family: inherit; cursor: pointer; transition: all .15s;
            border: 1.5px solid var(--brand-line); background: var(--brand-white); color: var(--brand-slate);
        }
        .btn-h:hover { border-color: var(--brand-blue); color: var(--brand-blue); }
        .btn-h-fill { background: var(--brand-blue); color: var(--brand-white); border-color: var(--brand-blue); }
        .btn-h-fill:hover { background: var(--brand-blue-deep); border-color: var(--brand-blue-deep); color: #fff; }
        .btn-h-ghost { border-color: transparent; background: var(--brand-mist); color: var(--brand-slate); }
        .btn-h-ghost:hover { background: var(--brand-line); }
        .h-username { font-size: 13px; color: var(--brand-muted); font-weight: 500; padding: 0 4px; }
        .btn-h-logout {
            padding: 6px 14px; border-radius: 7px; font-size: 12px; font-weight: 600;
            font-family: inherit; cursor: pointer; transition: all .15s;
            border: 1.5px solid var(--brand-line); background: transparent; color: var(--brand-muted);
        }
        .btn-h-logout:hover { border-color: #ef4444; color: #ef4444; }

        /* ── SEARCH HERO ── */
        .search-hero { background: var(--brand-white); border-bottom: 1px solid var(--brand-line); padding: 52px 32px 40px; }
        .search-hero-inner { max-width: 680px; margin: 0 auto; }
        .sh-eyebrow {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .2em; text-transform: uppercase; color: var(--brand-muted);
            margin-bottom: 14px; text-align: center;
        }
        .sh-title {
            font-size: 34px; font-weight: 700; color: var(--brand-ink);
            letter-spacing: -.02em; text-align: center; margin-bottom: 28px; line-height: 1.2;
        }
        .sh-title em { color: var(--brand-blue); font-style: normal; }
        .sh-row { display: flex; gap: 8px; }
        .sh-input {
            flex: 1; padding: 12px 18px; background: var(--brand-mist);
            border: 1.5px solid var(--brand-line); border-radius: 8px;
            font-size: 14px; font-family: 'Space Grotesk', sans-serif;
            color: var(--brand-ink); outline: none; transition: border-color .15s, background .15s;
        }
        .sh-input::placeholder { color: var(--brand-muted); }
        .sh-input:focus { border-color: var(--brand-blue); background: var(--brand-white); }
        .sh-btn {
            padding: 12px 24px; background: var(--brand-ink); color: var(--brand-white);
            border: none; border-radius: 8px; font-size: 14px; font-weight: 600;
            cursor: pointer; font-family: inherit; white-space: nowrap; transition: background .15s;
        }
        .sh-btn:hover { background: var(--brand-slate); }

        /* ── MAIN ── */
        .main-wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }

        /* ── EXPERT BLOCK ── */
        .expert-block { padding: 48px 0 0; }
        .expert-block + .expert-block { border-top: 1px solid var(--brand-line); }
        .expert-block:last-of-type { padding-bottom: 64px; }
        .block-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .block-head-left { display: flex; align-items: baseline; gap: 12px; }
        .block-kw {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .15em; text-transform: uppercase; padding: 3px 9px; border-radius: 4px;
        }
        .kw-blue  { background: #dde8ff; color: var(--brand-blue); }
        .kw-amber { background: #fef9c3; color: #92400e; }
        .kw-green { background: #dcfce7; color: #166534; }
        .block-sub { font-size: 20px; font-weight: 700; color: var(--brand-ink); letter-spacing: -.02em; }
        .block-more {
            font-size: 12px; font-weight: 600; color: var(--brand-blue);
            font-family: 'JetBrains Mono', monospace; letter-spacing: .02em;
        }
        .block-more:hover { text-decoration: underline; }

        /* ── CAROUSEL ── */
        .carousel-section { position: relative; }
        .c-viewport { overflow: hidden; }
        .c-track { display: flex; gap: 16px; will-change: transform; }

        /* ── BUSINESS CARD (명함) — dark style ── */
        .biz-card {
            flex: 0 0 calc((100% - 32px) / 3);
            min-height: 240px;
            background: #0d1728;
            border: 1px solid rgba(255,255,255,.07);
            border-radius: 16px;
            overflow: hidden;
            transition: border-color .25s, box-shadow .25s, transform .2s;
            cursor: pointer;
            display: block;
        }
        .biz-card:hover {
            border-color: rgba(45,107,255,.45);
            box-shadow: 0 8px 32px rgba(45,107,255,.18);
            transform: translateY(-2px);
        }
        .biz-inner {
            padding: 24px;
            min-height: 240px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Card top — brand area */
        .biz-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .biz-app-icon {
            width: 52px; height: 52px; border-radius: 12px;
            display: block; flex-shrink: 0;
        }
        .biz-wordmark {
            font-family: 'JetBrains Mono', monospace;
            font-size: 18px; font-weight: 700;
            letter-spacing: .12em;
            color: rgba(255,255,255,.80);
        }
        .bwm-iu { color: var(--brand-sky); }

        /* Card bottom — person info */
        .biz-body { }
        .biz-name-line {
            display: flex; flex-direction: column; gap: 6px;
            margin-bottom: 12px;
        }
        .biz-name {
            font-size: 16px; font-weight: 700; color: #ffffff;
            letter-spacing: -.02em; line-height: 1.35;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        }
        .biz-role {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 12px; font-weight: 500; color: var(--brand-sky);
            white-space: nowrap;
        }
        .biz-contacts { display: flex; flex-direction: column; gap: 5px; }
        .biz-ct {
            font-family: 'JetBrains Mono', monospace;
            font-size: 11px; color: rgba(255,255,255,.40);
            display: flex; align-items: center; gap: 8px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .biz-ct-dot { color: var(--brand-blue); font-size: 9px; flex-shrink: 0; }
        .biz-ct a { color: var(--brand-sky); text-decoration: none; }
        .biz-ct a:hover { text-decoration: underline; }

        /* ── TRUST BAR ── */
        .trust-bar {
            background: var(--brand-white);
            border-bottom: 1px solid var(--brand-line);
            padding: 0 32px;
        }
        .trust-bar-inner {
            max-width: 1200px; margin: 0 auto;
            display: flex; align-items: center; justify-content: center;
            gap: 0; height: 44px;
        }
        .trust-item {
            display: flex; align-items: center; gap: 7px;
            font-size: 12px; font-weight: 500; color: var(--brand-muted);
            padding: 0 28px;
        }
        .trust-item + .trust-item {
            border-left: 1px solid var(--brand-line);
        }
        .trust-item svg { flex-shrink: 0; }
        .trust-item strong { color: var(--brand-ink); font-weight: 700; }

        /* ── BIZ CARD OVERLAY ── */
        .biz-card { position: relative; }
        .biz-overlay {
            position: absolute;
            bottom: 0; left: 0; right: 0;
            background: linear-gradient(to bottom, rgba(13,23,40,0) 0%, rgba(13,23,40,.96) 28%, #0a1222 100%);
            border-radius: 0 0 16px 16px;
            padding: 32px 24px 24px;
            transform: translateY(100%);
            transition: transform .32s cubic-bezier(0.4,0,0.2,1);
            display: flex; flex-direction: column; gap: 14px;
        }
        .biz-card:hover .biz-overlay { transform: translateY(0); }
        .ov-stats {
            display: flex; gap: 16px;
        }
        .ov-stat {
            display: flex; flex-direction: column; gap: 2px;
        }
        .ov-stat-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 15px; font-weight: 700; color: #ffffff;
        }
        .ov-stat-val .ov-stars { color: #f59e0b; letter-spacing: 1px; font-size: 12px; }
        .ov-stat-label {
            font-size: 10px; color: rgba(255,255,255,.38);
            font-family: 'JetBrains Mono', monospace; letter-spacing: .05em;
        }
        .ov-divider {
            width: 1px; background: rgba(255,255,255,.08); align-self: stretch; flex-shrink: 0;
        }
        .ov-cta {
            display: block; width: 100%; padding: 10px 0;
            background: var(--brand-blue); color: #fff;
            border: none; border-radius: 8px;
            font-size: 13px; font-weight: 700; font-family: inherit;
            cursor: pointer; text-align: center;
            transition: background .15s;
        }
        .ov-cta:hover { background: var(--brand-blue-deep); color: #fff; }

        /* ── CAROUSEL ARROWS ── */
        .c-arrow {
            position: absolute; top: 0; bottom: 0; width: 80px;
            display: flex; align-items: center; border: none; cursor: pointer;
            z-index: 10; font-size: 28px; font-weight: 300;
            color: rgba(255,255,255,.6); transition: color .15s; padding: 0;
        }
        .c-arrow:hover { color: var(--brand-sky); }
        .c-arrow-right {
            right: 0;
            background: linear-gradient(to right, transparent 0%, var(--brand-mist) 60%);
            justify-content: flex-end; padding-right: 14px;
        }
        .c-arrow-left {
            left: 0;
            background: linear-gradient(to left, transparent 0%, var(--brand-mist) 60%);
            justify-content: flex-start; padding-left: 14px;
        }

        /* ── BANNER #5: 프로모션 카운트다운 ── */
        .promo-banner {
            background: linear-gradient(135deg, #1846C9 0%, #2D6BFF 50%, #5b8fff 100%);
            border-radius: 16px;
            padding: 28px 36px;
            margin: 48px 0 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            position: relative;
            overflow: hidden;
        }
        .promo-banner::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 80% 50%, rgba(255,255,255,.08) 0%, transparent 60%);
            pointer-events: none;
        }
        .promo-left { display: flex; flex-direction: column; gap: 6px; }
        .promo-badge {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(255,255,255,.18); border-radius: 20px;
            padding: 3px 10px; width: fit-content;
            font-family: 'JetBrains Mono', monospace; font-size: 10px;
            font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
            color: #fff;
        }
        .promo-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: blink 1.4s infinite; }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
        .promo-title {
            font-size: 22px; font-weight: 700; color: #fff;
            letter-spacing: -.02em; line-height: 1.2;
        }
        .promo-title span { opacity: .75; font-size: 14px; font-weight: 400; }
        .promo-right { display: flex; align-items: center; gap: 20px; flex-shrink: 0; }
        .promo-timer { display: flex; align-items: center; gap: 8px; }
        .promo-unit { display: flex; flex-direction: column; align-items: center; gap: 2px; }
        .promo-num {
            font-family: 'JetBrains Mono', monospace; font-size: 28px; font-weight: 700;
            color: #fff; line-height: 1;
            background: rgba(0,0,0,.2); border-radius: 8px;
            padding: 6px 12px; min-width: 52px; text-align: center;
        }
        .promo-label { font-size: 10px; color: rgba(255,255,255,.6); font-family: 'JetBrains Mono', monospace; letter-spacing: .08em; }
        .promo-sep { font-size: 22px; font-weight: 700; color: rgba(255,255,255,.5); padding-bottom: 14px; }
        .promo-cta {
            padding: 12px 24px; background: #fff; color: var(--brand-blue);
            border: none; border-radius: 10px; font-size: 14px; font-weight: 700;
            cursor: pointer; font-family: inherit; white-space: nowrap;
            transition: transform .15s, box-shadow .15s;
        }
        .promo-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,0,0,.2); }

        /* ── BANNER #9: 포트폴리오 하이라이트 ── */
        .portfolio-banner {
            margin: 0;
            padding: 48px 0 0;
            border-top: 1px solid var(--brand-line);
        }
        .portfolio-banner .block-head { margin-bottom: 24px; }
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }
        .pf-card {
            border-radius: 14px;
            overflow: hidden;
            background: var(--brand-white);
            border: 1px solid var(--brand-line);
            transition: transform .2s, box-shadow .2s;
            cursor: pointer;
        }
        .pf-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(45,107,255,.12); }
        .pf-thumb {
            height: 160px;
            background: var(--brand-ink);
            position: relative;
            overflow: hidden;
            display: flex; align-items: center; justify-content: center;
        }
        .pf-thumb-1 { background: linear-gradient(135deg, #0f1f3d 0%, #1a3566 100%); }
        .pf-thumb-2 { background: linear-gradient(135deg, #0d2416 0%, #14532d 100%); }
        .pf-thumb-3 { background: linear-gradient(135deg, #1a0a2e 0%, #3b0764 100%); }
        .pf-thumb-mockup {
            width: 80%; height: 75%;
            background: rgba(255,255,255,.06);
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,.1);
            display: flex; align-items: flex-start;
            padding: 10px; gap: 6px; flex-direction: column;
        }
        .pf-mock-bar { height: 6px; border-radius: 3px; background: rgba(255,255,255,.15); }
        .pf-mock-bar.w80 { width: 80%; }
        .pf-mock-bar.w60 { width: 60%; }
        .pf-mock-bar.w40 { width: 40%; background: rgba(45,107,255,.5); }
        .pf-mock-block { display: flex; gap: 6px; width: 100%; margin-top: 4px; }
        .pf-mock-sq { width: 36px; height: 36px; border-radius: 6px; background: rgba(255,255,255,.08); flex-shrink: 0; }
        .pf-mock-lines { display: flex; flex-direction: column; gap: 4px; flex: 1; padding-top: 4px; }
        .pf-tag {
            position: absolute; top: 12px; left: 12px;
            background: rgba(45,107,255,.85); color: #fff;
            font-family: 'JetBrains Mono', monospace; font-size: 9px;
            font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
            padding: 3px 8px; border-radius: 4px;
        }
        .pf-body { padding: 16px 18px; }
        .pf-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
        .pf-category {
            font-family: 'JetBrains Mono', monospace; font-size: 10px;
            color: var(--brand-blue); font-weight: 600; letter-spacing: .08em;
        }
        .pf-rating { font-size: 11px; color: #f59e0b; }
        .pf-title { font-size: 14px; font-weight: 700; color: var(--brand-ink); margin-bottom: 4px; line-height: 1.4; }
        .pf-expert { font-size: 12px; color: var(--brand-muted); }

        /* ── BANNER #7: 전문가 모집 ── */
        .recruit-banner {
            margin: 48px 0 0;
            background: var(--brand-ink);
            border-radius: 16px;
            padding: 40px 48px;
            display: flex; align-items: center; justify-content: space-between;
            gap: 32px; position: relative; overflow: hidden;
        }
        .recruit-banner::after {
            content: '';
            position: absolute; right: -60px; top: -60px;
            width: 240px; height: 240px;
            background: radial-gradient(circle, rgba(45,107,255,.18) 0%, transparent 70%);
            pointer-events: none;
        }
        .recruit-left { display: flex; flex-direction: column; gap: 10px; }
        .recruit-eyebrow {
            font-family: 'JetBrains Mono', monospace; font-size: 10px;
            font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
            color: var(--brand-sky);
        }
        .recruit-title {
            font-size: 24px; font-weight: 700; color: #fff;
            letter-spacing: -.02em; line-height: 1.25;
        }
        .recruit-title em { color: var(--brand-sky); font-style: normal; }
        .recruit-desc { font-size: 13px; color: rgba(255,255,255,.5); line-height: 1.7; max-width: 420px; }
        .recruit-stats { display: flex; gap: 32px; margin-top: 4px; }
        .recruit-stat-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 20px; font-weight: 700; color: #fff;
        }
        .recruit-stat-label { font-size: 11px; color: rgba(255,255,255,.4); margin-top: 2px; }
        .recruit-right { display: flex; flex-direction: column; align-items: flex-end; gap: 12px; flex-shrink: 0; }
        .recruit-cta {
            padding: 14px 32px; background: var(--brand-blue); color: #fff;
            border: none; border-radius: 10px; font-size: 14px; font-weight: 700;
            cursor: pointer; font-family: inherit; white-space: nowrap;
            transition: background .15s, transform .15s;
            text-decoration: none; display: inline-block;
        }
        .recruit-cta:hover { background: var(--brand-blue-deep); transform: translateY(-1px); color: #fff; }
        .recruit-note { font-size: 11px; color: rgba(255,255,255,.3); font-family: 'JetBrains Mono', monospace; }

        /* ── 누적거래 통계 배너 ── */
        .stats-banner {
            background: var(--brand-white);
            border-top: 1px solid var(--brand-line);
            border-bottom: 1px solid var(--brand-line);
            padding: 56px 32px;
        }
        .stats-inner { max-width: 1200px; margin: 0 auto; }
        .stats-eyebrow {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .2em; text-transform: uppercase; color: var(--brand-muted);
            text-align: center; margin-bottom: 10px;
        }
        .stats-title {
            font-size: 26px; font-weight: 700; color: var(--brand-ink);
            letter-spacing: -.02em; text-align: center; margin-bottom: 48px;
        }
        .stats-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 0; border: 1px solid var(--brand-line); border-radius: 16px; overflow: hidden;
        }
        .stats-item {
            padding: 32px 28px; text-align: center;
            border-right: 1px solid var(--brand-line);
            position: relative;
        }
        .stats-item:last-child { border-right: none; }
        .stats-item-icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: #dde8ff; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
        }
        .stats-item-icon svg { display: block; }
        .stats-num {
            font-family: 'JetBrains Mono', monospace;
            font-size: 36px; font-weight: 700; color: var(--brand-ink);
            letter-spacing: -.03em; line-height: 1;
            margin-bottom: 8px;
        }
        .stats-num em { color: var(--brand-blue); font-style: normal; }
        .stats-desc { font-size: 13px; color: var(--brand-muted); font-weight: 500; }

        /* ── REVIEW SECTION ── */
        .review-section { background: var(--brand-ink); padding: 64px 32px; margin-top: 64px; }
        .review-inner { max-width: 1200px; margin: 0 auto; }
        .r-eyebrow {
            font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700;
            letter-spacing: .2em; text-transform: uppercase; color: var(--brand-muted); margin-bottom: 8px;
        }
        .r-title { font-size: 26px; font-weight: 700; color: var(--brand-white); letter-spacing: -.02em; margin-bottom: 32px; }
        .r-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .r-card { background: var(--brand-slate); border: 1px solid rgba(255,255,255,.08); border-radius: 12px; padding: 24px; }
        .r-stars { font-size: 12px; color: #f59e0b; letter-spacing: 2px; margin-bottom: 12px; }
        .r-text { font-size: 13px; color: #a8b4c8; line-height: 1.8; margin-bottom: 20px; }
        .r-author { display: flex; align-items: center; gap: 10px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,.08); }
        .r-ava {
            width: 34px; height: 34px; border-radius: 8px; background: var(--brand-blue);
            display: flex; align-items: center; justify-content: center;
            font-size: 14px; font-weight: 700; color: #fff; flex-shrink: 0;
        }
        .r-name { font-size: 13px; font-weight: 700; color: var(--brand-white); }
        .r-sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--brand-muted); margin-top: 1px; }

        /* ── FOOTER ── */
        .footer { background: var(--brand-ink); border-top: 1px solid rgba(255,255,255,.06); padding: 24px 32px; }

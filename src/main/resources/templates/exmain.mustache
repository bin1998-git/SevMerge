<script>
    (function() {
        function setupCarousel(id) {
            const el = document.getElementById(id);
            if (!el) return;
            const track = el.querySelector('.c-track');
            const btnL  = el.querySelector('.c-arrow-left');
            const btnR  = el.querySelector('.c-arrow-right');
            if (!track || !btnL || !btnR) return;

            let currentIdx = 0;

            function getCardsPerView() {
                if (window.innerWidth <= 560) return 1;
                if (window.innerWidth <= 960) return 2;
                return 3;
            }

            function update() {
                const totalCards = track.children.length;
                const cpv = getCardsPerView();
                const maxIdx = Math.max(0, totalCards - cpv);

                if (currentIdx > maxIdx) currentIdx = maxIdx;
                if (currentIdx < 0) currentIdx = 0;

                const gap = 16;
                const cardWidth = (track.parentElement.clientWidth - (gap * (cpv - 1))) / cpv;

                Array.from(track.children).forEach(card => {
                    card.style.flex = `0 0 ${cardWidth}px`;
                });

                const offset = currentIdx * (cardWidth + gap);
                track.style.transform = `translateX(-${offset}px)`;

                btnL.style.display = currentIdx === 0 ? 'none' : 'flex';
                btnR.style.display = currentIdx >= maxIdx ? 'none' : 'flex';
            }

            btnL.addEventListener('click', () => { currentIdx--; update(); });
            btnR.addEventListener('click', () => { currentIdx++; update(); });
            window.addEventListener('resize', update);

            update();
            setTimeout(update, 200);
        }

        document.addEventListener('DOMContentLoaded', () => {
            setupCarousel('c1');
            setupCarousel('c2');
        });
    })();

    /* 카운트다운 타이머 구문 */
    (function() {
        const targetDate = new Date();
        targetDate.setDate(targetDate.getDate() + 3);

        const dEl = document.getElementById('cd-d');
        const hEl = document.getElementById('cd-h');
        const mEl = document.getElementById('cd-m');
        const sEl = document.getElementById('cd-s');

        function pad(n) { return n < 10 ? '0' + n : n; }

        function tick() {
            const now = new Date();
            const diff = targetDate - now;
            if (diff <= 0) {
                if (dEl) dEl.textContent = '00';
                if (hEl) hEl.textContent = '00';
                if (mEl) mEl.textContent = '00';
                if (sEl) sEl.textContent = '00';
                return;
            }
            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const m = Math.floor((diff / (1000 * 60)) % 60);
            const s = Math.floor((diff / 1000) % 60);

            if (dEl) dEl.textContent = pad(d);
            if (hEl) hEl.textContent = pad(h);
            if (mEl) mEl.textContent = pad(m);
            if (sEl) sEl.textContent = pad(s);
        }
        tick();
        setInterval(tick, 1000);
    })();

    /* 명함 마우스 오버 오버레이 부착 */
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.biz-card[data-project-id]').forEach(card => {
            if (card.querySelector('.biz-overlay')) return;
            const dday   = card.dataset.dday   || 'D-?';
            const budget = card.dataset.budget || '미정';
            const href   = card.getAttribute('href') || '#';

            const overlay = document.createElement('div');
            overlay.className = 'biz-overlay';
            overlay.innerHTML = `
                <div class="ov-stats">
                    <div class="ov-stat">
                        <span class="ov-stat-val">${dday}</span>
                        <span class="ov-stat-label">마감/등급</span>
                    </div>
                    <div class="ov-divider"></div>
                    <div class="ov-stat">
                        <span class="ov-stat-val">${budget}</span>
                        <span class="ov-stat-label">예산/내역</span>
                    </div>
                </div>
                <a class="ov-cta" href="${href}">자세히 보기 →</a>
            `;
            card.appendChild(overlay);
        });

        document.querySelectorAll('.biz-card').forEach(card => {
            card.addEventListener('click', (e) => {
                if(e.target.closest('.ov-cta')) return;
                const href = card.getAttribute('href');
                if(href) window.location.href = href;
            });
        });
    });
</script>

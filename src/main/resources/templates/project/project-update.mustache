{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    /* ── 페이지 래퍼 (list/detail과 동일) ── */
    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 상단 헤더 바 ── */
    .board-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 폼 본문 ── */
    .form-content { flex: 1; padding: 28px 32px 32px; }

    .save-form { display: flex; flex-direction: column; gap: 22px; }

    .form-group  { display: flex; flex-direction: column; gap: 8px; }
    .form-row    { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-label  { font-size: 13px; font-weight: 700; color: #2d4a7a; }

    .form-input, .form-select, .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 14px; font-family: inherit; color: #1e3a6e;
        outline: none; transition: all .15s;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
        border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95);
    }
    .form-select  { appearance: none; cursor: pointer; }
    .form-textarea { resize: vertical; min-height: 240px; line-height: 1.7; }

    /* ── 버튼 ── */
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 22px; border-radius: 20px;
        font-size: 14px; font-weight: 600; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); color: #2563eb; }
    .btn-lg { padding: 13px 32px; font-size: 15px; border-radius: 25px; }

    @media (max-width: 600px) {
        .page-wrap  { padding: 12px 12px 16px; }
        .board-header, .form-content { padding-left: 18px; padding-right: 18px; }
        .form-row   { grid-template-columns: 1fr; }
        .form-btns  { flex-direction: column; }
        .btn-lg     { width: 100%; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">프로젝트 수정</h1>
                <p class="board-desc">프로젝트 정보를 수정합니다.</p>
            </div>
            <a href="/projects/{{project.id}}" class="btn btn-outline" style="flex-shrink:0;">← 돌아가기</a>
        </div>

        <!-- 폼 본문 -->
        <div class="form-content">
            <form class="save-form" id="update-form">

                <div class="form-group">
                    <label class="form-label">프로젝트 제목</label>
                    <input type="text" name="title" id="title" class="form-input"
                           value="{{project.title}}" maxlength="100" />
                </div>

                <div class="form-group">
                    <label class="form-label">카테고리</label>
                    <select name="category" id="category" class="form-select">
                        <option value="WEB"   {{#isWeb}}selected{{/isWeb}}>웹개발</option>
                        <option value="APP"   {{#isApp}}selected{{/isApp}}>앱개발</option>
                        <option value="UI_UX" {{#isUiux}}selected{{/isUiux}}>UI/UX</option>
                        <option value="DATA"  {{#isData}}selected{{/isData}}>데이터</option>
                        <option value="VIDEO" {{#isVideo}}selected{{/isVideo}}>영상편집</option>
                        <option value="ETC"   {{#isEtc}}selected{{/isEtc}}>기타</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">프로젝트 내용</label>
                    <textarea name="description" id="description" class="form-textarea">{{project.description}}</textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">최소 예산 (만원)</label>
                        <input type="number" name="budgetMin" id="budgetMin" class="form-input"
                               value="{{project.budgetMin}}" min="0" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">최대 예산 (만원)</label>
                        <input type="number" name="budgetMax" id="budgetMax" class="form-input"
                               value="{{project.budgetMax}}" min="0" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">마감 기한</label>
                    <input type="date" name="deadline" id="deadline" class="form-input"
                           value="{{project.deadlineDate}}" />
                </div>

                <div class="form-group">
                    <label class="form-label">인증 전문가 설정</label>
                    <select name="bidFilter" id="bidFilter" class="form-select">
                        <option value="ALL"            {{^project.isCertifiedOnly}}selected{{/project.isCertifiedOnly}}>전체 수신</option>
                        <option value="CERTIFIED_ONLY" {{#project.isCertifiedOnly}}selected{{/project.isCertifiedOnly}}>인증 전문가만</option>
                        <option value="GENERAL_ONLY">일반 전문가만</option>
                    </select>
                </div>

                <div class="form-btns">
                    <a href="/projects/{{project.id}}" class="btn btn-outline">취소</a>
                    <button type="button" class="btn btn-primary btn-lg"
                            onclick="btnUpdate({{project.id}})">수정완료</button>
                </div>

            </form>
        </div>

    </div>
</section>

<script>
    function btnUpdate(id) {
        const data = {
            title:       document.getElementById('title').value,
            category:    document.getElementById('category').value,
            description: document.getElementById('description').value,
            budgetMin:   document.getElementById('budgetMin').value,
            budgetMax:   document.getElementById('budgetMax').value,
            deadline:    document.getElementById('deadline').value,
            bidFilter:   document.getElementById('bidFilter').value
        };
        if (!data.title.trim() || !data.category || !data.description.trim()) {
            alert('필수 항목을 입력해주세요.'); return;
        }
        fetch(`/projects/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json; charset=utf-8' },
            body: JSON.stringify(data)
        }).then(response => {
            if (response.ok) {
                alert('프로젝트가 성공적으로 수정되었습니다.');
                location.href = `/projects/${id}`;
            } else {
                alert('수정에 실패했습니다. 입력값을 확인해주세요.');
            }
        }).catch(error => { console.error('Error:', error); alert('네트워크 오류가 발생했습니다.'); });
    }
</script>

{{> layout/footer}}

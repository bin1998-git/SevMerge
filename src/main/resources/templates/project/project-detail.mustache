{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    /* ── 페이지 래퍼 (list와 동일) ── */
    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 상단 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title-wrap { display: flex; flex-direction: column; gap: 4px; }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 빵크럼 ── */
    .detail-nav {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: #93aecf;
        padding: 16px 32px 0;
    }
    .detail-nav a { color: #93aecf; text-decoration: none; transition: color .15s; }
    .detail-nav a:hover { color: #2563eb; }

    /* ── 본문 영역 ── */
    .detail-content { flex: 1; padding: 24px 32px 32px; }

    /* ── 프로젝트 헤더 블록 ── */
    .detail-header {
        padding-bottom: 24px;
        border-bottom: 1.5px solid rgba(37,99,235,.1);
        margin-bottom: 24px;
    }
    .detail-header-top { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
    .detail-category {
        font-size: 11px; font-weight: 700; color: #2563eb;
        background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2);
        padding: 4px 10px; border-radius: 6px;
    }
    .badge-certified {
        font-size: 10px; font-weight: 700; color: #b45309;
        background: #fffbeb; border: 1px solid #fde68a;
        padding: 4px 10px; border-radius: 6px;
    }
    .detail-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; line-height: 1.4; margin-bottom: 16px; }
    .detail-meta { display: flex; align-items: center; gap: 14px; font-size: 13px; color: #93aecf; flex-wrap: wrap; }
    .detail-meta .author { color: #2d4a7a; font-weight: 700; }
    .detail-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #93aecf; flex-shrink: 0; }

    /* ── 수정/삭제 액션 버튼 ── */
    .detail-actions { display: flex; justify-content: flex-end; gap: 8px; margin-bottom: 20px; }

    /* ── 2컬럼 바디 ── */
    .detail-body { display: grid; grid-template-columns: 1fr 296px; gap: 32px; align-items: start; }

    /* ── 제안서 목록 컨테이너 ── */
    .bid-list-container {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 20px; padding: 28px;
        box-shadow: 0 4px 20px rgba(37,99,235,.07);
        margin-bottom: 24px;
    }
    .bid-list-title { font-size: 16px; font-weight: 900; color: #1e3a6e; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .bid-count-badge {
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; font-size: 12px; padding: 2px 10px; border-radius: 12px; font-weight: 700;
    }

    /* ── 제안서 카드 ── */
    .bid-item-card {
        backdrop-filter: blur(12px); background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 14px; padding: 22px;
        display: flex; justify-content: space-between; align-items: stretch;
        transition: all .2s; position: relative;
    }
    .bid-item-card + .bid-item-card { margin-top: 16px; }
    .bid-item-card:hover { border-color: rgba(37,99,235,.3); box-shadow: 0 6px 20px rgba(37,99,235,.1); transform: translateY(-1px); }

    .bid-left { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
    .bid-top-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; flex-wrap: wrap; gap: 10px; }
    .bid-expert-info { display: flex; align-items: center; gap: 10px; }
    .bid-expert-name { font-weight: 800; color: #1e3a6e; font-size: 15px; }
    .expert-rating { font-size: 12px; color: #f59e0b; font-weight: 700; display: inline-flex; align-items: center; gap: 2px; }
    .badge-hold { background: #fff7ed; color: #ea580c; border: 1px solid #ffedd5; font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 700; }
    .bid-tags { display: flex; gap: 4px; }
    .expert-tag { font-size: 11px; background: rgba(71,85,105,.1); color: #475569; padding: 3px 8px; border-radius: 4px; font-weight: 600; }
    .expert-tag-portfolio { background: rgba(99,102,241,.1); color: #4f46e5; }

    .bid-cover {
        font-size: 14px; color: #2d4a7a; line-height: 1.7;
        margin: 0 0 14px; white-space: pre-wrap;
        background: rgba(255,255,255,.5); padding: 14px 16px;
        border: 1px solid rgba(37,99,235,.08); border-radius: 10px;
    }
    .bid-approach {
        background: rgba(255,255,255,.4); padding: 12px 16px;
        border-radius: 10px; border-left: 3px solid rgba(37,99,235,.3);
        font-size: 13px; color: #2d4a7a; line-height: 1.6;
    }

    /* ── 제안서 우측 가격/버튼 영역 ── */
    .bid-right {
        text-align: right; margin-left: 28px;
        display: flex; flex-direction: column; justify-content: center; align-items: flex-end;
        min-width: 140px;
        border-left: 1px dashed rgba(37,99,235,.15); padding-left: 24px;
    }
    .price-box {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5);
        border: 1px solid rgba(37,99,235,.15);
        padding: 12px 16px; border-radius: 10px;
        text-align: right; margin-bottom: 12px; width: 100%; box-sizing: border-box;
    }
    .price-label { font-size: 11px; color: #4a6fa5; margin-bottom: 2px; font-weight: 500; }
    .price-value { font-size: 19px; font-weight: 900; color: #2563eb; }
    .bid-actions { display: flex; flex-direction: column; gap: 6px; width: 100%; }

    /* ── 상세 요구사항 카드 ── */
    .detail-desc-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 18px; padding: 28px; margin-bottom: 24px;
        box-shadow: 0 4px 16px rgba(37,99,235,.07);
    }
    .detail-desc-title { font-size: 15px; font-weight: 900; color: #1e3a6e; margin: 0 0 16px; padding-bottom: 12px; border-bottom: 1px solid rgba(37,99,235,.08); }
    .detail-description { font-size: 15px; color: #2d4a7a; line-height: 1.9; white-space: pre-wrap; min-height: 120px; }

    /* ── 하단 목록으로 / 관리자 삭제 ── */
    .detail-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 24px; border-top: 1.5px solid rgba(37,99,235,.1);
    }

    /* ── 우측 사이드 카드 ── */
    .side-sticky { position: sticky; top: 84px; display: flex; flex-direction: column; gap: 16px; }
    .info-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 18px; padding: 22px;
        box-shadow: 0 4px 20px rgba(37,99,235,.08);
    }
    .info-card-title { font-size: 14px; font-weight: 900; color: #1e3a6e; margin-bottom: 14px; padding-bottom: 11px; border-bottom: 1px solid rgba(37,99,235,.08); }
    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid rgba(37,99,235,.06); font-size: 13px; }
    .info-row:last-of-type { border-bottom: none; }
    .info-label { color: #4a6fa5; font-weight: 500; }
    .info-value { color: #1e3a6e; font-weight: 700; }
    .info-value.highlight { color: #2563eb; font-size: 15px; font-weight: 800; }
    .info-value.urgent    { color: #ef4444; }
    .info-value.muted     { color: #93aecf; font-weight: 500; }

    /* ── 공용 버튼 ── */
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 20px; border-radius: 20px;
        font-size: 14px; font-weight: 600; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .btn-sm { padding: 8px 16px; font-size: 13px; }
    .btn-danger { background: rgba(254,242,242,.85); color: #ef4444; border: 1.5px solid #fecaca; }
    .btn-danger:hover { background: rgba(255,238,236,.95); }

    .bid-btn {
        display: block; width: 100%; padding: 13px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none; border-radius: 22px;
        font-size: 14px; font-weight: 700; cursor: pointer;
        font-family: inherit; margin-top: 16px;
        text-align: center; text-decoration: none;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .bid-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }
    .bid-btn-outline {
        display: block; width: 100%; padding: 12px;
        background: rgba(255,255,255,.6); color: #2563eb;
        border: 1.5px solid rgba(37,99,235,.3); border-radius: 22px;
        font-size: 14px; font-weight: 700; cursor: pointer;
        font-family: inherit; margin-top: 10px;
        text-align: center; text-decoration: none; transition: all .15s;
    }
    .bid-btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.5); }

    /* 낙찰 전문가 카드 강조 */
    .info-card-winner { border-color: rgba(37,99,235,.3); }
    .info-card-winner .info-card-title { color: #2563eb; }
    .info-value-winner { color: #2563eb; }
    .info-value-email  { font-size: 12px; font-weight: 600; color: #4a6fa5; }
    .info-value-task   { max-width: 150px; text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* 빈 상태 */
    .empty-bids {
        text-align: center; color: #93aecf; padding: 52px 0;
        border: 2px dashed rgba(37,99,235,.15); border-radius: 14px;
        font-size: 14px; background: rgba(255,255,255,.3);
    }
    .empty-bids-icon { font-size: 24px; margin-bottom: 10px; }

    /* 마감 뱃지 */
    .closed-badge {
        width: 100%; text-align: center; padding: 10px 0;
        background: rgba(255,255,255,.4); border: 1px solid rgba(37,99,235,.1);
        border-radius: 8px; font-size: 13px; color: #4a6fa5; font-weight: 700;
    }

    /* 보류 버튼 */
    .btn-hold {
        width: 100%; border-color: rgba(203,213,225,.8); color: #475569;
        font-weight: 600; background: rgba(255,255,255,.6);
        padding: 7px 0; border-radius: 20px;
    }
    .btn-held {
        width: 100%; border-color: #fed7aa; color: #ea580c;
        font-weight: 600; background: rgba(255,247,237,.8);
        padding: 7px 0; border-radius: 20px; cursor: default;
    }
    .btn-action-full {
        width: 100%; padding: 10px 0; border-radius: 20px;
    }

    @media (max-width: 960px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .detail-nav, .detail-content { padding-left: 18px; padding-right: 18px; }
        .detail-body { grid-template-columns: 1fr; }
        .side-sticky { position: static; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 상단 헤더 바 -->
        <div class="board-header">
            <div class="board-title-wrap">
                <h1 class="board-title">프로젝트 상세</h1>
                <p class="board-desc">프로젝트 내용과 제안서를 확인하세요.</p>
            </div>
            <a href="/projects" class="btn btn-outline btn-sm">← 목록으로</a>
        </div>

        <!-- 빵크럼 -->
        <div class="detail-nav">
            <a href="/projects">프로젝트</a>
            <span>›</span>
            <span>{{project.title}}</span>
        </div>

        <!-- 본문 -->
        <div class="detail-content">

            <!-- 프로젝트 헤더 -->
            <div class="detail-header">
                <div class="detail-header-top">
                    <span class="detail-category">{{project.categoryName}}</span>
                    {{#project.isCertifiedOnly}}<span class="badge-certified">⭐ 인증 전문가만</span>{{/project.isCertifiedOnly}}
                </div>
                <h2 class="detail-title">{{project.title}}</h2>
                <div class="detail-meta">
                    <span class="author">{{project.memberName}}</span>
                    <div class="detail-meta-dot"></div>
                    <span>{{project.createdAt}}</span>
                    <div class="detail-meta-dot"></div>
                    <span>조회 {{project.viewCount}}</span>
                </div>
            </div>

            <!-- 수정/삭제 (작성자 전용) -->
            {{#isOwner}}
                <div class="detail-actions">
                    <a href="/projects/{{project.id}}/edit" class="btn btn-outline btn-sm">수정</a>
                    <button onclick="deleteProject({{project.id}})" class="btn btn-sm btn-danger">삭제</button>
                </div>
            {{/isOwner}}

            <!-- 2컬럼 바디 -->
            <div class="detail-body">

                <!-- 좌: 제안서 목록 + 상세 요구사항 -->
                <div>

                    {{#isOwner}}
                        <div class="bid-list-container">
                            <h3 class="bid-list-title">
                                📄 접수된 전문가 제안서 목록
                                <span class="bid-count-badge">{{bidCount}}건 도착</span>
                            </h3>

                            <div>
                                {{#bids}}
                                    <div class="bid-item-card">

                                        <!-- 제안서 좌측 -->
                                        <div class="bid-left">
                                            <div>
                                                <div class="bid-top-row">
                                                    <div class="bid-expert-info">
                                                        <span class="bid-expert-name">{{expertName}} 전문가</span>
                                                        <span class="expert-rating">⭐ {{avgRating}}</span>
                                                        {{#isHold}}<span class="badge-hold">⏳ 보류 중</span>{{/isHold}}
                                                        <div class="detail-meta-dot"></div>
                                                        <span style="font-size:12px;color:#93aecf;">{{createdAt}}</span>
                                                    </div>
                                                    <div class="bid-tags">
                                                        <span class="expert-tag">경력인증</span>
                                                        <span class="expert-tag">신원확인</span>
                                                        <span class="expert-tag expert-tag-portfolio">포트폴리오 📂</span>
                                                    </div>
                                                </div>
                                                <p class="bid-cover">{{coverLetter}}</p>
                                            </div>
                                            {{#approach}}
                                                <div class="bid-approach">
                                                    🎯 <strong>제시한 접근 방식:</strong> {{approach}}
                                                </div>
                                            {{/approach}}
                                        </div>

                                        <!-- 제안서 우측 -->
                                        <div class="bid-right">
                                            <div class="price-box">
                                                <div class="price-label">제안 금액</div>
                                                <div class="price-value">{{proposedPrice}} 만원</div>
                                            </div>

                                            {{^expertCard}}
                                                <div class="bid-actions">
                                                    <button type="button" class="btn btn-outline btn-sm btn-action-full"
                                                            style="border-color:rgba(37,99,235,.4);color:#2563eb;font-weight:700;background:rgba(255,255,255,.6);"
                                                            onclick="selectBid({{id}}, {{project.id}})">
                                                        선택 및 낙찰
                                                    </button>

                                                    {{^isHold}}
                                                        <button type="button" class="btn btn-outline btn-sm btn-hold"
                                                                onclick="holdBid({{id}}, {{project.id}})">
                                                            잠정 보류
                                                        </button>
                                                    {{/isHold}}

                                                    {{#isHold}}
                                                        <button type="button" class="btn btn-outline btn-sm btn-held" disabled>
                                                            보류 처리됨
                                                        </button>
                                                    {{/isHold}}

                                                    <a href="/chat/start/project/{{project.id}}?withMemberId={{expertId}}"
                                                    class="btn btn-outline btn-sm btn-action-full"
                                                    style="border-color:rgba(37,99,235,.2);color:#2563eb;background:rgba(255,255,255,.6);text-align:center;">
                                                    💬 채팅 문의
                                                    </a>
                                                </div>
                                            {{/expertCard}}

                                            {{#expertCard}}
                                                <div class="closed-badge">🔒 마감 종료</div>
                                            {{/expertCard}}
                                        </div>

                                    </div>
                                {{/bids}}

                                {{^bids}}
                                    <div class="empty-bids">
                                        <div class="empty-bids-icon">✉️</div>
                                        현재 프로젝트에 등록된 전문가 제안서가 없습니다.
                                    </div>
                                {{/bids}}
                            </div>
                        </div>
                    {{/isOwner}}

                    <!-- 상세 요구사항 -->
                    <div class="detail-desc-card">
                        <h3 class="detail-desc-title">📋 프로젝트 상세 요구사항</h3>
                        <div class="detail-description">{{project.description}}</div>
                    </div>

                    <!-- 하단 액션 -->
                    <div class="detail-footer">
                        <a href="/projects" class="btn btn-outline">← 목록으로</a>
                        {{#isAdmin}}
                            <form action="/admin/projects/{{project.id}}/delete" method="POST"
                                  onsubmit="return confirm('정말로 이 프로젝트를 삭제하시겠습니까?');"
                                  style="margin:0;">
                                <button type="submit" class="btn btn-danger btn-sm">삭제</button>
                            </form>
                        {{/isAdmin}}
                    </div>
                </div>

                <!-- 우: 사이드 정보 카드 -->
                <div class="side-sticky">

                    <div class="info-card">
                        <div class="info-card-title">프로젝트 요약 정보</div>
                        <div class="info-row">
                            <span class="info-label">예산 범위</span>
                            <span class="info-value highlight">{{project.budgetMin}}~{{project.budgetMax}}만원</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">남은 기간</span>
                            <span class="info-value urgent">D-{{project.dDay}}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">카테고리</span>
                            <span class="info-value">{{project.categoryName}}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label">총 입찰 수</span>
                            {{#project.privateProject}}
                                {{#isOwner}}<span class="info-value" style="color:#2563eb;">{{bidCount}}개</span>{{/isOwner}}
                                {{^isOwner}}<span class="info-value muted">🔒 비공개</span>{{/isOwner}}
                            {{/project.privateProject}}
                            {{^project.privateProject}}<span class="info-value" style="color:#2563eb;">{{bidCount}}개</span>{{/project.privateProject}}
                        </div>
                        <div class="info-row">
                            <span class="info-label">인증 전문가</span>
                            <span class="info-value">
                                {{#project.isCertifiedOnly}}필수 요구{{/project.isCertifiedOnly}}
                                {{^project.isCertifiedOnly}}제한 없음{{/project.isCertifiedOnly}}
                            </span>
                        </div>
                        {{^isOwner}}
                            <a href="/bids/save-form?projectId={{project.id}}" class="bid-btn">제안서 보내기</a>
                            <a href="/chat/start/project/{{project.id}}?withMemberId={{project.memberId}}" class="bid-btn-outline">💬 의뢰인에게 문의</a>
                        {{/isOwner}}
                    </div>

                    {{#expertCard}}
                        <div class="info-card info-card-winner">
                            <div class="info-card-title">🏆 낙찰된 전문가 정보</div>
                            <div class="info-row">
                                <span class="info-label">이름</span>
                                <span class="info-value info-value-winner">{{expertName}}</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">이메일</span>
                                <span class="info-value info-value-email">{{expertEmail}}</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">작업명</span>
                                <span class="info-value info-value-task" title="{{taskTitle}}">{{taskTitle}}</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">시작기간</span>
                                <span class="info-value">{{startDate}}</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label">마감기간</span>
                                <span class="info-value">{{endDate}}</span>
                            </div>
                        </div>
                    {{/expertCard}}

                </div>
            </div>

        </div>
    </div>
</section>

<script>
    function deleteProject(id) {
        if (!confirm('정말 삭제하시겠습니까?')) return;
        fetch('/projects/' + id, { method: 'DELETE' })
            .then(res => { if (res.ok) window.location.href = '/projects'; });
    }

    function selectBid(bidId, projectId) {
        if (!confirm('이 전문가를 낙찰하시겠습니까?\n보유 잔액에서 계약금이 자동 차감됩니다.')) return;
        fetch('/bids/' + bidId + '/select', { method: 'POST' })
            .then(res => {
                if (res.ok) {
                    alert('🎉 낙찰이 완료되었습니다!\n계약금이 에스크로로 이체되었습니다.');
                    window.location.href = '/projects/' + projectId;
                } else {
                    return res.json().then(data => {
                        alert('낙찰 처리 실패\n' + (data.message || '잠시 후 다시 시도해주세요.'));
                    });
                }
            })
            .catch(err => { console.error('에러 발생:', err); alert('네트워크 오류가 발생했습니다.'); });
    }

    function holdBid(bidId, projectId) {
        if (!confirm('이 제안서를 잠정 보류 처리하시겠습니까?')) return;
        fetch('/bids/' + bidId + '/hold', { method: 'POST' })
            .then(res => {
                if (res.ok) {
                    alert('보류 처리가 완료되었습니다.');
                    window.location.href = '/projects/' + projectId;
                } else {
                    alert('보류 처리에 실패했습니다. 다시 시도해 주세요.');
                }
            })
            .catch(err => { console.error('에러 발생:', err); alert('네트워크 오류가 발생했습니다.'); });
    }
</script>

{{> layout/footer}}

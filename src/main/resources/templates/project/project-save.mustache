{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    /* ── 페이지 래퍼 (list/detail과 동일) ── */
    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 상단 헤더 바 ── */
    .board-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 폼 본문 ── */
    .form-content { flex: 1; padding: 28px 32px 32px; }

    .save-form { display: flex; flex-direction: column; gap: 22px; }

    .form-group  { display: flex; flex-direction: column; gap: 8px; }
    .form-row    { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-label  { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-label .required { color: #ef4444; margin-left: 2px; }

    .form-input, .form-select, .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 14px; font-family: inherit; color: #1e3a6e;
        outline: none; transition: all .15s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color: #93aecf; }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
        border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95);
    }
    .form-select  { appearance: none; cursor: pointer; }
    .form-textarea { resize: vertical; min-height: 240px; line-height: 1.7; }

    .form-checkbox-wrap {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 16px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.45);
        border-radius: 10px; border: 1.5px solid rgba(255,255,255,.8);
        cursor: pointer; color: #2d4a7a; font-size: 14px;
    }

    /* ── 버튼 ── */
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 22px; border-radius: 20px;
        font-size: 14px; font-weight: 600; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); color: #2563eb; }
    .btn-draft {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(37,99,235,.3); color: #2563eb;
    }
    .btn-draft:hover { background: rgba(255,255,255,.9); }
    .btn-lg { padding: 13px 32px; font-size: 15px; border-radius: 25px; }

    @media (max-width: 600px) {
        .page-wrap  { padding: 12px 12px 16px; }
        .board-header, .form-content { padding-left: 18px; padding-right: 18px; }
        .form-row   { grid-template-columns: 1fr; }
        .form-btns  { flex-direction: column; }
        .btn-lg     { width: 100%; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">프로젝트 등록</h1>
                <p class="board-desc">프로젝트를 등록하면 전문가들이 직접 제안서를 보내드립니다.</p>
            </div>
            <a href="/projects" class="btn btn-outline" style="flex-shrink:0;">← 목록으로</a>
        </div>

        <!-- 폼 본문 -->
        <div class="form-content">
            <form class="save-form" action="/projects/save" method="POST" id="projectForm">

                <div class="form-group">
                    <label class="form-label">프로젝트 제목 <span class="required">*</span></label>
                    <input type="text" name="title" id="title" class="form-input"
                           placeholder="프로젝트 제목을 입력하세요" maxlength="100" />
                </div>

                <div class="form-group">
                    <label class="form-label">카테고리 <span class="required">*</span></label>
                    <select name="category" id="category" class="form-select">
                        <option value="">카테고리 선택</option>
                        <option value="WEB">웹개발</option>
                        <option value="APP">앱개발</option>
                        <option value="UI_UX">UI/UX</option>
                        <option value="DATA">데이터</option>
                        <option value="VIDEO">영상편집</option>
                        <option value="ETC">기타</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">프로젝트 내용 <span class="required">*</span></label>
                    <textarea name="description" id="description" class="form-textarea"
                              placeholder="상세 내용을 입력하세요"></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">최소 예산 (만원)</label>
                        <input type="number" name="budgetMin" id="budgetMin" class="form-input" placeholder="예: 100" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">최대 예산 (만원)</label>
                        <input type="number" name="budgetMax" id="budgetMax" class="form-input" placeholder="예: 300" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">마감 기한</label>
                    <input type="date" name="deadline" id="deadline" class="form-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">보안 설정</label>
                    <label class="form-checkbox-wrap">
                        <input type="checkbox" name="isPrivate" id="isPrivate" value="true" />
                        <span>🔒 비공개 입찰(블라인드) 적용하기</span>
                    </label>
                </div>

                <div class="form-btns">
                    <a href="/projects" class="btn btn-outline">취소</a>
                    <button type="button" class="btn btn-draft" onclick="saveDraft()">임시저장</button>
                    <button type="submit" class="btn btn-primary btn-lg">프로젝트 등록</button>
                </div>

            </form>
        </div>

    </div>
</section>

<script>
    function getFormData() {
        return {
            title:       document.querySelector("#title").value,
            category:    document.querySelector("#category").value,
            description: document.querySelector("#description").value,
            budgetMin:   document.querySelector("#budgetMin").value,
            budgetMax:   document.querySelector("#budgetMax").value,
            deadline:    document.querySelector("#deadline").value,
            isPrivate:   document.querySelector("#isPrivate").checked
        };
    }

    window.onload = function () {
        fetch('/projects/draft')
            .then(res => res.status === 200 ? res.json() : null)
            .then(data => {
                if (data) {
                    if (confirm("임시저장된 내용이 있습니다. 불러오시겠습니까?")) {
                        document.querySelector("#title").value       = data.title || "";
                        document.querySelector("#category").value    = data.category || "";
                        document.querySelector("#description").value = data.description || "";
                        document.querySelector("#budgetMin").value   = data.budgetMin || "";
                        document.querySelector("#budgetMax").value   = data.budgetMax || "";
                        document.querySelector("#isPrivate").checked = !!data.isPrivate;
                        if (data.deadline) document.querySelector("#deadline").value = data.deadline.substring(0, 10);
                    }
                }
            });
    };

    function saveDraft() {
        fetch('/projects/draft', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getFormData())
        }).then(res => res.ok ? alert("임시저장 되었습니다!") : alert("저장 실패"));
    }
</script>

{{> layout/footer}}

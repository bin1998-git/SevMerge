{{> layout/header}}

<style>
    .save-section { padding: 52px 28px 80px; }
    .save-inner { max-width: 760px; margin: 0 auto; }
    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #9ca3af; }
    .save-form { display: flex; flex-direction: column; gap: 22px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-input { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input:focus { border-color: #2563eb; }
    .form-select { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; appearance: none; cursor: pointer; }
    .form-textarea { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; resize: vertical; min-height: 240px; line-height: 1.7; transition: border-color .15s; }
    .form-checkbox-wrap { display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: #f8f9fc; border-radius: 10px; border: 1.5px solid #e2e5ef; cursor: pointer; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-outline { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
</style>

<section class="save-section">
    <div class="save-inner">
        <div class="save-header">
            <h1 class="save-title">프로젝트 등록</h1>
            <p class="save-desc">프로젝트를 등록하면 전문가들이 직접 제안서를 보내드립니다.</p>
        </div>

        <form class="save-form" action="/projects/save" method="POST" id="projectForm">
            <div class="form-group">
                <label class="form-label">프로젝트 제목 <span class="required">*</span></label>
                <input type="text" name="title" id="title" class="form-input" placeholder="프로젝트 제목을 입력하세요" maxlength="100" />
            </div>

            <div class="form-group">
                <label class="form-label">카테고리 <span class="required">*</span></label>
                <select name="category" id="category" class="form-select">
                    <option value="">카테고리 선택</option>
                    <option value="WEB">웹개발</option>
                    <option value="APP">앱개발</option>
                    <option value="UI_UX">UI/UX</option>
                    <option value="DATA">데이터</option>
                    <option value="VIDEO">영상편집</option>
                    <option value="ETC">기타</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">프로젝트 내용 <span class="required">*</span></label>
                <textarea name="description" id="description" class="form-textarea" placeholder="상세 내용을 입력하세요"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">최소 예산 (만원)</label>
                    <input type="number" name="budgetMin" id="budgetMin" class="form-input" placeholder="예: 100" />
                </div>
                <div class="form-group">
                    <label class="form-label">최대 예산 (만원)</label>
                    <input type="number" name="budgetMax" id="budgetMax" class="form-input" placeholder="예: 300" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">마감 기한</label>
                <input type="date" name="deadline" id="deadline" class="form-input" />
            </div>

            <div class="form-group">
                <label class="form-label">인증 전문가 설정</label>
                <select name="bidFilter" id="bidFilter" class="form-select">
                    <option value="ALL">전체 수신</option>
                    <option value="CERTIFIED_ONLY">인증 전문가만</option>
                    <option value="GENERAL_ONLY">일반 전문가만</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">보안 설정</label>
                <label class="form-checkbox-wrap">
                    <input type="checkbox" name="isPrivate" id="isPrivate" value="true" />
                    <span>🔒 비공개 입찰(블라인드) 적용하기</span>
                </label>
            </div>

            <div class="form-btns">
                <a href="/projects" class="btn btn-outline">취소</a>
                <button type="button" class="btn btn-outline" onclick="saveDraft()" style="color: #2563eb;">임시저장</button>
                <button type="submit" class="btn btn-primary btn-lg">프로젝트 등록</button>
            </div>
        </form>
    </div>
</section>

<script>
    function getFormData() {
        return {
            title: document.querySelector("#title").value,
            category: document.querySelector("#category").value,
            description: document.querySelector("#description").value,
            budgetMin: document.querySelector("#budgetMin").value,
            budgetMax: document.querySelector("#budgetMax").value,
            deadline: document.querySelector("#deadline").value,
            bidFilter: document.querySelector("#bidFilter").value,
            isPrivate: document.querySelector("#isPrivate").checked
        };
    }

    window.onload = function() {
        fetch('/projects/draft')
            .then(res => res.status === 200 ? res.json() : null)
            .then(data => {
                if (data) {
                    if (confirm("임시저장된 내용이 있습니다. 불러오시겠습니까?")) {
                        document.querySelector("#title").value = data.title || "";
                        document.querySelector("#category").value = data.category || "";
                        document.querySelector("#description").value = data.description || "";
                        document.querySelector("#budgetMin").value = data.budgetMin || "";
                        document.querySelector("#budgetMax").value = data.budgetMax || "";
                        document.querySelector("#bidFilter").value = data.bidFilter || "ALL";
                        document.querySelector("#isPrivate").checked = !!data.isPrivate;
                        if(data.deadline) document.querySelector("#deadline").value = data.deadline.substring(0, 10);
                    }
                }
            });
    };

    function saveDraft() {
        fetch('/projects/draft', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getFormData())
        }).then(res => res.ok ? alert("임시저장 되었습니다!") : alert("저장 실패"));
    }
</script>

{{> layout/footer}}
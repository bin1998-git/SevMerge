{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }

    .detail-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* 헤더 */
    .detail-header {
        padding: 28px 36px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08);
        flex-shrink: 0;
    }
    .detail-header-top {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
        margin-bottom: 14px;
    }
    .detail-title-wrap { flex: 1; }
    .detail-title {
        font-size: 22px; font-weight: 900; color: #1e3a6e;
        letter-spacing: -.5px; line-height: 1.35; margin-bottom: 8px;
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    }
    .detail-badges { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .badge { font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 20px; flex-shrink: 0; }
    .badge-notice { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; }
    .badge-free   { background: rgba(37,99,235,.1); color: #2563eb; border: 1px solid rgba(37,99,235,.2); }
    .badge-new    { background: rgba(239,68,68,.1); color: #ef4444; border: 1px solid rgba(239,68,68,.2); }

    .detail-header-actions { display: flex; gap: 8px; flex-shrink: 0; }
    .btn-back {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; transition: all .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); }
    .btn-edit {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; transition: all .15s;
    }
    .btn-edit:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .btn-delete {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        background: rgba(255,243,243,.8); border: 1.5px solid #fecaca; color: #ef4444;
        cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .btn-delete:hover { background: #fff0f0; border-color: #ef4444; }

    .detail-meta {
        display: flex; align-items: center; gap: 16px;
        font-size: 13px; color: #4a6fa5;
    }
    .detail-meta .author { font-weight: 700; color: #1e3a6e; display: flex; align-items: center; gap: 6px; }
    .author-avatar {
        width: 24px; height: 24px; border-radius: 50%;
        background: rgba(37,99,235,.1); border: 1.5px solid rgba(37,99,235,.15);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 10px; font-weight: 900; color: #2563eb; flex-shrink: 0;
    }
    .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #93aecf; }

    /* 본문 */
    .detail-body { flex: 1; padding: 28px 36px; overflow-y: auto; display: flex; flex-direction: column; gap: 24px; }
    .detail-content { font-size: 15px; color: #2d4a7a; line-height: 1.9; white-space: pre-wrap; min-height: 120px; }

    /* 첨부파일 */
    .attachment-section {}
    .attachment-title { font-size: 13px; font-weight: 800; color: #1e3a6e; margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
    .attachment-grid { display: flex; gap: 10px; flex-wrap: wrap; }
    .attachment-item {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 16px; min-width: 200px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 14px;
        transition: all .15s; text-decoration: none; color: inherit;
    }
    .attachment-item:hover { border-color: rgba(37,99,235,.3); background: rgba(255,255,255,.9); }
    .attachment-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .attachment-icon.pdf { background: rgba(239,68,68,.1); color: #ef4444; }
    .attachment-icon.img { background: rgba(37,99,235,.1); color: #2563eb; }
    .attachment-icon.file { background: rgba(100,116,139,.1); color: #4a6fa5; }
    .attachment-name { font-size: 13px; font-weight: 600; color: #1e3a6e; word-break: break-all; }
    .attachment-size { font-size: 11px; color: #93aecf; margin-top: 2px; }
    .attachment-download { margin-left: auto; color: #93aecf; flex-shrink: 0; transition: color .15s; }
    .attachment-item:hover .attachment-download { color: #2563eb; }

    /* 구분선 */
    .divider { height: 1px; background: rgba(37,99,235,.07); }

    /* 댓글 섹션 */
    .comment-section { display: flex; flex-direction: column; gap: 16px; }
    .comment-section-title { font-size: 14px; font-weight: 800; color: #1e3a6e; display: flex; align-items: center; gap: 8px; }
    .comment-count-badge {
        font-size: 11px; font-weight: 700; color: #2563eb;
        background: rgba(37,99,235,.1); padding: 2px 9px; border-radius: 20px;
    }

    .comment-list { display: flex; flex-direction: column; gap: 2px; }
    .comment-item { padding: 14px 0; border-bottom: 1px solid rgba(37,99,235,.05); }
    .comment-item:last-child { border-bottom: none; }
    .comment-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .comment-author-wrap { display: flex; align-items: center; gap: 8px; }
    .comment-avatar {
        width: 30px; height: 30px; border-radius: 50%;
        background: rgba(37,99,235,.1); border: 1.5px solid rgba(37,99,235,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 12px; font-weight: 900; color: #2563eb; flex-shrink: 0;
    }
    .comment-author-name { font-size: 13px; font-weight: 700; color: #1e3a6e; }
    .comment-date { font-size: 11px; color: #93aecf; margin-left: 6px; }
    .comment-actions { display: flex; gap: 4px; }
    .comment-btn {
        font-size: 12px; color: #93aecf; font-weight: 600;
        background: none; border: none; cursor: pointer; font-family: inherit;
        padding: 4px 8px; border-radius: 8px; transition: all .15s;
    }
    .comment-btn:hover { background: rgba(37,99,235,.08); color: #2563eb; }
    .comment-btn.delete:hover { background: rgba(239,68,68,.08); color: #ef4444; }
    .comment-content { font-size: 14px; color: #2d4a7a; line-height: 1.7; padding-left: 38px; }
    .comment-edit-wrap { padding-left: 38px; margin-top: 8px; display: none; }
    .comment-edit-input {
        width: 100%; padding: 9px 14px;
        background: rgba(255,255,255,.7); border: 1.5px solid rgba(37,99,235,.2);
        border-radius: 10px; font-size: 14px; font-family: inherit;
        color: #1e3a6e; outline: none; margin-bottom: 6px;
    }
    .comment-edit-input:focus { border-color: #2563eb; }
    .comment-edit-btns { display: flex; gap: 6px; justify-content: flex-end; }
    .btn-sm {
        padding: 7px 14px; border-radius: 12px; font-size: 12px; font-weight: 700;
        cursor: pointer; font-family: inherit; border: none; transition: all .15s;
    }
    .btn-confirm { background: #10b981; color: #fff; }
    .btn-confirm:hover { background: #059669; }
    .btn-gray { background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #4a6fa5; }
    .btn-gray:hover { background: rgba(255,255,255,.9); }

    .comment-empty { text-align: center; padding: 28px 0; font-size: 14px; color: #93aecf; }

    /* 댓글 작성 */
    .comment-form-wrap {
        display: flex; gap: 10px; align-items: center;
        padding: 16px 36px 24px;
        border-top: 1px solid rgba(37,99,235,.07);
        flex-shrink: 0;
    }
    .comment-textarea {
        flex: 1; padding: 14px 18px; height: 52px;
        background: rgba(255,255,255,.65); border: 1.5px solid rgba(37,99,235,.12);
        border-radius: 16px; font-size: 14px; font-family: inherit;
        color: #1e3a6e; outline: none; resize: none; line-height: 1.6;
        transition: all .15s;
    }
    .comment-textarea::placeholder { color: #93aecf; }
    .comment-textarea:focus { border-color: #2563eb; background: rgba(255,255,255,.9); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .comment-submit {
        padding: 14px 24px; border-radius: 16px; font-size: 14px; font-weight: 800;
        background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff;
        border: none; cursor: pointer; font-family: inherit; white-space: nowrap;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .comment-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    /* 신고 모달 */
    .modal-bg { display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(13,27,46,.5); backdrop-filter: blur(4px); justify-content: center; align-items: center; }
    .modal-bg.open { display: flex; }
    .modal-card { backdrop-filter: blur(20px); background: rgba(255,255,255,.92); border: 1.5px solid rgba(255,255,255,.9); border-radius: 20px; padding: 32px; max-width: 460px; width: 90%; box-shadow: 0 20px 60px rgba(37,99,235,.15); }
    .modal-title { font-size: 18px; font-weight: 900; color: #1e3a6e; margin-bottom: 6px; }
    .modal-desc { font-size: 13px; color: #4a6fa5; margin-bottom: 20px; }
    .modal-label { font-size: 13px; font-weight: 700; color: #2d4a7a; margin-bottom: 6px; display: block; }
    .modal-select, .modal-textarea-s {
        width: 100%; box-sizing: border-box; padding: 12px 14px;
        background: rgba(255,255,255,.8); border: 1.5px solid rgba(37,99,235,.15);
        border-radius: 10px; font-size: 14px; font-family: inherit; color: #1e3a6e;
        outline: none; margin-bottom: 14px;
    }
    .modal-textarea-s { height: 100px; resize: none; }
    .modal-btns { display: flex; gap: 10px; justify-content: flex-end; }
    .modal-cancel { padding: 10px 20px; background: rgba(243,244,248,.8); color: #4a6fa5; border: none; border-radius: 20px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: inherit; }
    .modal-submit { padding: 10px 20px; background: #ef4444; color: #fff; border: none; border-radius: 20px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }

    @media (max-width: 640px) {
        .page-wrap { padding: 12px 12px 16px; }
        .detail-header { padding: 20px 18px 16px; }
        .detail-body { padding: 20px 18px; }
        .comment-form-wrap { padding: 12px 18px 16px; }
        .detail-header-top { flex-direction: column; gap: 12px; }
    }
</style>

<section class="page-wrap">
    <div class="detail-card">

        <!-- 헤더 -->
        <div class="detail-header">
            <div class="detail-header-top">
                <div class="detail-title-wrap">
                    <div class="detail-title">
                        {{board.title}}
                    </div>
                    <div class="detail-badges">
                        {{#isNotice}}<span class="badge badge-notice">공지</span>{{/isNotice}}
                        {{^isNotice}}<span class="badge badge-free">자유</span>{{/isNotice}}
                    </div>
                </div>
                <div class="detail-header-actions">
                    {{^isNotice}}
                        {{#isOwner}}
                            <a href="/boards/{{board.id}}/edit" class="btn-edit">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.42a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                                수정
                            </a>
                            <button type="button" onclick="deleteBoard({{board.id}})" class="btn-delete">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                삭제
                            </button>
                        {{/isOwner}}
                    {{/isNotice}}
                    {{#isNotice}}{{#isAdmin}}
                        <a href="/admin/notices/{{board.id}}/update" class="btn-edit">수정</a>
                        <form action="/admin/notices/{{board.id}}/delete" method="POST" style="margin:0;" onsubmit="return confirm('삭제하시겠습니까?');">
                            <button type="submit" class="btn-delete">삭제</button>
                        </form>
                    {{/isAdmin}}{{/isNotice}}
                    {{#isAdmin}}{{^isNotice}}
                        <form action="/admin/boards/{{board.id}}/delete" method="POST" style="margin:0;" onsubmit="return confirm('관리자 권한으로 삭제하시겠습니까?');">
                            <button type="submit" class="btn-delete">관리자 삭제</button>
                        </form>
                    {{/isNotice}}{{/isAdmin}}
                    <a href="/boards?boardType={{board.boardType}}" class="btn-back">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                    목록으로
                    </a>
                </div>
            </div>
            <div class="detail-meta">
            <span class="author">
                <span class="author-avatar" id="authorAvatar">{{board.memberName}}</span>
                {{board.memberName}}
            </span>
                <span class="meta-dot"></span>
                <span>{{board.createdAt}}</span>
                <span class="meta-dot"></span>
                <span>조회 {{board.viewCount}}</span>
            </div>
        </div>

        <!-- 본문 -->
        <div class="detail-body">

            <!-- 내용 -->
            <div class="detail-content">{{board.content}}</div>

            <!-- 첨부파일 -->
            {{#board.hasAttachment}}
                <div class="attachment-section">
                    <div class="attachment-title">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5a2.5 2.5 0 015 0v10.5c0 .83-.67 1.5-1.5 1.5s-1.5-.67-1.5-1.5V6H9v9.5a3 3 0 006 0V5c0-2.76-2.24-5-5-5S5 2.24 5 5v12.5c0 3.87 3.13 7 7 7s7-3.13 7-7V6h-2.5z"/></svg>
                        첨부파일
                    </div>
                    <div class="attachment-grid">
                        <a href="{{board.attachmentUrl}}" target="_blank" class="attachment-item">
                            <div class="attachment-icon file">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg>
                            </div>
                            <div>
                                <div class="attachment-name">{{board.attachmentName}}</div>
                                <div class="attachment-size">첨부파일</div>
                            </div>
                            <span class="attachment-download">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                        </a>
                    </div>
                </div>
            {{/board.hasAttachment}}

            <div class="divider"></div>

            <!-- 댓글 -->
            <div class="comment-section">
                <div class="comment-section-title">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M4 18h2v2H4v2H2V4h2v14Zm16 0H6v-2h14v2Zm2-2h-2V4h2v12Zm-12-2H6v-2h4v2Zm4-4H6V8h8v2Zm6-6H4V2h16v2Z"/></svg>
                    댓글
                    <span class="comment-count-badge">{{comments.size}}</span>
                </div>

                <div class="comment-list">
                    {{#comments}}
                        <div class="comment-item">
                            <div class="comment-header">
                                <div class="comment-author-wrap">
                                    <div class="comment-avatar">{{memberName}}</div>
                                    <span class="comment-author-name">{{memberName}}</span>
                                    <span class="comment-date">{{createdAt}}</span>
                                </div>
                                <div class="comment-actions">
                                    {{#isOwner}}
                                        <button class="comment-btn" onclick="toggleEdit('{{id}}')">수정</button>
                                        <form action="/comments/{{id}}/delete" method="POST" style="display:inline;margin:0;">
                                            <input type="hidden" name="boardId" value="{{boardId}}">
                                            <button type="submit" class="comment-btn delete">삭제</button>
                                        </form>
                                    {{/isOwner}}
                                    {{^isOwner}}{{^isAdmin}}{{^isCommentAdmin}}
                                        <button type="button" class="comment-btn" onclick="openReportModal({{id}}, {{boardId}})" style="color:#ef4444;">신고</button>
                                    {{/isCommentAdmin}}{{/isAdmin}}{{/isOwner}}
                                    {{#isAdmin}}{{^isOwner}}
                                        <form action="/comments/{{id}}/delete" method="POST" style="display:inline;margin:0;">
                                            <input type="hidden" name="boardId" value="{{boardId}}">
                                            <button type="submit" class="comment-btn delete">관리자 삭제</button>
                                        </form>
                                    {{/isOwner}}{{/isAdmin}}
                                </div>
                            </div>
                            <div class="comment-content" id="comment-text-{{id}}">{{comment}}</div>
                            <div class="comment-edit-wrap" id="comment-edit-form-{{id}}">
                                <form action="/comments/{{id}}/update" method="POST">
                                    <input type="hidden" name="boardId" value="{{boardId}}">
                                    <input type="text" name="comment" value="{{comment}}" required class="comment-edit-input"/>
                                    <div class="comment-edit-btns">
                                        <button type="button" onclick="toggleEdit('{{id}}')" class="btn-sm btn-gray">취소</button>
                                        <button type="submit" class="btn-sm btn-confirm">수정완료</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    {{/comments}}
                    {{^comments}}
                        <div class="comment-empty">아직 댓글이 없습니다. 첫 댓글을 남겨보세요!</div>
                    {{/comments}}
                </div>
            </div>

        </div>

        <!-- 댓글 작성 -->
        <form class="comment-form-wrap" action="/boards/{{board.id}}/comments/save" method="POST">
            <textarea class="comment-textarea" name="content" placeholder="댓글을 입력하세요..."></textarea>
            <button type="submit" class="comment-submit">댓글 등록</button>
        </form>

    </div>
</section>

<!-- 신고 모달 -->
<div id="reportModal" class="modal-bg">
    <div class="modal-card">
        <h3 class="modal-title">댓글 신고하기</h3>
        <p class="modal-desc">신고 사유와 상세 내용을 작성해 주세요.</p>
        <form id="reportForm" action="" method="POST">
            <input type="hidden" id="modalBoardId" name="boardId" value="">
            <label class="modal-label">신고 분류</label>
            <select name="reason" required class="modal-select">
                <option value="" disabled selected>신고 사유를 선택하세요</option>
                <option>스팸 광고 / 홍보성 도배</option>
                <option>욕설 / 비속어 및 혐오 표현</option>
                <option>타인 비방 및 명예훼손</option>
                <option>음란성 혹은 부적절한 내용</option>
                <option>기타 사유</option>
            </select>
            <label class="modal-label">상세 내용</label>
            <textarea name="contentDetail" placeholder="신고 사유에 대한 구체적인 내용을 입력해 주세요." maxlength="300" required class="modal-textarea-s"></textarea>
            <div class="modal-btns">
                <button type="button" onclick="closeReportModal()" class="modal-cancel">취소</button>
                <button type="submit" class="modal-submit">신고 보내기</button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleEdit(id) {
        const text = document.getElementById('comment-text-' + id);
        const form = document.getElementById('comment-edit-form-' + id);
        const show = form.style.display !== 'block';
        form.style.display = show ? 'block' : 'none';
        text.style.display = show ? 'none' : 'block';
    }

    async function deleteBoard(boardId) {
        if (!confirm('정말 삭제하시겠습니까?')) return;
        const res = await fetch('/boards/' + boardId, { method: 'DELETE' });
        if (res.ok) location.href = '/boards';
    }

    function openReportModal(commentId, boardId) {
        document.getElementById('reportForm').action = '/comments/' + commentId + '/report';
        document.getElementById('modalBoardId').value = boardId;
        document.getElementById('reportModal').classList.add('open');
    }
    function closeReportModal() {
        document.getElementById('reportModal').classList.remove('open');
        document.getElementById('reportForm').reset();
    }
    window.addEventListener('click', e => {
        if (e.target === document.getElementById('reportModal')) closeReportModal();
    });

    // 아바타 첫 글자
    document.querySelectorAll('.comment-avatar').forEach(el => {
        const t = el.textContent.trim();
        el.textContent = t ? t.charAt(0) : '?';
    });
    const aa = document.getElementById('authorAvatar');
    if (aa) { const t = aa.textContent.trim(); aa.textContent = t ? t.charAt(0) : '?'; }
</script>


{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    .page-section { padding: 40px 28px 80px; }
    .page-inner { max-width: 900px; margin: 0 auto; }
    .page-title { font-size: 24px; font-weight: 900; color: #1e3a6e; margin-bottom: 6px; }
    .page-desc { font-size: 14px; color: #4a6fa5; margin-bottom: 28px; }

    .bid-item {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 16px; padding: 20px 24px;
        margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .bid-slot-name { font-size: 15px; font-weight: 700; color: #1e3a6e; margin-bottom: 4px; }
    .bid-meta { font-size: 12px; color: #4a6fa5; }
    .bid-price { font-size: 18px; font-weight: 900; color: #1e3a6e; margin-bottom: 6px; text-align: right; }

    .status-badge { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; display: inline-block; }
    .status-pending  { background: #fef3c7; color: #b45309; border: 1px solid #fde68a; }
    .status-winner   { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-lost     { background: #f3f4f8; color: #9ca3af; }
    .status-refunded { background: #eff6ff; color: #2563eb; border: 1px solid #bfdbfe; }

    .empty-state { text-align: center; padding: 80px 0; color: #93aecf; font-size: 14px; }
</style>

<section class="page-section">
    <div class="page-inner">
        <h1 class="page-title">내 입찰 내역</h1>
        <p class="page-desc">경매 입찰 현황을 확인하세요.</p>

        {{#bids}}
            <div class="bid-item">
                <div>
                    <div class="bid-slot-name">{{slotName}}</div>
                    <div class="bid-meta">입찰일: {{createdAt}}</div>
                </div>
                <div style="text-align:right;">
                    <div class="bid-price">{{bidPrice}}P</div>
                    {{#isPending}}<span class="status-badge status-pending">입찰중</span>{{/isPending}}
                    {{#isWinner}}
                        <span class="status-badge status-winner">🎉 낙찰!</span>
                        {{#needsBanner}}
                            <!-- 배너 미제출 상태 -->
                            <div style="margin-top:8px;">
                                <span style="font-size:11px;color:#ef4444;font-weight:700;">⚠ 배너 이미지 제출 필요</span>
                                <button onclick="openBannerModal({{bidId}})"
                                        style="display:block;margin-top:6px;padding:8px 16px;
                                       background:linear-gradient(135deg,#f59e0b,#d97706);
                                       color:#fff;border:none;border-radius:8px;
                                       font-size:12px;font-weight:700;cursor:pointer;width:100%;">
                                    📸 배너 이미지 제출하기
                                </button>
                            </div>
                        {{/needsBanner}}
                        {{#isApproved}}
                            <div style="margin-top:6px;font-size:11px;color:#059669;font-weight:700;">✓ 메인화면 노출중</div>
                        {{/isApproved}}
                        {{#isPendingReview}}
                            <div style="margin-top:6px;font-size:11px;color:#b45309;font-weight:700;">⏳ 관리자 검토중</div>
                        {{/isPendingReview}}
                        {{#isRejectedReview}}
                            <div style="margin-top:6px;font-size:11px;color:#ef4444;font-weight:700;">✗ 거절됨 — 재제출 필요</div>
                            <button onclick="openBannerModal({{bidId}})"
                                    style="display:block;margin-top:6px;padding:8px 16px;
                                   background:linear-gradient(135deg,#ef4444,#dc2626);
                                   color:#fff;border:none;border-radius:8px;
                                   font-size:12px;font-weight:700;cursor:pointer;width:100%;">
                                🔄 배너 재제출
                            </button>
                        {{/isRejectedReview}}
                    {{/isWinner}}
                    {{#isLost}}<span class="status-badge status-lost">탈락</span>{{/isLost}}
                    {{#isRefunded}}<span class="status-badge status-refunded">환불완료</span>{{/isRefunded}}
                </div>
            </div>
        {{/bids}}
        {{^bids}}
            <div class="empty-state">입찰 내역이 없습니다.<br>
                <a href="/ad-auction" style="color:#2563eb;font-weight:700;margin-top:12px;display:inline-block;">경매 참여하기 →</a>
            </div>
        {{/bids}}
    </div>
</section>
<!-- 배너 제출 모달 -->
<div id="bannerModalBg" style="display:none;position:fixed;inset:0;
     background:rgba(13,27,46,.6);backdrop-filter:blur(6px);
     z-index:9999;align-items:center;justify-content:center;">
    <div style="background:rgba(255,255,255,.95);border-radius:20px;
                padding:32px;max-width:480px;width:90%;
                box-shadow:0 20px 60px rgba(13,27,46,.2);">
        <h3 style="font-size:17px;font-weight:900;color:#1e3a6e;margin-bottom:6px;">📸 배너 이미지 제출</h3>
        <p style="font-size:13px;color:#4a6fa5;margin-bottom:20px;line-height:1.6;">
            낙찰 축하드립니다! 아래 양식을 작성하면 관리자 검토 후 메인화면에 노출됩니다.
        </p>

        <div style="margin-bottom:14px;">
            <div style="font-size:12px;font-weight:700;color:#4a6fa5;margin-bottom:8px;">
                배너 이미지 <span style="color:#ef4444;">*</span>
                <span style="font-weight:400;color:#9ca3af;">(728×90px, JPG/PNG, 최대 2MB)</span>
            </div>
            <input type="file" id="bannerFileInput" accept="image/*"
                   style="width:100%;padding:10px;background:rgba(255,255,255,.7);
                          border:1.5px dashed rgba(37,99,235,.3);border-radius:10px;
                          font-size:13px;cursor:pointer;box-sizing:border-box;"/>
            <div id="bannerPreviewWrap" style="display:none;margin-top:8px;">
                <img id="bannerPreviewImg"
                     style="width:100%;height:45px;object-fit:cover;border-radius:6px;
                            border:1px solid #e2e8f0;"/>
            </div>
        </div>

        <div style="margin-bottom:20px;">
            <div style="font-size:12px;font-weight:700;color:#4a6fa5;margin-bottom:8px;">
                광고 문구 <span style="font-weight:400;color:#9ca3af;">(최대 100자)</span>
            </div>
            <input type="text" id="bannerMessageInput" maxlength="100"
                   placeholder="예) 지금 상담하면 견적서 무료 제공!"
                   style="width:100%;padding:12px 14px;background:rgba(255,255,255,.7);
                          border:1.5px solid rgba(37,99,235,.15);border-radius:10px;
                          font-size:14px;font-family:inherit;color:#1e3a6e;
                          outline:none;box-sizing:border-box;"/>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:8px;">
            <button onclick="closeBannerModal()"
                    style="padding:10px 18px;border-radius:10px;font-size:13px;font-weight:700;
                           background:rgba(255,255,255,.6);border:1.5px solid rgba(37,99,235,.15);
                           color:#4a6fa5;cursor:pointer;font-family:inherit;">취소</button>
            <button onclick="submitBanner()"
                    style="padding:10px 18px;border-radius:10px;font-size:13px;font-weight:700;
                           background:linear-gradient(135deg,#f59e0b,#d97706);border:none;
                           color:#fff;cursor:pointer;font-family:inherit;
                           box-shadow:0 4px 12px rgba(245,158,11,.3);">제출하기</button>
        </div>
    </div>
</div>
<script>
    let currentBidId = null;

function openBannerModal(bidId) {
    currentBidId = bidId;
    document.getElementById('bannerFileInput').value = '';
    document.getElementById('bannerMessageInput').value = '';
    document.getElementById('bannerPreviewWrap').style.display = 'none';
    const bg = document.getElementById('bannerModalBg');
    bg.style.display = 'flex';
}

function closeBannerModal() {
    document.getElementById('bannerModalBg').style.display = 'none';
    currentBidId = null;
}

function submitBanner() {
    const file = document.getElementById('bannerFileInput').files[0];
    const message = document.getElementById('bannerMessageInput').value.trim();

    if (!file) {
        alert('배너 이미지를 선택해주세요.');
        return;
    }

    const formData = new FormData();
    formData.append('bannerImageFile', file);
    if (message) formData.append('adMessage', message);

    fetch('/api/ad-bids/' + currentBidId + '/banner', {
        method: 'POST',
        body: formData
    })
    .then(res => res.text().then(t => ({ ok: res.ok, t })))
    .then(({ ok, t }) => {
        if (ok) {
            alert('배너가 제출되었습니다. 관리자 검토 후 메인화면에 노출됩니다.');
            closeBannerModal();
            location.reload();
        } else {
            alert(t);
        }
    })
    .catch(() => alert('통신 오류가 발생했습니다.'));
}

// 이미지 미리보기
document.getElementById('bannerFileInput').addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
        document.getElementById('bannerPreviewImg').src = e.target.result;
        document.getElementById('bannerPreviewWrap').style.display = 'block';
    };
    reader.readAsDataURL(file);
});

// 배경 클릭 시 닫기
document.getElementById('bannerModalBg').addEventListener('click', function(e) {
    if (e.target === this) closeBannerModal();
});
</script>
{{> layout/footer}}
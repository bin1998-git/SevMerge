{{> layout/header}}

<style>
    .chat-wrap { display: grid; grid-template-columns: 300px 1fr; height: calc(100vh - 64px); background: #fff; border-top: 1px solid #eaecf4; }

    /* 왼쪽: 채팅방 목록 */
    .chat-sidebar { border-right: 1px solid #eaecf4; display: flex; flex-direction: column; min-height: 0; }
    .chat-sidebar-head { padding: 20px; border-bottom: 1px solid #f3f4f8; flex-shrink: 0; }
    .chat-sidebar-title { font-size: 18px; font-weight: 900; color: #1c1e26; }
    .chat-room-list { flex: 1; overflow-y: auto; }
    .chat-room-list::-webkit-scrollbar { width: 5px; }
    .chat-room-list::-webkit-scrollbar-thumb { background: #e2e5ef; border-radius: 4px; }
    .chat-room-item { display: flex; align-items: center; gap: 12px; padding: 14px 18px; text-decoration: none; color: inherit; border-bottom: 1px solid #f8f9fc; transition: background .12s; }
    .chat-room-item:hover { background: #f8f9ff; }
    .chat-avatar { width: 44px; height: 44px; border-radius: 50%; background: #eff6ff; border: 1.5px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .chat-room-info { flex: 1; min-width: 0; }
    .chat-room-name { font-size: 14px; font-weight: 700; color: #1c1e26; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-room-sub { font-size: 12px; color: #9ca3af; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .chat-unread { background: #ef4444; color: #fff; font-size: 11px; font-weight: 700; min-width: 18px; height: 18px; border-radius: 9px; display: inline-flex; align-items: center; justify-content: center; padding: 0 5px; flex-shrink: 0; }

    /* 오른쪽: 선택 전 안내 */
    .chat-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; background: #fafbff; color: #c4c9d9; }
    .chat-placeholder-icon { font-size: 48px; }
    .chat-placeholder-title { font-size: 17px; font-weight: 800; color: #9ca3af; }
    .chat-placeholder-sub { font-size: 13px; color: #c4c9d9; }
</style>

<div class="chat-wrap">

    <!-- 왼쪽: 내 채팅방 목록 -->
    <aside class="chat-sidebar">
        <div class="chat-sidebar-head">
            <div class="chat-sidebar-title">💬 채팅</div>
        </div>
        <div class="chat-room-list">
            {{#rooms}}
                <a href="/chat/room/{{id}}" class="chat-room-item">
                    <div class="chat-avatar">{{#projectTitle}}📁{{/projectTitle}}{{^projectTitle}}👤{{/projectTitle}}</div>
                    <div class="chat-room-info">
                        <div class="chat-room-name">{{displayName}}</div>
                        <div class="chat-room-sub">{{#lastMessage}}{{lastMessage}}{{/lastMessage}}{{^lastMessage}}{{#projectTitle}}프로젝트 문의{{/projectTitle}}{{^projectTitle}}1:1 문의{{/projectTitle}}{{/lastMessage}}</div>
                    </div>
                    {{#hasUnread}}<span class="chat-unread">{{unreadCount}}</span>{{/hasUnread}}
                </a>
            {{/rooms}}
            {{^rooms}}
                <div style="padding: 40px 16px; text-align: center; color: #c4c9d9; font-size: 13px;">아직 채팅방이 없습니다.</div>
            {{/rooms}}
        </div>
    </aside>

    <!-- 오른쪽: 안내 -->
    <section class="chat-placeholder">
        <div class="chat-placeholder-icon">💬</div>
        <div class="chat-placeholder-title">대화를 선택해주세요</div>
        <div class="chat-placeholder-sub">왼쪽에서 채팅방을 선택하면 대화를 시작할 수 있어요</div>
    </section>

</div>

{{> layout/footer}}

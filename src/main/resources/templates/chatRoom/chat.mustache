{{> layout/header}}

<style>
    .chat-wrap {
        display: grid;
        grid-template-columns: 300px 1fr;
        height: calc(100vh - 64px);
        background: #fff;
        border-top: 1px solid #eaecf4;
    }

    /* 왼쪽: 채팅방 목록 */
    .chat-sidebar {
        border-right: 1px solid #eaecf4;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .chat-sidebar-head {
        padding: 20px;
        border-bottom: 1px solid #f3f4f8;
        flex-shrink: 0;
    }

    .chat-sidebar-title {
        font-size: 18px;
        font-weight: 900;
        color: #1c1e26;
    }

    .chat-room-list {
        flex: 1;
        overflow-y: auto;
    }

    .chat-room-list::-webkit-scrollbar {
        width: 5px;
    }

    .chat-room-list::-webkit-scrollbar-thumb {
        background: #e2e5ef;
        border-radius: 4px;
    }

    .chat-room-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        text-decoration: none;
        color: inherit;
        border-bottom: 1px solid #f8f9fc;
        transition: background .12s;
    }

    .chat-room-item:hover {
        background: #f8f9ff;
    }

    .chat-room-item.active {
        background: #eff6ff;
    }

    .chat-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #eff6ff;
        border: 1.5px solid #bfdbfe;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .chat-room-info {
        flex: 1;
        min-width: 0;
    }

    .chat-room-name {
        font-size: 14px;
        font-weight: 700;
        color: #1c1e26;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-room-sub {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-unread {
        background: #ef4444;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        min-width: 18px;
        height: 18px;
        border-radius: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 5px;
        flex-shrink: 0;
    }

    /* 오른쪽: 대화 */
    .chat-main {
        display: flex;
        flex-direction: column;
        min-height: 0;
    }

    .chat-head {
        padding: 16px 24px;
        border-bottom: 1px solid #f3f4f8;
        font-weight: 800;
        font-size: 16px;
        color: #1c1e26;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        flex-shrink: 0;
    }

    .chat-leave-btn {
        background: none;
        border: 1.5px solid #e2e5ef;
        color: #9ca3af;
        font-size: 12px;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 8px;
        cursor: pointer;
        font-family: inherit;
    }

    .chat-leave-btn:hover {
        border-color: #ef4444;
        color: #ef4444;
    }

    .chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #fafbff;
    }

    .chat-body::-webkit-scrollbar {
        width: 6px;
    }

    .chat-body::-webkit-scrollbar-thumb {
        background: #e2e5ef;
        border-radius: 4px;
    }

    .msg-row {
        display: flex;
        flex-direction: column;
        max-width: 68%;
    }

    .msg-row.mine {
        align-self: flex-end;
        align-items: flex-end;
    }

    .msg-row.theirs {
        align-self: flex-start;
        align-items: flex-start;
    }

    .msg-sender {
        font-size: 11px;
        color: #9ca3af;
        margin-bottom: 3px;
        padding: 0 4px;
    }

    .msg-bubble {
        padding: 10px 14px;
        border-radius: 14px;
        font-size: 14px;
        line-height: 1.55;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .mine .msg-bubble {
        background: #2563eb;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .theirs .msg-bubble {
        background: #fff;
        color: #1c1e26;
        border: 1px solid #eaecf4;
        border-bottom-left-radius: 4px;
    }

    .msg-date {
        align-self: center;
        margin: 14px 0 6px;
        font-size: 11px;
        color: #9ca3af;
        background: #eef0f5;
        padding: 4px 12px;
        border-radius: 12px;
    }

    .msg-line {
        display: flex;
        align-items: flex-end;
        gap: 6px;
    }

    .mine .msg-line {
        flex-direction: row-reverse;
    }

    .msg-time {
        font-size: 10px;
        color: #c4c9d9;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .msg-row {
        cursor: context-menu;
    }

    /* 우클릭 삭제 메뉴 */
    .ctx-menu {
        position: fixed;
        z-index: 9999;
        background: #fff;
        border: 1px solid #e2e5ef;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, .12);
        padding: 6px;
        display: none;
        min-width: 150px;
    }

    .ctx-menu button {
        display: block;
        width: 100%;
        text-align: left;
        background: none;
        border: none;
        padding: 9px 14px;
        font-size: 13px;
        color: #1c1e26;
        cursor: pointer;
        border-radius: 6px;
        font-family: inherit;
    }

    .ctx-menu button:hover {
        background: #f8f9ff;
    }

    .ctx-menu button.danger {
        color: #ef4444;
    }

    .ctx-menu button.danger:hover {
        background: #fee2e2;
    }

    /* 입력 바 */
    .chat-input-bar {
        display: flex;
        gap: 10px;
        padding: 16px 20px;
        border-top: 1px solid #f3f4f8;
        background: #fff;
        flex-shrink: 0;
    }

    .chat-input {
        flex: 1;
        padding: 12px 18px;
        background: #f8f9fc;
        border: 1.5px solid #e2e5ef;
        border-radius: 24px;
        font-size: 14px;
        font-family: inherit;
        color: #1c1e26;
        outline: none;
        transition: border-color .15s;
    }

    .chat-input:focus {
        border-color: #2563eb;
        background: #fff;
    }

    .chat-input::placeholder {
        color: #c4c9d9;
    }

    .chat-send {
        padding: 0 24px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 24px;
        font-weight: 700;
        font-size: 14px;
        cursor: pointer;
        font-family: inherit;
        transition: background .15s;
    }

    .chat-send:hover {
        background: #1d4ed8;
    }
</style>

<div class="chat-wrap">

    <!-- 왼쪽: 내 채팅방 목록 -->
    <aside class="chat-sidebar">
        <div class="chat-sidebar-head">
            <div class="chat-sidebar-title">💬 채팅</div>
        </div>
        <div class="chat-room-list">
            {{#rooms}}
                <a href="/chat/room/{{id}}" class="chat-room-item" data-room-id="{{id}}">
                    <div class="chat-avatar">{{#projectTitle}}
                        📁{{/projectTitle}}{{^projectTitle}}👤{{/projectTitle}}</div>
                    <div class="chat-room-info">
                        <div class="chat-room-name">{{displayName}}</div>
                        <div class="chat-room-sub">{{#lastMessage}}{{lastMessage}}{{/lastMessage}}{{^lastMessage}}{{#projectTitle}}
                            프로젝트 문의{{/projectTitle}}{{^projectTitle}}1:1 문의{{/projectTitle}}{{/lastMessage}}</div>
                    </div>
                    {{#hasUnread}}<span class="chat-unread">{{unreadCount}}</span>{{/hasUnread}}
                </a>
            {{/rooms}}
            {{^rooms}}
                <div style="padding: 40px 16px; text-align: center; color: #c4c9d9; font-size: 13px;">아직 채팅방이 없습니다.
                </div>
            {{/rooms}}
        </div>
    </aside>

    <!-- 오른쪽: 대화 -->
    <section class="chat-main">
        <div class="chat-head">
            <span>💬 {{roomName}}</span>
            <form action="/chat/room/{{roomId}}/delete" method="POST" style="margin:0;"
                  onsubmit="return confirm('이 채팅방을 나가시겠습니까? (상대방에게는 유지됩니다)');">
                <button type="submit" class="chat-leave-btn">나가기</button>
            </form>
        </div>
        <div class="chat-body" id="chatBody"></div>
        <div class="chat-input-bar">
            <input id="msgInput" class="chat-input" type="text" placeholder="메시지를 입력하세요" autocomplete="off"/>
            <button id="sendBtn" class="chat-send">전송</button>
        </div>
    </section>

</div>

<!-- 과거 메시지 (서버 렌더 → JS가 읽어서 그림) -->
<div id="historyData" style="display:none;">
    {{#messages}}
        <div class="hist" data-id="{{id}}" data-sender-id="{{senderId}}" data-sender-name="{{senderName}}"
             data-text="{{text}}" data-date="{{date}}" data-time="{{time}}"></div>
    {{/messages}}
</div>

<!-- 우클릭 삭제 메뉴 -->
<div id="msgCtxMenu" class="ctx-menu">
    <button type="button" id="ctxDelMine">나에게서 삭제</button>
    <button type="button" id="ctxDelAll" class="danger">모두에게서 삭제</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/sockjs-client@1.6.1/dist/sockjs.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@stomp/stompjs@7.0.0/bundles/stomp.umd.min.js"></script>
<script>
    (function () {
        const roomId = "{{roomId}}";
        const myId = "{{loginUserId}}";
        const body = document.getElementById("chatBody");
        const input = document.getElementById("msgInput");

        // 사이드바에서 현재 방 활성 표시
        document.querySelectorAll(".chat-room-item").forEach(function (el) {
            if (el.dataset.roomId === roomId) el.classList.add("active");
        });

        function csrfToken() {
            var c = document.cookie.split(";").map(function (s) {
                return s.trim();
            })
                    .find(function (s) {
                        return s.startsWith("XSRF-TOKEN=");
                    });
            return c ? decodeURIComponent(c.split("=")[1]) : "";
        }

        function deleteMsgForMe(id, row) {
            if (!confirm("나에게서 삭제할까요?")) return;
            fetch("/chat/messages/" + id + "/delete?forAll=false", {
                method: "POST",
                headers: {"X-XSRF-TOKEN": csrfToken()}
            }).then(function (r) {
                if (r.ok) row.remove(); else alert("삭제에 실패했습니다.");
            });
        }

        // 메시지 1건 그리기 (과거/실시간 공통)
        let lastDate = null;

        function render(m) {
            // 날짜가 바뀌면 구분선 (YYYY/MM/DD)
            if (m.date && m.date !== lastDate) {
                const sep = document.createElement("div");
                sep.className = "msg-date";
                sep.textContent = m.date;
                body.appendChild(sep);
                lastDate = m.date;
            }

            const mine = String(m.senderId) === String(myId);
            const row = document.createElement("div");
            row.className = "msg-row " + (mine ? "mine" : "theirs");

            if (!mine) {
                const name = document.createElement("div");
                name.className = "msg-sender";
                name.textContent = m.senderName || "";
                row.appendChild(name);
            }

            // 버블 + 시간(흐린 글자)
            const line = document.createElement("div");
            line.className = "msg-line";
            const bubble = document.createElement("div");
            bubble.className = "msg-bubble";
            bubble.textContent = m.text || "";
            line.appendChild(bubble);
            if (m.time) {
                const time = document.createElement("span");
                time.className = "msg-time";
                time.textContent = m.time;
                line.appendChild(time);
            }
            row.appendChild(line);

            // 우클릭 삭제용 메타
            if (m.id) {
                row.dataset.id = m.id;
                row.dataset.mine = mine ? "true" : "false";
            }

            body.appendChild(row);
            body.scrollTop = body.scrollHeight;
        }

        // 과거 메시지 로드
        document.querySelectorAll("#historyData .hist").forEach(function (el) {
            render({
                id: el.dataset.id,
                senderId: el.dataset.senderId,
                senderName: el.dataset.senderName,
                text: el.dataset.text,
                date: el.dataset.date,
                time: el.dataset.time
            });
        });

        // 우클릭 삭제 메뉴
        const ctxMenu = document.getElementById("msgCtxMenu");
        const ctxDelMine = document.getElementById("ctxDelMine");
        const ctxDelAll = document.getElementById("ctxDelAll");
        let ctxTarget = null;

        body.addEventListener("contextmenu", function (e) {
            const row = e.target.closest(".msg-row");
            if (!row || !row.dataset.id) return;
            e.preventDefault();
            ctxTarget = row;
            ctxDelAll.style.display = row.dataset.mine === "true" ? "block" : "none"; // 모두삭제는 내 메시지만
            ctxMenu.style.left = e.clientX + "px";
            ctxMenu.style.top = e.clientY + "px";
            ctxMenu.style.display = "block";
        });
        document.addEventListener("click", function () {
            ctxMenu.style.display = "none";
        });
        ctxMenu.addEventListener("click", function (e) {
            e.stopPropagation();
        });
        ctxDelMine.addEventListener("click", function () {
            if (ctxTarget) deleteMsgForMe(ctxTarget.dataset.id, ctxTarget);
            ctxMenu.style.display = "none";
        });
        ctxDelAll.addEventListener("click", function () {
            if (ctxTarget) {
                if (!confirm("모두에게서 삭제할까요?")) return;
                stompClient.publish({
                    destination: "/pub/chat/message/delete",
                    body: JSON.stringify({ messageId: Number(ctxTarget.dataset.id), chatRoomId: Number(roomId) })
                });
            }
            ctxMenu.style.display = "none";
        });

        // 실시간 연결
        let subscription = null;
        const stompClient = new StompJs.Client({
            webSocketFactory: () => new SockJS("/ws-stomp"),
            onConnect: () => {
                if (subscription) subscription.unsubscribe();
                subscription = stompClient.subscribe("/sub/chat/room/" + roomId, (msg) => {
                    const data = JSON.parse(msg.body);
                    if (data.type === "DELETE") {
                        const row = document.querySelector('.msg-row[data-id="' + data.id + '"]');
                        if (row) row.remove();
                    } else {
                        render(data);
                    }
                });
            }
        });
        stompClient.activate();

        function send() {
            const text = input.value.trim();
            if (!text) return;
            stompClient.publish({
                destination: "/pub/chat/message",
                body: JSON.stringify({chatRoomId: Number(roomId), text: text})
            });
            input.value = "";
        }

        document.getElementById("sendBtn").addEventListener("click", send);
        input.addEventListener("keydown", (e) => {
            if (e.key === "Enter") send();
        });
    })();
</script>
<script>
    window.addEventListener('pageshow', function (e) {
        if (e.persisted) location.reload();
    });
</script>

{{> layout/footer}}

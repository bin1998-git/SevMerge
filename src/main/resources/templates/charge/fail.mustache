{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    .fail-section {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-height: calc(100vh - 64px); padding: 80px 28px; text-align: center;
    }
    .fail-box {
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 28px; padding: 56px 52px;
        box-shadow: 0 8px 32px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        max-width: 440px; width: 100%;
    }
    .fail-icon  { font-size: 56px; margin-bottom: 20px; }
    .fail-title { font-size: 22px; font-weight: 900; color: #1e3a6e; margin-bottom: 10px; }
    .fail-msg   { font-size: 14px; color: #4a6fa5; margin-bottom: 36px; line-height: 1.6; }
    .btn-primary {
        display: inline-block; padding: 13px 32px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border-radius: 25px; font-size: 14px; font-weight: 700;
        text-decoration: none; box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }
</style>

<section class="fail-section">
    <div class="fail-box">
        <div class="fail-icon">❌</div>
        <h1 class="fail-title">충전에 실패했습니다</h1>
        <p class="fail-msg">{{errorMessage}}</p>
        <a href="/charge/form" class="btn-primary">다시 시도하기</a>
    </div>
</section>

{{> layout/footer}}
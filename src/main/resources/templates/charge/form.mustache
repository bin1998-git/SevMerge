{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-header {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.75); border-bottom: 1px solid rgba(255,255,255,.6);
        padding: 36px 28px 28px;
    }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 6px; }
    .page-desc  { font-size: 14px; color: #4a6fa5; }

    .charge-section { padding: 40px 28px 80px; }
    .charge-inner   { max-width: 520px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }

    .balance-card {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        border-radius: 18px; padding: 32px 36px; color: #fff;
        box-shadow: 0 8px 24px rgba(37,99,235,.3);
    }
    .balance-label  { font-size: 13px; font-weight: 600; opacity: .75; margin-bottom: 8px; }
    .balance-amount { font-size: 36px; font-weight: 900; letter-spacing: -1px; }
    .balance-amount span { font-size: 18px; font-weight: 600; margin-left: 4px; opacity: .8; }

    .charge-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 18px; padding: 36px;
        box-shadow: 0 4px 20px rgba(37,99,235,.07);
    }
    .charge-card-title { font-size: 16px; font-weight: 900; color: #1e3a6e; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(37,99,235,.08); }

    .quick-amounts { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
    .quick-btn {
        flex: 1; min-width: 80px; padding: 10px 8px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 13px; font-weight: 700; color: #2d4a7a; cursor: pointer; text-align: center; transition: all .15s;
    }
    .quick-btn:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }

    .amount-input-wrap { position: relative; margin-bottom: 20px; }
    .amount-input {
        width: 100%; padding: 14px 52px 14px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px;
        font-size: 18px; font-weight: 700; color: #1e3a6e; outline: none; box-sizing: border-box; font-family: inherit; transition: all .15s;
    }
    .amount-input:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95); }
    .amount-unit { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); font-size: 14px; font-weight: 600; color: #93aecf; }

    .charge-btn {
        display: block; width: 100%; padding: 16px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none; border-radius: 25px;
        font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .charge-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }
    .charge-btn:disabled { background: rgba(156,163,175,.4); cursor: not-allowed; transform: none; box-shadow: none; }

    .charge-notice { font-size: 12px; color: #93aecf; text-align: center; margin-top: 12px; line-height: 1.8; }
    .min-notice { font-size: 12px; color: #f59e0b; margin-bottom: 16px; font-weight: 600; }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">잔액 충전</h1>
        <p class="page-desc">충전한 잔액으로 프로젝트 계약금을 안전하게 에스크로 보관합니다.</p>
    </div>
</div>

<section class="charge-section">
    <div class="charge-inner">

        <div class="balance-card">
            <div class="balance-label">현재 잔액</div>
            <div class="balance-amount">{{balance}}<span>원</span></div>
        </div>

        <div class="charge-card">
            <div class="charge-card-title">충전 금액 입력</div>

            <div class="quick-amounts">
                <button class="quick-btn" onclick="setAmount(10000)">1만원</button>
                <button class="quick-btn" onclick="setAmount(30000)">3만원</button>
                <button class="quick-btn" onclick="setAmount(50000)">5만원</button>
                <button class="quick-btn" onclick="setAmount(100000)">10만원</button>
                <button class="quick-btn" onclick="setAmount(300000)">30만원</button>
            </div>

            <div class="amount-input-wrap">
                <input type="number" id="chargeAmount" class="amount-input"
                       placeholder="충전 금액 입력" min="1000" step="1000" />
                <span class="amount-unit">원</span>
            </div>
            <p class="min-notice">※ 최소 충전 금액: 1,000원</p>

            <button class="charge-btn" id="chargeBtn" onclick="requestCharge()">
                토스페이먼츠로 충전하기
            </button>
            <p class="charge-notice">
                충전된 잔액은 프로젝트 계약 시 에스크로로 보관되며,<br>
                프로젝트 완료 후 전문가에게 지급됩니다.
            </p>
        </div>

    </div>
</section>

<script src="https://js.tosspayments.com/v1/payment"></script>
<script>
    const tossPayments = TossPayments('{{clientKey}}');
    const memberId = '{{memberId}}';

    function setAmount(val) {
        document.getElementById('chargeAmount').value = val;
    }

    function requestCharge() {
        const amount = parseInt(document.getElementById('chargeAmount').value, 10);
        if (!amount || amount < 1000) {
            alert('최소 1,000원 이상 입력해주세요.');
            return;
        }
        const orderId = 'charge-' + memberId + '-' + Date.now();

        tossPayments.requestPayment('카드', {
            amount:        amount,
            orderId:       orderId,
            orderName:     '잔액 충전',
            customerName:  '회원',
            successUrl:    window.location.origin + '/charge/success',
            failUrl:       window.location.origin + '/charge/fail',
        });
    }
</script>

{{> layout/footer}}
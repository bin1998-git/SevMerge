{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .save-section { padding: 52px 28px 80px; position: relative; z-index: 1; }
    .save-inner   { max-width: 760px; margin: 0 auto; }

    .save-header { margin-bottom: 32px; }
    .save-title  { font-size: 24px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc   { font-size: 14px; color: #4a6fa5; }

    .project-preview {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 12px; padding: 18px 20px; margin-bottom: 32px;
    }
    .project-preview-label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
    .project-preview-title { font-size: 16px; font-weight: 800; color: #1e3a6e; margin-bottom: 6px; }
    .project-preview-meta  { font-size: 12px; color: #4a6fa5; display: flex; gap: 14px; }

    .save-form {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 18px; padding: 36px;
        box-shadow: 0 4px 24px rgba(37,99,235,.08);
        display: flex; flex-direction: column; gap: 22px;
    }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-input, .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .15s;
    }
    .form-input::placeholder, .form-textarea::placeholder { color: #93aecf; }
    .form-input:focus, .form-textarea:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95); }
    .form-textarea { resize: vertical; min-height: 240px; line-height: 1.7; }
    .form-hint { font-size: 12px; color: #93aecf; margin-top: 4px; }

    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 20px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); }
    .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 25px; }
</style>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            <h1 class="save-title">제안서 작성</h1>
            <p class="save-desc">프로젝트 의뢰인에게 제안서를 보내세요.</p>
        </div>

        <div class="project-preview">
            <div class="project-preview-label">제안 대상 프로젝트</div>
            <div class="project-preview-title">{{project.title}}</div>
            <div class="project-preview-meta">
                <span>{{project.categoryName}}</span>
                <span>예산 {{project.budgetMin}}~{{project.budgetMax}}만원</span>
                <span>D-{{project.dDay}}</span>
            </div>
        </div>

        <form class="save-form" action="/bids" method="POST">
            <input type="hidden" name="projectId" value="{{project.id}}" />

            <div class="form-group">
                <label class="form-label">제목 <span class="required">*</span></label>
                <input type="text" name="title" class="form-input" placeholder="제안서 제목을 입력하세요" maxlength="100" />
            </div>

            <div class="form-group">
                <label class="form-label">자기소개 <span class="required">*</span></label>
                <textarea name="coverLetter" class="form-textarea" style="min-height:160px;"
                          placeholder="본인 소개 및 경력&#10;관련 프로젝트 경험&#10;포트폴리오 링크 등"></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">예상 작업 기간 <span class="required">*</span></label>
                <input type="number" name="estimatedDays" class="form-input" placeholder="예: 30 (일 단위)" min="1" />
            </div>

            <div class="form-group">
                <label class="form-label">희망 금액 (만원) <span class="required">*</span></label>
                <input type="number" name="proposedPrice" class="form-input" placeholder="희망하는 금액을 입력하세요" min="0" />
                <span class="form-hint">프로젝트 예산 범위: {{project.budgetMin}}~{{project.budgetMax}}만원</span>
            </div>

            <div class="form-btns">
                <a href="/projects/{{project.id}}" class="btn btn-outline">취소</a>
                <button type="submit" class="btn btn-primary btn-lg">제안서 제출</button>
            </div>
        </form>

    </div>
</section>

{{> layout/footer}}
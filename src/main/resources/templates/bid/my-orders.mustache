{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-section { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .page-inner   { max-width: 1200px; margin: 0 auto; }
    .page-head    { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
    .page-title   { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; }
    .page-count   { font-size: 13px; color: #4a6fa5; font-weight: 500; }
    .page-count strong { color: #1e3a6e; }

    .order-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.60);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 18px; overflow: hidden;
        box-shadow: 0 4px 20px rgba(37,99,235,.08);
        margin-bottom: 20px;
    }
    .order-card-head {
        display: grid; grid-template-columns: 1fr 120px 120px 90px 150px 180px;
        gap: 12px; padding: 13px 24px;
        background: rgba(255,255,255,.4); border-bottom: 1px solid rgba(37,99,235,.08);
        font-size: 12px; font-weight: 700; color: #4a6fa5; letter-spacing: .3px;
    }
    .order-main-row {
        display: grid; grid-template-columns: 1fr 120px 120px 90px 150px 180px;
        gap: 12px; padding: 18px 24px;
        align-items: center;
    }
    .cell        { font-size: 13px; color: #4a6fa5; }
    .cell-title  { font-weight: 700; color: #1e3a6e; font-size: 14px; }
    .cell-price  { font-weight: 700; color: #1e3a6e; }
    .cell-settle { font-weight: 700; color: #2563eb; }

    /* 작업상태 뱃지 */
    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-in-progress { background: rgba(37,99,235,.1);  color: #1d4ed8; border: 1px solid rgba(37,99,235,.2); }
    .badge-under-review { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
    .badge-work-done   { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .badge-waiting  { background: #ede9fe; color: #5b21b6; border: 1px solid #ddd6fe; }
    .badge-settled  { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }

    .cell-actions { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }

    /* 버튼 */
    .btn-base { padding: 6px 13px; border-radius: 20px; font-size: 12px; font-weight: 700; cursor: pointer; font-family: inherit; border: none; transition: all .15s; }
    .btn-chat    { background: linear-gradient(135deg, #7c3aed, #6d28d9); color: #fff; box-shadow: 0 3px 8px rgba(124,58,237,.3); text-decoration: none; display: inline-flex; align-items: center; gap: 3px; }
    .btn-chat:hover { transform: translateY(-1px); box-shadow: 0 5px 12px rgba(124,58,237,.4); }
    .btn-done    { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; box-shadow: 0 3px 8px rgba(37,99,235,.25); }
    .btn-done:hover { transform: translateY(-1px); }
    .btn-view    { backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a; border-radius: 20px; font-size: 12px; font-weight: 600; text-decoration: none; display: inline-block; padding: 6px 13px; }
    .btn-view:hover { background: rgba(255,255,255,.9); }
    .btn-status  { background: rgba(37,99,235,.08); color: #2563eb; border: 1.5px solid rgba(37,99,235,.2); }
    .btn-status:hover { background: rgba(37,99,235,.15); }
    .btn-submit  { background: linear-gradient(135deg, #059669, #047857); color: #fff; box-shadow: 0 3px 8px rgba(5,150,105,.25); }
    .btn-submit:hover { transform: translateY(-1px); }

    /* 작업상태 변경 + 파일제출 패널 */
    .order-panel {
        padding: 16px 24px;
        border-top: 1px solid rgba(37,99,235,.06);
        background: rgba(255,255,255,.25);
        display: none;
    }
    .order-panel.open { display: block; }
    .panel-row { display: flex; gap: 10px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 10px; }
    .panel-label { font-size: 12px; font-weight: 700; color: #4a6fa5; margin-bottom: 6px; }
    .status-btn-group { display: flex; gap: 6px; }
    .status-chip { padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; cursor: pointer; border: 1.5px solid rgba(37,99,235,.25); background: rgba(255,255,255,.6); color: #4a6fa5; transition: all .12s; }
    .status-chip.active { background: #2563eb; color: #fff; border-color: #2563eb; }
    .status-chip:hover:not(.active) { background: rgba(255,255,255,.9); }

    .file-submit-area { border-top: 1px dashed rgba(37,99,235,.15); padding-top: 14px; margin-top: 6px; }
    .file-submit-area input[type=file] { font-size: 13px; }
    .file-submit-area textarea { width: 100%; padding: 8px 12px; border-radius: 10px; border: 1.5px solid rgba(37,99,235,.15); font-size: 13px; resize: vertical; background: rgba(255,255,255,.7); font-family: inherit; margin-top: 6px; }
    .submitted-file-link { font-size: 13px; color: #2563eb; font-weight: 600; }

    /* 제출된 파일 표시 영역 */
    .submitted-info { font-size: 12px; color: #059669; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 8px 14px; margin-top: 8px; }

    .empty-state { text-align: center; padding: 80px 0; }
    .empty-icon  { font-size: 36px; margin-bottom: 14px; }
    .empty-msg   { font-size: 14px; color: #93aecf; margin-bottom: 18px; }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 32px; }
    .pagination .page-info { font-size: 13px; color: #6b7280; font-weight: 600; }
    .page-btn { padding: 9px 15px; border-radius: 8px; backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); font-size: 13px; font-weight: 600; color: #6b7280; text-decoration: none; }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; }
</style>

<section class="page-section">
    <div class="page-inner">

        <div class="page-head">
            <h1 class="page-title">📦 주문 관리</h1>
            <span class="page-count">총 <strong>{{orderCount}}</strong>건</span>
        </div>

        {{#cancelRequests}}
        <div class="order-card" style="border:1.5px solid rgba(239,68,68,.35); background:rgba(254,242,242,.6);">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:16px; flex-wrap:wrap;">
                <div style="flex:1; min-width:240px;">
                    <div style="font-weight:800; color:#dc2626; font-size:14px; margin-bottom:6px;">⚠️ 프로젝트 취소 요청</div>
                    <div style="font-weight:700; color:#1e3a6e; margin-bottom:4px;">{{project.title}}</div>
                    <div style="font-size:13px; color:#6b7280; margin-bottom:8px;">요청자: {{requester.name}}</div>
                    <div style="background:#fff; border:1px solid rgba(239,68,68,.2); border-radius:10px; padding:10px 12px; font-size:13px; color:#374151; line-height:1.6; white-space:pre-line;">{{reason}}</div>
                </div>
                <form action="/cancel-requests/{{id}}/approve" method="post"
                      onsubmit="return confirm('취소 요청을 승인하시겠습니까?\n승인 시 의뢰인에게 환불되고 프로젝트가 삭제됩니다.');"
                      style="margin:0;">
                    <button type="submit" style="background:#dc2626; color:#fff; border:none; padding:10px 18px; border-radius:8px; font-weight:700; cursor:pointer; white-space:nowrap;">취소 승인</button>
                </form>
            </div>
        </div>
        {{/cancelRequests}}

        {{^orders}}
        <div class="order-card">
            <div class="empty-state">
                <div class="empty-icon">📦</div>
                <p class="empty-msg">아직 진행중인 주문이 없습니다.</p>
            </div>
        </div>
        {{/orders}}

        {{#orders}}
        <div class="order-card">
            <div class="order-card-head">
                <span>프로젝트</span>
                <span>제안 금액</span>
                <span>정산 예정액</span>
                <span>예상 기간</span>
                <span>작업 상태</span>
                <span>액션</span>
            </div>
            <div class="order-main-row">
                <span class="cell cell-title">{{projectTitle}}</span>
                <span class="cell cell-price">{{proposedPrice}}원</span>
                <span class="cell cell-settle">{{payment.netAmount}}원</span>
                <span class="cell">{{estimatedDays}}일</span>
                <span class="cell">
                    {{#workIsInProgress}}<span class="badge badge-in-progress">진행중</span>{{/workIsInProgress}}
                    {{#workIsUnderReview}}<span class="badge badge-under-review">검토제안중</span>{{/workIsUnderReview}}
                    {{#workIsDone}}<span class="badge badge-work-done">작업완료</span>{{/workIsDone}}
                    {{#isDone}}
                        {{^payment.isSettled}}<span class="badge badge-waiting">승인 대기</span>{{/payment.isSettled}}
                        {{#payment.isSettled}}<span class="badge badge-settled">정산완료</span>{{/payment.isSettled}}
                    {{/isDone}}
                </span>
                <span class="cell cell-actions">
                    <a href="/projects/{{projectId}}" class="btn-view">보기</a>
                    <a href="/chat/start/project/{{projectId}}?withMemberId={{clientId}}" class="btn-base btn-chat">💬 채팅</a>
                    {{#isInProgress}}
                    <button class="btn-base btn-submit" onclick="togglePanel({{id}})">작업관리</button>
                    {{/isInProgress}}
                </span>
            </div>

            {{#isInProgress}}
            <div class="order-panel" id="panel-{{id}}">
                <div class="panel-row">
                    <div>
                        <div class="panel-label">작업 상태 변경</div>
                        <div class="status-btn-group">
                            <button class="status-chip {{#workIsInProgress}}active{{/workIsInProgress}}"
                                    onclick="changeStatus({{id}}, 'IN_PROGRESS', this)">진행중</button>
                            <button class="status-chip {{#workIsUnderReview}}active{{/workIsUnderReview}}"
                                    onclick="changeStatus({{id}}, 'UNDER_REVIEW', this)">검토제안중</button>
                            <button class="status-chip {{#workIsDone}}active{{/workIsDone}}"
                                    onclick="changeStatus({{id}}, 'WORK_DONE', this)">작업완료</button>
                        </div>
                    </div>
                </div>

                <div class="file-submit-area">
                    <div class="panel-label">📦 작업물 (n차 제출 · 의뢰인 컨펌)</div>

                    {{#deliverables}}
                    <div class="submitted-info" style="margin-bottom:8px;">
                        <strong>{{round}}차{{#isFinal}} (최종본){{/isFinal}}</strong>
                        {{#isSubmitted}}<span style="color:#d97706;"> · 확인 대기</span>{{/isSubmitted}}
                        {{#isRevisionRequested}}<span style="color:#dc2626;"> · 보완 요청됨</span>{{/isRevisionRequested}}
                        {{#isApproved}}<span style="color:#16a34a;"> · 승인 완료</span>{{/isApproved}}
                        {{#fileName}}<br>📎 {{fileName}}{{/fileName}}
                        {{#feedback}}<br><span style="color:#b91c1c;">보완 요청: {{feedback}}</span>{{/feedback}}
                    </div>
                    {{/deliverables}}

                    <form action="/projects/{{projectId}}/deliverables" method="post" enctype="multipart/form-data" style="margin-top:10px;">
                        <input type="file" name="file" required style="margin-bottom:8px;display:block;" />
                        <textarea name="note" rows="2" placeholder="의뢰인에게 전달할 설명 (선택)"></textarea>
                        <label style="display:flex;align-items:center;gap:6px;margin-top:8px;font-size:13px;color:#374151;">
                            <input type="checkbox" name="isFinal" value="true" /> 최종본으로 제출 (의뢰인 최종 승인 시 정산)
                        </label>
                        <div style="display:flex;gap:8px;margin-top:8px;">
                            <button type="submit" class="btn-base btn-done">✓ 작업물 제출</button>
                        </div>
                    </form>
                </div>
            </div>
            {{/isInProgress}}
        </div>
        {{/orders}}

        <div class="pagination">
            {{#hasPrev}}<a href="/bids/my-orders?page={{prevPage}}" class="page-btn">이전</a>{{/hasPrev}}
            <span class="page-info">{{currentPage}} / {{totalPages}}</span>
            {{#hasNext}}<a href="/bids/my-orders?page={{nextPage}}" class="page-btn">다음</a>{{/hasNext}}
        </div>

    </div>
</section>

<script>
    function togglePanel(bidId) {
        const panel = document.getElementById('panel-' + bidId);
        panel.classList.toggle('open');
    }

    function changeStatus(bidId, status, btn) {
        fetch(`/bids/${bidId}/work-status?status=${status}`, { method: 'PATCH' })
            .then(res => {
                if (res.ok) {
                    btn.closest('.status-btn-group').querySelectorAll('.status-chip').forEach(c => c.classList.remove('active'));
                    btn.classList.add('active');
                    alert('작업 상태가 변경되었습니다. 의뢰인에게 알림이 전송됩니다.');
                    location.reload();
                } else {
                    res.json().then(d => alert(d.message || '오류가 발생했습니다.'));
                }
            });
    }

    function submitWork(bidId) {
        const fileInput = document.getElementById('file-' + bidId);
        const note = document.getElementById('note-' + bidId).value;
        if (!fileInput.files[0]) { alert('제출할 파일을 선택해주세요.'); return; }
        if (!confirm('작업물을 제출하고 의뢰인에게 완료 확인을 요청하시겠습니까?')) return;

        const fd = new FormData();
        fd.append('file', fileInput.files[0]);
        fd.append('note', note);

        fetch(`/bids/${bidId}/submit-work`, { method: 'POST', body: fd })
            .then(res => {
                if (res.ok) { alert('작업물이 제출되었습니다. 의뢰인의 승인을 기다려주세요.'); location.reload(); }
                else { res.json().then(d => alert(d.message || '제출 중 오류가 발생했습니다.')); }
            });
    }
</script>

{{> layout/footer}}

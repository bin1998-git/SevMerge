{{> layout/header}}

<style>
    /* ── 탭바 ── */
    .dash-tabs-bar { background: #fff; border-bottom: 2px solid #eaecf4; position: sticky; top: 64px; z-index: 90; }
    .dash-tabs-inner { max-width: 1200px; margin: 0 auto; padding: 0 28px; display: flex; }
    .dash-tab { padding: 13px 20px; font-size: 13px; font-weight: 600; color: #6b7280; border-bottom: 2px solid transparent; margin-bottom: -2px; white-space: nowrap; transition: color .15s, border-color .15s; }
    .dash-tab:hover { color: #1c1e26; border-color: #d1d5db; }
    .dash-tab.active { color: #2563eb; border-color: #2563eb; }

    /* ── 본문 ── */
    .page-section { padding: 40px 28px 80px; }
    .page-inner { max-width: 1200px; margin: 0 auto; }
    .page-head { margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
    .page-title { font-size: 22px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; }
    .page-count { font-size: 13px; color: #9ca3af; font-weight: 500; }

    /* ── 주문 카드 ── */
    .order-grid { display: flex; flex-direction: column; gap: 16px; }
    .order-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 16px; padding: 24px 28px; transition: border-color .2s, box-shadow .2s; }
    .order-card:hover { border-color: #bfdbfe; box-shadow: 0 4px 16px rgba(37,99,235,.07); }

    .order-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .order-title { font-size: 16px; font-weight: 800; color: #1c1e26; letter-spacing: -0.3px; margin-bottom: 4px; }
    .order-meta { font-size: 12px; color: #9ca3af; font-weight: 400; }

    /* ── 상태 뱃지 ── */
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-progress { background: #dbeafe; color: #1d4ed8; }
    .badge-done     { background: #d1fae5; color: #065f46; }
    .badge-settled  { background: #ede9fe; color: #5b21b6; }
    .badge-waiting  { background: #fef3c7; color: #92400e; }

    /* ── 상세 정보 ── */
    .order-info-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding: 16px 0; border-top: 1px solid #f3f4f8; border-bottom: 1px solid #f3f4f8; margin-bottom: 16px; }
    .info-item { display: flex; flex-direction: column; gap: 4px; }
    .info-label { font-size: 11px; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: .5px; }
    .info-value { font-size: 14px; font-weight: 700; color: #1c1e26; }
    .info-value.blue { color: #2563eb; }
    .info-value.green { color: #059669; }

    /* ── 에스크로 안내 ── */
    .escrow-notice { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 10px; padding: 12px 16px; font-size: 13px; color: #2563eb; font-weight: 500; margin-bottom: 14px; }
    .waiting-notice { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 12px 16px; font-size: 13px; color: #92400e; font-weight: 500; margin-bottom: 14px; }
    .settled-notice { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 10px; padding: 12px 16px; font-size: 13px; color: #15803d; font-weight: 500; margin-bottom: 14px; }

    /* ── 버튼 ── */
    .order-actions { display: flex; justify-content: flex-end; gap: 10px; }
    .btn-done { padding: 10px 22px; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; transition: background .15s; }
    .btn-done:hover { background: #1d4ed8; }
    .btn-detail { padding: 10px 22px; background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; font-family: inherit; transition: all .15s; text-decoration: none; display: inline-block; }
    .btn-detail:hover { border-color: #2563eb; color: #2563eb; }

    /* ── 빈 상태 ── */
    .empty-box { background: #fff; border: 1.5px solid #eaecf4; border-radius: 16px; text-align: center; padding: 80px 0; }
    .empty-icon { font-size: 36px; margin-bottom: 14px; }
    .empty-msg { font-size: 14px; color: #c4c9d9; }
</style>

<!-- 탭바 -->
<div class="dash-tabs-bar">
    <div class="dash-tabs-inner">
        <a href="/experts/dashboard" class="dash-tab">대시보드</a>
        <a href="/bid/my-list"       class="dash-tab">제안서 관리</a>
        <a href="/bid/my-orders"     class="dash-tab active">주문 관리</a>
        <a href="/payment/my"        class="dash-tab">수익 &amp; 정산</a>
        <a href="/reviews/my"        class="dash-tab">평가 및 리뷰</a>
        <a href="/experts/my/form"   class="dash-tab">프로필 수정</a>
    </div>
</div>

<section class="page-section">
    <div class="page-inner">

        <div class="page-head">
            <h1 class="page-title">📦 주문 관리</h1>
            <span class="page-count">총 <strong>{{orderCount}}</strong>건</span>
        </div>

        <div class="order-grid">

            {{#orders}}
            <!-- 실제 데이터 반복 -->
            <div class="order-card">
                <div class="order-card-top">
                    <div>
                        <div class="order-title">{{projectTitle}}</div>
                        <div class="order-meta">제안일 {{createdAt}}</div>
                    </div>
                    <div>
                        {{#isInProgress}}<span class="badge badge-progress">진행중</span>{{/isInProgress}}
                        {{#isDone}}
                            {{^payment.isSettled}}<span class="badge badge-waiting">승인 대기</span>{{/payment.isSettled}}
                            {{#payment.isSettled}}<span class="badge badge-settled">정산완료</span>{{/payment.isSettled}}
                        {{/isDone}}
                    </div>
                </div>

                <div class="order-info-row">
                    <div class="info-item">
                        <span class="info-label">제안 금액</span>
                        <span class="info-value">{{proposedPrice}}원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">정산 예정액</span>
                        <span class="info-value blue">{{payment.netAmount}}원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">수수료 (10%)</span>
                        <span class="info-value">{{payment.platformFee}}원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">예상 기간</span>
                        <span class="info-value">{{estimatedDays}}일</span>
                    </div>
                </div>

                {{#isInProgress}}
                <div class="escrow-notice">
                    💳 의뢰인이 에스크로에 결제금을 예치했습니다. 작업 완료 후 "작업 완료" 버튼을 눌러주세요.
                </div>
                {{/isInProgress}}

                {{#isDone}}
                    {{^payment.isSettled}}
                    <div class="waiting-notice">
                        ⏳ 의뢰인의 최종 승인을 기다리고 있습니다. 승인 완료 시 포인트가 자동 정산됩니다.
                    </div>
                    {{/payment.isSettled}}
                    {{#payment.isSettled}}
                    <div class="settled-notice">
                        ✅ 정산이 완료되었습니다. 수익 &amp; 정산 탭에서 확인하세요.
                    </div>
                    {{/payment.isSettled}}
                {{/isDone}}

                <div class="order-actions">
                    <a href="/projects/{{projectId}}/detail" class="btn-detail">프로젝트 보기</a>
                    {{#isInProgress}}
                    <button class="btn-done" data-project-id="{{projectId}}">✓ 작업 완료</button>
                    {{/isInProgress}}
                </div>
            </div>
            {{/orders}}

            {{^orders}}
            <!-- ── 더미 데이터 (실제 데이터 연결 전 UI 확인용) ── -->

            <!-- 진행중 카드 -->
            <div class="order-card">
                <div class="order-card-top">
                    <div>
                        <div class="order-title">React 기반 대시보드 구축</div>
                        <div class="order-meta">제안일 2026.05.28</div>
                    </div>
                    <span class="badge badge-progress">진행중</span>
                </div>
                <div class="order-info-row">
                    <div class="info-item">
                        <span class="info-label">제안 금액</span>
                        <span class="info-value">2,800,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">정산 예정액</span>
                        <span class="info-value blue">2,520,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">수수료 (10%)</span>
                        <span class="info-value">280,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">예상 기간</span>
                        <span class="info-value">21일</span>
                    </div>
                </div>
                <div class="escrow-notice">
                    💳 의뢰인이 에스크로에 결제금을 예치했습니다. 작업 완료 후 "작업 완료" 버튼을 눌러주세요.
                </div>
                <div class="order-actions">
                    <a href="#" class="btn-detail">프로젝트 보기</a>
                    <button class="btn-done" data-project-id="101">✓ 작업 완료</button>
                </div>
            </div>

            <!-- 승인 대기 카드 -->
            <div class="order-card">
                <div class="order-card-top">
                    <div>
                        <div class="order-title">iOS 쇼핑몰 앱 리뉴얼</div>
                        <div class="order-meta">제안일 2026.05.10</div>
                    </div>
                    <span class="badge badge-waiting">승인 대기</span>
                </div>
                <div class="order-info-row">
                    <div class="info-item">
                        <span class="info-label">제안 금액</span>
                        <span class="info-value">5,000,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">정산 예정액</span>
                        <span class="info-value blue">4,500,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">수수료 (10%)</span>
                        <span class="info-value">500,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">예상 기간</span>
                        <span class="info-value">60일</span>
                    </div>
                </div>
                <div class="waiting-notice">
                    ⏳ 의뢰인의 최종 승인을 기다리고 있습니다. 승인 완료 시 포인트가 자동 정산됩니다.
                </div>
                <div class="order-actions">
                    <a href="#" class="btn-detail">프로젝트 보기</a>
                </div>
            </div>

            <!-- 정산완료 카드 -->
            <div class="order-card">
                <div class="order-card-top">
                    <div>
                        <div class="order-title">Spring Boot 마이그레이션</div>
                        <div class="order-meta">제안일 2026.04.01</div>
                    </div>
                    <span class="badge badge-settled">정산완료</span>
                </div>
                <div class="order-info-row">
                    <div class="info-item">
                        <span class="info-label">제안 금액</span>
                        <span class="info-value">4,500,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">정산액</span>
                        <span class="info-value green">4,050,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">수수료 (10%)</span>
                        <span class="info-value">450,000원</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">예상 기간</span>
                        <span class="info-value">45일</span>
                    </div>
                </div>
                <div class="settled-notice">
                    ✅ 정산이 완료되었습니다. 수익 &amp; 정산 탭에서 확인하세요.
                </div>
                <div class="order-actions">
                    <a href="#" class="btn-detail">프로젝트 보기</a>
                </div>
            </div>
            {{/orders}}

        </div>
    </div>
</section>

<script>
document.querySelectorAll('.btn-done').forEach(btn => {
    btn.addEventListener('click', function () {
        const projectId = this.dataset.projectId;
        if (!confirm('작업 완료 처리하시겠습니까?\n의뢰인에게 승인 요청이 전송됩니다.')) return;
        fetch(`/projects/${projectId}/done`, { method: 'POST' })
            .then(res => {
                if (res.ok) {
                    alert('작업 완료 처리되었습니다. 의뢰인의 승인을 기다려주세요.');
                    location.reload();
                } else {
                    alert('처리 중 오류가 발생했습니다.');
                }
            })
            .catch(() => alert('서버와 통신 중 오류가 발생했습니다.'));
    });
});
</script>

{{> layout/footer}}

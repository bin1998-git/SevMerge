{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 폼 본문 ── */
    .form-content { flex: 1; padding: 28px 32px 32px; }

    /* ── 프로젝트 프리뷰 ── */
    .project-preview {
        backdrop-filter: blur(12px); background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 12px; padding: 18px 20px; margin-bottom: 28px;
    }
    .project-preview-label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; }
    .project-preview-title { font-size: 16px; font-weight: 800; color: #1e3a6e; margin-bottom: 6px; }
    .project-preview-meta  { font-size: 12px; color: #4a6fa5; display: flex; gap: 14px; flex-wrap: wrap; }

    /* ── 폼 ── */
    .save-form { display: flex; flex-direction: column; gap: 22px; }
    .form-group  { display: flex; flex-direction: column; gap: 8px; }
    .form-label  { font-size: 13px; font-weight: 700; color: #2d4a7a; }

    .form-input, .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 14px; font-family: inherit; color: #1e3a6e;
        outline: none; transition: all .15s;
    }
    .form-input:focus, .form-textarea:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95); }
    .form-textarea { resize: vertical; min-height: 160px; line-height: 1.7; }

    /* ── 버튼 ── */
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 22px; border-radius: 20px;
        font-size: 14px; font-weight: 700; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); color: #2563eb; }
    .btn-lg { padding: 13px 32px; font-size: 15px; border-radius: 25px; }

    @media (max-width: 600px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .form-content { padding-left: 18px; padding-right: 18px; }
        .form-btns { flex-direction: column; }
        .btn-lg { width: 100%; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">제안서 수정</h1>
                <p class="board-desc">제안서 내용을 수정하세요.</p>
            </div>
            <a href="my-pages?tab=bids" class="btn btn-outline" style="flex-shrink:0;">← 돌아가기</a>
        </div>

        <!-- 폼 본문 -->
        <div class="form-content">

            <!-- 프로젝트 프리뷰 -->
            <div class="project-preview">
                <div class="project-preview-label">제안 대상 프로젝트</div>
                <div class="project-preview-title">{{bid.projectTitle}}</div>
                <div class="project-preview-meta">
                    <span>희망금액 {{bid.proposedPrice}}원</span>
                    <span>예상기간 {{bid.estimatedDays}}일</span>
                </div>
            </div>

            <form class="save-form" id="bid-update-form">
                <input type="hidden" id="bidId" value="{{bid.id}}" />

                <div class="form-group">
                    <label class="form-label">자기소개</label>
                    <textarea id="coverLetter" class="form-textarea">{{bid.coverLetter}}</textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">접근 방식</label>
                    <textarea id="approach" class="form-textarea" style="min-height:120px;">{{bid.approach}}</textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">예상 작업 기간 (일)</label>
                    <input type="number" id="estimatedDays" class="form-input" value="{{bid.estimatedDays}}" min="1" />
                </div>

                <div class="form-group">
                    <label class="form-label">희망 금액 (원)</label>
                    <input type="number" id="proposedPrice" class="form-input" value="{{bid.proposedPrice}}" min="0" />
                </div>

                <div class="form-btns">
                    <a href="/my-page?tab=bids" class="btn btn-outline">취소</a>
                    <button type="button" class="btn btn-primary btn-lg" onclick="updateBid()">수정완료</button>
                </div>
            </form>

        </div>
    </div>
</section>

<script>
function updateBid() {
    const id   = document.querySelector('#bidId').value;
    const data = {
        coverLetter:   document.querySelector('#coverLetter').value,
        approach:      document.querySelector('#approach').value,
        estimatedDays: document.querySelector('#estimatedDays').value,
        proposedPrice: document.querySelector('#proposedPrice').value
    };
    if (!data.coverLetter.trim() || !data.approach.trim() || !data.estimatedDays || !data.proposedPrice) {
        alert('⚠️ 모든 입력 항목을 올바르게 입력해 주세요.'); return;
    }
    fetch(`/bids/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json; charset=utf-8' }, body: JSON.stringify(data) })
        .then(res => {
            if (res.ok) { alert('✏️ 제안서 수정이 완료되었습니다!'); location.href = '/my-pages?tab=bids'; }
            else alert('제안서 수정에 실패했습니다. 권한이 없거나 대기 중(PENDING) 상태가 아닐 수 있습니다.');
        })
        .catch(err => { console.error('Error:', err); alert('서버 통신 중 오류가 발생했습니다.'); });
}
</script>

{{> layout/footer}}

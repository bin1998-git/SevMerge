{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }
    .board-count { font-size: 13px; color: #4a6fa5; font-weight: 500; }
    .board-count strong { color: #1e3a6e; font-weight: 700; }

    /* ── 본문 ── */
    .list-content { flex: 1; padding: 24px 32px 32px; display: flex; flex-direction: column; }

    /* ── 테이블 ── */
    .bid-table {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; overflow: hidden;
        box-shadow: 0 4px 20px rgba(37,99,235,.07);
    }
    .bid-table-head {
        display: grid; grid-template-columns: 1fr 110px 100px 90px 110px 140px;
        gap: 12px; padding: 13px 24px;
        background: rgba(37,99,235,.06); border-bottom: 1.5px solid rgba(37,99,235,.1);
        font-size: 12px; font-weight: 800; color: #4a6fa5; letter-spacing: .3px;
    }
    .bid-row {
        display: grid; grid-template-columns: 1fr 110px 100px 90px 110px 140px;
        gap: 12px; padding: 18px 24px;
        border-bottom: 1px solid rgba(37,99,235,.06);
        align-items: center; transition: background .12s;
    }
    .bid-row:last-child { border-bottom: none; }
    .bid-row:hover { background: rgba(255,255,255,.5); }

    .cell       { font-size: 13px; color: #4a6fa5; }
    .cell-title { font-weight: 700; color: #1e3a6e; font-size: 14px; }
    .cell-price { font-weight: 700; color: #1e3a6e; }

    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-pending  { background: #fef3c7; color: #92400e; border: 1px solid #fde68a; }
    .badge-selected { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
    .badge-rejected { background: rgba(156,163,175,.12); color: #4a6fa5; border: 1px solid rgba(156,163,175,.2); }

    .btn-edit {
        padding: 6px 12px;
        background: rgba(99,102,241,.1); border: 1.5px solid rgba(99,102,241,.2);
        color: #4f46e5; border-radius: 20px; font-size: 12px; font-weight: 600;
        cursor: pointer; text-decoration: none; display: inline-block; transition: all .15s;
    }
    .btn-edit:hover { background: rgba(99,102,241,.2); }
    .btn-cancel {
        padding: 6px 12px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(254,202,202,.8); color: #dc2626;
        border-radius: 20px; font-size: 12px; font-weight: 600;
        cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .btn-cancel:hover { background: rgba(254,242,242,.85); border-color: #dc2626; }
    .btn-disabled {
        padding: 6px 12px; background: rgba(156,163,175,.1);
        border: 1.5px solid rgba(156,163,175,.2);
        color: #93aecf; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: not-allowed;
    }
    .cell-btns { display: flex; gap: 6px; }

    /* ── 빈 상태 ── */
    .empty-state { text-align: center; padding: 80px 0; }
    .empty-icon  { font-size: 36px; margin-bottom: 14px; }
    .empty-msg   { font-size: 14px; color: #93aecf; margin-bottom: 18px; }

    /* ── 페이지네이션 ── */
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; padding-top: 24px; margin-top: auto; }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .page-btn {
        padding: 8px 16px; border-radius: 20px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        font-size: 13px; font-weight: 600; color: #4a6fa5; text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }

    @media (max-width: 900px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .list-content { padding-left: 18px; padding-right: 18px; }
        .bid-table-head { display: none; }
        .bid-row { grid-template-columns: 1fr; padding: 16px 18px; gap: 6px; }
        .cell-btns { justify-content: flex-start; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">제안서 관리</h1>
                <p class="board-desc">내가 제출한 제안서 현황을 확인하세요.</p>
            </div>
            <span class="board-count">총 <strong>{{bidCount}}</strong>건</span>
        </div>

        <!-- 본문 -->
        <div class="list-content">

            <div class="bid-table">
                <div class="bid-table-head">
                    <span>프로젝트</span>
                    <span>제안 금액</span>
                    <span>예상 기간</span>
                    <span>제안일</span>
                    <span>상태</span>
                    <span>관리</span>
                </div>

                {{#bids}}
                <div class="bid-row">
                    <span class="cell cell-title">{{projectTitle}}</span>
                    <span class="cell cell-price">{{proposedPrice}}만원</span>
                    <span class="cell">{{estimatedDays}}일</span>
                    <span class="cell">{{createdAt}}</span>
                    <span class="cell">
                        {{#isPending}}<span class="badge badge-pending">검토중</span>{{/isPending}}
                        {{#isSelected}}<span class="badge badge-selected">낙찰됨</span>{{/isSelected}}
                        {{^isPending}}{{^isSelected}}<span class="badge badge-rejected">미선정</span>{{/isSelected}}{{/isPending}}
                    </span>
                    <span class="cell">
                        {{#isPending}}
                        <div class="cell-btns">
                            <a href="/bids/{{id}}/edit" class="btn-edit">수정</a>
                            <button class="btn-cancel" data-bid-id="{{id}}">취소</button>
                        </div>
                        {{/isPending}}
                        {{^isPending}}
                        <span class="btn-disabled">수정/취소불가</span>
                        {{/isPending}}
                    </span>
                </div>
                {{/bids}}

                {{^bids}}
                <div class="empty-state">
                    <div class="empty-icon">📋</div>
                    <p class="empty-msg">아직 제출한 제안서가 없습니다.</p>
                    <a href="/projects" style="font-size:13px;color:#2563eb;font-weight:600;">프로젝트 둘러보기 →</a>
                </div>
                {{/bids}}
            </div>

            <div class="pagination">
                {{#hasPrev}}<a href="/bids/my-list?page={{prevPage}}" class="page-btn">← 이전</a>{{/hasPrev}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#hasNext}}<a href="/bids/my-list?page={{nextPage}}" class="page-btn">다음 →</a>{{/hasNext}}
            </div>

        </div>
    </div>
</section>

<script>
document.querySelectorAll('.btn-cancel').forEach(btn => {
    btn.addEventListener('click', function () {
        const bidId = this.dataset.bidId;
        if (!confirm('제안서를 취소하시겠습니까? 취소 후 복구할 수 없습니다.')) return;
        fetch(`/bids/${bidId}`, { method: 'DELETE' })
            .then(res => {
                if (res.ok) { alert('제안서가 취소되었습니다.'); location.reload(); }
                else alert('취소 처리 중 오류가 발생했습니다.');
            })
            .catch(() => alert('서버와 통신 중 오류가 발생했습니다.'));
    });
});
</script>

{{> layout/footer}}

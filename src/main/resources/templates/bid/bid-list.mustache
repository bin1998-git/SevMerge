{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 본문 ── */
    .list-content { flex: 1; padding: 24px 32px 32px; display: flex; flex-direction: column; }

    /* ── 프로젝트 요약 카드 ── */
    .project-info-card {
        backdrop-filter: blur(12px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 14px; padding: 20px 24px; margin-bottom: 24px;
        display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 4px 16px rgba(37,99,235,.07);
    }
    .proj-info-left h3 { font-size: 17px; font-weight: 800; color: #1e3a6e; margin-bottom: 6px; }
    .proj-meta { font-size: 13px; color: #4a6fa5; display: flex; gap: 14px; }
    .proj-info-right { text-align: right; }
    .proj-budget { font-size: 20px; font-weight: 900; color: #2563eb; }
    .proj-d-day  { font-size: 12px; color: #ef4444; font-weight: 700; margin-top: 4px; }

    /* ── 카운트 바 ── */
    .bid-count-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
    .bid-count { font-size: 14px; color: #4a6fa5; font-weight: 500; }
    .bid-count strong { color: #1e3a6e; font-weight: 700; }

    /* ── 제안서 카드 ── */
    .bid-list { display: flex; flex-direction: column; gap: 14px; }
    .bid-card {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 14px; padding: 22px 24px;
        display: flex; gap: 18px; align-items: flex-start;
        box-shadow: 0 4px 16px rgba(37,99,235,.06); transition: all .2s;
    }
    .bid-card:hover { border-color: rgba(37,99,235,.25); box-shadow: 0 8px 24px rgba(37,99,235,.1); }
    .bid-card.selected { border-color: rgba(37,99,235,.4); background: rgba(239,246,255,.8); }
    .bid-card.rejected { border-color: rgba(254,202,202,.6); background: rgba(255,241,242,.6); opacity: .7; }

    .bid-avatar {
        width: 48px; height: 48px; border-radius: 14px;
        background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; flex-shrink: 0;
    }
    .bid-body { flex: 1; }
    .bid-name-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
    .bid-name { font-size: 15px; font-weight: 800; color: #1e3a6e; }
    .cert-badge { font-size: 10px; padding: 2px 8px; border-radius: 5px; font-weight: 700; }
    .bid-content { font-size: 13px; color: #4a6fa5; line-height: 1.7; }

    .bid-right { text-align: right; flex-shrink: 0; min-width: 130px; }
    .bid-price { font-size: 20px; font-weight: 900; color: #2563eb; margin-bottom: 4px; }
    .bid-date  { font-size: 11px; color: #93aecf; margin-bottom: 12px; }

    .selected-badge { font-size: 12px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .rejected-badge { font-size: 12px; background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; }

    .select-btn {
        padding: 9px 18px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        border: none; border-radius: 20px;
        font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;
        display: block; margin-bottom: 8px; width: 100%;
        box-shadow: 0 4px 12px rgba(37,99,235,.25); transition: all .15s;
    }
    .select-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .reject-btn {
        padding: 9px 18px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        color: #ef4444; border: 1.5px solid rgba(254,202,202,.8);
        border-radius: 20px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;
        display: block; width: 100%; transition: all .15s;
    }
    .reject-btn:hover { background: rgba(254,242,242,.85); border-color: #ef4444; }

    /* ── 빈 상태 ── */
    .empty-state { text-align: center; padding: 60px 0; color: #93aecf; font-size: 15px; }

    /* ── 페이지네이션 ── */
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; padding-top: 24px; margin-top: auto; }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .page-btn {
        padding: 8px 16px; border-radius: 20px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        font-size: 13px; font-weight: 600; color: #4a6fa5; text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }

    @media (max-width: 768px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .list-content { padding-left: 18px; padding-right: 18px; }
        .bid-card { flex-direction: column; }
        .bid-right { text-align: left; width: 100%; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">제안서 목록</h1>
                <p class="board-desc">내 프로젝트에 들어온 제안서를 확인하세요.</p>
            </div>
            <a href="/projects" style="display:inline-flex;align-items:center;padding:9px 18px;border-radius:20px;font-size:13px;font-weight:700;backdrop-filter:blur(8px);background:rgba(255,255,255,.6);border:1.5px solid rgba(255,255,255,.8);color:#2d4a7a;text-decoration:none;transition:all .15s;">← 프로젝트 목록</a>
        </div>

        <!-- 본문 -->
        <div class="list-content">

            <!-- 프로젝트 요약 -->
            <div class="project-info-card">
                <div class="proj-info-left">
                    <h3>{{projects.title}}</h3>
                    <div class="proj-meta">
                        <span>{{projects.categoryName}}</span>
                        <span>등록일 {{projects.createdAt}}</span>
                    </div>
                </div>
                <div class="proj-info-right">
                    <div class="proj-budget">{{projects.budgetMin}}~{{projects.budgetMax}}만원</div>
                    <div class="proj-d-day">D-{{projects.dDay}}</div>
                </div>
            </div>

            <!-- 카운트 -->
            <div class="bid-count-bar">
                <span class="bid-count">총 <strong>{{bids.size}}</strong>개의 제안서</span>
            </div>

            <!-- 제안서 카드 목록 -->
            <div class="bid-list">
                {{#bids}}
                <div class="bid-card {{#isSelected}}selected{{/isSelected}}{{#isRejected}}rejected{{/isRejected}}">
                    <div class="bid-avatar">👨‍💻</div>
                    <div class="bid-body">
                        <div class="bid-name-wrap">
                            <span class="bid-name">{{expertName}}</span>
                            {{#isPending}}<span class="cert-badge" style="background:rgba(234,88,12,.1);color:#ea580c;border:1px solid rgba(234,88,12,.2);">⏳ 검토 대기중</span>{{/isPending}}
                            {{#isSelected}}<span class="cert-badge" style="background:#ecfdf5;color:#059669;border:1px solid #a7f3d0;">🎉 최종 낙찰됨</span>{{/isSelected}}
                            {{#isRejected}}<span class="cert-badge" style="background:#fff1f2;color:#e11d48;border:1px solid #fecdd3;">❌ 거절됨</span>{{/isRejected}}
                        </div>
                        <div class="bid-content">{{coverLetter}}</div>
                    </div>
                    <div class="bid-right">
                        <div class="bid-price">{{proposedPrice}}만원</div>
                        <div class="bid-date">{{createdAt}}</div>
                        {{#isSelected}}<span class="selected-badge">✓ 낙찰 완료</span>{{/isSelected}}
                        {{#isRejected}}<span class="rejected-badge">✕ 거절됨</span>{{/isRejected}}
                        {{#isPending}}
                        <button type="button" class="select-btn" onclick="selectBid({{id}})">낙찰 선택</button>
                        <button type="button" class="reject-btn"  onclick="rejectBid({{id}})">거절</button>
                        {{/isPending}}
                    </div>
                </div>
                {{/bids}}

                {{^bids}}
                <div class="empty-state">아직 들어온 제안서가 없습니다.</div>
                {{/bids}}
            </div>

            <!-- 페이지네이션 -->
            <div class="pagination">
                {{#hasPrev}}<a href="/bids?projectId={{projectId}}&page={{prevPage}}" class="page-btn">← 이전</a>{{/hasPrev}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#hasNext}}<a href="/bids?projectId={{projectId}}&page={{nextPage}}" class="page-btn">다음 →</a>{{/hasNext}}
            </div>

        </div>
    </div>
</section>

<script>
function selectBid(bidId) {
    if (!confirm('정말 이 전문가를 낙찰하시겠습니까?\n낙찰 완료 후 보유 잔액에서 계약금이 자동 차감됩니다.')) return;
    fetch(`/bids/${bidId}/select`, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
        .then(res => {
            if (res.ok) { alert('🎉 낙찰 처리가 완료되었습니다!\n계약금이 에스크로로 이체되었습니다.'); location.href = '/projects'; }
            else res.json().then(d => alert('낙찰 처리 실패\n' + (d.message || '잠시 후 다시 시도해주세요.')));
        }).catch(() => alert('서버 통신 중 오류가 발생했습니다.'));
}
function rejectBid(bidId) {
    if (!confirm('이 제안서를 거절하시겠습니까?')) return;
    fetch(`/bids/${bidId}/reject`, { method: 'DELETE', headers: { 'Content-Type': 'application/json' } })
        .then(res => {
            if (res.ok) { alert('제안서가 거절되었습니다.'); location.reload(); }
            else alert('거절 처리에 실패했습니다.');
        }).catch(() => alert('서버 통신 중 오류가 발생했습니다.'));
}
</script>

{{> layout/footer}}

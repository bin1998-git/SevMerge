{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-header {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.75); border-bottom: 1px solid rgba(255,255,255,.6);
        padding: 36px 28px 28px; position: relative; z-index: 1;
    }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; margin-bottom: 6px; }
    .page-desc  { font-size: 14px; color: #4a6fa5; }

    .list-section { padding: 36px 28px 80px; position: relative; z-index: 1; }
    .list-inner   { max-width: 1140px; margin: 0 auto; }

    .project-info-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 14px; padding: 22px 24px; margin-bottom: 32px;
        display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 4px 16px rgba(37,99,235,.07);
    }
    .proj-info-left h3 { font-size: 17px; font-weight: 800; color: #1e3a6e; margin-bottom: 6px; }
    .proj-info-left .meta { font-size: 13px; color: #4a6fa5; display: flex; gap: 14px; }
    .proj-info-right { text-align: right; }
    .proj-budget { font-size: 20px; font-weight: 900; color: #2563eb; }
    .proj-d-day  { font-size: 12px; color: #ef4444; font-weight: 700; margin-top: 4px; }

    .bid-count-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .bid-count { font-size: 14px; color: #4a6fa5; font-weight: 500; }
    .bid-count strong { color: #1e3a6e; font-weight: 700; }

    .bid-list { display: flex; flex-direction: column; gap: 14px; }
    .bid-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 14px; padding: 22px 24px; display: flex; gap: 18px; align-items: flex-start;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
        transition: all .2s;
    }
    .bid-card:hover { border-color: rgba(37,99,235,.25); box-shadow: 0 8px 24px rgba(37,99,235,.1); }
    .bid-card.selected { border-color: rgba(37,99,235,.4); background: rgba(239,246,255,.8); }
    .bid-card.rejected { border-color: rgba(254,202,202,.6); background: rgba(255,241,242,.6); opacity: 0.7; }

    .bid-avatar { width: 48px; height: 48px; border-radius: 14px; background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .bid-body { flex: 1; }
    .bid-name-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .bid-name { font-size: 15px; font-weight: 800; color: #1e3a6e; }
    .cert-badge { font-size: 10px; padding: 2px 8px; border-radius: 5px; font-weight: 700; }
    .bid-spec    { font-size: 12px; color: #4a6fa5; margin-bottom: 10px; }
    .bid-content { font-size: 13px; color: #4a6fa5; line-height: 1.7; }
    .bid-right   { text-align: right; flex-shrink: 0; }
    .bid-price   { font-size: 20px; font-weight: 900; color: #2563eb; margin-bottom: 10px; }
    .bid-date    { font-size: 11px; color: #93aecf; margin-bottom: 14px; }

    .select-btn {
        padding: 9px 18px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none; border-radius: 20px;
        font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;
        display: block; margin-bottom: 8px; width: 100%;
        box-shadow: 0 4px 12px rgba(37,99,235,.25); transition: all .15s;
    }
    .select-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }

    .reject-btn {
        padding: 9px 18px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        color: #ef4444; border: 1.5px solid rgba(254,202,202,.8);
        border-radius: 20px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit;
        display: block; width: 100%; transition: all .15s;
    }
    .reject-btn:hover { background: rgba(254,242,242,.85); border-color: #ef4444; }

    .selected-badge { font-size: 12px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .rejected-badge { font-size: 12px; background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .empty-state { text-align: center; padding: 60px 0; }
    .empty-msg   { font-size: 15px; color: #93aecf; }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">제안서 목록</h1>
        <p class="page-desc">내 프로젝트에 들어온 제안서를 확인하세요.</p>
    </div>
</div>

<section class="list-section">
    <div class="list-inner">

        <div class="project-info-card">
            <div class="proj-info-left">
                <h3>{{projects.title}}</h3>
                <div class="meta">
                    <span>{{projects.categoryName}}</span>
                    <span>등록일 {{projects.createdAt}}</span>
                </div>
            </div>
            <div class="proj-info-right">
                <div class="proj-budget">{{projects.budgetMin}}~{{projects.budgetMax}}만원</div>
                <div class="proj-d-day">D-{{projects.dDay}}</div>
            </div>
        </div>

        <div class="bid-count-bar">
            <span class="bid-count">총 <strong>{{bids.size}}</strong>개의 제안서</span>
        </div>

        <div class="bid-list">
            {{#bids}}
            <div class="bid-card {{#isSelected}}selected{{/isSelected}}{{#isRejected}}rejected{{/isRejected}}">
                <div class="bid-avatar">👨‍💻</div>
                <div class="bid-body">
                    <div class="bid-name-wrap">
                        <span class="bid-name">{{expertName}}</span>
                        {{#isPending}}
                        <span class="cert-badge" style="background:rgba(234,88,12,.1); color:#ea580c; border:1px solid rgba(234,88,12,.2); margin-left:8px;">⏳ 검토 대기중</span>
                        {{/isPending}}
                        {{#isSelected}}
                        <span class="cert-badge" style="background:#ecfdf5; color:#059669; border:1px solid #a7f3d0; margin-left:8px;">🎉 최종 낙찰됨</span>
                        {{/isSelected}}
                        {{#isRejected}}
                        <span class="cert-badge" style="background:#fff1f2; color:#e11d48; border:1px solid #fecdd3; margin-left:8px;">❌ 거절됨</span>
                        {{/isRejected}}
                    </div>
                    <div class="bid-content">{{coverLetter}}</div>
                </div>
                <div class="bid-right">
                    <div class="bid-price">{{proposedPrice}}만원</div>
                    <div class="bid-date">{{createdAt}}</div>

                    {{#isSelected}}<span class="selected-badge">✓ 낙찰 완료</span>{{/isSelected}}
                    {{#isRejected}}<span class="rejected-badge">✕ 거절됨</span>{{/isRejected}}

                    {{#isPending}}
                    <button type="button" class="select-btn" onclick="selectBid({{id}})">낙찰 선택</button>
                    <button type="button" class="reject-btn" onclick="rejectBid({{id}})">거절</button>
                    {{/isPending}}
                </div>
            </div>
            {{/bids}}

            {{^bids}}
            <div class="empty-state">
                <p class="empty-msg">아직 들어온 제안서가 없습니다.</p>
            </div>
            {{/bids}}
        </div>
    </div>
</section>

<script>
function selectBid(bidId) {
    if (!confirm("정말 이 전문가를 낙찰하시겠습니까? 낙찰 완료 후 보유 잔액에서 계약금이 자동 차감됩니다.")) return;
    fetch(`/bids/${bidId}/select`, { method: "POST", headers: { "Content-Type": "application/json" } })
        .then(response => {
            if (response.ok) {
                alert("🎉 낙찰 처리가 완료되었습니다!\n계약금이 에스크로로 이체되었습니다.");
                location.href = "/projects";
            } else {
                return response.json().then(data => { alert("낙찰 처리 실패\n" + (data.message || "잠시 후 다시 시도해주세요.")); });
            }
        }).catch(() => alert("서버 통신 중 오류가 발생했습니다."));
}

function rejectBid(bidId) {
    if (!confirm("이 제안서를 거절하시겠습니까?")) return;
    fetch(`/bids/${bidId}/reject`, { method: "DELETE", headers: { "Content-Type": "application/json" } })
        .then(response => {
            if (response.ok) { alert("제안서가 거절되었습니다."); location.reload(); }
            else alert("거절 처리에 실패했습니다.");
        }).catch(() => alert("서버 통신 중 오류가 발생했습니다."));
}
</script>

{{> layout/footer}}
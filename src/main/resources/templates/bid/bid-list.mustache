{{> layout/header}}

<style>
    .page-header { background: #fff; border-bottom: 1px solid #eaecf4; padding: 40px 28px 28px; }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .page-desc { font-size: 14px; color: #9ca3af; }
    .list-section { padding: 36px 28px 80px; }
    .list-inner { max-width: 1140px; margin: 0 auto; }
    .project-info-card { background: #f8f9ff; border: 1.5px solid #e0e8ff; border-radius: 14px; padding: 22px 24px; margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center; }
    .proj-info-left h3 { font-size: 17px; font-weight: 800; color: #1c1e26; margin-bottom: 6px; }
    .proj-info-left .meta { font-size: 13px; color: #9ca3af; display: flex; gap: 14px; }
    .proj-info-right { text-align: right; }
    .proj-budget { font-size: 20px; font-weight: 900; color: #2563eb; }
    .proj-d-day { font-size: 12px; color: #ef4444; font-weight: 700; margin-top: 4px; }
    .bid-count-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .bid-count { font-size: 14px; color: #9ca3af; font-weight: 500; }
    .bid-count strong { color: #1c1e26; font-weight: 700; }
    .bid-list { display: flex; flex-direction: column; gap: 14px; }
    .bid-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 14px; padding: 22px 24px; display: flex; gap: 18px; align-items: flex-start; transition: border-color .2s; }
    .bid-card:hover { border-color: #bfdbfe; }
    .bid-card.selected { border-color: #2563eb; background: #f8f9ff; }
    .bid-avatar { width: 48px; height: 48px; border-radius: 14px; background: #eff6ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .bid-body { flex: 1; }
    .bid-name-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .bid-name { font-size: 15px; font-weight: 800; color: #1c1e26; }
    .cert-badge { font-size: 10px; background: #fffbeb; color: #b45309; border: 1px solid #fde68a; padding: 2px 8px; border-radius: 5px; font-weight: 700; }
    .bid-spec { font-size: 12px; color: #9ca3af; margin-bottom: 10px; }
    .bid-content { font-size: 13px; color: #6b7280; line-height: 1.7; }
    .bid-right { text-align: right; flex-shrink: 0; }
    .bid-price { font-size: 20px; font-weight: 900; color: #2563eb; margin-bottom: 10px; }
    .bid-date { font-size: 11px; color: #c4c9d9; margin-bottom: 14px; }
    .select-btn { padding: 9px 18px; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .select-btn:hover { background: #1d4ed8; }
    .selected-badge { font-size: 12px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 4px 12px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .empty-state { text-align: center; padding: 60px 0; }
    .empty-msg { font-size: 15px; color: #c4c9d9; }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">제안서 목록</h1>
        <p class="page-desc">내 프로젝트에 들어온 제안서를 확인하세요.</p>
    </div>
</div>

<section class="list-section">
    <div class="list-inner">

        <!-- 프로젝트 정보 -->
        <div class="project-info-card">
            <div class="proj-info-left">
                <h3>{{project.title}}</h3>
                <div class="meta">
                    <span>{{project.categoryName}}</span>
                    <span>등록일 {{project.createdAt}}</span>
                </div>
            </div>
            <div class="proj-info-right">
                <div class="proj-budget">{{project.budgetMin}}~{{project.budgetMax}}만원</div>
                <div class="proj-d-day">D-{{project.dDay}}</div>
            </div>
        </div>

        <div class="bid-count-bar">
            <span class="bid-count">총 <strong>{{bidCount}}</strong>개의 제안서</span>
        </div>

        <!-- 제안서 목록 -->
        <div class="bid-list">
            {{#bids}}
            <div class="bid-card {{#isSelected}}selected{{/isSelected}}">
                <div class="bid-avatar">👨‍💻</div>
                <div class="bid-body">
                    <div class="bid-name-wrap">
                        <span class="bid-name">{{expertName}}</span>
                    </div>
                    <div class="bid-content">{{coverLetter}}</div>
                </div>
                <div class="bid-right">
                    <div class="bid-price">{{proposedPrice}}만원</div>
                    <div class="bid-date">{{createdAt}}</div>
                    {{#isSelected}}
                    <span class="selected-badge">✓ 낙찰 완료</span>
                    {{/isSelected}}
                    {{^isSelected}}
                    <form action="/bid/{{id}}/select" method="POST">
                        <button type="submit" class="select-btn">낙찰 선택</button>
                    </form>
                    {{/isSelected}}
                </div>
            </div>
            {{/bids}}

            {{^bids}}
            <div class="empty-state">
                <p class="empty-msg">아직 들어온 제안서가 없습니다.</p>
            </div>
            {{/bids}}
        </div>
    </div>
</section>

{{> layout/footer}}
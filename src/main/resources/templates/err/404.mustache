{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    .err-section {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-height: calc(100vh - 64px); padding: 60px 20px; text-align: center;
    }
    .err-box {
        backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 28px; padding: 60px 56px;
        box-shadow: 0 8px 32px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .err-code { font-size: 96px; font-weight: 900; color: #2563eb; letter-spacing: -4px; line-height: 1; margin-bottom: 8px; }
    .err-title { font-size: 22px; font-weight: 800; color: #1e3a6e; margin: 16px 0 10px; }
    .err-desc { font-size: 14px; color: #4a6fa5; margin-bottom: 32px; line-height: 1.6; }
    .err-btn {
        display: inline-block; padding: 13px 32px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border-radius: 25px; font-size: 14px; font-weight: 700;
        text-decoration: none; box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
    }
    .err-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }
</style>

<section class="err-section">
    <div class="err-box">
        <div class="err-code">404</div>
        <div class="err-title">페이지를 찾을 수 없습니다</div>
        <div class="err-desc">요청하신 페이지가 존재하지 않거나 이동되었습니다.</div>
        <a href="/" class="err-btn">홈으로 돌아가기</a>
    </div>
</section>

{{> layout/footer}}
{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-header {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.75); border-bottom: 1px solid rgba(255,255,255,.6);
        padding: 36px 28px 28px;
    }
    .page-header-inner { max-width: 1140px; margin: 0 auto; }
    .page-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 6px; }
    .page-desc  { font-size: 14px; color: #4a6fa5; }

    .pay-section { padding: 40px 28px 80px; }
    .pay-inner   { max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }

    .balance-card {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        border-radius: 18px; padding: 28px 32px; color: #fff;
        display: flex; justify-content: space-between; align-items: center;
        box-shadow: 0 8px 24px rgba(37,99,235,.3);
    }
    .balance-left .balance-label  { font-size: 13px; font-weight: 600; opacity: .75; margin-bottom: 6px; }
    .balance-left .balance-amount { font-size: 30px; font-weight: 900; letter-spacing: -.5px; }
    .balance-right a {
        display: inline-block; padding: 8px 18px;
        background: rgba(255,255,255,.2); color: #fff; border-radius: 25px;
        font-size: 13px; font-weight: 700; text-decoration: none; transition: background .15s;
    }
    .balance-right a:hover { background: rgba(255,255,255,.35); }

    .pay-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 18px; padding: 36px;
        box-shadow: 0 4px 20px rgba(37,99,235,.07);
    }
    .pay-card-title { font-size: 16px; font-weight: 900; color: #1e3a6e; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(37,99,235,.08); }

    .info-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid rgba(37,99,235,.06); font-size: 14px; }
    .info-row:last-of-type { border-bottom: none; }
    .info-label { color: #4a6fa5; font-weight: 500; }
    .info-value { color: #1e3a6e; font-weight: 700; }
    .info-value.highlight { color: #2563eb; font-size: 22px; font-weight: 900; }
    .divider { border: none; border-top: 1.5px solid rgba(37,99,235,.08); margin: 20px 0; }
    .fee-note { font-size: 12px; color: #93aecf; text-align: right; margin-top: -12px; margin-bottom: 24px; }

    .confirm-btn {
        display: block; width: 100%; padding: 16px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none; border-radius: 25px;
        font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s; text-align: center;
    }
    .confirm-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    .shortage-box {
        background: rgba(254,242,242,.85); border: 1.5px solid #fecaca;
        border-radius: 12px; padding: 18px 20px; margin-bottom: 16px;
    }
    .shortage-title  { font-size: 14px; font-weight: 700; color: #dc2626; margin-bottom: 6px; }
    .shortage-desc   { font-size: 13px; color: #6b7280; }
    .shortage-amount { font-weight: 700; color: #dc2626; }

    .charge-link {
        display: block; width: 100%; padding: 16px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(37,99,235,.3); color: #2563eb;
        border-radius: 25px; font-size: 15px; font-weight: 700; text-align: center; text-decoration: none; transition: all .15s; box-sizing: border-box;
    }
    .charge-link:hover { background: rgba(255,255,255,.9); }

    .pay-notice { font-size: 12px; color: #93aecf; text-align: center; margin-top: 14px; line-height: 1.8; }
    .btn-outline {
        display: block; margin-top: 12px; padding: 13px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 25px;
        font-size: 14px; font-weight: 600; color: #4a6fa5; text-align: center; text-decoration: none; transition: all .15s;
    }
    .btn-outline:hover { background: rgba(255,255,255,.85); }
</style>

<div class="page-header">
    <div class="page-header-inner">
        <h1 class="page-title">에스크로 계약</h1>
        <p class="page-desc">계약금이 잔액에서 차감되어 에스크로로 안전하게 보관됩니다.</p>
    </div>
</div>

<section class="pay-section">
    <div class="pay-inner">

        <div class="balance-card">
            <div class="balance-left">
                <div class="balance-label">현재 잔액</div>
                <div class="balance-amount">{{balance}}원</div>
            </div>
            <div class="balance-right">
                <a href="/charge/form">충전하기</a>
            </div>
        </div>

        <div class="pay-card">
            <div class="pay-card-title">계약 정보 확인</div>

            <div class="info-row">
                <span class="info-label">프로젝트 번호</span>
                <span class="info-value">#{{projectId}}</span>
            </div>
            <div class="info-row">
                <span class="info-label">전문가 ID</span>
                <span class="info-value">#{{expertId}}</span>
            </div>

            <hr class="divider" />

            <div class="info-row">
                <span class="info-label">계약 금액</span>
                <span class="info-value highlight">{{amount}}원</span>
            </div>
            <div class="info-row">
                <span class="info-label">플랫폼 수수료 (10%)</span>
                <span class="info-value">{{platformFee}}원</span>
            </div>
            <div class="info-row">
                <span class="info-label">전문가 수령 예정</span>
                <span class="info-value">{{netAmount}}원</span>
            </div>
            <p class="fee-note">※ 프로젝트 완료 확인 후 전문가에게 지급됩니다</p>

            {{#balanceSufficient}}
            <form action="/payment/escrow" method="post">
                <input type="hidden" name="projectId" value="{{projectId}}" />
                <input type="hidden" name="expertId"  value="{{expertId}}" />
                <input type="hidden" name="amount"    value="{{amount}}" />
                <button type="submit" class="confirm-btn">잔액으로 계약하기 (에스크로 보관)</button>
            </form>
            {{/balanceSufficient}}

            {{#balanceInsufficient}}
            <div class="shortage-box">
                <div class="shortage-title">잔액이 부족합니다</div>
                <div class="shortage-desc">
                    <span class="shortage-amount">{{shortage}}원</span> 이상 충전이 필요합니다.
                </div>
            </div>
            <a href="/charge/form" class="charge-link">충전하러 가기 →</a>
            {{/balanceInsufficient}}

            <a href="javascript:history.back()" class="btn-outline">← 돌아가기</a>
            <p class="pay-notice">
                계약금은 에스크로로 안전하게 보관됩니다.<br>
                프로젝트 완료 확인 전까지 전문가에게 지급되지 않습니다.
            </p>
        </div>

    </div>
</section>

{{> layout/footer}}
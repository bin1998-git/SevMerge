{{>layout/header}}

<style>
    .faq-hero { background:#fff; border-bottom:1px solid #eaecf4; padding:48px 28px 0; }
    .faq-hero-inner { max-width:1140px; margin:0 auto; text-align:center; padding-bottom:36px; }
    .faq-hero-inner h1 { font-size:32px; font-weight:900; color:#1c1e26; letter-spacing:-1px; margin-bottom:10px; }
    .faq-hero-inner p { font-size:14px; color:#6b7280; }

    .faq-section { padding:48px 28px 80px; max-width:880px; margin:0 auto; }

    .faq-write-box { background:#fff; border:1.5px solid #eaecf4; border-radius:16px; padding:32px; margin-bottom:28px; }
    .faq-write-box h2 { font-size:16px; font-weight:900; color:#1c1e26; margin-bottom:18px; }
    .faq-form-group { margin-bottom:14px; }
    .faq-form-group label { display:block; font-size:13px; font-weight:700; color:#374151; margin-bottom:6px; }
    .faq-form-group input,
    .faq-form-group textarea {
        width:100%; box-sizing:border-box; padding:10px 12px;
        border:1.5px solid #eaecf4; border-radius:8px; font-size:13px; color:#1c1e26;
        font-family:inherit;
    }
    .faq-form-group input:focus,
    .faq-form-group textarea:focus { outline:none; border-color:#c7cbe0; }
    .faq-form-group textarea { resize:vertical; line-height:1.6; }

    .faq-submit-btn {
        display:inline-block; padding:10px 22px; border-radius:8px;
        background:#1c1e26; color:#fff; font-size:13px; font-weight:700;
        border:none; cursor:pointer;
    }
    .faq-submit-btn:hover { background:#33363f; }

    .faq-list { background:#fff; border:1.5px solid #eaecf4; border-radius:16px; overflow:hidden; }

    .faq-item { border-bottom:1px solid #eaecf4; }
    .faq-item:last-child { border-bottom:none; }

    .faq-question {
        display:flex; align-items:flex-start; gap:10px; cursor:pointer;
        padding:18px 24px; font-size:14px; font-weight:700; color:#1c1e26;
    }
    .faq-question .badge {
        flex-shrink:0; width:20px; height:20px; border-radius:6px;
        background:#f8f9fc; color:#6b7280; font-size:12px; font-weight:900;
        display:flex; align-items:center; justify-content:center;
    }

    .faq-answer {
        display:none; padding:0 24px 18px 54px;
        font-size:13px; color:#4b5563; line-height:1.9; white-space:pre-line;
    }
    .faq-answer.open { display:block; }

    .faq-empty { text-align:center; font-size:13px; color:#9ca3af; padding:48px 0; }
</style>

<section class="faq-hero">
    <div class="faq-hero-inner">
        <h1>자주 묻는 질문</h1>
        <p>SevMerge 이용 중 자주 묻는 질문을 확인하세요.</p>
    </div>
</section>

<section class="faq-section">

    {{#isAdmin}}
        <div class="faq-write-box">
            <h2>FAQ 등록</h2>
            <form action="/faq" method="post">
                <div class="faq-form-group">
                    <label>질문</label>
                    <input type="text" name="question" placeholder="질문을 입력하세요" required>
                </div>
                <div class="faq-form-group">
                    <label>답변</label>
                    <textarea name="answer" rows="4" placeholder="답변을 입력하세요" required></textarea>
                </div>
                <button type="submit" class="faq-submit-btn">등록하기</button>
            </form>
        </div>
    {{/isAdmin}}

    <div class="faq-list">
        {{#faqList}}
            <div class="faq-item">
                <div class="faq-question" onclick="toggleAnswer(this)">
                    <span class="badge">Q</span> {{question}}
                </div>
                <div class="faq-answer">
                    <span class="badge">A</span> {{answer}}
                </div>
            </div>
        {{/faqList}}

        {{^faqList}}
            <p class="faq-empty">등록된 FAQ가 없습니다.</p>
        {{/faqList}}
    </div>

</section>

<script>
    function toggleAnswer(el) {
        const answer = el.nextElementSibling;
        answer.classList.toggle('open');
    }
</script>

{{>layout/footer}}
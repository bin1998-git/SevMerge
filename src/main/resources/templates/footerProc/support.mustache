<script>
    function selectType(type, el) {
        document.getElementById('partnerShipType').value = type;
        document.querySelectorAll('.type-card').forEach(card => {
            card.classList.remove('active');
        });
        el.classList.add('active');
    }

    function partner(event) {
        event.preventDefault();
        const companyName = document.querySelector('[name="companyName"]').value.trim();
        const managerName = document.querySelector('[name="managerName"]').value.trim();
        const email = document.querySelector('[name="email"]').value.trim();
        const content = document.querySelector('[name="content"]').value.trim();
        const partnerFile = document.querySelector('[name="partnerFile"]').files[0];

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!companyName) { alert("회사명을 입력해 주세요"); return; }
        if (!managerName) { alert("담당자 이름을 적어 주세요"); return; }
        if (!email) { alert("담당자 이메일을 입력해 주세요"); return; }
        if (!emailRegex.test(email)) { alert("올바른 이메일 형식을 입력해 주세요"); return; }
        if (!content) { alert("제휴 내용을 입력해 주세요"); return; }
        if (!partnerFile) { alert("파일을 올려 주세요"); return; }

        if (!confirm("제휴문의를 보내시겠습니까?")) return;
        alert("제휴문의를 메일로 보냈습니다.");
        event.target.closest('form').submit();
    }
</script>


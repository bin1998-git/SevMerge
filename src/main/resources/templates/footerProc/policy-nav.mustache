<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
    }

    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .policy-hero {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.55);
        border-bottom: 1px solid rgba(255,255,255,.7);
        padding:48px 28px 0;
        position: relative; z-index: 1;
    }
    .policy-hero-inner { max-width:1140px; margin:0 auto; text-align:center; padding-bottom:36px; }
    .policy-hero-inner h1 { font-size:32px; font-weight:900; color:#1c1e26; letter-spacing:-1px; margin-bottom:10px; }
    .policy-hero-inner p { font-size:14px; color:#6b7280; margin-bottom:28px; }

    .policy-tabs { display:flex; justify-content:center; gap:8px; flex-wrap:wrap; }

    .policy-section { padding:48px 28px 80px; max-width:880px; margin:0 auto; position: relative; z-index: 1; }

    .policy-doc {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 16px; padding: 40px;
        box-shadow: 0 8px 32px rgba(37,99,235,.06), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .policy-doc h2 { font-size:18px; font-weight:900; color:#1c1e26; margin-bottom:6px; }
    .policy-doc .policy-updated { font-size:12px; color:#9ca3af; font-weight:600; margin-bottom:28px; }

    .policy-article { margin-bottom:24px; }
    .policy-article-title { font-size:14px; font-weight:700; color:#1c1e26; margin-bottom:8px; }
    .policy-article-body { font-size:13px; color:#4b5563; line-height:1.9; }
    .policy-article-body p { margin-bottom:8px; }
    .policy-article-body ol, .policy-article-body ul { margin:8px 0 8px 18px; }
    .policy-article-body li { margin-bottom:4px; }

    .policy-table { width:100%; border-collapse:collapse; margin:12px 0; font-size:12px; }
    .policy-table th, .policy-table td { border:1px solid rgba(255,255,255,.6); padding:8px 10px; text-align:left; }
    .policy-table th { background:rgba(255,255,255,.5); font-weight:700; color:#374151; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>

<section class="policy-hero">
    <div class="policy-hero-inner">
        <h1>약관 및 정책</h1>
        <p>SevMerge 서비스 이용을 위한 약관과 정책을 확인하세요.</p>
        <div class="policy-tabs">
            <a href="/policys/terms" class="tab {{#isTerms}}active{{/isTerms}}">이용약관</a>
            <a href="/policys/privacy" class="tab {{#isPrivacy}}active{{/isPrivacy}}">개인정보처리방침</a>
            <a href="/policys/ad" class="tab {{#isAd}}active{{/isAd}}">광고방침</a>
            <a href="/policys/operation" class="tab {{#isOperation}}active{{/isOperation}}">운영정책</a>
        </div>
    </div>
</section>
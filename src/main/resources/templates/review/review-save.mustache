{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
        line-height: 1.6;
    }

    /* ══ 배경 글로우 ══ */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 {
        width: 600px; height: 600px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%);
        top: -150px; left: -150px;
    }
    .bg-glow-2 {
        width: 500px; height: 500px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%);
        bottom: 10%; right: -100px;
    }
    .bg-glow-3 {
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%);
        top: 40%; left: 30%;
    }

    .save-section { padding: 52px 28px 80px; position: relative; z-index: 1; }
    .save-inner { max-width: 680px; margin: 0 auto; }

    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #9ca3af; }

    /* 전문가 + 프로젝트 미리보기 */
    .preview-box {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(239,246,255,.55);
        border: 1.5px solid rgba(191,219,254,.5);
        border-radius: 18px; padding: 20px 22px; margin-bottom: 32px;
        display: flex; gap: 14px; align-items: center;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .preview-avatar {
        width: 48px; height: 48px; border-radius: 14px;
        background: rgba(239,246,255,.8); border: 1px solid rgba(191,219,254,.6);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .preview-info .label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
    .preview-info .name { font-size: 15px; font-weight: 800; color: #1c1e26; margin-bottom: 2px; }
    .preview-info .sub { font-size: 12px; color: #9ca3af; }

    /* 폼 카드 */
    .form-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 24px; padding: 32px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .save-form { display: flex; flex-direction: column; gap: 24px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .required { color: #ef4444; margin-left: 2px; }

    /* 별점 선택 */
    .star-wrap { display: flex; gap: 8px; }
    .star-btn { font-size: 32px; color: #e2e5ef; cursor: pointer; background: none; border: none; padding: 0; transition: color .1s; line-height: 1; }
    .star-btn:hover,
    .star-btn.active { color: #f59e0b; }
    .star-hint { font-size: 12px; color: #9ca3af; margin-top: 6px; }

    /* 텍스트에어리어 */
    .form-textarea {
        padding: 13px 16px;
        background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 12px; font-size: 14px; font-family: inherit; color: #1c1e26;
        outline: none; resize: vertical; min-height: 200px; line-height: 1.7;
        backdrop-filter: blur(4px);
        transition: border-color .15s, background .15s;
    }
    .form-textarea::placeholder { color: #c4c9d9; }
    .form-textarea:focus { border-color: #2563eb; background: rgba(255,255,255,.9); }

    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 4px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: #2563eb; color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,.3); }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); }
    .btn-outline {
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #4b5563;
    }
    .btn-outline:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }
    .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            <h1 class="save-title">리뷰 작성</h1>
            <p class="save-desc">솔직한 리뷰를 남겨주세요.</p>
        </div>

        <!-- 미리보기 -->
        <div class="preview-box">
            <div class="preview-avatar">👨‍💻</div>
            <div class="preview-info">
                <div class="label">리뷰 대상 {{#targeter.isExpert}}전문가{{/targeter.isExpert}}{{^target.isExpert}}의뢰인{{/target.isExpert}}</div>
                <div class="name">{{targeter.name}}</div>
            </div>
        </div>

        <div class="form-card">
            <form class="save-form" action="/reviews/save" method="POST">

                <input type="hidden" name="reviewerId" value="{{reviewer.id}}" />
                <input type="hidden" name="targetId" value="{{targeter.id}}" />
                <input type="hidden" name="projectId" value="{{projectId}}" />
                <input type="hidden" name="rating" id="ratingInput" value="0" />

                <!-- 별점 -->
                <div class="form-group">
                    <label class="form-label">별점 <span class="required">*</span></label>
                    <div class="star-wrap">
                        <button type="button" class="star-btn" onclick="setRating(1)">★</button>
                        <button type="button" class="star-btn" onclick="setRating(2)">★</button>
                        <button type="button" class="star-btn" onclick="setRating(3)">★</button>
                        <button type="button" class="star-btn" onclick="setRating(4)">★</button>
                        <button type="button" class="star-btn" onclick="setRating(5)">★</button>
                    </div>
                    <span class="star-hint" id="starHint">별점을 선택하세요</span>
                </div>

                <!-- 리뷰 내용 -->
                <div class="form-group">
                    <label class="form-label">리뷰 내용 <span class="required">*</span></label>
                    <textarea name="content" class="form-textarea" placeholder="전문가와의 작업 경험을 자세히 작성해주세요.&#10;&#10;- 커뮤니케이션은 어땠나요?&#10;- 결과물 퀄리티는 만족스러웠나요?&#10;- 일정 준수는 잘 되었나요?"></textarea>
                </div>

                <div class="form-btns">
                    <a href="/mypage" class="btn btn-outline">취소</a>
                    <button type="submit" class="btn btn-primary btn-lg">리뷰 등록</button>
                </div>

            </form>
        </div>
    </div>
</section>

<script>
    const hints = ['', '별로예요', '조금 아쉬워요', '괜찮아요', '좋아요', '최고예요!'];
    function setRating(val) {
        document.getElementById('ratingInput').value = val;
        document.getElementById('starHint').textContent = hints[val];
        document.querySelectorAll('.star-btn').forEach((btn, i) => {
            btn.classList.toggle('active', i < val);
        });
    }
</script>

{{> layout/footer}}

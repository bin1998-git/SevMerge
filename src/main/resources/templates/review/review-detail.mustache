{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
        line-height: 1.6;
    }

    /* ══ 배경 글로우 ══ */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 {
        width: 600px; height: 600px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%);
        top: -150px; left: -150px;
    }
    .bg-glow-2 {
        width: 500px; height: 500px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%);
        bottom: 10%; right: -100px;
    }
    .bg-glow-3 {
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%);
        top: 40%; left: 30%;
    }

    .detail-section { padding: 52px 28px 80px; position: relative; z-index: 1; }
    .detail-inner { max-width: 760px; margin: 0 auto; }
    .detail-nav { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #9ca3af; margin-bottom: 32px; }
    .detail-nav a { color: #9ca3af; text-decoration: none; transition: color .15s; }
    .detail-nav a:hover { color: #2563eb; }

    .review-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 24px; padding: 32px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .review-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        margin-bottom: 24px; padding-bottom: 20px;
        border-bottom: 1px solid rgba(255,255,255,.6);
    }
    .review-author-wrap { display: flex; align-items: center; gap: 14px; }
    .review-avatar {
        width: 48px; height: 48px; border-radius: 14px;
        background: rgba(243,244,248,.8); backdrop-filter: blur(4px);
        border: 1px solid rgba(255,255,255,.7);
        display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0;
    }
    .review-author-info .author { font-size: 15px; font-weight: 800; color: #1c1e26; margin-bottom: 3px; }
    .review-author-info .role { font-size: 12px; color: #9ca3af; }
    .review-rating-wrap { text-align: right; }
    .review-stars { color: #f59e0b; font-size: 22px; margin-bottom: 4px; }
    .review-date { font-size: 12px; color: #c4c9d9; }

    .target-box {
        backdrop-filter: blur(8px);
        background: rgba(239,246,255,.6);
        border: 1px solid rgba(191,219,254,.5);
        border-radius: 14px; padding: 16px 18px; margin-bottom: 24px;
        display: flex; align-items: center; gap: 14px;
    }
    .target-avatar {
        width: 42px; height: 42px; border-radius: 12px;
        background: rgba(239,246,255,.8); border: 1px solid rgba(191,219,254,.6);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
    }
    .target-label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 3px; }
    .target-name { font-size: 14px; font-weight: 700; color: #1c1e26; }
    .target-role { font-size: 12px; color: #9ca3af; }

    .review-content { font-size: 15px; color: #374151; line-height: 1.9; margin-bottom: 28px; white-space: pre-wrap; }
    .review-actions {
        display: flex; justify-content: space-between; align-items: center;
        padding-top: 20px; border-top: 1px solid rgba(255,255,255,.6);
    }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-outline {
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #4b5563;
    }
    .btn-outline:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }
    .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: 7px; }
    .btn-danger {
        backdrop-filter: blur(8px);
        background: rgba(255,243,243,.7); color: #ef4444; border: 1.5px solid rgba(254,202,202,.7);
    }
    .btn-danger:hover { background: rgba(255,243,243,.95); }
    .owner-btns { display: flex; gap: 8px; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="detail-section">
    <div class="detail-inner">

        <div class="detail-nav">
            <a href="/mypage?tab=reviews">← 내 리뷰 목록</a>
            <span>›</span>
            <span>리뷰 상세</span>
        </div>

        <div class="review-card">

            <!-- 작성자 + 별점 -->
            <div class="review-header">
                <div class="review-author-wrap">
                    <div class="review-avatar">👤</div>
                    <div class="review-author-info">
                        <div class="author">{{review.reviewerName}}</div>
                        <div class="role">작성자</div>
                    </div>
                </div>
                <div class="review-rating-wrap">
                    <div class="review-stars">★ {{review.countStar}}</div>
                    <div class="review-date">{{review.createdAt}}</div>
                </div>
            </div>

            <!-- 리뷰 대상자 -->
            <div class="target-box">
                <div class="target-avatar">👤</div>
                <div>
                    <div class="target-label">리뷰 대상</div>
                    <div class="target-name">{{review.targeterName}}</div>
                </div>
            </div>

            <!-- 본문 -->
            <div class="review-content">{{review.content}}</div>

            <!-- 액션 -->
            <div class="review-actions">
                <a href="/mypage?tab=reviews" class="btn btn-outline">← 목록으로</a>
                {{#isOwner}}
                    <div class="owner-btns">
                        <a href="/reviews/{{review.id}}/edit" class="btn btn-outline btn-sm">수정</a>
                        <form action="/reviews/{{review.id}}/delete" method="POST" style="display:inline;">
                            <button type="submit" class="btn btn-sm btn-danger">삭제</button>
                        </form>
                    </div>
                {{/isOwner}}
            </div>

        </div>
    </div>
</section>

{{> layout/footer}}

{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }

    .detail-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* 헤더 */
    .detail-header {
        padding: 28px 36px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08);
        flex-shrink: 0;
    }
    .detail-header-top {
        display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
        margin-bottom: 14px;
    }
    .detail-author-wrap { display: flex; align-items: center; gap: 14px; }
    .detail-avatar {
        width: 48px; height: 48px; border-radius: 50%;
        background: rgba(37,99,235,.1); border: 1.5px solid rgba(37,99,235,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; font-weight: 900; color: #2563eb; flex-shrink: 0;
    }
    .detail-author-name { font-size: 17px; font-weight: 800; color: #1e3a6e; margin-bottom: 3px; }
    .detail-author-sub { font-size: 12px; color: #93aecf; }

    .detail-star-wrap { text-align: right; }
    .detail-stars { font-size: 24px; color: #f59e0b; margin-bottom: 4px; }
    .detail-date { font-size: 12px; color: #93aecf; }

    .detail-header-actions { display: flex; gap: 8px; flex-shrink: 0; }
    .btn-back {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; transition: all .15s;
    }
    .btn-back:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); }
    .btn-edit {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; transition: all .15s;
    }
    .btn-edit:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .btn-delete {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 18px; border-radius: 20px; font-size: 13px; font-weight: 700;
        background: rgba(255,243,243,.8); border: 1.5px solid #fecaca; color: #ef4444;
        cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .btn-delete:hover { background: #fff0f0; border-color: #ef4444; }

    /* 본문 */
    .detail-body { flex: 1; padding: 28px 36px; overflow-y: auto; display: flex; flex-direction: column; gap: 24px; }

    .target-box {
        backdrop-filter: blur(8px);
        background: rgba(239,246,255,.6);
        border: 1px solid rgba(191,219,254,.5);
        border-radius: 14px; padding: 16px 20px;
        display: flex; align-items: center; gap: 14px;
    }
    .target-avatar {
        width: 40px; height: 40px; border-radius: 12px;
        background: rgba(239,246,255,.8); border: 1px solid rgba(191,219,254,.6);
        display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;
    }
    .target-label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 3px; }
    .target-name { font-size: 14px; font-weight: 700; color: #1e3a6e; }

    .divider { height: 1px; background: rgba(37,99,235,.07); }

    .review-content { font-size: 15px; color: #2d4a7a; line-height: 1.9; white-space: pre-wrap; min-height: 120px; }

    @media (max-width: 640px) {
        .page-wrap { padding: 12px 12px 16px; }
        .detail-header { padding: 20px 18px 16px; }
        .detail-body { padding: 20px 18px; }
        .detail-header-top { flex-direction: column; gap: 12px; }
    }
</style>

<section class="page-wrap">
    <div class="detail-card">

        <!-- 헤더 -->
        <div class="detail-header">
            <div class="detail-header-top">
                <div class="detail-author-wrap">
                    <div class="detail-avatar" id="reviewerAvatar">{{review.reviewerName}}</div>
                    <div>
                        <div class="detail-author-name">{{review.reviewerName}}</div>
                        <div class="detail-author-sub">작성자</div>
                    </div>
                </div>
                <div style="display:flex;align-items:flex-start;gap:12px;">
                    <div class="detail-star-wrap">
                        <div class="detail-stars">★ {{review.countStar}}</div>
                        <div class="detail-date">{{review.createdAt}}</div>
                    </div>
                    <div class="detail-header-actions">
                        {{#isOwner}}
                            <a href="/reviews/{{review.id}}/edit" class="btn-edit">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm17.71-10.42a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
                                수정
                            </a>
                            <form action="/reviews/{{review.id}}/delete" method="POST" style="display:inline;margin:0;" onsubmit="return confirm('리뷰를 삭제하시겠습니까?');">
                                <button type="submit" class="btn-delete">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                                    삭제
                                </button>
                            </form>
                        {{/isOwner}}
                        <a href="/mypage?tab=reviews" class="btn-back">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                            목록으로
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 본문 -->
        <div class="detail-body">

            <!-- 리뷰 대상자 -->
            <div class="target-box">
                <div class="target-avatar">👤</div>
                <div>
                    <div class="target-label">리뷰 대상</div>
                    <div class="target-name">{{review.targeterName}}</div>
                </div>
            </div>

            <div class="divider"></div>

            <!-- 리뷰 본문 -->
            <div class="review-content">{{review.content}}</div>

        </div>

    </div>
</section>

<script>
    const el = document.getElementById('reviewerAvatar');
    if (el) {
        const t = el.textContent.trim();
        el.textContent = t ? t.charAt(0).toUpperCase() : '?';
    }
</script>

{{> layout/footer}}
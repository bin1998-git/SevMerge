{{> layout/header}}

<style>
    .detail-section { padding: 52px 28px 80px; }
    .detail-inner { max-width: 760px; margin: 0 auto; }
    .detail-nav { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #9ca3af; margin-bottom: 32px; }
    .detail-nav a { color: #9ca3af; text-decoration: none; }
    .detail-nav a:hover { color: #2563eb; }
    /* 리뷰 카드 */
    .review-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 18px; padding: 32px; }
    .review-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid #f3f4f8; }
    .review-author-wrap { display: flex; align-items: center; gap: 14px; }
    .review-avatar { width: 48px; height: 48px; border-radius: 14px; background: #f3f4f8; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .review-author-info .author { font-size: 15px; font-weight: 800; color: #1c1e26; margin-bottom: 3px; }
    .review-author-info .project { font-size: 12px; color: #9ca3af; }
    .review-rating-wrap { text-align: right; }
    .review-stars { color: #f59e0b; font-size: 22px; letter-spacing: 2px; margin-bottom: 4px; }
    .review-date { font-size: 12px; color: #c4c9d9; }
    /* 대상 전문가 */
    .expert-box { background: #f8f9ff; border: 1px solid #e0e8ff; border-radius: 12px; padding: 16px 18px; margin-bottom: 24px; display: flex; align-items: center; gap: 14px; }
    .expert-avatar { width: 42px; height: 42px; border-radius: 12px; background: #eff6ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .expert-label { font-size: 11px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 3px; }
    .expert-name { font-size: 14px; font-weight: 700; color: #1c1e26; }
    .expert-career { font-size: 12px; color: #9ca3af; }
    /* 본문 */
    .review-content { font-size: 15px; color: #374151; line-height: 1.9; margin-bottom: 28px; white-space: pre-wrap; }
    /* 액션 */
    .review-actions { display: flex; justify-content: space-between; align-items: center; padding-top: 20px; border-top: 1px solid #f3f4f8; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-outline { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: 7px; }
    .btn-danger { background: #fff3f3; color: #ef4444; border: 1.5px solid #fecaca; }
    .owner-btns { display: flex; gap: 8px; }
</style>

<section class="detail-section">
    <div class="detail-inner">

        <div class="detail-nav">
            <a href="/experts/{{review.expertProfile.id}}">전문가 프로필</a>
            <span>›</span>
            <span>리뷰 상세</span>
        </div>

        <div class="review-card">
            <!-- 작성자 + 별점 -->
            <div class="review-header">
                <div class="review-author-wrap">
                    <div class="review-avatar">👤</div>
                    <div class="review-author-info">
                        <div class="author">{{review.member.name}}</div>
                        <div class="project">프로젝트: {{!review.project.title}}</div>
                    </div>
                </div>
                <div class="review-rating-wrap">
                    <div class="review-stars">★★★★★</div>
                    <div class="review-date">{{review.createdAt}}</div>
                </div>
            </div>

            <!-- 대상 전문가 -->
            <div class="expert-box">
                <div class="expert-avatar">👨‍💻</div>
                <div>
                    <div class="expert-label">리뷰 대상 전문가</div>
                    <div class="expert-name">{{review.expertProfile.member.name}}</div>
                    <div class="expert-career">{{review.expertProfile.career}}</div>
                </div>
            </div>

            <!-- 본문 -->
            <div class="review-content">{{review.content}}</div>

            <!-- 액션 -->
            <div class="review-actions">
                <a href="/experts/{{review.expertProfile.id}}" class="btn btn-outline">← 전문가 프로필</a>
                {{#isOwner}}
                <div class="owner-btns">
                    <a href="/reviews/{{review.id}}/edit" class="btn btn-outline btn-sm">수정</a>
                    <form action="/reviews/{{review.id}}/delete" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">삭제</button>
                    </form>
                </div>
                {{/isOwner}}
            </div>
        </div>

    </div>
</section>

{{> layout/footer}}

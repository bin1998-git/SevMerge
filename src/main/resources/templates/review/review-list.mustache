{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }

    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08);
        flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc { font-size: 13px; color: #4a6fa5; }

    .review-summary {
        display: flex; align-items: center; gap: 28px;
        padding: 14px 32px;
        border-bottom: 1px solid rgba(37,99,235,.06);
        background: rgba(255,255,255,.25); flex-shrink: 0;
    }
    .summary-circle {
        width: 56px; height: 56px; border-radius: 50%;
        border: 2px solid #2563eb;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        background: rgba(255,255,255,.65); backdrop-filter: blur(8px); flex-shrink: 0;
    }
    .summary-circle .val { font-size: 18px; font-weight: 900; color: #1e3a6e; line-height: 1; }
    .summary-circle .sub { font-size: 9px; color: #93aecf; }
    .summary-divider { width: 1px; height: 36px; background: rgba(37,99,235,.1); }
    .summary-info .label { font-size: 13px; color: #4a6fa5; }
    .summary-info .label strong { color: #1e3a6e; font-weight: 700; }
    .summary-info .count { font-size: 12px; color: #93aecf; margin-top: 2px; }

    .table-head {
        display: grid; grid-template-columns: 48px 1fr 120px 100px 130px;
        gap: 16px; padding: 10px 32px;
        background: rgba(255,255,255,.3);
        border-bottom: 1px solid rgba(37,99,235,.06);
        font-size: 12px; font-weight: 700; color: #4a6fa5;
        flex-shrink: 0;
    }

    .table-body { flex: 1; overflow-y: auto; }

    .review-row {
        display: grid; grid-template-columns: 48px 1fr 120px 100px 130px;
        gap: 16px; padding: 16px 32px;
        border-bottom: 1px solid rgba(37,99,235,.05);
        align-items: center; transition: background .12s;
    }
    .review-row:last-child { border-bottom: none; }
    .review-row:hover { background: rgba(255,255,255,.4); }

    .reviewer-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(37,99,235,.1); border: 1.5px solid rgba(37,99,235,.15);
        display: flex; align-items: center; justify-content: center;
        font-size: 14px; font-weight: 900; color: #2563eb; flex-shrink: 0;
    }
    .review-content-text {
        font-size: 14px; font-weight: 500; color: #1e3a6e;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .review-reviewer-name { font-size: 12px; color: #93aecf; margin-top: 3px; }
    .review-name-cell { font-size: 13px; color: #4a6fa5; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .review-stars { font-size: 14px; color: #f59e0b; text-align: center; }
    .review-date { font-size: 12px; color: #93aecf; }

    .empty-state { text-align: center; padding: 60px 0; font-size: 14px; color: #93aecf; }

    .board-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 32px 20px;
        border-top: 1px solid rgba(37,99,235,.06); flex-shrink: 0;
    }
    .board-total { font-size: 13px; color: #4a6fa5; font-weight: 500; }
    .board-total strong { color: #1e3a6e; font-weight: 700; }
    .paging { display: flex; align-items: center; gap: 8px; }
    .page-btn {
        padding: 8px 18px; border-radius: 10px; font-size: 13px; font-weight: 600;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; display: inline-flex; align-items: center;
        transition: all .15s;
    }
    .page-btn:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; }

    @media (max-width: 768px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .review-summary, .table-head, .review-row, .board-footer { padding-left: 18px; padding-right: 18px; }
        .table-head, .review-row { grid-template-columns: 36px 1fr 80px; }
        .review-name-cell, .review-date { display: none; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">받은 리뷰</h1>
                <p class="board-desc">{{sessionUser.name}}님이 받은 리뷰 목록입니다.</p>
            </div>
        </div>

        <!-- 요약 통계 -->
        <div class="review-summary">
            <div class="summary-circle">
                <div class="val">{{avgStar}}</div>
                <div class="sub">/ 5.0</div>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-info">
                <div class="label">평균 별점 <strong>{{avgStar}}점</strong></div>
                <div class="count">총 {{totalReviews}}개 리뷰</div>
            </div>
        </div>

        <!-- 테이블 헤더 -->
        <div class="table-head">
            <div></div>
            <div>리뷰 내용</div>
            <div>작성자</div>
            <div style="text-align:center;">별점</div>
            <div>작성일</div>
        </div>

        <!-- 리뷰 목록 -->
        <div class="table-body">
            {{#reviews}}
                <div class="review-row">
                    <div class="reviewer-avatar" data-name="{{reviewerName}}">{{reviewerName}}</div>
                    <div>
                        <div class="review-content-text">{{content}}</div>
                    </div>
                    <span class="review-name-cell">{{reviewerName}}</span>
                    <span class="review-stars">{{star}}</span>
                    <span class="review-date">{{createdAt}}</span>
                </div>
            {{/reviews}}
            {{^reviews}}
                <div class="empty-state">아직 등록된 리뷰가 없습니다.</div>
            {{/reviews}}
        </div>

        <!-- 푸터: 건수 + 페이지네이션 -->
        <div class="board-footer">
            <span class="board-total">전체 <strong>{{totalReviews}}</strong>건</span>
            <div class="paging">
                {{#prevPage}}<a href="/reviews/my?page={{prevPage}}" class="page-btn">이전</a>{{/prevPage}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#nextPage}}<a href="/reviews/my?page={{nextPage}}" class="page-btn">다음</a>{{/nextPage}}
            </div>
        </div>

    </div>
</section>

<script>
    document.querySelectorAll('.reviewer-avatar').forEach(el => {
        const t = el.textContent.trim();
        el.textContent = t ? t.charAt(0).toUpperCase() : '?';
    });
</script>

{{> layout/footer}}
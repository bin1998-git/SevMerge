{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
        line-height: 1.6;
    }

    /* ══ 배경 글로우 ══ */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 {
        width: 600px; height: 600px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%);
        top: -150px; left: -150px;
    }
    .bg-glow-2 {
        width: 500px; height: 500px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%);
        bottom: 10%; right: -100px;
    }
    .bg-glow-3 {
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%);
        top: 40%; left: 30%;
    }

    /* ── 탭바 ── */
    .dash-tabs-bar {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.55);
        border-bottom: 1.5px solid rgba(255,255,255,.7);
        position: sticky; top: 64px; z-index: 90;
    }
    .dash-tabs-inner { max-width: 1200px; margin: 0 auto; padding: 0 28px; display: flex; }
    .dash-tab {
        padding: 13px 20px; font-size: 13px; font-weight: 600; color: #6b7280;
        border-bottom: 2px solid transparent; margin-bottom: -2px; white-space: nowrap;
        transition: color .15s, border-color .15s;
    }
    .dash-tab:hover { color: #1c1e26; border-color: rgba(255,255,255,.6); }
    .dash-tab.active { color: #2563eb; border-color: #2563eb; }

    /* ── 본문 ── */
    .page-section { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .page-inner { max-width: 1200px; margin: 0 auto; }

    /* ── 요약 헤더 ── */
    .review-summary {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 20px; padding: 28px 32px; margin-bottom: 24px;
        display: flex; align-items: center; gap: 40px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .summary-score { text-align: center; }
    .summary-count { font-size: 13px; color: #9ca3af; font-weight: 500; }
    .summary-divider { width: 1px; height: 72px; background: rgba(255,255,255,.6); }
    .summary-label { font-size: 14px; color: #6b7280; font-weight: 500; }
    .summary-label strong { color: #1c1e26; font-weight: 800; }

    /* ── 섹션 헤더 ── */
    .section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .section-title { font-size: 18px; font-weight: 800; color: #1c1e26; }

    /* ── 리뷰 카드 ── */
    .review-list { display: flex; flex-direction: column; gap: 16px; }
    .review-card {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; overflow: hidden;
        box-shadow: 0 4px 16px rgba(37,99,235,.05);
        transition: all .2s;
    }
    .review-card:hover { border-color: #93c5fd; box-shadow: 0 8px 28px rgba(37,99,235,.1); transform: translateY(-2px); background: rgba(255,255,255,.8); }
    .review-card-body { padding: 24px 28px; }
    .review-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
    .reviewer-info { display: flex; align-items: center; gap: 12px; }
    .reviewer-avatar {
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(239,246,255,.9); border: 1px solid rgba(191,219,254,.7);
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
        backdrop-filter: blur(4px);
    }
    .reviewer-name { font-size: 14px; font-weight: 700; color: #1c1e26; }
    .reviewer-date { font-size: 12px; color: #9ca3af; margin-top: 2px; }
    .review-stars { font-size: 18px; color: #f59e0b; }
    .review-content { font-size: 14px; color: #4b5563; line-height: 1.8; }

    /* ── 댓글(답글) 영역 ── */
    .reply-area {
        backdrop-filter: blur(8px);
        background: rgba(176,200,232,.25);
        border-top: 1px solid rgba(255,255,255,.6);
        padding: 18px 28px;
    }
    .reply-label { font-size: 12px; font-weight: 700; color: #9ca3af; margin-bottom: 10px; }
    .reply-form { display: flex; gap: 10px; }
    .reply-input {
        flex: 1; padding: 10px 14px;
        background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 8px; font-size: 13px; font-family: inherit; color: #1c1e26;
        outline: none; backdrop-filter: blur(4px); transition: border-color .15s;
    }
    .reply-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); }
    .reply-input::placeholder { color: #c4c9d9; }
    .btn-reply {
        padding: 10px 18px; background: #2563eb; color: #fff; border: none;
        border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
        font-family: inherit; white-space: nowrap;
        box-shadow: 0 4px 12px rgba(37,99,235,.3); transition: all .15s;
    }
    .btn-reply:hover { background: #1d4ed8; transform: translateY(-1px); }

    /* ── 빈 상태 ── */
    .empty-box {
        backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; text-align: center; padding: 80px 0;
        box-shadow: 0 4px 16px rgba(37,99,235,.05);
    }
    .empty-icon { font-size: 40px; margin-bottom: 14px; }
    .empty-msg { font-size: 14px; color: #c4c9d9; margin-bottom: 6px; }
    .empty-sub { font-size: 12px; color: #d1d5db; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="page-section">
    <div class="page-inner">

        <!-- 요약 통계 -->
        <div class="review-summary">
            <div class="summary-score">
                <div style="width:90px; height:90px; border-radius:50%; border: 2px solid #2563eb; display:flex; flex-direction:column; align-items:center; justify-content:center; margin:0 auto; background:rgba(255,255,255,.6); backdrop-filter:blur(8px);">
                    <div style="font-size:30px; font-weight:900; color:#1c1e26; letter-spacing:-1px; line-height:1;">{{avgStar}}</div>
                    <div style="font-size:10px; color:#9ca3af; margin-top:2px;">/ 5.0</div>
                </div>
                <div class="summary-count" style="margin-top:10px;">총 {{reviews.size}}개 리뷰</div>
            </div>
            <div class="summary-divider"></div>
            <div>
                <div class="summary-label">전문가 <strong>{{sessionUser.name}}</strong>님이 받은 리뷰 목록입니다.</div>
                <div class="summary-label" style="margin-top:6px;color:#9ca3af;font-size:13px;">성실한 프로젝트 수행이 높은 평점으로 이어집니다.</div>
            </div>
        </div>

        <!-- 리뷰 목록 -->
        <div class="section-head">
            <h2 class="section-title">⭐ 받은 리뷰</h2>
        </div>

        <div class="review-list">

            {{#reviews}}
                <div class="review-card">
                    <div class="review-card-body">
                        <div class="review-header">
                            <div class="reviewer-info">
                                <div class="reviewer-avatar">👤</div>
                                <div>
                                    <div class="reviewer-name">{{reviewerName}}</div>
                                    <div class="reviewer-date">{{createdAt}}</div>
                                </div>
                            </div>
                            <div class="review-stars">{{star}}</div>
                        </div>
                        <p class="review-content">{{content}}</p>
                    </div>
                </div>
            {{/reviews}}

            {{^reviews}}
                <div class="empty-box">
                    <div class="empty-icon">📭</div>
                    <div class="empty-msg">아직 등록된 리뷰가 없습니다.</div>
                    <div class="empty-sub">첫 번째 리뷰를 기다리고 있어요!</div>
                </div>
            {{/reviews}}

        </div>
    </div>
</section>

{{> layout/footer}}

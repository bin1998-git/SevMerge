{{> layout/header}}

<style>
    /* ── 본문 ── */
    .page-section { padding: 48px 28px 80px; }
    .page-inner   { max-width: 560px; margin: 0 auto; }

    /* ── 잔액 카드 ── */
    .balance-card { background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 16px; padding: 24px 28px; margin-bottom: 28px; display: flex; align-items: center; justify-content: space-between; }
    .balance-label { font-size: 13px; font-weight: 600; color: #3b82f6; }
    .balance-amount { font-size: 28px; font-weight: 900; color: #1d4ed8; letter-spacing: -1px; }

    /* ── 폼 카드 ── */
    .form-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 16px; padding: 32px 32px; }
    .form-title { font-size: 20px; font-weight: 900; color: #1c1e26; letter-spacing: -.5px; margin-bottom: 28px; }

    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-size: 13px; font-weight: 700; color: #374151; margin-bottom: 7px; }
    .form-input  { width: 100%; box-sizing: border-box; padding: 11px 14px; border: 1.5px solid #e2e5ef; border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input:focus { border-color: #2563eb; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-select { width: 100%; box-sizing: border-box; padding: 11px 14px; border: 1.5px solid #e2e5ef; border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26; background: #fff; outline: none; cursor: pointer; transition: border-color .15s; }
    .form-select:focus { border-color: #2563eb; }
    .form-hint { font-size: 12px; color: #9ca3af; margin-top: 5px; }

    /* ── 빠른 금액 ── */
    .quick-btns { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
    .quick-btn { padding: 7px 16px; background: #f1f5f9; border: 1.5px solid #e2e5ef; border-radius: 8px; font-size: 13px; font-weight: 600; color: #374151; cursor: pointer; font-family: inherit; transition: all .15s; }
    .quick-btn:hover { background: #eff6ff; border-color: #93c5fd; color: #2563eb; }

    /* ── 경고 박스 ── */
    .notice-box { background: #fffbeb; border: 1px solid #fde68a; border-radius: 10px; padding: 14px 16px; margin-bottom: 24px; font-size: 13px; color: #92400e; line-height: 1.6; }
    .notice-box strong { font-weight: 700; }

    /* ── 제출 버튼 ── */
    .submit-btn { width: 100%; padding: 14px; background: #2563eb; color: #fff; border: none; border-radius: 10px; font-size: 16px; font-weight: 800; cursor: pointer; font-family: inherit; transition: background .15s; margin-top: 8px; }
    .submit-btn:hover { background: #1d4ed8; }
    .submit-btn:disabled { background: #c4c9d9; cursor: not-allowed; }

    /* ── 하단 링크 ── */
    .bottom-link { text-align: center; margin-top: 20px; font-size: 13px; color: #9ca3af; }
    .bottom-link a { color: #2563eb; font-weight: 600; text-decoration: none; }
</style>

<section class="page-section">
    <div class="page-inner">

        <!-- 현재 잔액 -->
        <div class="balance-card">
            <div>
                <div class="balance-label">출금 가능 잔액</div>
                <div class="balance-amount">{{balance}}원</div>
            </div>
            <span style="font-size:32px;">💰</span>
        </div>

        <!-- 출금 폼 -->
        <div class="form-card">
            <h1 class="form-title">💸 출금 신청</h1>

            <div class="notice-box">
                ⚠️ <strong>출금 안내</strong><br>
                출금 신청 후 영업일 1~3일 내에 등록된 계좌로 입금됩니다.<br>
                최소 출금 금액은 <strong>10,000원</strong>이며, 수수료 없이 전액 입금됩니다.
            </div>

            <form id="withdrawalForm" action="/withdrawal/request" method="POST">
                <!-- 은행 선택 -->
                <div class="form-group">
                    <label class="form-label">은행</label>
                    <select name="bankName" class="form-select" required>
                        <option value="" disabled selected>은행을 선택하세요</option>
                        <option value="국민은행">국민은행</option>
                        <option value="신한은행">신한은행</option>
                        <option value="우리은행">우리은행</option>
                        <option value="하나은행">하나은행</option>
                        <option value="농협은행">농협은행</option>
                        <option value="기업은행">기업은행</option>
                        <option value="카카오뱅크">카카오뱅크</option>
                        <option value="토스뱅크">토스뱅크</option>
                        <option value="케이뱅크">케이뱅크</option>
                        <option value="SC제일은행">SC제일은행</option>
                        <option value="씨티은행">씨티은행</option>
                    </select>
                </div>

                <!-- 계좌번호 -->
                <div class="form-group">
                    <label class="form-label">계좌번호</label>
                    <input type="text" name="accountNumber" class="form-input"
                           placeholder="'-' 없이 숫자만 입력" pattern="[0-9]+" required />
                    <p class="form-hint">예: 3333012345678</p>
                </div>

                <!-- 예금주 -->
                <div class="form-group">
                    <label class="form-label">예금주명</label>
                    <input type="text" name="accountHolder" class="form-input"
                           placeholder="예금주 이름을 입력하세요" required />
                </div>

                <!-- 출금 금액 -->
                <div class="form-group">
                    <label class="form-label">출금 금액</label>
                    <input type="number" name="amount" id="amountInput" class="form-input"
                           placeholder="출금할 금액 입력 (최소 10,000원)"
                           min="10000" max="{{balance}}" step="1000" required />
                    <div class="quick-btns">
                        <button type="button" class="quick-btn" data-amount="10000">1만원</button>
                        <button type="button" class="quick-btn" data-amount="30000">3만원</button>
                        <button type="button" class="quick-btn" data-amount="50000">5만원</button>
                        <button type="button" class="quick-btn" data-amount="100000">10만원</button>
                        <button type="button" class="quick-btn" id="allBtn">전액</button>
                    </div>
                    <p class="form-hint">출금 가능 최대: <strong>{{balance}}원</strong></p>
                </div>

                <button type="submit" class="submit-btn" id="submitBtn">출금 신청하기</button>
            </form>
        </div>

        <div class="bottom-link">
            <a href="/withdrawal/history">출금내역 보기 →</a>
            &nbsp;·&nbsp;
            <a href="/payment/my">수익 &amp; 정산으로 돌아가기</a>
        </div>

    </div>
</section>

<script>
    const balance = {{balance}};

    // 빠른 금액 버튼
    document.querySelectorAll('.quick-btn[data-amount]').forEach(btn => {
        btn.addEventListener('click', function () {
            const amount = parseInt(this.dataset.amount);
            if (amount > balance) {
                alert('잔액이 부족합니다.');
                return;
            }
            document.getElementById('amountInput').value = amount;
        });
    });

    // 전액 버튼
    document.getElementById('allBtn').addEventListener('click', function () {
        document.getElementById('amountInput').value = balance;
    });

    // 제출 유효성 검사
    document.getElementById('withdrawalForm').addEventListener('submit', function (e) {
        const amount = parseInt(document.getElementById('amountInput').value);
        if (!amount || amount < 10000) {
            e.preventDefault();
            alert('최소 출금 금액은 10,000원입니다.');
            return;
        }
        if (amount > balance) {
            e.preventDefault();
            alert('출금 가능 잔액을 초과했습니다.');
            return;
        }
        if (!confirm(`${amount.toLocaleString()}원을 출금 신청하시겠습니까?`)) {
            e.preventDefault();
        }
    });
</script>

{{> layout/footer}}

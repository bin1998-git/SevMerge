{{> layout/header}}

<style>
    :root {
        --navy:      #0d1b2e;
        --cyan:      #00c8e0;
        --cyan-dark: #00a8be;
        --blue:      #2563eb;
        --blue-dark: #1d4ed8;
        --blue-soft: #eff6ff;
        --white:     #ffffff;
        --gray:      #6b7280;
        --gray-lt:   #9ca3af;
        --border:    #e5e7eb;
        --bg:        #f0f4fa;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
        font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b; line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }

    /* 배경 글로우 */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; border-radius: 50%; }
    .bg-glow-1 { width: 600px; height: 600px; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .bg-glow-3 { width: 400px; height: 400px; background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%); top: 40%; left: 30%; }

    /* ══ 히어로 ══ */
    .ex-hero {
        background: linear-gradient(140deg, rgba(13,27,46,.90) 0%, rgba(14,42,74,.85) 60%, rgba(13,32,64,.92) 100%),
                    url('/mainBackground.jpg') center/cover no-repeat;
        padding: 52px 28px 48px;
        position: relative; overflow: hidden;
        border-bottom: 1px solid rgba(255,255,255,.1);
        box-shadow: 0 4px 32px rgba(13,27,46,.15);
    }
    .ex-hero::before {
        content: ''; position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(0,200,224,.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,200,224,.05) 1px, transparent 1px);
        background-size: 40px 40px; pointer-events: none;
    }
    .ex-hero-inner {
        max-width: 1300px; margin: 0 auto;
        display: flex; align-items: center; justify-content: space-between; gap: 32px;
        position: relative; z-index: 1;
    }
    .ex-hero-left { flex: 1; }
    .ex-hero-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(0,200,224,.12); border: 1px solid rgba(0,200,224,.3);
        border-radius: 999px; padding: 4px 14px;
        font-size: 11px; font-weight: 700; color: var(--cyan);
        margin-bottom: 18px; letter-spacing: .3px;
    }
    .ex-hero-title {
        font-size: clamp(26px, 3vw, 40px); font-weight: 900; color: #fff;
        line-height: 1.2; letter-spacing: -1.5px; margin-bottom: 10px;
    }
    .ex-hero-title .hl { color: var(--cyan); }
    .ex-hero-desc { font-size: 14px; color: rgba(255,255,255,.55); line-height: 1.75; margin-bottom: 28px; max-width: 400px; }

    .ex-search-row { display: flex; gap: 8px; max-width: 520px; }
    .ex-search-input {
        flex: 1; padding: 12px 18px;
        background: rgba(255,255,255,.08); border: 1.5px solid rgba(255,255,255,.18);
        border-radius: 10px; font-size: 14px; font-family: inherit; color: #fff; outline: none;
        transition: border-color .15s, background .15s;
    }
    .ex-search-input::placeholder { color: rgba(255,255,255,.38); }
    .ex-search-input:focus { border-color: var(--cyan); background: rgba(255,255,255,.12); }
    .ex-search-btn {
        padding: 12px 24px; background: var(--cyan); color: var(--navy);
        border: none; border-radius: 10px; font-size: 14px; font-weight: 800;
        cursor: pointer; font-family: inherit; white-space: nowrap; transition: all .15s;
        box-shadow: 0 4px 14px rgba(0,200,224,.3);
    }
    .ex-search-btn:hover { background: var(--cyan-dark); transform: translateY(-1px); }

    .ex-hero-right { display: flex; flex-direction: column; gap: 12px; flex-shrink: 0; }
    .ex-trust-item {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
        border-radius: 14px; padding: 16px 20px;
        display: flex; align-items: center; gap: 14px; min-width: 220px;
        transition: background .15s, border-color .15s;
    }
    .ex-trust-item:hover { background: rgba(255,255,255,.13); border-color: rgba(0,200,224,.3); }
    .ex-trust-val { font-size: 18px; font-weight: 900; color: #fff; letter-spacing: -0.5px; }
    .ex-trust-val em { color: var(--cyan); font-style: normal; }
    .ex-trust-label { font-size: 11px; color: rgba(255,255,255,.45); font-weight: 500; }

    .ex-hero-actions { display: flex; flex-direction: column; gap: 14px; }
    .ex-hero-links { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .ex-hero-link {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 8px 16px; border-radius: 20px;
        background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.2);
        font-size: 12px; font-weight: 700; color: rgba(255,255,255,.8);
        transition: all .15s; backdrop-filter: blur(4px);
    }
    .ex-hero-link:hover { background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.4); color: #fff; }

    .ex-search-btn-outline {
        padding: 12px 24px; background: rgba(255,255,255,.08); color: #fff;
        border: 1.5px solid rgba(255,255,255,.25); border-radius: 10px;
        font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit;
        white-space: nowrap; transition: all .15s; text-decoration: none;
        display: inline-flex; align-items: center; backdrop-filter: blur(8px);
    }
    .ex-search-btn-outline:hover { border-color: rgba(255,255,255,.6); background: rgba(255,255,255,.14); }

    .ex-hero-step {
        display: inline-flex; align-items: center; gap: 7px;
        background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
        border-radius: 10px; padding: 7px 12px; backdrop-filter: blur(4px);
    }
    .ex-step-num {
        width: 20px; height: 20px; border-radius: 50%;
        background: var(--cyan); color: var(--navy);
        font-size: 10px; font-weight: 900;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .ex-step-txt { font-size: 11px; font-weight: 700; color: rgba(255,255,255,.75); white-space: nowrap; }
    .ex-step-arrow { font-size: 12px; color: rgba(255,255,255,.3); }

    /* ══ 광고 카드 (크몽 스타일) ══ */
.ad-grid { display: flex; gap: 16px; flex-wrap: wrap; }
.ad-card {
    flex: 0 0 calc((100% - 32px) / 3);
    background: #fff; border: 1.5px solid var(--border);
    border-radius: 16px; overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    text-decoration: none; color: inherit;
}
.ad-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(37,99,235,.10);
    border-color: #93c5fd;
}

/* 썸네일 — 이미지만, 글자 없음 */
.ad-thumb {
    position: relative; width: 100%; padding-top: 58%;
    background: #f0f4fa; flex-shrink: 0; overflow: hidden;
}
.ad-thumb-img {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    transition: transform .4s ease;
}
.ad-card:hover .ad-thumb-img { transform: scale(1.04); }
.ad-badge {
    position: absolute; top: 10px; left: 10px;
    background: rgba(255,255,255,.92); color: #92400e;
    font-size: 9px; font-weight: 800; letter-spacing: .1em;
    padding: 3px 8px; border-radius: 5px;
}

/* 카드 본문 */
.ad-body {
    padding: 14px 16px 16px;
    display: flex; flex-direction: column; gap: 10px;
    flex: 1;
}

/* 홍보문구 */
.ad-msg {
    font-size: 13px; color: #1e293b; line-height: 1.6; font-weight: 500;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
}

/* 하단 — 평점 + 전문가 프로필 */
.ad-footer {
    display: flex; align-items: center;
    justify-content: space-between;
    padding-top: 10px; border-top: 1px solid var(--border);
    margin-top: auto;
}
.ad-expert-info {
    display: flex; align-items: center; gap: 8px;
}
.ad-expert-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: #eff6ff; border: 1.5px solid #bfdbfe;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: var(--blue);
    flex-shrink: 0; overflow: hidden;
}
.ad-expert-avatar img {
    width: 100%; height: 100%; object-fit: cover;
}
.ad-expert-name {
    font-size: 12px; font-weight: 700; color: #374151;
}
.ad-rating {
    font-size: 12px; font-weight: 700; color: #f59e0b;
}
.ad-cta {
    font-size: 11px; font-weight: 700; color: var(--blue);
}

/* AD 뱃지 */
.ad-badge {
    position: absolute; top: 10px; left: 10px;
    background: rgba(255,255,255,.95); color: #92400e;
    font-size: 9px; font-weight: 800; letter-spacing: .1em;
    padding: 3px 8px; border-radius: 5px;
    font-family: 'JetBrains Mono', monospace;
}

/* 호버 효과 */
.ad-card:hover .ad-thumb-img {
    transform: scale(1.04);
    transition: transform .4s ease;
}
.ad-thumb { overflow: hidden; }
.ad-thumb-img { transition: transform .4s ease; }

    /* ══ 캐러셀 ══ */
    .carousel-section { position: relative; }
    .c-viewport { overflow: hidden; }
    .c-track { display: flex; gap: 16px; will-change: transform; transition: transform .3s ease; }

    /* ══ 프로젝트 카드 - 글래스 ══ */
    .proj-card {
        flex: 0 0 calc((100% - 32px) / 3);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 24px;
        display: flex; flex-direction: column; gap: 14px;
        transition: all .2s; cursor: pointer;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .proj-card:hover { border-color: #93c5fd; box-shadow: 0 10px 28px rgba(37,99,235,.12); transform: translateY(-2px); background: rgba(255,255,255,.75); }
    .proj-card-top { display: flex; align-items: center; justify-content: space-between; }
    .proj-id { font-size: 11px; font-weight: 700; color: var(--gray-lt); letter-spacing: .05em; }
    .proj-dday { font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 6px; background: #fef3c7; color: #92400e; }
    .proj-title { font-size: 15px; font-weight: 800; color: #0f172a; line-height: 1.4; }
    .proj-category { font-size: 12px; color: var(--blue); font-weight: 600; }
    .proj-tags { display: flex; gap: 6px; flex-wrap: wrap; }
    .proj-tag { font-size: 11px; font-weight: 700; border-radius: 6px; padding: 3px 9px; background: #dbeafe; color: #1e40af; }
    .proj-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 10px; border-top: 1px solid rgba(37,99,235,.1); }
    .proj-budget { font-size: 14px; font-weight: 900; color: var(--blue); }
    .proj-deadline { font-size: 11px; color: var(--gray-lt); }
    /* ══ 광고 카드 개선 ══ */
.ad-thumb { padding-top: 62%; }

.ad-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top,
        rgba(13,27,46,.85) 0%,
        rgba(13,27,46,.4) 60%,
        transparent 100%);
    padding: 20px 16px 14px;
}
.ad-overlay-name {
    font-size: 15px; font-weight: 900; color: #fff;
    letter-spacing: -.3px; margin-bottom: 3px;
}
.ad-overlay-spec {
    font-size: 11px; color: rgba(255,255,255,.7); font-weight: 500;
}
.ad-body {
    padding: 14px 18px 16px;
    display: flex; flex-direction: column; gap: 10px;
}
.ad-msg-wrap {
    display: flex; gap: 6px; align-items: flex-start;
}
.ad-quote {
    font-size: 20px; color: var(--cyan); font-weight: 900;
    line-height: 1; flex-shrink: 0; margin-top: -2px;
}
.ad-msg {
    font-size: 13px; color: #374151; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
    font-style: italic;
}
.ad-cta {
    font-size: 12px; font-weight: 700; color: var(--blue);
    text-align: right;
}
.ad-badge {
    position: absolute; top: 10px; left: 10px;
    background: rgba(255,255,255,.95); color: #92400e;
    font-size: 9px; font-weight: 800; letter-spacing: .1em;
    padding: 3px 8px; border-radius: 5px;
}
.ad-thumb { overflow: hidden; }
.ad-thumb-img { transition: transform .4s ease; }
.ad-card:hover .ad-thumb-img { transform: scale(1.04); }

/* ══ 인피드 광고 카드 ══ */
.ad-infeed-card {
    border-color: #fde68a !important;
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%) !important;
    text-decoration: none;
    position: relative;
}

.ad-infeed-card:hover {
    border-color: #f59e0b !important;
    box-shadow: 0 6px 24px rgba(245,158,11,.15) !important;
}

    /* ══ 전문가 카드 - 글래스 ══ */
    .expert-card {
        flex: 0 0 calc((100% - 32px) / 3);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 24px;
        display: flex; flex-direction: column; gap: 14px;
        transition: all .2s; cursor: pointer;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .expert-card:hover { border-color: #93c5fd; box-shadow: 0 10px 28px rgba(37,99,235,.12); transform: translateY(-2px); background: rgba(255,255,255,.75); }
    .expert-card-top { display: flex; align-items: center; gap: 14px; }
    .expert-avatar {
        width: 52px; height: 52px; border-radius: 14px;
        background: rgba(37,99,235,.1); border: 1.5px solid rgba(37,99,235,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 900; color: var(--blue); flex-shrink: 0;
    }
    .expert-info { flex: 1; min-width: 0; }
    .expert-name { font-size: 15px; font-weight: 800; color: #0f172a; }
    .expert-grade { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 5px; margin-top: 3px; }
    .grade-master { background: #fef3c7; color: #92400e; }
    .grade-skilled { background: #dbeafe; color: #1e40af; }
    .grade-normal { background: #f3f4f6; color: #4b5563; }
    .expert-stack { font-size: 12px; color: #4a6fa5; line-height: 1.5; }
    .expert-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 10px; border-top: 1px solid rgba(37,99,235,.1); }
    .expert-rating { font-size: 13px; font-weight: 700; color: #f59e0b; }
    .expert-career { font-size: 12px; color: var(--gray-lt); }

    /* ══ 캐러셀 화살표 ══ */
    .c-arrow {
        position: absolute; top: 0; bottom: 0; width: 60px;
        display: flex; align-items: center;
        border: none; cursor: pointer; z-index: 10; font-size: 24px;
        color: #4a6fa5; transition: color .15s; padding: 0; background: none;
    }
    .c-arrow:hover { color: var(--blue); }
    .c-arrow-right { right: -16px; background: linear-gradient(to right, transparent 0%, rgba(200,216,240,.6) 60%); justify-content: flex-end; }
    .c-arrow-left  { left: -16px;  background: linear-gradient(to left,  transparent 0%, rgba(200,216,240,.6) 60%); justify-content: flex-start; }

    /* ══ 프로모 배너 ══ */
    .promo-banner {
        background: linear-gradient(135deg, #0d1b2e 0%, #1d4ed8 50%, #1e1b4b 100%);
        border-radius: 20px; padding: 32px 36px; margin: 52px 0 0;
        display: flex; align-items: center; justify-content: space-between; gap: 24px;
        position: relative; overflow: hidden;
        box-shadow: 0 8px 32px rgba(13,27,46,.2);
        border: 1px solid rgba(255,255,255,.1);
    }
    .promo-banner::before {
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(circle at 80% 50%, rgba(0,200,224,.12) 0%, transparent 60%);
        pointer-events: none;
    }
    .promo-left { display: flex; flex-direction: column; gap: 8px; position: relative; z-index: 1; }
    .promo-badge {
        display: inline-flex; align-items: center; gap: 6px;
        background: rgba(0,200,224,.15); border: 1px solid rgba(0,200,224,.3);
        border-radius: 20px; padding: 3px 12px; width: fit-content;
        font-size: 10px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--cyan);
    }
    .promo-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: blink 1.4s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
    .promo-title { font-size: 22px; font-weight: 900; color: #fff; letter-spacing: -.5px; line-height: 1.25; }
    .promo-title span { opacity: .65; font-size: 13px; font-weight: 400; display: block; margin-top: 4px; }
    .promo-right { display: flex; align-items: center; gap: 20px; flex-shrink: 0; position: relative; z-index: 1; }
    .promo-timer { display: flex; align-items: center; gap: 8px; }
    .promo-unit { display: flex; flex-direction: column; align-items: center; gap: 2px; }
    .promo-num { font-size: 28px; font-weight: 900; color: #fff; background: rgba(0,0,0,.2); padding: 4px 10px; border-radius: 8px; min-width: 48px; text-align: center; letter-spacing: -.5px; }
    .promo-colon { font-size: 22px; font-weight: 500; color: rgba(255,255,255,.4); padding-bottom: 16px; }
    .promo-label { font-size: 9px; font-weight: 600; color: rgba(255,255,255,.4); letter-spacing: .05em; text-transform: uppercase; }
    .promo-btn {
        background: var(--cyan); color: var(--navy); font-size: 14px; font-weight: 800;
        padding: 13px 28px; border-radius: 30px;
        box-shadow: 0 4px 14px rgba(0,200,224,.3); transition: all .15s;
    }
    .promo-btn:hover { background: var(--cyan-dark); transform: translateY(-1px); }

    /* ══ 리뷰 - 글래스 ══ */
    .review-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .review-card {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 22px; transition: all .2s;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .review-card:hover { border-color: #93c5fd; background: rgba(255,255,255,.75); box-shadow: 0 8px 24px rgba(37,99,235,.1); }
    .rev-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .rev-project { font-size: 14px; font-weight: 800; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%; }
    .rev-stars { color: #f59e0b; font-size: 13px; font-weight: 700; }
    .rev-comment { font-size: 13px; color: #4a6fa5; line-height: 1.6; margin-bottom: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .rev-meta { font-size: 11px; color: var(--gray-lt); display: flex; gap: 8px; }
    .rev-author { font-weight: 700; color: #4a6fa5; }

    /* ══ 통계 - 글래스 ══ */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; padding-bottom: 64px; }
    .stat-card {
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 28px; text-align: center;
        transition: all .2s; box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .stat-card:hover { border-color: #93c5fd; box-shadow: 0 8px 24px rgba(37,99,235,.1); background: rgba(255,255,255,.75); transform: translateY(-2px); }
    .st-val { font-size: 32px; font-weight: 900; color: var(--blue); letter-spacing: -1px; margin-bottom: 6px; }
    .st-label { font-size: 12px; font-weight: 600; color: #4a6fa5; }

    /* ══ 빈 상태 ══ */
    .empty-state {
        flex: 1; backdrop-filter: blur(8px);
        background: rgba(255,255,255,.4); border: 1.5px dashed rgba(37,99,235,.2);
        border-radius: 18px; padding: 48px; text-align: center;
        font-size: 13px; color: #4a6fa5;
    }

    /* ══ 반응형 ══ */
    @media (max-width: 960px) {
        .ex-hero-inner { flex-direction: column; }
        .ex-hero-right { flex-direction: row; flex-wrap: wrap; }
        .ex-trust-item { min-width: 160px; }
        .ad-card, .proj-card, .expert-card { flex: 0 0 calc((100% - 16px) / 2); }
        .review-grid { grid-template-columns: 1fr; }
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .promo-banner { flex-direction: column; align-items: flex-start; padding: 24px; }

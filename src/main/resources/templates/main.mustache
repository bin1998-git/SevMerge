<script>
    (function() {
        function setupCarousel(id) {
            const el = document.getElementById(id);
            if (!el) return;
            const track = el.querySelector('.c-track');
            const btnL  = el.querySelector('.c-arrow-left');
            const btnR  = el.querySelector('.c-arrow-right');
            if (!track || !btnL || !btnR) return;
            let idx = 0;
            function cpv() { return window.innerWidth <= 560 ? 1 : window.innerWidth <= 960 ? 2 : 3; }
            function update() {
                const total = track.children.length;
                const n = cpv();
                const max = Math.max(0, total - n);
                if (idx > max) idx = max;
                if (idx < 0)   idx = 0;
                const gap = 16;
                const w = (track.parentElement.clientWidth - gap * (n - 1)) / n;
                Array.from(track.children).forEach(c => { c.style.flex = `0 0 ${w}px`; });
                track.style.transform = `translateX(-${idx * (w + gap)}px)`;
                btnL.style.display = idx === 0  ? 'none' : 'flex';
                btnR.style.display = idx >= max ? 'none' : 'flex';
            }
            btnL.addEventListener('click', () => { idx--; update(); });
            btnR.addEventListener('click', () => { idx++; update(); });
            window.addEventListener('resize', update);
            update(); setTimeout(update, 200);
        }
        document.addEventListener('DOMContentLoaded', () => {
            setupCarousel('c1');
            setupCarousel('c2');
            document.querySelectorAll('[data-href]').forEach(card => {
                card.addEventListener('click', () => { window.location.href = card.dataset.href; });
            });
            document.querySelectorAll('.expert-avatar').forEach(el => {
                const t = el.textContent.trim();
                if (t) el.textContent = t.charAt(0);
            });
            document.querySelectorAll('.ad-expert-avatar').forEach(el => {
    if (el.querySelector('img')) return; // 이미지 있으면 건너뜀
    const t = el.textContent.trim();
    if (t) el.textContent = t.charAt(0);
});
        });
    })();

    (function() {
        const target = new Date();
        target.setDate(target.getDate() + 3);
        const els = { d: document.getElementById('cd-d'), h: document.getElementById('cd-h'), m: document.getElementById('cd-m'), s: document.getElementById('cd-s') };
        function pad(n) { return n < 10 ? '0' + n : '' + n; }
        function tick() {
            const diff = target - new Date();
            if (diff <= 0) { Object.values(els).forEach(e => { if(e) e.textContent = '00'; }); return; }
            if (els.d) els.d.textContent = pad(Math.floor(diff / 86400000));
            if (els.h) els.h.textContent = pad(Math.floor(diff / 3600000) % 24);
            if (els.m) els.m.textContent = pad(Math.floor(diff / 60000) % 60);
            if (els.s) els.s.textContent = pad(Math.floor(diff / 1000) % 60);
        }
        tick(); setInterval(tick, 1000);
    })();
</script>


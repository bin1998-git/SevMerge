{{> layout/header}}

<style>
    .noti-section {
        padding: 40px 28px 80px;
    }

    .noti-inner {
        max-width: 860px;
        margin: 0 auto;
    }

    .noti-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }

    .noti-title {
        font-size: 26px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -0.5px;
    }

    .btn-read-all {
        padding: 10px 18px;
        background: #fff;
        border: 1.5px solid #e2e5ef;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        color: #4b5563;
        cursor: pointer;
        transition: all .15s;
    }

    .btn-read-all:hover {
        border-color: #2563eb;
        color: #2563eb;
    }

    .noti-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .noti-card {
        background: #fff;
        border: 1.5px solid #e2e8ff;
        border-radius: 14px;
        overflow: hidden;
        transition: border-color .15s, box-shadow .15s;
    }

    .noti-card:hover {
        border-color: #bfdbfe;
        box-shadow: 0 6px 20px rgba(37, 99, 235, .06);
    }

    /* 읽은 알림은 연하게 */
    .noti-card.read {
        border-color: #eef0f6;
        background: #fafbfe;
    }

    .noti-card.read .noti-card-title,
    .noti-card.read .noti-card-preview {
        color: #9ca3af;
    }

    .noti-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 22px;
        cursor: pointer;
    }

    .noti-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
    }

    .noti-card.read .noti-dot {
        background: transparent;
    }

    .noti-card-main {
        flex: 1;
        min-width: 0;
    }

    .noti-card-title {
        font-size: 14px;
        font-weight: 700;
        color: #1c1e26;
        margin-bottom: 3px;
    }

    /* 길어지면 ... 처리 */
    .noti-card-preview {
        font-size: 13px;
        color: #6b7280;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .noti-card-date {
        font-size: 12px;
        color: #c4c9d9;
        font-weight: 500;
        flex-shrink: 0;
        white-space: nowrap;
    }

    .noti-chevron {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        color: #c4c9d9;
        transition: transform .2s;
    }

    .noti-card.open .noti-chevron {
        transform: rotate(180deg);
    }

    /* 펼침 영역 */
    .noti-card-body {
        display: none;
        padding: 0 22px 20px 42px;
    }

    .noti-card.open .noti-card-body {
        display: block;
    }

    .noti-card-content {
        font-size: 14px;
        color: #374151;
        line-height: 1.8;
        padding: 14px 0 16px;
        border-top: 1px dashed #e8ecf8;
        white-space: pre-line;
    }

    .btn-goto {
        display: inline-block;
        padding: 9px 18px;
        background: #2563eb;
        color: #fff;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        transition: background .15s;
    }

    .btn-goto:hover {
        background: #1d4ed8;
    }

    .noti-empty {
        text-align: center;
        padding: 80px 0;
    }

    .noti-empty-msg {
        font-size: 15px;
        color: #c4c9d9;
    }
</style>

<section class="noti-section">
    <div class="noti-inner">
        <div class="noti-head">
            <h1 class="noti-title">알림</h1>
            <form action="/notifications/read-all" method="POST" style="margin:0;">
                <button type="submit" class="btn-read-all">알림 모두 읽음</button>
            </form>
        </div>

        <div class="noti-list">
            {{#notifications}}
                <div class="noti-card {{#isRead}}read{{/isRead}}" data-id="{{id}}" onclick="toggleNoti(this)">
                    <div class="noti-card-header">
                        <span class="noti-dot"></span>
                        <div class="noti-card-main">
                            <div class="noti-card-title">{{typeLabel}}</div>
                            <div class="noti-card-preview">{{content}}</div>
                        </div>
                        <span class="noti-card-date">{{createdAt}}</span>
                        <svg class="noti-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                    </div>
                    <div class="noti-card-body">
                        <div class="noti-card-content">{{content}}</div>
                        <a href="{{url}}" class="btn-goto">관련 페이지로 이동</a>
                    </div>
                </div>
            {{/notifications}}

            {{^notifications}}
                <div class="noti-empty">
                    <p class="noti-empty-msg">받은 알림이 없습니다.</p>
                </div>
            {{/notifications}}
        </div>
    </div>
</section>

<script>
    function toggleNoti(card) {
        const opening = !card.classList.contains('open');
        card.classList.toggle('open');

        // 펼칠 때 아직 안 읽은 알림이면 읽음 처리 + 연하게
        if (opening && !card.classList.contains('read')) {
            const id = card.dataset.id;
            fetch('/notifications/' + id + '/read', {method: 'POST'})
                    .then(() => card.classList.add('read'))
                    .catch(() => {
                    });
        }
    }
</script>

{{> layout/footer}}
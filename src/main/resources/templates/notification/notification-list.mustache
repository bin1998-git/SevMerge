{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .noti-section { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .noti-inner   { max-width: 860px; margin: 0 auto; }

    .noti-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22px; }
    .noti-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -0.5px; }

    .noti-head-actions { display: flex; gap: 8px; }
    .btn-read-all {
        padding: 10px 18px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 20px;
        font-size: 13px; font-weight: 700; color: #2d4a7a; cursor: pointer; transition: all .15s;
    }
    .btn-read-all:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }

    .btn-delete-all {
        padding: 10px 18px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(254,202,202,.8); border-radius: 20px;
        font-size: 13px; font-weight: 700; color: #ef4444; cursor: pointer; transition: all .15s;
    }
    .btn-delete-all:hover { background: rgba(254,242,242,.85); border-color: #ef4444; }

    .noti-list { display: flex; flex-direction: column; gap: 10px; }

    .noti-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 14px; overflow: hidden;
        box-shadow: 0 2px 12px rgba(37,99,235,.06);
        transition: border-color .15s, box-shadow .15s;
    }
    .noti-card:hover { border-color: rgba(37,99,235,.25); box-shadow: 0 6px 20px rgba(37,99,235,.1); }

    .noti-card.read {
        background: rgba(255,255,255,.35); border-color: rgba(255,255,255,.6);
    }
    .noti-card.read .noti-card-title,
    .noti-card.read .noti-card-preview { color: #93aecf; }

    .noti-card-header {
        display: flex; align-items: center; gap: 12px;
        padding: 18px 22px; cursor: pointer;
    }

    .noti-dot { width: 8px; height: 8px; border-radius: 50%; background: #2563eb; flex-shrink: 0; }
    .noti-card.read .noti-dot { background: transparent; }

    .noti-card-main { flex: 1; min-width: 0; }
    .noti-card-title { font-size: 14px; font-weight: 700; color: #1e3a6e; margin-bottom: 3px; }
    .noti-card-preview { font-size: 13px; color: #4a6fa5; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .noti-card-date   { font-size: 12px; color: #93aecf; font-weight: 500; flex-shrink: 0; white-space: nowrap; }

    .noti-chevron { width: 16px; height: 16px; flex-shrink: 0; color: #93aecf; transition: transform .2s; }
    .noti-card.open .noti-chevron { transform: rotate(180deg); }

    .noti-card-body { display: none; padding: 0 22px 20px 42px; }
    .noti-card.open .noti-card-body { display: block; }
    .noti-card-content { font-size: 14px; color: #2d4a7a; line-height: 1.8; padding: 14px 0 16px; border-top: 1px dashed rgba(37,99,235,.15); white-space: pre-line; }

    .btn-goto {
        display: inline-block; padding: 9px 18px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border-radius: 20px; font-size: 13px; font-weight: 700;
        text-decoration: none; box-shadow: 0 4px 12px rgba(37,99,235,.25); transition: all .15s;
    }
    .btn-goto:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }

    .noti-card-actions { display: flex; justify-content: flex-end; gap: 8px; }

    .btn-delete {
        padding: 9px 18px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(254,202,202,.8); color: #ef4444;
        border-radius: 20px; font-size: 13px; font-weight: 700; cursor: pointer; transition: all .15s;
    }
    .btn-delete:hover { background: rgba(254,242,242,.85); border-color: #ef4444; }

    .noti-delete {
        background: none; border: none; cursor: pointer; padding: 6px; border-radius: 6px;
        color: #93aecf; flex-shrink: 0; display: inline-flex; transition: background .15s, color .15s;
    }
    .noti-delete:hover { background: rgba(254,242,242,.85); color: #ef4444; }
    .noti-delete svg { width: 15px; height: 15px; }

    .noti-empty { text-align: center; padding: 80px 0; }
    .noti-empty-msg { font-size: 15px; color: #93aecf; }
</style>

<section class="noti-section">
    <div class="noti-inner">
        <div class="noti-head">
            <h1 class="noti-title">알림</h1>
            <div class="noti-head-actions">
                <form action="/notifications/read-all" method="POST" style="margin:0;">
                    <button type="submit" class="btn-read-all">알림 모두 읽음</button>
                </form>
                <form action="/notifications/delete-all" method="POST" style="margin:0;"
                      onsubmit="return confirm('모든 알림을 삭제하시겠습니까?');">
                    <button type="submit" class="btn-delete-all">알림 전체 삭제</button>
                </form>
            </div>
        </div>

        <div class="noti-list">
            {{#notifications}}
                <div class="noti-card {{#isRead}}read{{/isRead}}" data-id="{{id}}" onclick="toggleNoti(this)">
                    <div class="noti-card-header">
                        <span class="noti-dot"></span>
                        <div class="noti-card-main">
                            <div class="noti-card-title">{{typeLabel}}</div>
                            <div class="noti-card-preview">{{content}}</div>
                        </div>
                        <span class="noti-card-date">{{createdAt}}</span>
                        <svg class="noti-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                        <button type="button" class="noti-delete" onclick="deleteNoti(event, this)" aria-label="삭제">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"></line>
                                <line x1="6" y1="6" x2="18" y2="18"></line>
                            </svg>
                        </button>
                    </div>
                    <div class="noti-card-body">
                        <div class="noti-card-content">{{content}}</div>
                        <div class="noti-card-actions">
                            <a href="{{url}}" class="btn-goto">관련 페이지로 이동</a>
                            <button type="button" class="btn-delete" onclick="deleteNoti(event, this)">삭제</button>
                        </div>
                    </div>
                </div>
            {{/notifications}}

            {{^notifications}}
                <div class="noti-empty">
                    <p class="noti-empty-msg">받은 알림이 없습니다.</p>
                </div>
            {{/notifications}}
        </div>
    </div>
</section>

<script>
    function toggleNoti(card) {
        const opening = !card.classList.contains('open');
        card.classList.toggle('open');
        if (opening && !card.classList.contains('read')) {
            const id = card.dataset.id;
            fetch('/notifications/' + id + '/read', {method: 'POST'})
                .then(() => { card.classList.add('read'); refreshBellDot(); })
                .catch(() => {});
        }
    }

    function deleteNoti(event, btn) {
        event.stopPropagation();
        const card = btn.closest('.noti-card');
        const id = card.dataset.id;
        fetch('/notifications/' + id + '/delete', { method: 'POST' })
            .then(res => res.json())
            .then(body => { if (body.success) { card.remove(); refreshBellDot(); } })
            .catch(() => {});
    }

    function refreshBellDot() {
        const hasUnread = document.querySelector('.noti-card:not(.read)') !== null;
        if (!hasUnread) {
            const dot = document.querySelector('.nav-bell-dot');
            if (dot) dot.remove();
        }
    }
</script>

{{> layout/footer}}
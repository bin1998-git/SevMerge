{{> layout/header}}

<style>
    .edit-tab-header { background: #fff; border-bottom: 1px solid #eaecf4; }
    .edit-tab-inner  { max-width: 760px; margin: 0 auto; padding: 0 28px; display: flex; align-items: flex-end; gap: 0; }
    .edit-tab-title  { font-size: 15px; font-weight: 900; color: #1c1e26; padding: 20px 24px 0 0; margin-right: 8px; white-space: nowrap; align-self: center; }
    .edit-tab        { padding: 18px 20px 16px; font-size: 14px; font-weight: 600; color: #9ca3af; border-bottom: 2.5px solid transparent; text-decoration: none; transition: color .15s, border-color .15s; white-space: nowrap; }
    .edit-tab:hover  { color: #1c1e26; }
    .edit-tab.active { color: #2563eb; border-bottom-color: #2563eb; }

    .save-section    { padding: 40px 28px 80px; }
    .save-inner      { max-width: 760px; margin: 0 auto; }
    .notice-box      { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 10px; padding: 14px 18px; font-size: 13px; color: #2563eb; font-weight: 500; margin-bottom: 28px; line-height: 1.7; }
    .save-form       { display: flex; flex-direction: column; gap: 22px; }
    .form-group      { display: flex; flex-direction: column; gap: 8px; }
    .form-label      { font-size: 13px; font-weight: 700; color: #374151; }
    .form-label .req { color: #ef4444; margin-left: 2px; }
    .form-input      { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input:focus { border-color: #2563eb; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-select     { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; cursor: pointer; }
    .form-select:focus { border-color: #2563eb; }
    .form-textarea   { padding: 13px 16px; background: #fff; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; resize: vertical; min-height: 180px; line-height: 1.7; transition: border-color .15s; }
    .form-textarea:focus { border-color: #2563eb; }
    .form-textarea::placeholder { color: #c4c9d9; }
    .form-hint       { font-size: 12px; color: #9ca3af; }
    .form-btns       { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn             { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary     { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-outline     { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .btn-lg          { padding: 14px 32px; font-size: 15px; border-radius: 10px; }

    .stack-box  { background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 10px; padding: 16px; display: none; }
    .stack-box.visible { display: block; }
    .stack-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .stack-chip { display: flex; align-items: center; cursor: pointer; }
    .stack-chip input[type="checkbox"] { display: none; }
    .stack-chip-label {
        padding: 6px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
        border: 1.5px solid #e2e5ef; background: #fff; color: #6b7280;
        cursor: pointer; transition: all .15s; user-select: none;
    }
    .stack-chip input:checked + .stack-chip-label { background: #2563eb; color: #fff; border-color: #2563eb; }
    .stack-chip-label:hover { border-color: #2563eb; color: #2563eb; }
    .stack-preview { margin-top: 10px; font-size: 12px; color: #6b7280; min-height: 18px; }
    /* ── FOOTER (exmain 스타일) ── */
    :root {
        --brand-blue:      #2D6BFF;
        --brand-blue-deep: #1846C9;
        --brand-sky:       #6BA0FF;
        --brand-ink:       #0C1424;
        --brand-slate:     #33415C;
        --brand-muted:     #5A6B85;
        --brand-mist:      #EBEEF4;
        --brand-line:      #E2E7F0;
        --brand-white:     #FFFFFF;
    }
    .footer {
        background: var(--brand-ink) !important;
        border-top: 1px solid rgba(255,255,255,.06) !important;
        padding: 40px 32px 28px !important;
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
    }
    .footer-brand-logo {
        font-size: 20px;
        font-weight: 800;
        color: rgba(255,255,255,.85);
        letter-spacing: .05em;
    }
    .footer-brand-logo span { color: var(--brand-sky); }
    .footer-actions { display: flex; gap: 8px; }
    .footer-actions .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.55);
        font-size: 13px;
        padding: 8px 16px;
        border-radius: 7px;
        transition: border-color .15s, color .15s;
    }
    .footer-actions .btn-outline:hover {
        border-color: var(--brand-sky);
        color: var(--brand-sky);
    }
    .footer-nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .footer-nav a {
        font-size: 13px;
        color: rgba(255,255,255,.45);
        transition: color .15s;
    }
    .footer-nav a:hover { color: rgba(255,255,255,.8); }
    .footer-nav-sep {
        display: inline-block;
        width: 1px;
        height: 12px;
        background: rgba(255,255,255,.15);
        vertical-align: middle;
    }
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,.07);
        flex-wrap: wrap;
        gap: 10px;
    }
    .footer-policy-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }
    .footer-policy-links a {
        font-size: 12px;
        color: rgba(255,255,255,.32);
        transition: color .15s;
    }
    .footer-policy-links a:hover { color: rgba(255,255,255,.6); }
    .footer-policy-strong {
        font-weight: 700;
        color: rgba(255,255,255,.5) !important;
    }
    .footer-hours-inline {
        font-size: 12px;
        color: rgba(255,255,255,.22);
    }
    .footer-copy {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--brand-muted) !important;
        letter-spacing: .02em;
    }
</style>

<!-- 탭 헤더 -->
<div class="edit-tab-header">
    <div class="edit-tab-inner">
        <span class="edit-tab-title">내 정보 수정</span>
        <a href="/experts/my/info-edit" class="edit-tab">개인정보 수정</a>
        <a href="/experts/my/form"      class="edit-tab active">전문가 프로필 수정</a>
    </div>
</div>

<!-- 서버 데이터 전달용 (JS에서 data 속성으로 읽음, JS string literal에 Mustache 삽입 금지) -->
<div id="profileData"
     data-career="{{expertProfile.career}}"
     data-speciality="{{expertProfile.speciality}}"
     style="display:none"></div>

<section class="save-section">
    <div class="save-inner">

        <div class="notice-box">
            인증 심사 안내<br>
            제출된 프로필은 관리자 검토 후 승인됩니다. 승인까지 최대 3 영업일이 소요될 수 있습니다.
        </div>

        <form class="save-form" id="profileForm" action="/experts/my/form" method="POST">

            <div class="form-group">
                <label class="form-label">직종 / 전문 분야 <span class="req">*</span></label>
                <select name="career" id="careerSelect" class="form-select">
                    <option value="">선택하세요</option>
                    <option value="풀스택">풀스택 개발자</option>
                    <option value="백엔드">백엔드 개발자</option>
                    <option value="프론트엔드">프론트엔드 개발자</option>
                    <option value="앱개발">앱 개발자</option>
                    <option value="UI/UX">UI/UX 디자이너</option>
                    <option value="데이터">데이터 엔지니어</option>
                    <option value="영상편집">영상 편집</option>
                    <option value="기타">기타</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">주요 기술 스택</label>
                <div class="stack-box" id="stackBox">
                    <div class="stack-grid" id="stackGrid"></div>
                    <div class="stack-preview" id="stackPreview">기술 스택을 선택하세요.</div>
                </div>
                <input type="hidden" name="speciality" id="specialityInput" />
                <span class="form-hint">직종 선택 후 해당 기술을 체크하세요.</span>
            </div>

            <div class="form-group">
                <label class="form-label">자기소개 <span class="req">*</span></label>
                <textarea name="intro" class="form-textarea"
                          placeholder="본인의 경력, 강점, 대표 프로젝트 경험 등을 소개해주세요.">{{expertProfile.intro}}</textarea>
            </div>

            <div class="form-group">
                <label class="form-label">GitHub / 포트폴리오 URL</label>
                <input type="url" name="githubUrl" class="form-input"
                       value="{{expertProfile.githubUrl}}"
                       placeholder="https://github.com/..." />
                <span class="form-hint">GitHub, Notion, 개인 블로그 등 자유롭게 입력하세요.</span>
            </div>

            <div class="form-group">
                <label class="form-label">연락처 이메일</label>
                <input type="email" name="contactEmail" class="form-input"
                       value="{{expertProfile.contactEmail}}"
                       placeholder="contact@example.com" />
            </div>

            <div class="form-btns">
                <a href="/experts/dashboard" class="btn btn-outline">취소</a>
                <button type="submit" class="btn btn-primary btn-lg">
                    {{#isUpdate}}수정 완료{{/isUpdate}}{{^isUpdate}}신청서 제출{{/isUpdate}}
                </button>
            </div>

        </form>
    </div>
</section>

<script>
(function () {
    var STACKS = {
        '풀스택':    ['Java','Spring Boot','Node.js','React','Vue','TypeScript','Python','Docker','MySQL','MongoDB','PostgreSQL','AWS'],
        '백엔드':    ['Java','Spring Boot','Node.js','Python','Django','FastAPI','Express','MySQL','PostgreSQL','Redis','Docker','AWS'],
        '프론트엔드': ['React','Vue','Angular','TypeScript','Next.js','Nuxt.js','Tailwind CSS','SCSS','JavaScript','HTML/CSS','Webpack','Vite'],
        '앱개발':    ['Flutter','React Native','Swift','Kotlin','Android','iOS','Firebase','Dart'],
        'UI/UX':    ['Figma','Adobe XD','Sketch','Zeplin','Framer','Principle','Photoshop','Illustrator'],
        '데이터':    ['Python','Pandas','NumPy','TensorFlow','PyTorch','SQL','Spark','Tableau','Power BI','R'],
        '영상편집':  ['Premiere Pro','After Effects','DaVinci Resolve','Final Cut Pro','CapCut','Blender'],
        '기타':     ['WordPress','Shopify','Git','Linux','Nginx','Jenkins','Kubernetes','Figma']
    };

    var careerSelect    = document.getElementById('careerSelect');
    var stackBox        = document.getElementById('stackBox');
    var stackGrid       = document.getElementById('stackGrid');
    var stackPreview    = document.getElementById('stackPreview');
    var specialityInput = document.getElementById('specialityInput');
    var profileForm     = document.getElementById('profileForm');
    var profileData     = document.getElementById('profileData');

    function getChecked() {
        return Array.from(stackGrid.querySelectorAll('input[type="checkbox"]:checked'))
                    .map(function (cb) { return cb.value; });
    }

    function syncHidden() {
        var checked = getChecked();
        specialityInput.value = checked.join(', ');
        stackPreview.textContent = checked.length
            ? '선택됨: ' + checked.join(', ')
            : '기술 스택을 선택하세요.';
    }

    function renderStacks(career, preChecked) {
        var list = STACKS[career] || [];
        stackGrid.innerHTML = '';
        if (!list.length) {
            stackBox.classList.remove('visible');
            syncHidden();
            return;
        }
        list.forEach(function (tech) {
            var label = document.createElement('label');
            label.className = 'stack-chip';

            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.value = tech;
            cb.checked = preChecked.indexOf(tech) !== -1;
            cb.addEventListener('change', syncHidden);

            var span = document.createElement('span');
            span.className = 'stack-chip-label';
            span.textContent = tech;

            label.appendChild(cb);
            label.appendChild(span);
            stackGrid.appendChild(label);
        });
        stackBox.classList.add('visible');
        syncHidden();
    }

    careerSelect.addEventListener('change', function () {
        renderStacks(this.value, []);
    });

    profileForm.addEventListener('submit', function () {
        specialityInput.value = getChecked().join(', ');
    });

    // 수정 모드: data 속성에서 서버 값 읽어 복원 (JS string literal에 Mustache 삽입 불가)
    var savedCareer    = profileData ? profileData.getAttribute('data-career')    || '' : '';
    var savedSpeciality = profileData ? profileData.getAttribute('data-speciality') || '' : '';

    if (savedCareer) {
        careerSelect.value = savedCareer;
        var preChecked = savedSpeciality
            ? savedSpeciality.split(',').map(function (s) { return s.trim(); }).filter(Boolean)
            : [];
        renderStacks(savedCareer, preChecked);
    }
}());
</script>

{{> layout/footer}}

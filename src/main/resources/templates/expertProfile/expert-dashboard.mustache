<script>
    const el = document.getElementById('expertAvatar');
    if (el) { const t = el.textContent.trim(); el.textContent = t ? t.charAt(0) : '?'; }

    function confirmWithdraw() {
        if (confirm('정말로 회원탈퇴를 진행하시겠습니까?\n탈퇴 후 계정과 모든 데이터가 삭제되며 복구할 수 없습니다.')) {
            fetch('/my-pages/withdraw', {
                method: 'DELETE',
                headers: {'Content-Type': 'application/json'}
            }).then(res => {
                if (res.ok) {
                    alert('회원탈퇴가 완료되었습니다.');
                    window.location.href = '/';
                } else {
                    return res.text().then(msg => {
                        alert(msg || '탈퇴 처리 중 오류가 발생했습니다.');
                    });
                }
            }).catch(() => alert('탈퇴 처리 중 오류가 발생했습니다.'));
        }
    }
</script>
<script>
    (function() {
        const el = document.getElementById('dashAvgRating');
        if (!el) return;
        const rating = parseFloat(el.dataset.rating) || 0;
        let stars = '';
        for (let i = 1; i <= 5; i++) {
            if (rating >= i) {
                stars += '<span style="color:#f59e0b">★</span>';
            } else if (rating >= i - 0.5) {
                stars += '<span style="position:relative;display:inline-block;color:#d1d5db">' +
                    '<span style="position:absolute;left:0;top:0;width:50%;overflow:hidden;color:#f59e0b">★</span>★</span>';
            } else {
                stars += '<span style="color:#d1d5db">★</span>';
            }
        }
        el.innerHTML = stars + '<br><small style="color:#6b7280">' + rating.toFixed(1) + '</small>';
    })();
</script>


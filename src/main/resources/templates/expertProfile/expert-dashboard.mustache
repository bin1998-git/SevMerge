{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
    }

    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .dash-section { padding: 16px 28px 40px; position: relative; z-index: 1; }
    .dash-inner { max-width: 1200px; margin: 0 auto; }

    /* 4컬럼 유지 */
    .dash-grid {
        display: grid;
        grid-template-columns: 200px 1fr 260px;
        gap: 14px;
        align-items: stretch;
    }
    .dash-col { display: flex; flex-direction: column; gap: 10px; }

    /* ── 카드 공통 ── */
    .dash-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 12px; overflow: hidden;
        display: flex; flex-direction: column;
        box-shadow: 0 4px 16px rgba(37,99,235,.06), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .dash-col .dash-card:last-child { flex: 1; }

    .dash-card-header {
        padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,.5);
        background: rgba(255,255,255,.3);
        display: flex; justify-content: space-between; align-items: center; flex-shrink: 0;
    }
    .dash-card-title { font-size: 12px; font-weight: 700; color: #1c1e26; }
    .dash-card-more  { font-size: 11px; color: #2563eb; font-weight: 600; text-decoration: none; }
    .dash-card-more:hover { text-decoration: underline; }
    .dash-card-body { padding: 12px 14px; flex: 1; display: flex; flex-direction: column; }

    /* ── 전문가 프로필 ── */
    .expert-avatar {
        width: 52px; height: 52px; border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        border: 2px solid rgba(255,255,255,.9);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; font-weight: 900; color: #fff;
        margin: 0 auto 8px;
        box-shadow: 0 4px 12px rgba(37,99,235,.2);
    }
    .expert-name { text-align: center; font-size: 13px; font-weight: 700; color: #1c1e26; margin-bottom: 3px; }
    .expert-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; }
    .expert-stat {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5);
        border: 1px solid rgba(255,255,255,.7); border-radius: 8px; padding: 7px 4px; text-align: center;
    }
    .expert-stat-val { display: block; font-size: 16px; font-weight: 900; color: #2563eb; margin-bottom: 1px; }
    .expert-stat-lbl { font-size: 9px; color: #9ca3af; font-weight: 500; }

    .grade-badge { display: inline-flex; align-items: center; background: transparent; border: none; padding: 0; }
    .grade-badge-img { width: 114px; height: 48px; object-fit: contain; flex-shrink: 0; margin-bottom: 10px; }
    .grade-badge-wrap { display: flex; justify-content: center; }

    /* ── 빠른 링크 ── */
    .quick-links { display: flex; flex-direction: column; gap: 6px; }
    .quick-link {
        display: flex; align-items: center; gap: 8px; padding: 8px 10px; border-radius: 8px;
        font-size: 12px; font-weight: 600; color: #4b5563; text-decoration: none;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5); border: 1.5px solid rgba(255,255,255,.7);
        transition: all .15s;
    }
    .quick-link:hover { background: rgba(239,246,255,.85); border-color: rgba(191,219,254,.9); color: #2563eb; }
    .quick-link-icon { display: flex; align-items: center; flex-shrink: 0; }
    .quick-links { display: flex; flex-direction: column; gap: 5px; }

    /* ── 섹션 링크 카드 ── */
    .section-links { display: flex; flex-direction: column; gap: 7px; }
    .section-link-card {
        display: block; padding: 9px 12px; text-decoration: none;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5); border: 1.5px solid rgba(255,255,255,.7);
        border-radius: 9px; transition: all .2s;
    }
    .section-link-card:hover {
        background: rgba(239,246,255,.85); border-color: rgba(191,219,254,.9);
        box-shadow: 0 2px 10px rgba(37,99,235,.07); transform: translateX(2px);
    }
    .section-link-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px; }
    .section-link-title { font-size: 12px; font-weight: 700; color: #1c1e26; display: flex; align-items: center; gap: 5px; }
    .section-link-arrow { font-size: 16px; color: #c4c9d9; }
    .section-link-desc  { font-size: 10px; color: #9ca3af; line-height: 1.4; }

    .badge-live { font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 20px; background: #dcfce7; color: #16a34a; border: 1px solid #bbf7d0; }
    .badge-ws   { font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 20px; background: #fdf4ff; color: #9333ea; border: 1px solid #e9d5ff; }

    /* ── 채팅 프리뷰 ── */
    .chat-panel-preview {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.4); border: 1px solid rgba(255,255,255,.6);
        border-radius: 9px; padding: 10px 12px; margin-top: 8px; flex: 1;
    }
    .chat-preview-header { font-size: 10px; font-weight: 700; color: #6b7280; margin-bottom: 7px; display: flex; align-items: center; gap: 5px; }
    .chat-bubble {
        backdrop-filter: blur(4px); background: rgba(255,255,255,.75); border: 1px solid rgba(255,255,255,.85);
        border-radius: 7px; padding: 6px 10px; margin-bottom: 5px;
    }
    .chat-bubble-name { font-size: 9px; font-weight: 700; color: #2563eb; margin-bottom: 2px; }
    .chat-bubble-text { font-size: 11px; color: #4b5563; line-height: 1.4; }
    .chat-open-btn { display: block; text-align: center; margin-top: 8px; font-size: 11px; color: #2563eb; font-weight: 600; text-decoration: none; }

    /* ── 4번째 컬럼: 프로젝트 목록 ── */
    .proj-search-bar { display: flex; gap: 6px; margin-bottom: 8px; }
    .proj-search-input {
        flex: 1; padding: 7px 10px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 8px;
        font-size: 11px; font-family: inherit; color: #1c1e26; outline: none; transition: all .15s;
    }
    .proj-search-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); }
    .proj-search-input::placeholder { color: #93aecf; }
    .proj-search-btn {
        padding: 7px 12px; background: linear-gradient(135deg, #2563eb, #1d4ed8);
        color: #fff; border: none; border-radius: 8px; font-size: 11px; font-weight: 700;
        cursor: pointer; font-family: inherit; transition: all .15s; white-space: nowrap;
    }
    .proj-search-btn:hover { transform: translateY(-1px); }

    .proj-cat-tabs { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
    .proj-tab {
        padding: 3px 8px; border-radius: 20px; font-size: 10px; font-weight: 600;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8); color: #4a6fa5;
        text-decoration: none; transition: all .15s;
    }
    .proj-tab:hover { border-color: rgba(37,99,235,.3); color: #2563eb; }
    .proj-tab.active { background: #2563eb; border-color: #2563eb; color: #fff; }

    .proj-list { display: flex; flex-direction: column; gap: 7px; overflow-y: auto; flex: 1; }
    .proj-item {
        display: block; text-decoration: none; padding: 9px 12px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.5); border: 1.5px solid rgba(255,255,255,.7);
        border-radius: 9px; transition: all .2s;
    }
    .proj-item:hover { background: rgba(239,246,255,.85); border-color: rgba(191,219,254,.9); box-shadow: 0 2px 10px rgba(37,99,235,.07); transform: translateX(2px); }
    .proj-item-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px; }
    .proj-item-title { font-size: 12px; font-weight: 700; color: #1c1e26; display: flex; align-items: center; gap: 5px; }
    .proj-item-cat { font-size: 9px; font-weight: 700; color: #2563eb; background: rgba(239,246,255,.8); padding: 1px 6px; border-radius: 4px; flex-shrink: 0; }
    .proj-item-arrow { font-size: 16px; color: #c4c9d9; }
    .proj-item-desc { font-size: 10px; color: #9ca3af; line-height: 1.4; display: flex; justify-content: space-between; }
    .proj-item-dday { font-size: 10px; font-weight: 600; color: #c4c9d9; flex-shrink: 0; }
    .proj-item-dday.urgent { color: #ef4444; }
    .proj-empty { text-align: center; padding: 20px 0; font-size: 11px; color: #93aecf; }
    .proj-viewall {
        display: block; text-align: center; margin-top: 8px;
        font-size: 11px; color: #2563eb; font-weight: 600; text-decoration: none;
        padding: 7px; backdrop-filter: blur(8px);
        background: rgba(255,255,255,.5); border: 1.5px solid rgba(255,255,255,.7);
        border-radius: 8px; transition: all .15s;
    }
    .proj-viewall:hover { background: rgba(239,246,255,.85); border-color: rgba(191,219,254,.9); }
    @media (max-width: 960px) { .dash-grid { grid-template-columns: 200px 1fr; } }
    @media (max-width: 640px) { .dash-grid { grid-template-columns: 1fr; } }
</style>

<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>


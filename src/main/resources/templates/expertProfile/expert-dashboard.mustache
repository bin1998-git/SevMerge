    .withdraw-info h3 { font-size: 14px; font-weight: 600; color: #dc2626; margin: 0 0 4px; }
    .withdraw-info p { font-size: 13px; color: #6b7280; margin: 0; }
    .withdraw-btn { background: #fff; border: 1px solid #dc2626; color: #dc2626; padding: 8px 20px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; white-space: nowrap; }
    .withdraw-btn:hover { background: #fef2f2; }
</style>

<section class="withdraw-section">

{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
    }

    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .edit-tab-header {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.65);
        border-bottom: 1px solid rgba(255,255,255,.7);
        position: relative; z-index: 1;
    }
    .edit-tab-inner  { max-width: 760px; margin: 0 auto; padding: 0 28px; height: 58px; display: flex; align-items: center; gap: 0; }
    .edit-tab-title  { font-size: 15px; font-weight: 900; color: #1c1e26; padding-right: 24px; margin-right: 8px; white-space: nowrap; }
    .edit-tab        { padding: 0 20px; height: 58px; display: flex; align-items: center; font-size: 14px; font-weight: 600; color: #9ca3af; border-bottom: 2.5px solid transparent; text-decoration: none; transition: color .15s, border-color .15s; white-space: nowrap; }
    .edit-tab:hover  { color: #1c1e26; }
    .edit-tab.active { color: #2563eb; border-bottom-color: #2563eb; }

    .save-section    { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .save-inner      { max-width: 760px; margin: 0 auto; }
    .edit-form {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 36px; display: flex; flex-direction: column; gap: 20px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .form-section-title { font-size: 13px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,.6); margin-bottom: 4px; }
    .form-group      { display: flex; flex-direction: column; gap: 7px; }
    .form-label      { font-size: 13px; font-weight: 700; color: #374151; }
    .form-input {
        padding: 13px 16px;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s;
    }
    .form-input::placeholder { color: #c4c9d9; }
    .form-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); }
    .form-input:disabled { color: #9ca3af; cursor: not-allowed; background: rgba(243,244,248,.5); }
    .form-hint       { font-size: 12px; color: #9ca3af; }
    .divider         { height: 1px; background: rgba(255,255,255,.6); }
    .form-btns       { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn             { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary     { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-outline {
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); color: #4b5563;
    }
    .btn-lg          { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
    /* ── FOOTER (exmain 스타일) ── */
    :root {
        --brand-blue:      #2D6BFF;
        --brand-blue-deep: #1846C9;
        --brand-sky:       #6BA0FF;
        --brand-ink:       #0C1424;
        --brand-slate:     #33415C;
        --brand-muted:     #5A6B85;
        --brand-mist:      #EBEEF4;
        --brand-line:      #E2E7F0;
        --brand-white:     #FFFFFF;
    }
    .footer {
        background: var(--brand-ink) !important;
        border-top: 1px solid rgba(255,255,255,.06) !important;
        padding: 40px 32px 28px !important;
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
    }
    .footer-brand-logo {
        font-size: 20px;
        font-weight: 800;
        color: rgba(255,255,255,.85);
        letter-spacing: .05em;
    }
    .footer-brand-logo span { color: var(--brand-sky); }
    .footer-actions { display: flex; gap: 8px; }
    .footer-actions .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.55);
        font-size: 13px;
        padding: 8px 16px;
        border-radius: 7px;
        transition: border-color .15s, color .15s;
    }
    .footer-actions .btn-outline:hover {
        border-color: var(--brand-sky);
        color: var(--brand-sky);
    }
    .footer-nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .footer-nav a {
        font-size: 13px;
        color: rgba(255,255,255,.45);
        transition: color .15s;
    }
    .footer-nav a:hover { color: rgba(255,255,255,.8); }
    .footer-nav-sep {
        display: inline-block;
        width: 1px;
        height: 12px;
        background: rgba(255,255,255,.15);
        vertical-align: middle;
    }
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,.07);
        flex-wrap: wrap;
        gap: 10px;
    }
    .footer-policy-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }
    .footer-policy-links a {
        font-size: 12px;
        color: rgba(255,255,255,.32);
        transition: color .15s;
    }
    .footer-policy-links a:hover { color: rgba(255,255,255,.6); }
    .footer-policy-strong {
        font-weight: 700;
        color: rgba(255,255,255,.5) !important;
    }
    .footer-hours-inline {
        font-size: 12px;
        color: rgba(255,255,255,.22);
    }
    .footer-copy {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--brand-muted) !important;
        letter-spacing: .02em;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>

<!-- 탭 헤더 -->
<div class="edit-tab-header">
    <div class="edit-tab-inner">
        <span class="edit-tab-title">내 정보 수정</span>
        <a href="/experts/my/info-edit" class="edit-tab active">개인정보 수정</a>
        <a href="/experts/my/form"      class="edit-tab">전문가 프로필 수정</a>
    </div>
</div>

<section class="save-section">
    <div class="save-inner">
        <form class="edit-form" action="/experts/my/info-edit" method="POST">

            <div class="form-section-title">기본 정보</div>

            <div class="form-group">
                <label class="form-label">이름</label>
                <input type="text" name="name" class="form-input"
                       value="{{member.name}}"
                       placeholder="이름을 입력하세요" maxlength="20" />
            </div>

            <div class="form-group">
                <label class="form-label">이메일</label>
                <input type="email" class="form-input" value="{{member.email}}" disabled />
                <span class="form-hint">이메일은 변경할 수 없습니다.</span>
            </div>

            <div class="form-group">
                <label class="form-label">전화번호</label>
                <input type="tel" name="phone" class="form-input"
                       value="{{member.phone}}"
                       placeholder="010-0000-0000" />
            </div>

            <div class="divider"></div>

            <div class="form-section-title">비밀번호 변경</div>

            <div class="form-group">
                <label class="form-label">현재 비밀번호</label>
                <input type="password" name="currentPassword" class="form-input"
                       placeholder="현재 비밀번호를 입력하세요" />
            </div>

            <div class="form-group">
                <label class="form-label">새 비밀번호</label>
                <input type="password" name="newPassword" id="newPassword" class="form-input"
                       placeholder="새 비밀번호를 입력하세요" />
                <span class="form-hint">영문, 숫자 포함 8자 이상 (변경하지 않으려면 비워두세요)</span>
            </div>

            <div class="form-group">
                <label class="form-label">새 비밀번호 확인</label>
                <input type="password" name="newPasswordConfirm" id="newPasswordConfirm" class="form-input"
                       placeholder="새 비밀번호를 다시 입력하세요" />
                <span class="form-hint" id="pwMatchHint"></span>
            </div>

            <div class="form-btns">
                <a href="/experts/dashboard" class="btn btn-outline">취소</a>
                <button type="submit" class="btn btn-primary btn-lg">수정 완료</button>
            </div>

        </form>
    </div>
</section>

<script>
(function () {
    var newPw    = document.getElementById('newPassword');
    var confirmPw = document.getElementById('newPasswordConfirm');
    var hint     = document.getElementById('pwMatchHint');

    function check() {
        if (!confirmPw.value) { hint.textContent = ''; hint.style.color = ''; return; }
        if (newPw.value === confirmPw.value) {
            hint.textContent = '비밀번호가 일치합니다.';
            hint.style.color = '#16a34a';
        } else {
            hint.textContent = '비밀번호가 일치하지 않습니다.';
            hint.style.color = '#ef4444';
        }
    }

    newPw.addEventListener('input', check);
    confirmPw.addEventListener('input', check);
}());
</script>

{{> layout/footer}}

{{> layout/header}}

<style>
    .edit-tab-header { background: #fff; border-bottom: 1px solid #eaecf4; }
    .edit-tab-inner  { max-width: 760px; margin: 0 auto; padding: 0 28px; display: flex; align-items: flex-end; gap: 0; }
    .edit-tab-title  { font-size: 15px; font-weight: 900; color: #1c1e26; padding: 20px 24px 0 0; margin-right: 8px; white-space: nowrap; align-self: center; }
    .edit-tab        { padding: 18px 20px 16px; font-size: 14px; font-weight: 600; color: #9ca3af; border-bottom: 2.5px solid transparent; text-decoration: none; transition: color .15s, border-color .15s; white-space: nowrap; }
    .edit-tab:hover  { color: #1c1e26; }
    .edit-tab.active { color: #2563eb; border-bottom-color: #2563eb; }

    .save-section    { padding: 40px 28px 80px; }
    .save-inner      { max-width: 760px; margin: 0 auto; }
    .edit-form       { background: #fff; border: 1.5px solid #eaecf4; border-radius: 18px; padding: 36px; display: flex; flex-direction: column; gap: 20px; }
    .form-section-title { font-size: 13px; font-weight: 700; color: #2563eb; letter-spacing: 1px; text-transform: uppercase; padding-bottom: 12px; border-bottom: 1px solid #f3f4f8; margin-bottom: 4px; }
    .form-group      { display: flex; flex-direction: column; gap: 7px; }
    .form-label      { font-size: 13px; font-weight: 700; color: #374151; }
    .form-input      { padding: 13px 16px; background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 10px; font-size: 14px; font-family: inherit; color: #1c1e26; outline: none; transition: border-color .15s; }
    .form-input::placeholder { color: #c4c9d9; }
    .form-input:focus { border-color: #2563eb; background: #fff; }
    .form-input:disabled { color: #9ca3af; cursor: not-allowed; background: #f3f4f8; }
    .form-hint       { font-size: 12px; color: #9ca3af; }
    .divider         { height: 1px; background: #f3f4f8; }
    .form-btns       { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn             { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary     { background: #2563eb; color: #fff; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-outline     { background: #fff; border: 1.5px solid #e2e5ef; color: #4b5563; }
    .btn-lg          { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
</style>

<!-- 탭 헤더 -->
<div class="edit-tab-header">
    <div class="edit-tab-inner">
        <span class="edit-tab-title">내 정보 수정</span>
        <a href="/experts/my/info-edit" class="edit-tab active">개인정보 수정</a>
        <a href="/experts/my/form"      class="edit-tab">전문가 프로필 수정</a>
    </div>
</div>

<section class="save-section">
    <div class="save-inner">
        <form class="edit-form" action="/experts/my/info-edit" method="POST">

            <div class="form-section-title">기본 정보</div>

            <div class="form-group">
                <label class="form-label">이름</label>
                <input type="text" name="name" class="form-input"
                       value="{{member.name}}"
                       placeholder="이름을 입력하세요" maxlength="20" />
            </div>

            <div class="form-group">
                <label class="form-label">이메일</label>
                <input type="email" class="form-input" value="{{member.email}}" disabled />
                <span class="form-hint">이메일은 변경할 수 없습니다.</span>
            </div>

            <div class="form-group">
                <label class="form-label">전화번호</label>
                <input type="tel" name="phone" class="form-input"
                       value="{{member.phone}}"
                       placeholder="010-0000-0000" />
            </div>

            <div class="divider"></div>

            <div class="form-section-title">비밀번호 변경</div>

            <div class="form-group">
                <label class="form-label">현재 비밀번호</label>
                <input type="password" name="currentPassword" class="form-input"
                       placeholder="현재 비밀번호를 입력하세요" />
            </div>

            <div class="form-group">
                <label class="form-label">새 비밀번호</label>
                <input type="password" name="newPassword" id="newPassword" class="form-input"
                       placeholder="새 비밀번호를 입력하세요" />
                <span class="form-hint">영문, 숫자 포함 8자 이상 (변경하지 않으려면 비워두세요)</span>
            </div>

            <div class="form-group">
                <label class="form-label">새 비밀번호 확인</label>
                <input type="password" name="newPasswordConfirm" id="newPasswordConfirm" class="form-input"
                       placeholder="새 비밀번호를 다시 입력하세요" />
                <span class="form-hint" id="pwMatchHint"></span>
            </div>

            <div class="form-btns">
                <a href="/experts/dashboard" class="btn btn-outline">취소</a>
                <button type="submit" class="btn btn-primary btn-lg">수정 완료</button>
            </div>

        </form>
    </div>
</section>

<script>
(function () {
    var newPw    = document.getElementById('newPassword');
    var confirmPw = document.getElementById('newPasswordConfirm');
    var hint     = document.getElementById('pwMatchHint');

    function check() {
        if (!confirmPw.value) { hint.textContent = ''; hint.style.color = ''; return; }
        if (newPw.value === confirmPw.value) {
            hint.textContent = '비밀번호가 일치합니다.';
            hint.style.color = '#16a34a';
        } else {
            hint.textContent = '비밀번호가 일치하지 않습니다.';
            hint.style.color = '#ef4444';
        }
    }

    newPw.addEventListener('input', check);
    confirmPw.addEventListener('input', check);
}());
</script>

{{> layout/footer}}

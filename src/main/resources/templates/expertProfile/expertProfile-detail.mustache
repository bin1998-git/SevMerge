{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .detail-section { padding: 40px 28px 80px; position: relative; z-index: 1; }
    .detail-inner { max-width: 900px; margin: 0 auto; }

    /* 프로필 헤더 - 글래스 */
    .profile-header {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.58); border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 24px; padding: 32px; margin-bottom: 16px; position: relative;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .profile-top { margin-bottom: 24px; }
    .profile-top-row { display: flex; align-items: center; gap: 20px; margin-bottom: 12px; }
    .profile-avatar {
        width: 76px; height: 76px; border-radius: 50%;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        border: 3px solid rgba(255,255,255,.9);
        display: flex; align-items: center; justify-content: center;
        font-size: 28px; font-weight: 900; color: #fff; flex-shrink: 0;
        box-shadow: 0 4px 16px rgba(37,99,235,.2);
    }
    .profile-name-row { display: flex; align-items: center; gap: 10px; }
    .profile-name { font-size: 22px; font-weight: 900; color: #1e3a6e; }
    .cert-badge { font-size: 11px; background: #fffbeb; color: #b45309; border: 1px solid #fde68a; padding: 3px 10px; border-radius: 20px; font-weight: 700; }
    .wish-btn { border: none; background: none; cursor: pointer; font-size: 22px; transition: transform .2s; outline: none; }
    .wish-btn:hover { transform: scale(1.1); }
    .profile-career { font-size: 13px; color: #4a6fa5; line-height: 1.6; margin-bottom: 10px; }
    .profile-stars { color: #f59e0b; font-size: 15px; }
    .profile-stars span { color: #4a6fa5; font-size: 13px; font-weight: 500; }
    .chat-btn { display: inline-flex; align-items: center; gap: 6px; padding: 0; background: none; border: none; color: #2563eb; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; text-decoration: none; transition: color .15s; }
    .chat-btn:hover { color: #1d4ed8; text-decoration: underline; }
    .profile-stars span { color: #9ca3af; font-size: 13px; font-weight: 500; }

    .chat-action-wrap { display: flex; gap: 10px; margin-top: 14px; }
    .chat-action-card { flex: 1; display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: #f8f9fc; border: 1.5px solid #e2e5ef; border-radius: 14px; text-decoration: none; color: inherit; transition: border-color .15s, background .15s; cursor: pointer; }
    .chat-action-card:hover { border-color: #2563eb; background: #eff6ff; }
    .chat-action-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .msg-icon { background: transparent; color: #2563eb; }
    .live-icon { background: transparent; color: #16a34a; }
    .chat-action-title { font-size: 13px; font-weight: 800; color: #1c1e26; margin-bottom: 2px; }
    .chat-action-desc { font-size: 11px; color: #9ca3af; }

    .profile-stats { display: flex; gap: 0; border-top: 1px solid rgba(37,99,235,.08); padding-top: 20px; }
    .profile-stat { flex: 1; display: flex; align-items: center; gap: 12px; padding: 0 24px; border-right: 1px solid rgba(37,99,235,.08); }
    .profile-stat:first-child { padding-left: 0; }
    .profile-stat:last-child { border-right: none; }
    .profile-stat-icon { width: 40px; height: 40px; border-radius: 12px; background: rgba(37,99,235,.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #2563eb; }
    .profile-stat-val { font-size: 20px; font-weight: 900; color: #1e3a6e; line-height: 1; margin-bottom: 3px; }
    .profile-stat-lbl { font-size: 11px; color: #4a6fa5; }

    /* 섹션 카드 - 글래스 */
    .section-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.55); border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; padding: 24px; margin-bottom: 14px;
        box-shadow: 0 4px 20px rgba(37,99,235,.06);
    }
    .section-card-title { font-size: 15px; font-weight: 800; color: #1e3a6e; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid rgba(37,99,235,.08); }
    .introduce-text { font-size: 14px; color: #2d4a7a; line-height: 1.9; white-space: pre-wrap; }
    .skills-wrap { display: flex; gap: 8px; flex-wrap: wrap; }
    .skill-tag { padding: 6px 14px; background: rgba(37,99,235,.08); border: 1px solid rgba(37,99,235,.15); border-radius: 20px; font-size: 13px; font-weight: 600; color: #2563eb; }
    .portfolio-link { display: inline-flex; align-items: center; gap: 6px; color: #2563eb; font-size: 14px; font-weight: 600; text-decoration: none; }
    .portfolio-link:hover { text-decoration: underline; }

    /* 리뷰 */
    .review-list { display: flex; flex-direction: column; gap: 12px; }
    .review-item { padding: 16px 18px; background: rgba(255,255,255,.5); border-radius: 12px; border: 1px solid rgba(255,255,255,.8); }
    .review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .review-author { font-size: 13px; font-weight: 700; color: #1e3a6e; }
    .review-stars { color: #f59e0b; font-size: 13px; letter-spacing: 1px; }
    .review-content { font-size: 13px; color: #4a6fa5; line-height: 1.7; }
    .empty-review { text-align: center; padding: 30px 0; font-size: 14px; color: #93aecf; }

    .grade-badge { display: inline-flex; align-items: center; }
    .grade-badge-img { width: 114px; height: 114px; object-fit: contain; flex-shrink: 0; margin-top: 8px; }

    /* 북마크 */
    .bookmark-btn {
        position: absolute; top: 18px; right: 18px;
        width: 36px; height: 36px; border-radius: 50%;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(255,255,255,.9);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; z-index: 10; transition: all .2s;
        box-shadow: 0 2px 8px rgba(37,99,235,.08);
    }
    .bookmark-btn:hover { transform: scale(1.1); border-color: rgba(37,99,235,.3); background: rgba(255,255,255,.95); }
    .bookmark-btn svg { width: 16px; height: 16px; fill: none; stroke: #93aecf; stroke-width: 2; transition: all .2s; }
    .bookmark-btn.active { border-color: rgba(37,99,235,.4); background: rgba(37,99,235,.1); }
    .bookmark-btn.active svg { fill: #2563eb; stroke: #2563eb; }
</style>

<section class="detail-section">
    <div class="detail-inner">
        <div class="profile-header">
            <button class="bookmark-btn {{#expertProfile.bookmarked}}active{{/expertProfile.bookmarked}}" onclick="toggleBookmark(event, {{expertProfile.id}}, this)">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                </svg>
            </button>

            <div class="profile-top">
                <div class="profile-top-row">
                    <div class="profile-avatar" id="profileAvatar">{{expertProfile.memberName}}</div>
                    <div class="profile-name-row">
                        <span class="profile-name">{{expertProfile.memberName}}</span>
                        <div class="grade-badge-wrap">
                            {{#expertProfile.normal}}
                                <div class="grade-badge">
                                    <img src="/normal.png" class="grade-badge-img" alt="일반 전문가"/>
                                </div>
                            {{/expertProfile.normal}}
                            {{#expertProfile.skilled}}
                                <div class="grade-badge">
                                    <img src="/skilled.png" class="grade-badge-img" alt="숙련 전문가"/>
                                </div>
                            {{/expertProfile.skilled}}
                            {{#expertProfile.master}}
                                <div class="grade-badge">
                                    <img src="/master.png" class="grade-badge-img" alt="마스터 전문가"/>
                                </div>
                            {{/expertProfile.master}}
                        </div>
                        <button id="wishBtn" type="button" class="wish-btn" data-expert-id="{{expertProfile.memberId}}">
                            <span id="wishIcon">{{#isWished}}♥{{/isWished}}{{^isWished}}♡{{/isWished}}</span>
                        </button>
                    </div>
                </div>
                <div class="profile-career">{{expertProfile.career}}</div>
                <div class="profile-stars">★ <span>{{avgRating}} ({{reviews.size}}개 리뷰)</span></div>
                {{^isOwner}}
                <div class="chat-action-wrap">
                    <a href="/messages/send?receiverId={{expertProfile.memberId}}" class="chat-action-card">
                        <div class="chat-action-icon msg-icon">
                            <svg viewBox="0 0 16 16" width="22" height="22" xmlns="http://www.w3.org/2000/svg">
                                <rect x="1" y="3" width="14" height="1" fill="currentColor"/>
                                <rect x="1" y="3" width="1" height="9" fill="currentColor"/>
                                <rect x="14" y="3" width="1" height="9" fill="currentColor"/>
                                <rect x="1" y="11" width="14" height="1" fill="currentColor"/>
                                <rect x="2" y="4" width="1" height="1" fill="currentColor"/>
                                <rect x="3" y="5" width="1" height="1" fill="currentColor"/>
                                <rect x="4" y="6" width="1" height="1" fill="currentColor"/>
                                <rect x="5" y="7" width="1" height="1" fill="currentColor"/>
                                <rect x="6" y="8" width="1" height="1" fill="currentColor"/>
                                <rect x="7" y="9" width="1" height="1" fill="currentColor"/>
                                <rect x="8" y="9" width="1" height="1" fill="currentColor"/>
                                <rect x="9" y="8" width="1" height="1" fill="currentColor"/>
                                <rect x="10" y="7" width="1" height="1" fill="currentColor"/>
                                <rect x="11" y="6" width="1" height="1" fill="currentColor"/>
                                <rect x="12" y="5" width="1" height="1" fill="currentColor"/>
                                <rect x="13" y="4" width="1" height="1" fill="currentColor"/>
                            </svg>
                        </div>
                        <div>
                            <div class="chat-action-title">1:1 문의</div>
                            <div class="chat-action-desc">메시지로 문의하기</div>
                        </div>
                    </a>
                    <a href="/chat/start/expert/{{expertProfile.memberId}}" class="chat-action-card">
                        <div class="chat-action-icon live-icon">
                            <svg viewBox="0 0 16 16" width="22" height="22" xmlns="http://www.w3.org/2000/svg">
                                <rect x="3" y="1" width="10" height="1" fill="currentColor"/>
                                <rect x="2" y="2" width="1" height="1" fill="currentColor"/>
                                <rect x="13" y="2" width="1" height="1" fill="currentColor"/>
                                <rect x="1" y="3" width="1" height="7" fill="currentColor"/>
                                <rect x="14" y="3" width="1" height="7" fill="currentColor"/>
                                <rect x="2" y="10" width="1" height="1" fill="currentColor"/>
                                <rect x="13" y="10" width="1" height="1" fill="currentColor"/>
                                <rect x="3" y="11" width="10" height="1" fill="currentColor"/>
                                <rect x="3" y="12" width="1" height="1" fill="currentColor"/>
                                <rect x="3" y="13" width="1" height="1" fill="currentColor"/>
                                <rect x="2" y="14" width="1" height="1" fill="currentColor"/>
                                <rect x="5" y="5" width="2" height="2" fill="currentColor"/>
                                <rect x="8" y="5" width="2" height="2" fill="currentColor"/>
                                <rect x="11" y="5" width="2" height="2" fill="currentColor"/>
                            </svg>
                        </div>
                        <div>
                            <div class="chat-action-title">실시간 채팅</div>
                            <div class="chat-action-desc">지금 바로 대화하기</div>
                        </div>
                    </a>
                </div>
                    <a href="/messages/send?receiverId={{expertProfile.memberId}}" class="chat-btn">문의하기 →</a>
                    <a href="/chat/start/expert/{{expertProfile.memberId}}" class="chat-btn">실시간 채팅 →</a>
                {{/isOwner}}
            </div>

            <div class="profile-stats">
                <div class="profile-stat">
                    <div class="profile-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 22H2V2h20v20ZM4 20h16V4H4v16Zm7-4H9v-2h2v2Zm-2-2H7v-2h2v2Zm4 0h-2v-2h2v2Zm2-2h-2v-2h2v2Zm2-2h-2V8h2v2Z"/></svg></div>
                    <div>
                        <div class="profile-stat-val">{{doneProject}}</div>
                        <div class="profile-stat-lbl">완료 프로젝트</div>
                    </div>
                </div>
                <div class="profile-stat">
                    <div class="profile-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="#f59e0b"><path d="M13 23h-2v-4h2v4Zm-2-4H9v-4h2v4Zm4 0h-2v-4h2v4Zm-6-4H5v-2h4v2Zm10-2v2h-4v-2h4ZM5 13H1v-2h4v2Zm18 0h-4v-2h4v2ZM9 11H5V9h4v2Zm10 0h-4V9h4v2Zm-8-2H9V5h2v4Zm4 0h-2V5h2v4Zm-2-4h-2V1h2v4Z"/></svg></div>
                    <div>
                        <div class="profile-stat-val">{{avgRating}}</div>
                        <div class="profile-stat-lbl">평균 평점</div>
                    </div>
                </div>
                <div class="profile-stat">
                    <div class="profile-stat-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4 18h2v2H4v2H2V4h2v14Zm16 0H6v-2h14v2Zm2-2h-2V4h2v12Zm-12-2H6v-2h4v2Zm4-4H6V8h8v2Zm6-6H4V2h16v2Z"/></svg></div>
                    <div>
                        <div class="profile-stat-val">{{reviews.size}}</div>
                        <div class="profile-stat-lbl">리뷰 수</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-card">
            <div class="section-card-title">자기소개</div>
            <div class="introduce-text">{{expertProfile.intro}}</div>
        </div>

        <div class="section-card">
            <div class="section-card-title">기술 스택</div>
            <div class="skills-wrap">
                {{#expertProfile.skillList}}
                    <span class="skill-tag">{{.}}</span>
                {{/expertProfile.skillList}}
            </div>
        </div>

        <div class="section-card">
            <div class="section-card-title">포트폴리오</div>
            <a href="/portfolios?expertId={{expertProfile.memberId}}" class="portfolio-link">포트폴리오 보기</a>
        </div>

        <div class="section-card">
            <div class="section-card-title">리뷰 ({{reviews.size}})</div>
            <div class="review-list">
                {{#reviews}}
                    <div class="review-item">
                        <div class="review-header">
                            <span class="review-author">{{reviewerName}}</span>
                            <span class="review-stars">{{star}}</span>
                        </div>
                        <div class="review-content">{{content}}</div>
                    </div>
                {{/reviews}}
                {{^reviews}}
                    <div class="empty-review">아직 리뷰가 없습니다.</div>
                {{/reviews}}
            </div>
        </div>

    </div>
</section>

<script>
    document.getElementById('wishBtn').addEventListener('click', function(e) {
        e.preventDefault();
        const expertId = this.getAttribute('data-expert-id');
        const icon = document.getElementById('wishIcon');
        fetch(`/experts/wish/${expertId}`, { method: 'POST' })
        .then(response => {
            if (response.status === 401) {
                alert("로그인이 필요한 기능입니다.");
                window.location.href = "/login";
            } else if (response.ok) {
                icon.innerText = (icon.innerText === '♥') ? '♡' : '♥';
            } else {
                alert("처리 중 오류가 발생했습니다.");
            }
        })
        .catch(err => console.error("통신 에러:", err));
    });

    // 북마크
    function toggleBookmark(event, expertId, btn) {
        event.preventDefault();
        event.stopPropagation();

        fetch(`/bookmarks/toggle/${expertId}`, {
            method: 'POST',
            credentials: 'include'
        })
                .then(res => {
                    if (!res.ok) {
                        alert('에러 발생! HTTP 상태 코드: ' + res.status);
                        throw new Error('bookmark toggle failed');
                    }
                    return res.json();
                })
                .then(data => {
                    // 💡 서버에서 온 북마크 유무(true/false)에 따라 active 클래스 토글!
                    if (data.bookmarked) {
                        btn.classList.add('active');
                    } else {
                        btn.classList.remove('active');
                    }
                })
                .catch(err => console.error(err));
    }
</script>


<script>
    const pAvatar = document.getElementById('profileAvatar');
    if (pAvatar) {
        const t = pAvatar.textContent.trim();
        pAvatar.textContent = t ? t.charAt(0) : '?';
    }
</script>
{{> layout/footer}}
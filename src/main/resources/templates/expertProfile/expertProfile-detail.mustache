{{> layout/header}}

<style>
    .detail-section { padding: 52px 28px 80px; }
    .detail-inner { max-width: 900px; margin: 0 auto; }

    .profile-header { background: #fff; border: 1.5px solid #eaecf4; border-radius: 20px; padding: 32px; margin-bottom: 20px; }
    .profile-top { display: flex; gap: 20px; align-items: flex-start; margin-bottom: 24px; }
    .profile-avatar { width: 76px; height: 76px; border-radius: 50%; background: #eff6ff; border: 2px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 34px; flex-shrink: 0; }
    .profile-info { flex: 1; }
    .profile-name { font-size: 22px; font-weight: 900; color: #1c1e26; display: flex; align-items: center; gap: 10px; margin-bottom: 6px; flex-wrap: wrap; }
    .cert-badge { font-size: 11px; background: #fffbeb; color: #b45309; border: 1px solid #fde68a; padding: 3px 10px; border-radius: 20px; font-weight: 700; }
    .profile-career { font-size: 13px; color: #6b7280; line-height: 1.6; margin-bottom: 10px; }
    .profile-stars { color: #f59e0b; font-size: 15px; }
    .profile-stars span { color: #9ca3af; font-size: 13px; font-weight: 500; }

    .chat-btn { display: inline-flex; align-items: center; gap: 6px; padding: 0; background: none; border: none; color: #2563eb; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; text-decoration: none; flex-shrink: 0; transition: color .15s; }
    .chat-btn:hover { color: #1d4ed8; text-decoration: underline; }

    .profile-stats { display: flex; gap: 0; border-top: 1px solid #eaecf4; padding-top: 20px; }
    .profile-stat { flex: 1; display: flex; align-items: center; gap: 12px; padding: 0 24px; border-right: 1px solid #eaecf4; }
    .profile-stat:first-child { padding-left: 0; }
    .profile-stat:last-child { border-right: none; }
    .profile-stat-icon { width: 36px; height: 36px; border-radius: 10px; background: #eff6ff; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .profile-stat-val { font-size: 20px; font-weight: 900; color: #1c1e26; line-height: 1; margin-bottom: 3px; }
    .profile-stat-lbl { font-size: 11px; color: #9ca3af; }

    .section-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 14px; padding: 24px; margin-bottom: 16px; }
    .section-card-title { font-size: 15px; font-weight: 800; color: #1c1e26; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid #f3f4f8; }
    .introduce-text { font-size: 14px; color: #374151; line-height: 1.9; white-space: pre-wrap; }
    .skills-wrap { display: flex; gap: 8px; flex-wrap: wrap; }
    .skill-tag { padding: 6px 14px; background: #f8f9fc; border: 1px solid #e2e5ef; border-radius: 20px; font-size: 13px; font-weight: 600; color: #374151; }
    .portfolio-link { display: inline-flex; align-items: center; gap: 6px; color: #2563eb; font-size: 14px; font-weight: 600; text-decoration: none; }
    .portfolio-link:hover { text-decoration: underline; }

    .review-list { display: flex; flex-direction: column; gap: 14px; }
    .review-item { padding: 18px; background: #f8f9fc; border-radius: 12px; border: 1px solid #eaecf4; }
    .review-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .review-author { font-size: 13px; font-weight: 700; color: #1c1e26; }
    .review-stars { color: #f59e0b; font-size: 13px; letter-spacing: 1px; }
    .review-content { font-size: 13px; color: #6b7280; line-height: 1.7; }
    .empty-review { text-align: center; padding: 30px 0; font-size: 14px; color: #c4c9d9; }

    .grade-badge-wrap { display: inline-flex; align-items: center; }

    .grade-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px 4px 4px;
        border-radius: 40px;
        border: 1px solid transparent;
    }

    .grade-badge-img {
        width: 52px;      /* 가로 더 넓게 */
        height: 36px;     /* 높이 줄임 */
        object-fit: contain;
        flex-shrink: 0;
    }

    .grade-badge-info {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .grade-badge-level {
        font-family: 'JetBrains Mono', monospace;
        font-size: 8px;
        font-weight: 700;
        letter-spacing: 0.15em;
    }

    .grade-badge-name {
        font-size: 11px;
        font-weight: 700;
    }

    /* NORMAL */
    .grade-badge-normal {
        background: #f8f9fc;
        border-color: #e2e5ef;
    }
    .grade-badge-normal .grade-badge-level { color: #9ca3af; }
    .grade-badge-normal .grade-badge-name  { color: #6b7280; }

    /* SKILLED */
    .grade-badge-skilled {
        background: #fffbeb;
        border-color: #ebe4bc;
        box-shadow: 0 0 10px rgba(212, 168, 67, 0.15);
    }
    .grade-badge-skilled .grade-badge-level {
        color: #c4a848;
        letter-spacing: 0.18em;
    }
    .grade-badge-skilled .grade-badge-name {
        color: #e8c96a;
        font-weight: 900;
    }

    /* MASTER */
    .grade-badge-master {
        background: #0f0f1a;
        border-color: #f59e0b;
    }
    .grade-badge-master .grade-badge-level { color: #f59e0b; }
    .grade-badge-master .grade-badge-name  { color: #fcd34d; }
</style>

<section class="detail-section">
    <div class="detail-inner">

        <div class="profile-header">
            <div class="profile-top">
                <div class="profile-avatar">👨‍💻</div>
                <div class="profile-info">
                    <div class="profile-name">
                        {{expertProfile.memberName}}
                        <div class="grade-badge-wrap">
                            {{#expertProfile.normal}}
                                <div class="grade-badge grade-badge-normal">
                                    <img src="/badge-normal.png" class="grade-badge-img" alt="일반 전문가"/>
                                    <div class="grade-badge-info">
                                        <span class="grade-badge-level">LEVEL 1</span>
                                        <span class="grade-badge-name">일반 전문가</span>
                                    </div>
                                </div>
                            {{/expertProfile.normal}}

                            {{#expertProfile.skilled}}
                                <div class="grade-badge grade-badge-skilled">
                                    <img src="/badge-skilled.png" class="grade-badge-img" alt="숙련 전문가"/>
                                    <div class="grade-badge-info">
                                        <span class="grade-badge-level">LEVEL 2</span>
                                        <span class="grade-badge-name">숙련 전문가</span>
                                    </div>
                                </div>
                            {{/expertProfile.skilled}}

                            {{#expertProfile.master}}
                                <div class="grade-badge grade-badge-master">
                                    <img src="/badge-master.png" class="grade-badge-img" alt="마스터 전문가"/>
                                    <div class="grade-badge-info">
                                        <span class="grade-badge-level">LEVEL 3</span>
                                        <span class="grade-badge-name">마스터 전문가</span>
                                    </div>
                                </div>
                            {{/expertProfile.master}}
                        </div>
                    </div>
                    <div class="profile-career">{{expertProfile.career}}</div>
                    <div class="profile-stars">★ <span>{{avgRating}} ({{reviews.size}}개 리뷰)</span></div>
                    {{^isOwner}}
                        <a href="/messages/send?receiverId={{expertProfile.memberId}}" class="chat-btn">💬 문의하기 →</a>
                    {{/isOwner}}
                </div>
            </div>

            <div class="profile-stats">
                <div class="profile-stat">
                    <div class="profile-stat-icon">✅</div>
                    <div>
                        <div class="profile-stat-val">{{doneProject}}</div>
                        <div class="profile-stat-lbl">완료 프로젝트</div>
                    </div>
                </div>
                <div class="profile-stat">
                    <div class="profile-stat-icon">⭐</div>
                    <div>
                        <div class="profile-stat-val">{{avgRating}}</div>
                        <div class="profile-stat-lbl">평균 평점</div>
                    </div>
                </div>
                <div class="profile-stat">
                    <div class="profile-stat-icon">💬</div>
                    <div>
                        <div class="profile-stat-val">{{reviews.size}}</div>
                        <div class="profile-stat-lbl">리뷰 수</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="section-card">
            <div class="section-card-title">자기소개</div>
            <div class="introduce-text">{{expertProfile.intro}}</div>
        </div>

        <div class="section-card">
            <div class="section-card-title">기술 스택</div>
            <div class="skills-wrap">
                {{#expertProfile.skillList}}
                    <span class="skill-tag">{{.}}</span>
                {{/expertProfile.skillList}}
            </div>
        </div>

        <div class="section-card">
            <div class="section-card-title">포트폴리오</div>
            <a href="/portfolios?expertId={{expertProfile.memberId}}" class="portfolio-link">🔗 포트폴리오 보기</a>
        </div>

        <div class="section-card">
            <div class="section-card-title">리뷰 ({{reviews.size}})</div>
            <div class="review-list">
                {{#reviews}}
                    <div class="review-item">
                        <div class="review-header">
                            <span class="review-author">{{reviewerName}}</span>
                            <span class="review-stars">{{star}}</span>
                        </div>
                        <div class="review-content">{{content}}</div>
                    </div>
                {{/reviews}}
                {{^reviews}}
                    <div class="empty-review">아직 리뷰가 없습니다.</div>{{/reviews}}
            </div>
        </div>

    </div>
</section>

{{> layout/footer}}
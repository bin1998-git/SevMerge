{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 본문 ── */
    .list-content { flex: 1; padding: 24px 32px 32px; display: flex; flex-direction: column; }

    /* ── 액션 바 ── */
    .action-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .list-count { font-size: 14px; color: #4a6fa5; font-weight: 500; }
    .list-count strong { color: #1e3a6e; font-weight: 800; }

    /* ── 그리드 ── */
    .port-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px; margin-bottom: 32px;
    }

    /* ── 카드 (a 태그로 전체 클릭) ── */
    .port-card {
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 18px; overflow: hidden;
        display: flex; flex-direction: column;
        transition: transform .2s, box-shadow .2s, border-color .2s;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
        text-decoration: none; color: inherit;
        cursor: pointer;
    }
    .port-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(37,99,235,.12); border-color: rgba(37,99,235,.25); }

    .port-card-thumb {
        width: 100%; height: 190px;
        background: rgba(219,234,254,.4);
        display: flex; align-items: center; justify-content: center;
        font-size: 52px; overflow: hidden; flex-shrink: 0;
    }
    .port-card-thumb img { width: 100%; height: 100%; object-fit: cover; }

    .port-card-body { padding: 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }
    .port-card-title { font-size: 15px; font-weight: 800; color: #1e3a6e; line-height: 1.4; }
    .port-card-desc {
        font-size: 13px; color: #4a6fa5; line-height: 1.65;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
        flex: 1;
    }
    .port-card-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 14px; border-top: 1px solid rgba(37,99,235,.08); margin-top: auto;
    }
    .port-card-date { font-size: 11px; color: #93aecf; }
    .port-ext-link {
        font-size: 12px; font-weight: 700; color: #4a6fa5; text-decoration: none; transition: color .15s;
    }
    .port-ext-link:hover { color: #2563eb; }

    /* ── 빈 상태 ── */
    .empty-state {
        text-align: center; padding: 80px 0;
        border: 2px dashed rgba(37,99,235,.12); border-radius: 18px;
        background: rgba(255,255,255,.3); grid-column: span 3;
    }
    .empty-ico { font-size: 48px; margin-bottom: 16px; }
    .empty-msg { font-size: 15px; color: #93aecf; margin-bottom: 20px; }

    /* ── 버튼 ── */
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 20px; border-radius: 20px;
        font-size: 14px; font-weight: 700; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-sm { padding: 8px 16px; font-size: 13px; }
    .btn-cyan {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        padding: 11px 22px; border-radius: 20px;
        font-size: 14px; font-weight: 700; text-decoration: none;
        box-shadow: 0 4px 12px rgba(37,99,235,.25); transition: all .15s;
    }
    .btn-cyan:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }

    /* ── 페이지네이션 ── */
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: auto; padding-top: 24px; }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .page-btn {
        padding: 8px 16px; border-radius: 20px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        font-size: 13px; font-weight: 600; color: #4a6fa5; text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }

    @media (max-width: 960px) { .port-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .list-content { padding-left: 18px; padding-right: 18px; }
        .port-grid { grid-template-columns: 1fr; }
        .empty-state { grid-column: span 1; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">{{expertProfile.memberName}} 전문가의 포트폴리오</h1>
                <p class="board-desc">실력을 작업물로 직접 확인해보세요.</p>
            </div>
            {{#isOwner}}
            <a href="/portfolios/save?expertId={{expertProfile.id}}" class="btn btn-primary btn-sm">+ 포트폴리오 추가</a>
            {{/isOwner}}
        </div>

        <!-- 본문 -->
        <div class="list-content">

            <div class="action-bar">
                <span class="list-count">총 <strong>{{portfolioCount}}</strong>개의 포트폴리오</span>
            </div>

            <div class="port-grid">
                {{#portfolios}}
                <a href="/portfolios/{{id}}" class="port-card">
                    <div class="port-card-thumb">
                        {{#imageUrl}}
                        <img src="/images/portfolio/{{imageUrl}}" alt="{{title}}" onerror="this.parentElement.innerHTML='🖼️'" />
                        {{/imageUrl}}
                        {{^imageUrl}}🖼️{{/imageUrl}}
                    </div>
                    <div class="port-card-body">
                        <div class="port-card-title">{{title}}</div>
                        <div class="port-card-desc">{{description}}</div>
                        <div class="port-card-footer">
                            <span class="port-card-date">{{createdAt}}</span>
                            {{#projectUrl}}
                            <a href="{{projectUrl}}" target="_blank" class="port-ext-link" onclick="event.stopPropagation()">🔗 보러가기</a>
                            {{/projectUrl}}
                        </div>
                    </div>
                </a>
                {{/portfolios}}

                {{^portfolios}}
                <div class="empty-state">
                    <div class="empty-ico">🖼️</div>
                    <p class="empty-msg">아직 등록된 포트폴리오가 없습니다.</p>
                    {{#isOwner}}
                    <a href="/portfolios/save?expertId={{expertProfile.id}}" class="btn-cyan">첫 포트폴리오 등록하기</a>
                    {{/isOwner}}
                </div>
                {{/portfolios}}
            </div>

            <div class="pagination">
                {{#hasPrev}}<a href="/portfolios?expertId={{expertProfile.memberId}}&page={{prevPage}}" class="page-btn">← 이전</a>{{/hasPrev}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#hasNext}}<a href="/portfolios?expertId={{expertProfile.memberId}}&page={{nextPage}}" class="page-btn">다음 →</a>{{/hasNext}}
            </div>

        </div>
    </div>
</section>

{{> layout/footer}}

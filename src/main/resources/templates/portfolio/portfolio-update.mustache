{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 폼 본문 ── */
    .form-content { flex: 1; padding: 28px 32px 32px; }
    .save-form { display: flex; flex-direction: column; gap: 22px; }

    .form-group  { display: flex; flex-direction: column; gap: 8px; }
    .form-label  { font-size: 13px; font-weight: 700; color: #2d4a7a; }
    .form-label .required { color: #ef4444; margin-left: 2px; }

    .form-input, .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(12px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 10px;
        font-size: 14px; font-family: inherit; color: #1e3a6e;
        outline: none; transition: all .15s;
        box-shadow: inset 0 1px 3px rgba(37,99,235,.04);
    }
    .form-input::placeholder { color: #93aecf; }
    .form-input:focus, .form-textarea:focus {
        border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95);
        box-shadow: 0 0 0 3px rgba(37,99,235,.08);
    }
    .form-textarea { resize: vertical; min-height: 200px; line-height: 1.7; }
    .form-hint { font-size: 12px; color: #4a6fa5; }

    .img-preview {
        width: 100%; height: 200px;
        backdrop-filter: blur(8px); background: rgba(219,234,254,.35);
        border: 1.5px dashed rgba(147,197,253,.6);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 48px; overflow: hidden;
    }
    .img-preview img { width: 100%; height: 100%; object-fit: cover; }

    /* ── 버튼 ── */
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: 10px 22px; border-radius: 20px;
        font-size: 14px; font-weight: 700; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.25);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 16px rgba(37,99,235,.35); }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); color: #2563eb; }
    .btn-lg { padding: 13px 32px; font-size: 15px; border-radius: 25px; }

    @media (max-width: 600px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .form-content { padding-left: 18px; padding-right: 18px; }
        .form-btns { flex-direction: column; }
        .btn-lg { width: 100%; }
    }
    @media (max-width: 640px) {
        .save-section { padding: 24px 12px 60px; }
        .save-form { padding: 24px 16px; }
        .form-row { grid-template-columns: 1fr; }
        .form-btns { flex-direction: column; }
        .btn-lg { width: 100%; text-align: center; }
    }
    @media (max-width: 640px) {
        .save-section { padding: 24px 12px 60px; }
        .save-form { padding: 24px 16px; }
        .form-row { grid-template-columns: 1fr; }
        .form-btns { flex-direction: column; }
        .btn-lg { width: 100%; text-align: center; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">포트폴리오 수정</h1>
                <p class="board-desc">포트폴리오 정보를 수정합니다.</p>
            </div>
            <a href="/portfolios/{{portfolio.id}}" class="btn btn-outline" style="flex-shrink:0;">← 돌아가기</a>
        </div>

        <!-- 폼 본문 -->
        <div class="form-content">
            <form class="save-form" action="/portfolios/{{portfolio.id}}/update" method="POST" enctype="multipart/form-data">

                <div class="form-group">
                    <label class="form-label">제목 <span class="required">*</span></label>
                    <input type="text" name="title" class="form-input" value="{{portfolio.title}}" maxlength="100" />
                </div>

                <div class="form-group">
                    <label class="form-label">설명 <span class="required">*</span></label>
                    <textarea name="description" class="form-textarea">{{portfolio.description}}</textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">대표 이미지</label>
                    <div class="img-preview" id="imgPreview">
                        {{#portfolio.imageUrl}}
                        <img src="/images/portfolio/{{portfolio.imageUrl}}" alt="{{portfolio.title}}"
                             onerror="this.parentElement.innerHTML='🖼️'" />
                        {{/portfolio.imageUrl}}
                        {{^portfolio.imageUrl}}🖼️{{/portfolio.imageUrl}}
                    </div>
                    <input type="file" name="imageFile" class="form-input" />
                    <span class="form-hint">새 이미지를 선택하면 기존 이미지가 교체됩니다.</span>
                </div>

                <div class="form-group">
                    <label class="form-label">프로젝트 링크</label>
                    <input type="url" name="projectUrl" class="form-input"
                           value="{{portfolio.projectUrl}}" placeholder="https://github.com/..." />
                    <span class="form-hint">GitHub, 배포 사이트 등 관련 링크를 입력하세요.</span>
                </div>

                <div class="form-btns">
                    <a href="/portfolios/{{portfolio.id}}" class="btn btn-outline">취소</a>
                    <input type="hidden" name="expertId" value="{{portfolio.expertId}}" />
                    <button type="submit" class="btn btn-primary btn-lg">수정완료</button>
                </div>

            </form>
        </div>
    </div>
</section>

<script>
    document.querySelector('input[name="imageFile"]').addEventListener('change', function () {
        const preview = document.getElementById('imgPreview');
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.innerHTML = '<img src="' + e.target.result + '" alt="미리보기" />';
            };
            reader.readAsDataURL(file);
        } else {
            preview.innerHTML = '🖼️';
        }
    });
</script>

{{> layout/footer}}

{{> layout/header}}

<style>
    /* ══ 글래스모피즘 배경 ══ */
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        min-height: 100vh;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .bg-glow-3 { width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%); top: 40%; left: 30%; }

    .save-section { padding: 52px 28px 80px; position: relative; z-index: 1; }
    .save-inner { max-width: 760px; margin: 0 auto; }
    .save-header { margin-bottom: 32px; }
    .save-title { font-size: 24px; font-weight: 900; color: #0f172a; letter-spacing: -0.5px; margin-bottom: 6px; }
    .save-desc { font-size: 14px; color: #4a6fa5; }

    /* ══ 글래스 폼 카드 ══ */
    .save-form {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 24px; padding: 36px;
        display: flex; flex-direction: column; gap: 22px;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .save-form::before {
        content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-label { font-size: 13px; font-weight: 700; color: #1e293b; }
    .form-label .required { color: #ef4444; margin-left: 2px; }
    .form-input {
        padding: 13px 16px;
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.75);
        border-radius: 10px; font-size: 14px; font-family: inherit; color: #1e293b;
        outline: none; transition: all .15s;
        box-shadow: inset 0 1px 3px rgba(37,99,235,.04);
    }
    .form-input::placeholder { color: #94a3b8; }
    .form-input:focus { border-color: rgba(37,99,235,.5); background: rgba(255,255,255,.85); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
    .form-textarea {
        padding: 13px 16px;
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.75);
        border-radius: 10px; font-size: 14px; font-family: inherit; color: #1e293b;
        outline: none; resize: vertical; min-height: 200px; line-height: 1.7;
        transition: all .15s; box-shadow: inset 0 1px 3px rgba(37,99,235,.04);
    }
    .form-textarea:focus { border-color: rgba(37,99,235,.5); background: rgba(255,255,255,.85); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
    .form-hint { font-size: 12px; color: #64748b; }
    .img-preview {
        width: 100%; height: 200px;
        backdrop-filter: blur(8px);
        background: rgba(219,234,254,.35);
        border: 1.5px dashed rgba(147,197,253,.6);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 48px; margin-bottom: 8px; overflow: hidden;
    }
    .img-preview img { width: 100%; height: 100%; object-fit: cover; }
    .form-btns { display: flex; justify-content: flex-end; gap: 10px; margin-top: 8px; }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-primary { background: #2563eb; color: #fff; box-shadow: 0 4px 14px rgba(37,99,235,.3); }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(37,99,235,.4); }
    .btn-outline { backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.75); color: #334155; }
    .btn-outline:hover { border-color: rgba(37,99,235,.4); color: #2563eb; background: rgba(255,255,255,.85); }
    .btn-lg { padding: 14px 32px; font-size: 15px; border-radius: 10px; }
    /* ── FOOTER (exmain 스타일) ── */
    :root {
        --brand-blue:      #2D6BFF;
        --brand-blue-deep: #1846C9;
        --brand-sky:       #6BA0FF;
        --brand-ink:       #0C1424;
        --brand-slate:     #33415C;
        --brand-muted:     #5A6B85;
        --brand-mist:      #EBEEF4;
        --brand-line:      #E2E7F0;
        --brand-white:     #FFFFFF;
    }
    .footer {
        background: var(--brand-ink) !important;
        border-top: 1px solid rgba(255,255,255,.06) !important;
        padding: 40px 32px 28px !important;
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
    }
    .footer-brand-logo {
        font-size: 20px;
        font-weight: 800;
        color: rgba(255,255,255,.85);
        letter-spacing: .05em;
    }
    .footer-brand-logo span { color: var(--brand-sky); }
    .footer-actions { display: flex; gap: 8px; }
    .footer-actions .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.55);
        font-size: 13px;
        padding: 8px 16px;
        border-radius: 7px;
        transition: border-color .15s, color .15s;
    }
    .footer-actions .btn-outline:hover {
        border-color: var(--brand-sky);
        color: var(--brand-sky);
    }
    .footer-nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .footer-nav a {
        font-size: 13px;
        color: rgba(255,255,255,.45);
        transition: color .15s;
    }
    .footer-nav a:hover { color: rgba(255,255,255,.8); }
    .footer-nav-sep {
        display: inline-block;
        width: 1px;
        height: 12px;
        background: rgba(255,255,255,.15);
        vertical-align: middle;
    }
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,.07);
        flex-wrap: wrap;
        gap: 10px;
    }
    .footer-policy-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }
    .footer-policy-links a {
        font-size: 12px;
        color: rgba(255,255,255,.32);
        transition: color .15s;
    }
    .footer-policy-links a:hover { color: rgba(255,255,255,.6); }
    .footer-policy-strong {
        font-weight: 700;
        color: rgba(255,255,255,.5) !important;
    }
    .footer-hours-inline {
        font-size: 12px;
        color: rgba(255,255,255,.22);
    }
    .footer-copy {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--brand-muted) !important;
        letter-spacing: .02em;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="save-section">
    <div class="save-inner">

        <div class="save-header">
            <h1 class="save-title">포트폴리오 수정</h1>
            <p class="save-desc">포트폴리오 정보를 수정합니다.</p>
        </div>

        <form class="save-form" action="/portfolios/{{portfolio.id}}/update" method="POST"
              enctype="multipart/form-data">

            <div class="form-group">
                <label class="form-label">제목 <span class="required">*</span></label>
                <input type="text" name="title" class="form-input" value="{{portfolio.title}}" maxlength="100"/>
            </div>

            <div class="form-group">
                <label class="form-label">설명 <span class="required">*</span></label>
                <textarea name="description" class="form-textarea">{{portfolio.description}}</textarea>
            </div>

            <div class="form-group">
                <label class="form-label">대표 이미지</label>
                <div class="img-preview" id="imgPreview">
                    {{#portfolio.imageUrl}}
                        <img src="/images/portfolio/{{portfolio.imageUrl}}" alt="{{portfolio.title}}"
                             onerror="this.parentElement.innerHTML='🖼️'"/>
                    {{/portfolio.imageUrl}}
                    {{^portfolio.imageUrl}}
                        🖼️
                    {{/portfolio.imageUrl}}
                </div>
                <input type="file" name="imageFile" class="form-input" placeholder="이미지 파일을 올리세요"/>
                <span class="form-hint">이미지 파일을 입력하면 미리보기가 표시됩니다.</span>
            </div>

            <div class="form-group">
                <label class="form-label">프로젝트 링크</label>
                <input type="url" name="projectUrl" class="form-input" value="{{portfolio.projectUrl}}"
                       placeholder="https://github.com/..."/>
                <span class="form-hint">GitHub, 배포 사이트 등 관련 링크를 입력하세요.</span>
            </div>

            <div class="form-btns">
                <a href="/portfolios/{{portfolio.id}}" class="btn btn-outline">취소</a>
                <input type="hidden" name="expertId" value="{{portfolio.expertId}}"/>
                <button type="submit" class="btn btn-primary btn-lg">수정완료</button>
            </div>

        </form>
    </div>
</section>

<script>
    document.querySelector('input[name="imageFile"]').addEventListener('change', function () {
        const preview = document.getElementById('imgPreview');
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                preview.innerHTML = '<img src="' + e.target.result + '"alt="미리보기" />';
            };
            reader.readAsDataURL(file);
        } else {
            preview.innerHTML = '🖼️';
        }
    });
</script>

{{> layout/footer}}

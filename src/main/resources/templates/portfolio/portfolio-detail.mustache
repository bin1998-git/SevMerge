{{> layout/header}}

<style>
    :root {
        --navy: #0d1b2e; --cyan: #00c8e0; --cyan-dark: #00a8be;
        --blue: #2563eb; --blue-soft: #eff6ff;
        --gray: #6b7280; --gray-lt: #9ca3af;
        --border: #e5e7eb; --bg: #f0f4fa;
    }
    body { background: var(--bg); font-family: 'Noto Sans KR', sans-serif; }

    /* 배경 글로우 */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .bg-glow-3 { width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%); top: 40%; left: 30%; }

    .detail-wrap { max-width: 860px; margin: 0 auto; padding: 40px 28px 80px; position: relative; z-index: 1; }

    /* 브레드크럼 */
    .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--gray-lt); margin-bottom: 28px; }
    .breadcrumb a { color: var(--gray-lt); text-decoration: none; transition: color .15s; }
    .breadcrumb a:hover { color: var(--blue); }
    .breadcrumb span { color: #0f172a; font-weight: 600; }

    /* 카드 */
    .detail-card { background: #fff; border: 1.5px solid var(--border); border-radius: 20px; overflow: hidden; }

    /* 이미지 */
    .detail-img { width: 100%; height: 340px; background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%); display: flex; align-items: center; justify-content: center; font-size: 88px; overflow: hidden; }
    .detail-img img { width: 100%; height: 100%; object-fit: cover; }

    /* 바디 */
    .detail-body { padding: 36px; }
    .detail-title { font-size: 26px; font-weight: 900; color: #0f172a; letter-spacing: -.8px; margin-bottom: 20px; line-height: 1.3; }

    /* 메타 */
    .detail-meta { display: flex; align-items: center; gap: 16px; padding-bottom: 20px; margin-bottom: 24px; border-bottom: 1px solid #f3f4f8; }
    .detail-expert { display: flex; align-items: center; gap: 10px; }
    .expert-avatar { width: 38px; height: 38px; border-radius: 12px; background: var(--blue-soft); border: 1.5px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .expert-name { font-size: 14px; font-weight: 700; color: #374151; }
    .detail-date { font-size: 12px; color: var(--gray-lt); margin-left: auto; }

    /* 설명 */
    .detail-desc { font-size: 15px; color: #374151; line-height: 1.9; white-space: pre-wrap; margin-bottom: 28px; }

    /* 링크 박스 */
    .detail-link-box { display: flex; align-items: center; justify-content: space-between; background: var(--blue-soft); border: 1px solid #bfdbfe; border-radius: 12px; padding: 14px 20px; margin-bottom: 28px; }
    .detail-link-label { font-size: 13px; color: var(--gray); font-weight: 600; }
    .detail-link-url { font-size: 13px; color: var(--blue); font-weight: 700; text-decoration: none; transition: opacity .15s; }
    .detail-link-url:hover { opacity: .7; }
    .no-link { font-size: 13px; color: var(--gray-lt); margin-bottom: 28px; }

    /* 액션 푸터 */
    .detail-actions { display: flex; align-items: center; justify-content: space-between; padding-top: 20px; border-top: 1px solid #f3f4f8; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-outline { background: #fff; border: 1.5px solid var(--border); color: #4b5563; }
    .btn-outline:hover { border-color: var(--blue); color: var(--blue); }
    .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: 7px; }
    .btn-danger { background: #fff3f3; color: #ef4444; border: 1.5px solid #fecaca; }
    .btn-danger:hover { background: #fef2f2; border-color: #f87171; }
    .owner-btns { display: flex; gap: 8px; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<div class="detail-wrap">

    <!-- 브레드크럼 -->
    <div class="breadcrumb">
        <a href="/portfolios?expertId={{portfolio.expertId}}">← 포트폴리오 목록</a>
        <span>›</span>
        <span>{{portfolio.title}}</span>
    </div>

    <div class="detail-card">
        <!-- 이미지 -->
        <div class="detail-img">
            {{#portfolio.imageUrl}}
                <img src="/images/portfolio/{{portfolio.imageUrl}}" alt="{{portfolio.title}}"
                     onerror="this.parentElement.innerHTML='🖼️'" />
            {{/portfolio.imageUrl}}
            {{^portfolio.imageUrl}}🖼️{{/portfolio.imageUrl}}
        </div>

        <div class="detail-body">
            <h1 class="detail-title">{{portfolio.title}}</h1>

            <div class="detail-meta">
                <div class="detail-expert">
                    <div class="expert-avatar">👨‍💻</div>
                    <span class="expert-name">{{portfolio.expertName}}</span>
                </div>
                <span class="detail-date">{{portfolio.createdAt}}</span>
            </div>

            <div class="detail-desc">{{portfolio.description}}</div>

            {{#portfolio.projectUrl}}
                <div class="detail-link-box">
                    <span class="detail-link-label">🔗 프로젝트 링크</span>
                    <a href="{{portfolio.projectUrl}}" target="_blank" class="detail-link-url">
                        {{portfolio.projectUrl}}
                    </a>
                </div>
            {{/portfolio.projectUrl}}
            {{^portfolio.projectUrl}}
                <p class="no-link">등록된 프로젝트 링크가 없습니다.</p>
            {{/portfolio.projectUrl}}

            <div class="detail-actions">
                <a href="/portfolios?expertId={{portfolio.expertId}}" class="btn btn-outline">← 목록으로</a>
                {{#isOwner}}
                    <div class="owner-btns">
                        <a href="/portfolios/{{portfolio.id}}/edit" class="btn btn-outline btn-sm">✏️ 수정</a>
                        <form action="/portfolios/{{portfolio.id}}/delete" method="POST" style="display:inline;">
                            <input type="hidden" name="expertId" value="{{portfolio.expertId}}" />
                            <button type="submit" class="btn btn-sm btn-danger"
                                    onclick="return confirm('정말 삭제하시겠습니까?')">🗑️ 삭제</button>
                        </form>
                    </div>
                {{/isOwner}}
            </div>
        </div>
    </div>

</div>

{{> layout/footer}}

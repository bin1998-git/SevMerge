{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 빵크럼 ── */
    .breadcrumb {
        display: flex; align-items: center; gap: 8px;
        font-size: 13px; color: #93aecf;
        padding: 16px 32px 0;
    }
    .breadcrumb a { color: #93aecf; text-decoration: none; transition: color .15s; }
    .breadcrumb a:hover { color: #2563eb; }

    /* ── 본문 ── */
    .detail-content { flex: 1; padding: 24px 32px 32px; }

    /* ── 이미지 ── */
    .detail-img {
        width: 100%; height: 340px;
        background: rgba(219,234,254,.4);
        display: flex; align-items: center; justify-content: center;
        font-size: 88px; overflow: hidden; border-radius: 18px; margin-bottom: 28px;
    }
    .detail-img img { width: 100%; height: 100%; object-fit: cover; border-radius: 18px; }

    /* ── 타이틀 ── */
    .detail-title { font-size: 26px; font-weight: 900; color: #1e3a6e; letter-spacing: -.8px; margin-bottom: 20px; line-height: 1.3; }

    /* ── 메타 ── */
    .detail-meta {
        display: flex; align-items: center; gap: 16px;
        padding-bottom: 20px; margin-bottom: 24px;
        border-bottom: 1px solid rgba(37,99,235,.08);
    }
    .detail-expert { display: flex; align-items: center; gap: 10px; }
    .expert-avatar {
        width: 38px; height: 38px; border-radius: 12px;
        background: rgba(219,234,254,.6); border: 1.5px solid rgba(147,197,253,.4);
        display: flex; align-items: center; justify-content: center; font-size: 18px;
    }
    .expert-name { font-size: 14px; font-weight: 700; color: #2d4a7a; }
    .detail-date { font-size: 12px; color: #93aecf; margin-left: auto; }

    /* ── 설명 ── */
    .detail-desc { font-size: 15px; color: #2d4a7a; line-height: 1.9; white-space: pre-wrap; margin-bottom: 28px; }

    /* ── 링크 박스 ── */
    .detail-link-box {
        display: flex; align-items: center; justify-content: space-between;
        backdrop-filter: blur(8px); background: rgba(219,234,254,.35);
        border: 1px solid rgba(147,197,253,.4);
        border-radius: 12px; padding: 14px 20px; margin-bottom: 28px;
    }
    .detail-link-label { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .detail-link-url { font-size: 13px; color: #2563eb; font-weight: 700; text-decoration: none; transition: opacity .15s; }
    .detail-link-url:hover { opacity: .7; }
    .no-link { font-size: 13px; color: #93aecf; margin-bottom: 28px; }

    /* ── 액션 푸터 ── */
    .detail-actions {
        display: flex; align-items: center; justify-content: space-between;
        padding-top: 20px; border-top: 1px solid rgba(37,99,235,.08);
    }
    .owner-btns { display: flex; gap: 8px; }

    /* ── 버튼 ── */
    .btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 10px 20px; border-radius: 20px;
        font-size: 13px; font-weight: 700; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; text-decoration: none;
    }
    .btn-outline {
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
    }
    .btn-outline:hover { border-color: rgba(37,99,235,.3); color: #2563eb; background: rgba(255,255,255,.9); }
    .btn-sm { padding: 8px 16px; font-size: 13px; }
    .btn-danger {
        backdrop-filter: blur(8px); background: rgba(254,226,226,.6);
        border: 1.5px solid rgba(252,165,165,.5); color: #ef4444;
    }
    .btn-danger:hover { background: rgba(254,226,226,.9); border-color: #f87171; }

    @media (max-width: 768px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .breadcrumb, .detail-content { padding-left: 18px; padding-right: 18px; }
        .detail-img { height: 220px; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">포트폴리오 상세</h1>
                <p class="board-desc">{{portfolio.expertName}} 전문가의 작업물입니다.</p>
            </div>
            <a href="/portfolios?expertId={{portfolio.expertId}}" class="btn btn-outline btn-sm">← 목록으로</a>
        </div>

        <!-- 빵크럼 -->
        <div class="breadcrumb">
            <a href="/portfolios?expertId={{portfolio.expertId}}">포트폴리오</a>
            <span>›</span>
            <span style="color:#2d4a7a;font-weight:600;">{{portfolio.title}}</span>
        </div>

        <!-- 본문 -->
        <div class="detail-content">

            <!-- 이미지 -->
            <div class="detail-img">
                {{#portfolio.imageUrl}}
                <img src="/images/portfolio/{{portfolio.imageUrl}}" alt="{{portfolio.title}}"
                     onerror="this.parentElement.innerHTML='🖼️'" />
                {{/portfolio.imageUrl}}
                {{^portfolio.imageUrl}}🖼️{{/portfolio.imageUrl}}
            </div>

            <h1 class="detail-title">{{portfolio.title}}</h1>

            <div class="detail-meta">
                <div class="detail-expert">
                    <div class="expert-avatar">👨‍💻</div>
                    <span class="expert-name">{{portfolio.expertName}}</span>
                </div>
                <span class="detail-date">{{portfolio.createdAt}}</span>
            </div>

            <div class="detail-desc">{{portfolio.description}}</div>

            {{#portfolio.projectUrl}}
            <div class="detail-link-box">
                <span class="detail-link-label">🔗 프로젝트 링크</span>
                <a href="{{portfolio.projectUrl}}" target="_blank" class="detail-link-url">{{portfolio.projectUrl}}</a>
            </div>
            {{/portfolio.projectUrl}}
            {{^portfolio.projectUrl}}
            <p class="no-link">등록된 프로젝트 링크가 없습니다.</p>
            {{/portfolio.projectUrl}}

            <div class="detail-actions">
                <a href="/portfolios?expertId={{portfolio.expertId}}" class="btn btn-outline">← 목록으로</a>
                {{#isOwner}}
                <div class="owner-btns">
                    <a href="/portfolios/{{portfolio.id}}/edit" class="btn btn-outline btn-sm">✏️ 수정</a>
                    <form action="/portfolios/{{portfolio.id}}/delete" method="POST" style="display:inline;">
                        <input type="hidden" name="expertId" value="{{portfolio.expertId}}" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('정말 삭제하시겠습니까?')">🗑️ 삭제</button>
                    </form>
                </div>
                {{/isOwner}}
            </div>

        </div>
    </div>
</section>

{{> layout/footer}}

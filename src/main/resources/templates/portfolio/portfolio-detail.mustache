{{> layout/header}}

<style>
    /* ══ 글래스모피즘 배경 ══ */
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        min-height: 100vh;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .bg-glow-3 { width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%); top: 40%; left: 30%; }

    .detail-section { padding: 52px 28px 80px; position: relative; z-index: 1; }
    .detail-inner { max-width: 860px; margin: 0 auto; }
    .detail-nav { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #4a6fa5; margin-bottom: 32px; }
    .detail-nav a { color: #4a6fa5; text-decoration: none; transition: color .15s; }
    .detail-nav a:hover { color: #2563eb; }

    .portfolio-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.55);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 24px; overflow: hidden;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
        position: relative;
    }
    .portfolio-card::before {
        content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    }
    .portfolio-img { width: 100%; height: 320px; background: rgba(219,234,254,.4); display: flex; align-items: center; justify-content: center; font-size: 80px; overflow: hidden; }
    .portfolio-img img { width: 100%; height: 100%; object-fit: cover; }
    .portfolio-body { padding: 32px; }
    .portfolio-title { font-size: 24px; font-weight: 900; color: #0f172a; letter-spacing: -0.5px; margin-bottom: 16px; }
    .portfolio-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,.6); }
    .portfolio-expert { display: flex; align-items: center; gap: 10px; }
    .expert-avatar { width: 36px; height: 36px; border-radius: 50%; backdrop-filter: blur(8px); background: rgba(219,234,254,.6); border: 1px solid rgba(147,197,253,.5); display: flex; align-items: center; justify-content: center; font-size: 16px; }
    .expert-name { font-size: 13px; font-weight: 700; color: #1e293b; }
    .portfolio-date { font-size: 12px; color: #94a3b8; margin-left: auto; }
    .portfolio-desc { font-size: 15px; color: #334155; line-height: 1.9; white-space: pre-wrap; margin-bottom: 28px; }

    .portfolio-link-box {
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        background: rgba(219,234,254,.4);
        border: 1px solid rgba(147,197,253,.5);
        border-radius: 12px; padding: 14px 18px;
        display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px;
    }
    .portfolio-link-label { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .portfolio-link-url { font-size: 13px; color: #2563eb; font-weight: 600; text-decoration: none; }
    .portfolio-link-url:hover { text-decoration: underline; }

    .portfolio-actions { display: flex; justify-content: space-between; align-items: center; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.6); }

    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-outline {
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.75); color: #334155;
    }
    .btn-outline:hover { border-color: rgba(37,99,235,.4); color: #2563eb; background: rgba(255,255,255,.85); }
    .btn-sm { padding: 8px 16px; font-size: 13px; border-radius: 7px; }
    .btn-danger { backdrop-filter: blur(8px); background: rgba(254,226,226,.6); color: #dc2626; border: 1.5px solid rgba(252,165,165,.5); }
    .btn-danger:hover { background: rgba(254,226,226,.9); }
    .owner-btns { display: flex; gap: 8px; }
    /* ── FOOTER (exmain 스타일) ── */
    :root {
        --brand-blue:      #2D6BFF;
        --brand-blue-deep: #1846C9;
        --brand-sky:       #6BA0FF;
        --brand-ink:       #0C1424;
        --brand-slate:     #33415C;
        --brand-muted:     #5A6B85;
        --brand-mist:      #EBEEF4;
        --brand-line:      #E2E7F0;
        --brand-white:     #FFFFFF;
    }
    .footer {
        background: var(--brand-ink) !important;
        border-top: 1px solid rgba(255,255,255,.06) !important;
        padding: 40px 32px 28px !important;
    }
    .footer-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        flex-wrap: wrap;
    }
    .footer-brand-logo {
        font-size: 20px;
        font-weight: 800;
        color: rgba(255,255,255,.85);
        letter-spacing: .05em;
    }
    .footer-brand-logo span { color: var(--brand-sky); }
    .footer-actions { display: flex; gap: 8px; }
    .footer-actions .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,.18);
        color: rgba(255,255,255,.55);
        font-size: 13px;
        padding: 8px 16px;
        border-radius: 7px;
        transition: border-color .15s, color .15s;
    }
    .footer-actions .btn-outline:hover {
        border-color: var(--brand-sky);
        color: var(--brand-sky);
    }
    .footer-nav {
        display: flex;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }
    .footer-nav a {
        font-size: 13px;
        color: rgba(255,255,255,.45);
        transition: color .15s;
    }
    .footer-nav a:hover { color: rgba(255,255,255,.8); }
    .footer-nav-sep {
        display: inline-block;
        width: 1px;
        height: 12px;
        background: rgba(255,255,255,.15);
        vertical-align: middle;
    }
    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,.07);
        flex-wrap: wrap;
        gap: 10px;
    }
    .footer-policy-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }
    .footer-policy-links a {
        font-size: 12px;
        color: rgba(255,255,255,.32);
        transition: color .15s;
    }
    .footer-policy-links a:hover { color: rgba(255,255,255,.6); }
    .footer-policy-strong {
        font-weight: 700;
        color: rgba(255,255,255,.5) !important;
    }
    .footer-hours-inline {
        font-size: 12px;
        color: rgba(255,255,255,.22);
    }
    .footer-copy {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--brand-muted) !important;
        letter-spacing: .02em;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="detail-section">
    <div class="detail-inner">

        <div class="detail-nav">
            <a href="/portfolios?expertId={{portfolio.expertId}}">포트폴리오 목록</a>
            <span>›</span>
            <span>{{portfolio.title}}</span>
        </div>

        <div class="portfolio-card">
            <div class="portfolio-img">
                {{#portfolio.imageUrl}}
                <img src="/images/portfolio/{{portfolio.imageUrl}}" alt="{{portfolio.title}}" onerror="handleImageError(this)" />
                {{/portfolio.imageUrl}}
                {{^portfolio.imageUrl}}
                🖼️
                {{/portfolio.imageUrl}}
            </div>
            <div class="portfolio-body">
                <h1 class="portfolio-title">{{portfolio.title}}</h1>
                <div class="portfolio-meta">
                    <div class="portfolio-expert">
                        <div class="expert-avatar">👨‍💻</div>
                        <span class="expert-name">{{portfolio.expertName}}</span>
                    </div>
                    <span class="portfolio-date">{{portfolio.createdAt}}</span>
                </div>
                <div class="portfolio-desc">{{portfolio.description}}</div>
                {{#portfolio.projectUrl}}
                <div class="portfolio-link-box">
                    <span class="portfolio-link-label">🔗 프로젝트 링크</span>
                    <a href="{{portfolio.projectUrl}}" target="_blank" class="portfolio-link-url">{{portfolio.projectUrl}}</a>
                </div>
                {{/portfolio.projectUrl}}
                {{^portfolio.projectUrl}}
                    <span class="no-link">등록된 프로젝트가 없습니다.</span>
                {{/portfolio.projectUrl}}
                <div class="portfolio-actions">
                    <a href="/portfolios?expertId={{portfolio.expertId}}" class="btn btn-outline">← 목록으로</a>
                    {{#isOwner}}
                    <div class="owner-btns">
                        <a href="/portfolios/{{portfolio.id}}/edit" class="btn btn-outline btn-sm">수정</a>
                        <form action="/portfolios/{{portfolio.id}}/delete" method="POST" style="display:inline;">
                            <input type="hidden" name="expertId" value="{{portfolio.expertId}}" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="deleteButton(event)">삭제</button>
                        </form>
                    </div>
                    {{/isOwner}}
                </div>
            </div>
        </div>

    </div>
</section>
<script>

    function deleteButton(event) {
        if(!confirm("정말 삭제 하시겠습니까?")){
            event.preventDefault();
        }
    }

    function handleImageError(image) {
        // 이미지를 감싸고 있는 부모 div를 찾아서
        const container = image.parentElement;
        // 엑스박스 뜬 <img> 태그를 지우고 이모지(🖼️)로 대체합니다.
        container.innerHTML = '🖼️';
    }
</script>

{{> layout/footer}}

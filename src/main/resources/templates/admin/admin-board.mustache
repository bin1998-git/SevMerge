{{> layout/header}}

<style>
    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 64px);
    }

    .admin-sidebar {
        width: 220px;
        background: #fff;
        border-right: 1px solid #eaecf4;
        padding: 28px 0;
        flex-shrink: 0;
        position: sticky;
        top: 64px;
        height: calc(100vh - 64px);
    }

    .sidebar-label {
        font-size: 11px;
        font-weight: 700;
        color: #c4c9d9;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0 20px;
        margin-bottom: 8px;
        margin-top: 20px;
    }

    .sidebar-label:first-child {
        margin-top: 0;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        color: #6b7280;
        text-decoration: none;
        transition: all .12s;
        border-left: 3px solid transparent;
    }

    .sidebar-link:hover {
        color: #2563eb;
        background: #f8f9ff;
    }

    .sidebar-link.active {
        color: #2563eb;
        background: #eff6ff;
        border-left-color: #2563eb;
    }

    .sidebar-icon {
        font-size: 16px;
    }

    .admin-content {
        flex: 1;
        padding: 36px 36px 80px;
        background: #f5f6fa;
    }

    .admin-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .admin-title {
        font-size: 22px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .admin-desc {
        font-size: 14px;
        color: #9ca3af;
    }

    .search-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .search-input {
        flex: 1;
        padding: 11px 16px;
        background: #fff;
        border: 1.5px solid #e2e5ef;
        border-radius: 9px;
        font-size: 14px;
        font-family: inherit;
        color: #1c1e26;
        outline: none;
        max-width: 360px;
    }

    .search-input:focus {
        border-color: #2563eb;
        outline: none;
    }

    .search-btn {
        padding: 11px 22px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
    }

    .admin-table-wrap {
        background: #fff;
        border-radius: 14px;
        border: 1.5px solid #eaecf4;
        overflow: hidden;
    }

    /* 상단 헤더와 하단 로우의 전체 틀 FlexBox 설정 */
    .admin-table-head, .admin-table-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 22px;
    }

    .admin-table-head {
        background: #f8f9fc;
        border-bottom: 1px solid #eaecf4;
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .5px;
    }

    .admin-table-row {
        padding: 15px 22px;
        border-bottom: 1px solid #f3f4f8;
        font-size: 13px;
    }

    /* 1. 상단 헤더와 하단 데이터 줄 전체 틀 */
    .admin-table-head, .admin-table-row {
        display: flex !important;
        align-items: center !important;
        gap: 12px !important;
        padding: 15px 22px !important;
    }

    .admin-table-head {
        background: #f8f9fc !important;
        border-bottom: 1px solid #eaecf4 !important;
        font-size: 11px !important;
        font-weight: 700 !important;
        color: #9ca3af !important;
        letter-spacing: .5px !important;
    }

    .admin-table-row {
        border-bottom: 1px solid #f3f4f8 !important;
        font-size: 13px !important;
        background: #fff !important;
    }


    /* 2. 상하단 태그 종류 상관없이 순서대로 정중앙 배치 */

    /* [1번째 칸] No (번호) - 무조건 60px 고정 후 정중앙 */
    .admin-table-head > *:nth-child(1),
    .cell-id {
        width: 60px !important;
        flex-shrink: 0 !important;
        text-align: center !important;
    }

    /* [2번째 칸] 제목 - 남은 여백 다 차지하고 무조건 정중앙 + 말줄임 */
    .admin-table-head > *:nth-child(2),
    .cell-title {
        flex: 1 !important;
        min-width: 0 !important;
        text-align: center !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
    }

    /* [3번째 칸] 날짜 - 무조건 150px 고정 후 정중앙 */
    .admin-table-head > *:nth-child(3),
    .cell-date {
        width: 150px !important;
        flex-shrink: 0 !important;
        text-align: center !important;
    }


    .admin-table-row:last-child {
        border-bottom: none;
    }

    .admin-table-row:hover {
        background: #f8f9ff;
    }

    .cell-id {
        color: #c4c9d9;
        font-weight: 500;
    }

    .cell-name {
        font-weight: 700;
        color: #1c1e26;
    }

    .cell-email {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .cell-date {
        color: #9ca3af;
        font-size: 12px;
    }

    .role-admin {
        font-size: 11px;
        background: #fef3c7;
        color: #b45309;
        border: 1px solid #fde68a;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .role-member {
        font-size: 11px;
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .status-active {
        font-size: 11px;
        background: #ecfdf5;
        color: #059669;
        border: 1px solid #a7f3d0;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .del-btn {
        padding: 5px 12px;
        background: #fff3f3;
        color: #ef4444;
        border: 1px solid #fecaca;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
    }

    .del-btn:hover {
        background: #fee2e2;
    }

    .paging {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 24px;
    }

    .page-btn {
        padding: 9px 15px;
        border-radius: 8px;
        border: 1.5px solid #e2e5ef;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        background: #fff;
        text-decoration: none;
        transition: all .15s;
    }

    .page-btn:hover {
        border-color: #2563eb;
        color: #2563eb;
    }

    .page-btn.active {
        background: #2563eb;
        border-color: #2563eb;
        color: #fff;
    }
</style>

<div class="admin-wrap">

    <aside class="admin-sidebar">
        <div class="sidebar-label">관리자</div>
        <a href="/admin" class="sidebar-link"><span class="sidebar-icon">📊</span> 대시보드</a>
        <div class="sidebar-label">관리</div>
        <a href="/admin/members" class="sidebar-link active"><span class="sidebar-icon">👥</span> 회원 관리</a>
        <a href="/admin/projects" class="sidebar-link"><span class="sidebar-icon">📋</span> 프로젝트 관리</a>
        <a href="/admin/boards" class="sidebar-link"><span class="sidebar-icon">📑</span> 게시판 관리</a>
        <a href="/admin/experts" class="sidebar-link"><span class="sidebar-icon">⭐</span> 전문가 승인</a>
    </aside>

    <main class="admin-content">

        <div class="admin-header">
            <div>
                <h1 class="admin-title">자유 게시판 관리</h1>
                <p class="admin-desc">전체 게시판 목록을 관리합니다.</p>
            </div>
        </div>

        <form action="/admin/boards" method="get" class="search-bar">
            <input type="text" class="search-input" name="keyword" placeholder="제목 또는 이름으로 검색..." value=""/>
            <button type="submit" class="search-btn">검색</button>
        </form>



        <div class="admin-table-wrap">
            <div class="admin-table-head">
                <span>No</span><span>제목</span><span>날짜</span>
            </div>

            {{#boards}}
                <div class="admin-table-row">
                    <!-- 1. 글 번호 -->
                    <span class="cell-id">{{id}}</span>

                    <!-- 2. 제목 -->
                    <a href="/boards/{{id}}" class="cell-title" style="font-weight: 500; text-decoration: none; color: inherit;">
                        {{title}}
                    </a>


                    <!-- 4. 작성일 -->
                    <span class="cell-date">{{createdAt}}</span>


                </div>
            {{/boards}}
        </div>
    </main>
</div>

{{> layout/footer}}

{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .board-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* ── 헤더 바 ── */
    .board-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .board-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .board-desc  { font-size: 13px; color: #4a6fa5; }

    /* ── 탭 ── */
    .list-content { flex: 1; padding: 24px 32px 32px; display: flex; flex-direction: column; }
    .ar-tabs { display: flex; gap: 8px; margin-bottom: 20px; }
    .ar-tab {
        padding: 8px 18px; border-radius: 10px;
        font-size: 13px; font-weight: 700; text-decoration: none; color: #4a6fa5;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); transition: all .15s;
    }
    .ar-tab:hover { border-color: #93c5fd; color: #2563eb; }
    .ar-tab.active { background: #2563eb; color: #fff; border-color: #2563eb; }

    /* ── 테이블 래퍼 ── */
    .table-wrap {
        flex: 1;
        backdrop-filter: blur(16px); background: rgba(255,255,255,.45);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 16px; overflow: hidden;
    }

    /* ── 테이블 헤더 ── */
    .tbl-head {
        display: grid;
        grid-template-columns: 80px 100px 1fr 220px 90px 160px;
        padding: 13px 20px;
        background: rgba(37,99,235,.06);
        border-bottom: 1.5px solid rgba(37,99,235,.1);
        font-size: 12px; font-weight: 800; color: #4a6fa5; letter-spacing: .3px;
    }

    /* ── 테이블 행 ── */
    .tbl-row {
        display: grid;
        grid-template-columns: 80px 100px 1fr 220px 90px 160px;
        padding: 0 20px;
        align-items: center;
        border-bottom: 1px solid rgba(37,99,235,.06);
        transition: background .12s;
        min-height: 64px;
    }
    .tbl-row:last-child { border-bottom: none; }
    .tbl-row:hover { background: rgba(255,255,255,.55); }

    /* ── 셀 공통 ── */
    .tbl-cell { padding: 14px 8px; font-size: 13px; color: #2d4a7a; display: flex; align-items: center; }
    .tbl-cell:first-child { padding-left: 0; }
    .tbl-cell:last-child  { padding-right: 0; }

    /* 결제 ID */
    .cell-id { font-size: 12px; font-weight: 700; color: #93aecf; }

    /* 카테고리 */
    .ar-cat {
        font-size: 11px; font-weight: 700; color: #2563eb;
        background: rgba(37,99,235,.1); border: 1px solid rgba(37,99,235,.2);
        padding: 3px 9px; border-radius: 6px; white-space: nowrap;
    }

    /* 사유 */
    .cell-reason { flex-direction: column; align-items: flex-start; gap: 4px; }
    .reason-text {
        font-size: 13px; color: #2d4a7a; line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .reason-comment { font-size: 11px; color: #4a6fa5; }

    /* 의뢰인 → 전문가 */
    .cell-people { flex-direction: column; align-items: flex-start; gap: 3px; }
    .people-row  { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #1e3a6e; font-weight: 700; }
    .people-row span { font-size: 11px; color: #93aecf; font-weight: 400; }
    .people-date { font-size: 11px; color: #93aecf; }

    /* 상태 */
    .ar-status { font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 20px; white-space: nowrap; }
    .ar-status.pending  { background: #fffbeb; color: #b45309; border: 1px solid #fde68a; }
    .ar-status.approved { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .ar-status.rejected { background: #fff3f3; color: #ef4444; border: 1px solid #fecaca; }

    /* 액션 버튼 */
    .cell-actions { gap: 6px; justify-content: flex-end; }
    .ar-btn {
        padding: 7px 16px; border-radius: 20px;
        font-size: 12px; font-weight: 700; cursor: pointer;
        border: none; font-family: inherit; transition: all .15s; white-space: nowrap;
    }
    .ar-btn-approve {
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        box-shadow: 0 2px 8px rgba(37,99,235,.25);
    }
    .ar-btn-approve:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(37,99,235,.35); }
    .ar-btn-reject {
        background: rgba(255,255,255,.6); color: #ef4444;
        border: 1.5px solid #fecaca;
    }
    .ar-btn-reject:hover { background: #fff3f3; }

    /* 처리완료 텍스트 */
    .done-label { font-size: 12px; color: #93aecf; font-weight: 600; width: 100%; text-align: right; }

    /* ── 빈 상태 ── */
    .ar-empty {
        text-align: center; padding: 80px 0; color: #93aecf; font-size: 15px;
        border: 2px dashed rgba(37,99,235,.12); border-radius: 14px;
        background: rgba(255,255,255,.3); margin-bottom: 20px;
    }

    /* ── 페이지네이션 ── */
    .pagination {
        display: flex; justify-content: center; align-items: center;
        gap: 10px; padding-top: 20px; margin-top: auto;
    }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; }
    .page-btn {
        padding: 8px 16px; border-radius: 20px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        font-size: 13px; font-weight: 600; color: #4a6fa5; text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }

    /* ── 모달 ── */
    .ar-modal-bg { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.35); z-index: 9999; align-items: center; justify-content: center; }
    .ar-modal-bg.open { display: flex; }
    .ar-modal {
        backdrop-filter: blur(20px); background: rgba(255,255,255,.92);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 20px; padding: 28px;
        max-width: 440px; width: 90%; box-shadow: 0 12px 40px rgba(37,99,235,.12);
    }
    .ar-modal-title { font-size: 17px; font-weight: 900; color: #1e3a6e; margin-bottom: 6px; }
    .ar-modal-sub   { font-size: 13px; color: #4a6fa5; margin-bottom: 16px; }
    .ar-modal-textarea {
        width: 100%; box-sizing: border-box; padding: 12px 14px;
        border: 1.5px solid rgba(37,99,235,.15); border-radius: 10px;
        font-size: 14px; font-family: inherit; resize: vertical; min-height: 90px;
        background: rgba(255,255,255,.7); outline: none; transition: border-color .15s;
    }
    .ar-modal-textarea:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.95); }
    .ar-modal-btns { display: flex; justify-content: flex-end; gap: 8px; margin-top: 16px; }
    .ar-modal-cancel {
        padding: 9px 16px; border-radius: 20px; font-size: 13px; font-weight: 700;
        background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8);
        color: #4a6fa5; cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .ar-modal-cancel:hover { background: rgba(255,255,255,.9); color: #2d4a7a; }
    .ar-modal-confirm {
        padding: 9px 16px; border-radius: 20px; font-size: 13px; font-weight: 700;
        border: none; cursor: pointer; font-family: inherit; color: #fff; transition: all .15s;
    }
    .ar-modal-confirm:hover { transform: translateY(-1px); }

    @media (max-width: 900px) {
        .page-wrap { padding: 12px 12px 16px; }
        .board-header, .list-content { padding-left: 18px; padding-right: 18px; }
        .tbl-head { display: none; }
        .tbl-row  { grid-template-columns: 1fr; padding: 16px 18px; gap: 6px; }
        .cell-actions { justify-content: flex-start; }
    }
</style>

<section class="page-wrap">
    <div class="board-card">

        <!-- 헤더 -->
        <div class="board-header">
            <div>
                <h1 class="board-title">환불 신청 관리</h1>
                <p class="board-desc">의뢰인의 환불 신청을 검토하고 승인 또는 거절을 처리하세요.</p>
            </div>
        </div>

        <!-- 본문 -->
        <div class="list-content">

            <!-- 탭 -->
            <div class="ar-tabs">
                <a href="/admin/refund-applications?status=pending" class="ar-tab {{#isPendingFilter}}active{{/isPendingFilter}}">대기중만 보기</a>
                <a href="/admin/refund-applications"                class="ar-tab {{^isPendingFilter}}active{{/isPendingFilter}}">전체보기</a>
            </div>

            {{#applications}}
                <!-- 테이블 -->
                <div class="table-wrap">

                    <!-- 컬럼 헤더 -->
                    <div class="tbl-head">
                        <div>결제 ID</div>
                        <div>카테고리</div>
                        <div>환불 사유</div>
                        <div>의뢰인 → 전문가</div>
                        <div>상태</div>
                        <div style="text-align:right;">처리</div>
                    </div>

                    {{#applications}}
                        <div class="tbl-row">

                            <!-- 결제 ID -->
                            <div class="tbl-cell cell-id">#{{paymentId}}</div>

                            <!-- 카테고리 -->
                            <div class="tbl-cell">
                                <span class="ar-cat">{{reasonCategoryLabel}}</span>
                            </div>

                            <!-- 사유 + 관리자 의견 -->
                            <div class="tbl-cell cell-reason">
                                <span class="reason-text">{{reason}}</span>
                                {{#adminComment}}<span class="reason-comment">💬 {{adminComment}}</span>{{/adminComment}}
                            </div>

                            <!-- 의뢰인 → 전문가 + 날짜 -->
                            <div class="tbl-cell cell-people">
                                <div class="people-row">
                                    {{clientName}} <span>→</span> {{expertName}}
                                </div>
                                <span class="people-date">{{createdAt}}</span>
                            </div>

                            <!-- 상태 뱃지 -->
                            <div class="tbl-cell">
                        <span class="ar-status {{#isPending}}pending{{/isPending}}{{#isApproved}}approved{{/isApproved}}{{#isRejected}}rejected{{/isRejected}}">
                            {{#isPending}}대기중{{/isPending}}
                            {{#isApproved}}승인완료{{/isApproved}}
                            {{#isRejected}}거절됨{{/isRejected}}
                        </span>
                            </div>

                            <!-- 액션 -->
                            <div class="tbl-cell cell-actions">
                                {{#isPending}}
                                    <button type="button" class="ar-btn ar-btn-approve" onclick="openModal({{id}}, 'approve')">승인</button>
                                    <button type="button" class="ar-btn ar-btn-reject"  onclick="openModal({{id}}, 'reject')">거절</button>
                                {{/isPending}}
                                {{^isPending}}
                                    <span class="done-label">처리완료</span>
                                {{/isPending}}
                            </div>

                        </div>
                    {{/applications}}

                </div>
            {{/applications}}

            {{^applications}}
                <div class="ar-empty">환불 신청 내역이 없습니다.</div>
            {{/applications}}

            <!-- 페이지네이션 -->
            <div class="pagination">
                {{#prevPage}}<a href="/admin/refund-applications?page={{prevPage}}&status={{currentStatus}}" class="page-btn">← 이전</a>{{/prevPage}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#nextPage}}<a href="/admin/refund-applications?page={{nextPage}}&status={{currentStatus}}" class="page-btn">다음 →</a>{{/nextPage}}
            </div>

        </div>
    </div>
</section>

<!-- 승인/거절 모달 -->
<div class="ar-modal-bg" id="arModalBg">
    <div class="ar-modal">
        <h3 class="ar-modal-title" id="arModalTitle">처리 의견 입력</h3>
        <p class="ar-modal-sub"   id="arModalSub"></p>
        <textarea id="arModalComment" class="ar-modal-textarea" placeholder="의견을 입력해 주세요."></textarea>
        <div class="ar-modal-btns">
            <button type="button" class="ar-modal-cancel"  onclick="closeModal()">취소</button>
            <button type="button" class="ar-modal-confirm" id="arModalConfirmBtn" onclick="submitModal()">처리</button>
        </div>
    </div>
</div>

<script>
    let currentRefundId = null;
    let currentAction   = null;

    function openModal(id, action) {
        currentRefundId = id;
        currentAction   = action;
        document.getElementById("arModalComment").value = "";

        const title      = document.getElementById("arModalTitle");
        const sub        = document.getElementById("arModalSub");
        const confirmBtn = document.getElementById("arModalConfirmBtn");

        if (action === "approve") {
            title.textContent           = "환불 승인";
            sub.textContent             = "승인 시 즉시 환불 처리되고 전문가에게 알림이 발송됩니다. 의견은 선택사항이에요.";
            confirmBtn.textContent      = "승인하기";
            confirmBtn.style.background = "linear-gradient(135deg,#2563eb,#1d4ed8)";
        } else {
            title.textContent           = "환불 거절";
            sub.textContent             = "거절 사유는 의뢰인에게 전달돼요. 반드시 입력해 주세요.";
            confirmBtn.textContent      = "거절하기";
            confirmBtn.style.background = "#ef4444";
        }
        document.getElementById("arModalBg").classList.add("open");
    }

    function closeModal() {
        document.getElementById("arModalBg").classList.remove("open");
        currentRefundId = null;
        currentAction   = null;
    }

    function submitModal() {
        const comment = document.getElementById("arModalComment").value.trim();
        if (currentAction === "reject" && !comment) { alert("거절 사유는 필수입니다."); return; }

        const params = new URLSearchParams();
        if (comment) params.append("comment", comment);

        fetch(`/admin/refund-applications/${currentRefundId}/${currentAction}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params.toString()
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert(currentAction === "approve" ? "승인 처리되었습니다." : "거절 처리되었습니다.");
                location.reload();
            } else {
                alert("처리 실패: " + (data.message || "알 수 없는 오류"));
            }
        })
        .catch(err => { console.error(err); alert("통신 오류가 발생했습니다."); })
        .finally(closeModal);
    }

    document.getElementById("arModalBg").addEventListener("click", function(e) {
        if (e.target === this) closeModal();
    });
</script>

{{> layout/footer}}

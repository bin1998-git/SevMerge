{{> layout/header}}

<style>
    .admin-wrap { display: flex; min-height: calc(100vh - 64px); }
    .admin-sidebar { width: 220px; background: #fff; border-right: 1px solid #eaecf4; padding: 28px 0; flex-shrink: 0; position: sticky; top: 64px; height: calc(100vh - 64px); }
    .sidebar-label { font-size: 11px; font-weight: 700; color: #c4c9d9; letter-spacing: 1.5px; text-transform: uppercase; padding: 0 20px; margin-bottom: 8px; margin-top: 20px; }
    .sidebar-label:first-child { margin-top: 0; }
    .sidebar-link { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 14px; font-weight: 600; color: #6b7280; text-decoration: none; transition: all .12s; border-left: 3px solid transparent; }
    .sidebar-link:hover { color: #2563eb; background: #f8f9ff; }
    .sidebar-link.active { color: #2563eb; background: #eff6ff; border-left-color: #2563eb; }
    .sidebar-icon { font-size: 16px; }
    .admin-content { flex: 1; padding: 36px 36px 80px; background: #f5f6fa; }
    .admin-header { margin-bottom: 24px; }
    .admin-title { font-size: 22px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 4px; }
    .admin-desc { font-size: 14px; color: #9ca3af; }
    .filter-tabs { display: flex; gap: 6px; margin-bottom: 20px; }
    .tab { padding: 8px 18px; border-radius: 20px; border: 1.5px solid #e2e5ef; font-size: 13px; font-weight: 600; color: #6b7280; background: #fff; text-decoration: none; transition: all .15s; }
    .tab:hover { border-color: #2563eb; color: #2563eb; }
    .tab.active { background: #2563eb; border-color: #2563eb; color: #fff; }
    .expert-list { display: flex; flex-direction: column; gap: 14px; }
    .expert-card { background: #fff; border: 1.5px solid #eaecf4; border-radius: 14px; padding: 22px 24px; display: flex; gap: 18px; align-items: flex-start; }
    .expert-avatar { width: 52px; height: 52px; border-radius: 14px; background: #eff6ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
    .expert-body { flex: 1; }
    .expert-name-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .expert-name { font-size: 16px; font-weight: 800; color: #1c1e26; }
    .status-pending { font-size: 11px; background: #fef3c7; color: #b45309; border: 1px solid #fde68a; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-approved { font-size: 11px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-rejected { font-size: 11px; background: #fff3f3; color: #ef4444; border: 1px solid #fecaca; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .expert-email { font-size: 13px; color: #9ca3af; margin-bottom: 10px; }
    .expert-info-row { display: flex; gap: 20px; flex-wrap: wrap; font-size: 13px; color: #6b7280; margin-bottom: 10px; }
    .expert-info-row span { display: flex; align-items: center; gap: 4px; }
    .expert-portfolio { font-size: 13px; color: #2563eb; text-decoration: none; }
    .expert-portfolio:hover { text-decoration: underline; }
    .expert-actions { display: flex; gap: 8px; flex-shrink: 0; align-items: center; }
    .approve-btn { padding: 9px 18px; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .approve-btn:hover { background: #1d4ed8; }
    .reject-btn { padding: 9px 18px; background: #fff; color: #ef4444; border: 1.5px solid #fecaca; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .reject-btn:hover { background: #fff3f3; }
    .empty-state { text-align: center; padding: 60px 0; font-size: 15px; color: #c4c9d9; }
    .paging { display: flex; justify-content: center; gap: 6px; margin-top: 24px; }
    .page-btn { padding: 9px 15px; border-radius: 8px; border: 1.5px solid #e2e5ef; font-size: 13px; font-weight: 600; color: #6b7280; background: #fff; text-decoration: none; transition: all .15s; }
    .page-btn:hover { border-color: #2563eb; color: #2563eb; }
    .page-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
</style>

<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="sidebar-label">관리자</div>
        <a href="/admin" class="sidebar-link"><span class="sidebar-icon">📊</span> 대시보드</a>
        <div class="sidebar-label">관리</div>
        <a href="/admin/members" class="sidebar-link"><span class="sidebar-icon">👥</span> 회원 관리</a>
        <a href="/admin/projects" class="sidebar-link"><span class="sidebar-icon">📋</span> 프로젝트 관리</a>
        <a href="/admin/boards" class="sidebar-link"><span class="sidebar-icon">📑</span> 게시판 관리</a>
        <a href="/admin/experts" class="sidebar-link active"><span class="sidebar-icon">⭐</span> 전문가 승인</a>
    </aside>

    <main class="admin-content">
        <div class="admin-header">
            <h1 class="admin-title">전문가 승인 관리</h1>
            <p class="admin-desc">인증 전문가 신청을 검토하고 승인 또는 거절합니다.</p>
        </div>

        <div class="filter-tabs">
            <a href="/admin/experts" class="tab {{#isAll}}active{{/isAll}}">전체</a>
            <a href="/admin/experts?status=PENDING" class="tab {{#isPending}}active{{/isPending}}">대기중</a>
            <a href="/admin/experts?status=APPROVED" class="tab {{#isApproved}}active{{/isApproved}}">승인완료</a>
            <a href="/admin/experts?status=REJECTED" class="tab {{#isRejected}}active{{/isRejected}}">거절</a>
        </div>

        <div class="expert-list">
            {{#experts}}
                <div class="expert-card">
                    <div class="expert-avatar">👨‍💻</div>
                    <div class="expert-body">
                        <div class="expert-name-wrap">
                            <span class="expert-name">{{name}}</span>
                            {{#isPending}}<span class="status-pending">대기중</span>{{/isPending}}
                            {{#isApproved}}<span class="status-approved">⭐ 승인완료</span>{{/isApproved}}
                            {{#isRejected}}<span class="status-rejected">거절</span>{{/isRejected}}
                        </div>
                        <div class="expert-email">{{email}}</div>
                        <div class="expert-info-row">
                            <span>💼 {{career}}</span>
                            <span>📅 경력 {{experienceYears}}년</span>
                            <span>📝 신청일 {{appliedAt}}</span>
                        </div>
                        {{#portfolioUrl}}
                            <a href="{{portfolioUrl}}" target="_blank" class="expert-portfolio">🔗 포트폴리오 보기</a>
                        {{/portfolioUrl}}
                    </div>
                    {{#isPending}}
                        <div class="expert-actions">
                            <button type="button" class="approve-btn" onclick="updateExpertStatus({{id}}, 'approve')">승인</button>
                            <button type="button" class="reject-btn" onclick="updateExpertStatus({{id}}, 'reject')">거절</button>
                        </div>
                    {{/isPending}}
                </div>
            {{/experts}}

            {{^experts}}
                <div class="empty-state">신청 내역이 없습니다.</div>
            {{/experts}}
        </div>

        <div class="paging">
            {{#paging}}
                {{#hasPrev}}<a href="/admin/experts?page={{prevPage}}" class="page-btn">이전</a>{{/hasPrev}}
                {{#pageList}}<a href="/admin/experts?page={{num}}" class="page-btn {{#isCurrent}}active{{/isCurrent}}">{{num}}</a>{{/pageList}}
                {{#hasNext}}<a href="/admin/experts?page={{nextPage}}" class="page-btn">다음</a>{{/hasNext}}
            {{/paging}}
        </div>
    </main>
</div>

<script>
    function updateExpertStatus(id, action) {
        const actionMessage = action === 'approve' ? '승인' : '거절';
        if (!confirm(`해당 전문가 신청을 ${actionMessage}하시겠습니까?`)) {
            return;
        }

        // URI에 행위 동사를 제거하고 상태 수정을 위한 PATCH 요청 송신
        fetch(`/admin/experts/${id}/status?action=${action}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => {
            if (response.ok) {
                alert(`전문가 신청이 ${actionMessage}되었습니다.`);
                location.reload();
            } else {
                alert("처리 중 문제가 발생했습니다.");
            }
        })
        .catch(error => {
            console.error("Error:", error);
            alert("통신 오류가 발생했습니다.");
        });
    }
</script>
{{> layout/footer}}

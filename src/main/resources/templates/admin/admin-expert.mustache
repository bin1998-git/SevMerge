{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }
    .admin-wrap { display: flex; min-height: calc(100vh - 64px); }
    .admin-sidebar { width: 220px; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); background: rgba(255,255,255,.7); border-right: 1px solid rgba(255,255,255,.8); padding: 28px 0; flex-shrink: 0; position: sticky; top: 64px; height: calc(100vh - 64px); }
    .sidebar-label { font-size: 11px; font-weight: 700; color: #c4c9d9; letter-spacing: 1.5px; text-transform: uppercase; padding: 0 20px; margin-bottom: 8px; margin-top: 20px; }
    .sidebar-label:first-child { margin-top: 0; }
    .sidebar-link { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 14px; font-weight: 600; color: #6b7280; text-decoration: none; transition: all .12s; border-left: 3px solid transparent; }
    .sidebar-link:hover { color: #2563eb; background: rgba(239,246,255,.7); }
    .sidebar-link.active { color: #2563eb; background: rgba(239,246,255,.6); border-left-color: #2563eb; }
    .sidebar-icon { font-size: 16px; }
    .admin-content { flex: 1; padding: 36px 36px 80px; background: transparent; position: relative; z-index: 1; }
    .admin-header { margin-bottom: 24px; }
    .admin-title { font-size: 22px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 4px; }
    .admin-desc { font-size: 14px; color: #9ca3af; }
    .filter-tabs { display: flex; gap: 6px; margin-bottom: 20px; }
    .tab { padding: 8px 18px; border-radius: 20px; border: 1.5px solid rgba(255,255,255,.8); font-size: 13px; font-weight: 600; color: #6b7280; backdrop-filter: blur(8px); background: rgba(255,255,255,.6); text-decoration: none; transition: all .15s; }
    .tab:hover { border-color: #2563eb; color: #2563eb; }
    .tab.active { background: #2563eb; border-color: #2563eb; color: #fff; }
    .expert-list { display: flex; flex-direction: column; gap: 14px; }
    .expert-card { backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); border-radius: 14px; padding: 22px 24px; display: flex; gap: 18px; align-items: flex-start; box-shadow: 0 4px 24px rgba(37,99,235,.06); }
    .expert-avatar { width: 52px; height: 52px; border-radius: 14px; background: #eff6ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
    .expert-body { flex: 1; }
    .expert-name-wrap { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
    .expert-name { font-size: 16px; font-weight: 800; color: #1c1e26; }
    .status-pending { font-size: 11px; background: #fef3c7; color: #b45309; border: 1px solid #fde68a; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-approved { font-size: 11px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .status-rejected { font-size: 11px; background: #fff3f3; color: #ef4444; border: 1px solid #fecaca; padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .expert-email { font-size: 13px; color: #9ca3af; margin-bottom: 10px; }
    .expert-info-row { display: flex; gap: 20px; flex-wrap: wrap; font-size: 13px; color: #6b7280; margin-bottom: 10px; }
    .expert-info-row span { display: flex; align-items: center; gap: 4px; }
    .expert-portfolio { font-size: 13px; color: #2563eb; text-decoration: none; }
    .expert-portfolio:hover { text-decoration: underline; }
    .expert-actions { display: flex; gap: 8px; flex-shrink: 0; align-items: center; }
    .approve-btn { padding: 9px 18px; background: #2563eb; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .approve-btn:hover { background: #1d4ed8; }
    .reject-btn { padding: 9px 18px; background: #fff; color: #ef4444; border: 1.5px solid #fecaca; border-radius: 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; }
    .reject-btn:hover { background: #fff3f3; }
    .empty-state { text-align: center; padding: 60px 0; font-size: 15px; color: #c4c9d9; }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 24px; }
    .pagination .page-info { font-size: 13px; color: #6b7280; font-weight: 600; }
    .page-btn { padding: 9px 15px; border-radius: 8px; border: 1.5px solid rgba(255,255,255,.8); font-size: 13px; font-weight: 600; color: #6b7280; backdrop-filter: blur(8px); background: rgba(255,255,255,.6); text-decoration: none; transition: all .15s; }
    .page-btn:hover { border-color: #2563eb; color: #2563eb; }
    .page-btn.active { background: #2563eb; border-color: #2563eb; color: #fff; }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="admin-wrap">
    <main class="admin-content">
        <div class="admin-header">
            <h1 class="admin-title">전문가 승인 관리</h1>
            <p class="admin-desc">인증 전문가 신청을 검토하고 승인 또는 거절합니다.</p>
        </div>

        <div class="filter-tabs">
            <a href="/admin/experts" class="tab {{#isAll}}active{{/isAll}}">전체</a>
            <a href="/admin/experts?status=PENDING" class="tab {{#isPending}}active{{/isPending}}">대기중</a>
            <a href="/admin/experts?status=APPROVED" class="tab {{#isApproved}}active{{/isApproved}}">승인완료</a>
            <a href="/admin/experts?status=REJECTED" class="tab {{#isRejected}}active{{/isRejected}}">거절</a>
        </div>

        <div class="expert-list">
            {{#experts}}
                <div class="expert-card" id="expert-card-{{memberId}}">
                    <div class="expert-avatar">👨‍💻</div>
                    <div class="expert-body">
                        <div class="expert-name-wrap">
                            <span class="expert-name">{{memberName}}</span>

                            {{#isCertified}}<span class="status-approved">⭐ 인증 완료</span>{{/isCertified}}
                            {{^isCertified}}<span class="status-pending">대기중</span>{{/isCertified}}
                        </div>
                        <div class="expert-email">{{#contactEmail}}📧 {{contactEmail}}{{/contactEmail}}</div>

                        <div class="expert-info-row">
                            <span>💬 소개: {{intro}}</span>
                        </div>
                        <div class="expert-info-row">
                            <span>💼 경력: {{career}}</span>
                            <span>🛠️ 기술: {{speciality}}</span>
                        </div>

                        {{#githubUrl}}
                            <a href="{{githubUrl}}" target="_blank" class="expert-portfolio">🔗 GitHub 저장소 보기</a>
                        {{/githubUrl}}
                    </div>

                    {{^isCertified}}
                        {{#isPending}}
                            <div class="expert-actions">
                                <button type="button" class="approve-btn"
                                        onclick="updateExpertStatus({{memberId}}, 'approve')">승인</button>
                                <button type="button" class="reject-btn"
                                        onclick="updateExpertStatus({{memberId}}, 'reject')">거절</button>
                            </div>
                        {{/isPending}}
                        {{#isRejected}}
                            <div class="expert-actions">
                                <span style="font-size:13px;color:#ef4444;font-weight:700;">거절됨</span>
                            </div>
                        {{/isRejected}}
                    {{/isCertified}} </div>
            {{/experts}}

            {{^experts}}
                <div class="empty-state">신청 내역이 없습니다.</div>
            {{/experts}}
        </div>

        <div class="pagination">
            {{#prevPage}}<a href="/admin/experts?page={{prevPage}}&status={{currentStatus}}" class="page-btn">이전</a>{{/prevPage}}
            <span class="page-info">{{currentPage}} / {{totalPages}}</span>
            {{#nextPage}}<a href="/admin/experts?page={{nextPage}}&status={{currentStatus}}" class="page-btn">다음</a>{{/nextPage}}
        </div>
    </main>
</div>

<script>
    function updateExpertStatus(memberId, action) {
    const actionMessage = action === 'approve' ? '승인' : '거절';

    let reason = null;
    if (action === 'reject') {
        reason = prompt("거절 사유를 입력해 주세요.\n(전문가에게 안내됩니다)");
        if (reason === null) return;
        if (reason.trim() === "") {
            alert("거절 사유를 입력해 주세요.");
            return;
        }
    } else {
        if (!confirm(`해당 전문가 신청을 ${actionMessage}하시겠습니까?`)) return;
    }

    // body 구성: 거절일 때만 reason 포함
    const body = { action: action.toUpperCase() };
    if (action === 'reject') {
        body.reason = reason;
    }

    fetch(`/api/admin/experts/${memberId}/approval`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    })
    .then(response => {
        if (response.ok) {
            alert(`전문가 신청이 ${actionMessage}되었습니다.`);
            location.reload();
        } else {
            alert("처리 중 문제가 발생했습니다.");
        }
    })
    .catch(error => {
        console.error("Error:", error);
        alert("통신 오류가 발생했습니다.");
    });
}
</script>
{{> layout/footer}}


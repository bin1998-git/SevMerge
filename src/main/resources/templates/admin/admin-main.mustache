{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .admin-wrap {
        display: flex;
        align-items: flex-start;
        min-height: 0;
    }

    /* 사이드바 */
    .admin-sidebar {
        width: 220px;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.7);
        border-right: 1px solid rgba(255,255,255,.8);
        padding: 28px 0;
        flex-shrink: 0;
        position: sticky;
        top: 64px;
        height: calc(100vh - 64px);
    }

    .sidebar-label {
        font-size: 11px;
        font-weight: 700;
        color: #c4c9d9;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0 20px;
        margin-bottom: 8px;
        margin-top: 20px;
    }

    .sidebar-label:first-child {
        margin-top: 0;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        color: #6b7280;
        text-decoration: none;
        transition: all .12s;
        border-left: 3px solid transparent;
    }

    .sidebar-link:hover {
        color: #2563eb;
        background: rgba(239,246,255,.7);
    }

    .sidebar-link.active {
        color: #2563eb;
        background: rgba(239,246,255,.6);
        border-left-color: #2563eb;
    }

    .sidebar-icon {
        font-size: 16px;
    }

    /* 어드민 본문 */
    .admin-content {
        flex: 1;
        padding: 36px 36px 0;
        background: transparent;
        position: relative;
        z-index: 1;
    }

    .admin-header {
        margin-bottom: 28px;
    }

    .admin-title {
        font-size: 22px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .admin-desc {
        font-size: 14px;
        color: #9ca3af;
    }

    /* 통계 카드 */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 32px;
    }

    .stat-card {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,.8);
        padding: 22px 20px;
    }

    .stat-card-label {
        font-size: 12px;
        font-weight: 700;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 10px;
    }

    .stat-card-val {
        font-size: 30px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -1px;
        margin-bottom: 6px;
    }

    .stat-card-sub {
        font-size: 12px;
        color: #9ca3af;
    }

    .stat-card-sub .up {
        color: #059669;
        font-weight: 700;
    }

    .stat-card-sub .down {
        color: #ef4444;
        font-weight: 700;
    }

    /* 테이블 공통 */
    .admin-table-wrap {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,.8);
        box-shadow: 0 4px 24px rgba(37,99,235,.06);
        overflow: hidden;
    }

    .admin-table-header {
        padding: 18px 22px;
        border-bottom: 1px solid rgba(255,255,255,.6);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .admin-table-title {
        font-size: 15px;
        font-weight: 800;
        color: #1c1e26;
    }

    .admin-table-link {
        font-size: 13px;
        color: #2563eb;
        font-weight: 600;
        text-decoration: none;
    }

    .admin-table {
        width: 100%;
    }

    .admin-table-head {
        display: grid;
        padding: 11px 22px;
        background: rgba(255,255,255,.4);
        border-bottom: 1px solid rgba(255,255,255,.6);
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .5px;
    }

    .admin-table-row {
        display: grid;
        padding: 14px 22px;
        border-bottom: 1px solid rgba(255,255,255,.5);
        align-items: center;
        font-size: 13px;
        background: transparent;
    }

    .admin-table-row:last-child {
        border-bottom: none;
    }

    .admin-table-row:hover {
        background: rgba(239,246,255,.5);
    }

    .col-member {
        grid-template-columns: 40px 1fr 120px 100px 80px;
        gap: 12px;
    }

    .col-project {
        grid-template-columns: 40px 1fr 100px 100px 80px;
        gap: 12px;
    }

    .cell-id {
        color: #c4c9d9;
        font-weight: 500;
    }

    .cell-name {
        font-weight: 600;
        color: #1c1e26;
    }

    .cell-email {
        color: #9ca3af;
    }

    .cell-date {
        color: #c4c9d9;
    }

    .status-active {
        font-size: 11px;
        background: #ecfdf5;
        color: #059669;
        border: 1px solid #a7f3d0;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .status-wait {
        font-size: 11px;
        background: #f3f4f8;
        color: #9ca3af;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }
</style>
<script src="/webjars/chart.js/4.4.1/dist/chart.umd.js"></script>
<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="admin-wrap">


    <!-- 본문 -->
    <main class="admin-content">

        <div class="admin-header">
            <h1 class="admin-title">관리자 대시보드</h1>
            <p class="admin-desc">SevMerge 플랫폼 현황을 한눈에 확인하세요.</p>
        </div>

        <div class="dashboard-chart-flex-box"
             style="display: flex; flex-direction: row; gap: 24px; align-items: flex-start; width: 100%; max-width: none !important; margin: 0 !important; justify-content: flex-start !important; box-sizing: border-box;">

            <div class="dashboard-chart-flex-box"
                 style="display: flex; flex-direction: row; gap: 24px; align-items: stretch; width: 100%; max-width: none !important; margin: 0 0 24px 0 !important; justify-content: flex-start !important; box-sizing: border-box;">

                <div class="dashboard-sidebar"
                     style="width: 260px; height: auto; min-height: 0; background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,.8); border-radius: 12px; padding: 20px; box-sizing: border-box; display: flex; flex-direction: column; gap: 16px; flex-shrink: 0;">

                    <!-- 📅 달력 기간 선택 폼 -->
                    <form action="/admin/main" method="get"
                          style="display: flex; flex-direction: column; gap: 8px; margin: 0;">
                        <input type="hidden" name="roleFilter" value="{{roleFilter}}"/>
                        <span style="font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 2px;">📅 기간 설정</span>
                        <input type="date" name="startDate" value="{{startDate}}"
                               style="width: 100%; padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; color: #334155; font-size: 13px; cursor: pointer; background: #fff; box-sizing: border-box; height: 34px;">
                        <div style="text-align: center; color: #94a3b8; font-size: 12px; margin: -2px 0;">~</div>
                        <input type="date" name="endDate" value="{{endDate}}"
                               style="width: 100%; padding: 6px 10px; border: 1px solid #cbd5e1; border-radius: 6px; color: #334155; font-size: 13px; cursor: pointer; background: #fff; box-sizing: border-box; height: 34px;">
                        <button type="submit"
                                style="width: 100%; padding: 0; background-color: #0056ff; color: white; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 500; margin-top: 4px; height: 34px; line-height: 34px; text-align: center;">
                            기간 적용 조회
                        </button>
                    </form>

                    <div style="border-top: 1px solid #f1f5f9; margin: 0;"></div>

                    <!-- 📋 통계 메뉴 링크 목록 -->
                    <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
                        <span style="font-size: 12px; font-weight: 600; color: #64748b; margin-bottom: 2px;">📋 통계 메뉴</span>

                        <!-- 총 회원수 -->
                        <div style="display: flex; flex-direction: column; gap: 4px; width: 100%; position: relative;">
                            <div onclick="toggleMemberMenu()"
                                 style="display: flex; align-items: center; justify-content: space-between; padding: 0 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; color: #334155; font-size: 13px; font-weight: 500; height: 38px; line-height: 38px; box-sizing: border-box; width: 100%; cursor: pointer; user-select: none;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <span style="width: 8px; height: 8px; background: #0056ff; border-radius: 50%; flex-shrink: 0;"></span>
                                    총 회원수
                                </div>
                                <span id="menuArrow" style="font-size: 10px; color: #94a3b8; transition: transform 0.2s; transform: rotate(-90deg);">▼</span>
                            </div>
                            <div id="memberSubMenu"
                                 style="display: none; flex-direction: column; gap: 4px; padding: 8px; margin-top: 2px; position: absolute; top: 38px; left: 0; width: 100%; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px; z-index: 999; box-shadow: 0 4px 6px -1px rgba(0,0,0,.1); box-sizing: border-box;">
                                <a href="/admin/main?roleFilter=CLIENT&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• 일반 회원</a>
                                <a href="/admin/main?roleFilter=EXPERT&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• 전문가 목록</a>
                            </div>
                        </div>

                        <!-- 전체 프로젝트 -->
                        <div style="display: flex; flex-direction: column; gap: 4px; width: 100%; position: relative;">
                            <div onclick="toggleProjectMenu()"
                                 style="display: flex; align-items: center; justify-content: space-between; padding: 0 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; color: #334155; font-size: 13px; font-weight: 500; height: 38px; line-height: 38px; box-sizing: border-box; width: 100%; cursor: pointer; user-select: none;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <span style="width: 8px; height: 8px; background: #00b4d8; border-radius: 50%; flex-shrink: 0;"></span>
                                    전체 프로젝트
                                </div>
                                <span id="projectArrow" style="font-size: 10px; color: #94a3b8; transition: transform 0.2s; transform: rotate(-90deg);">▼</span>
                            </div>
                            <div id="projectSubMenu"
                                 style="display: none; flex-direction: column; gap: 4px; padding: 8px; margin-top: 2px; position: absolute; top: 38px; left: 0; width: 100%; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px; z-index: 999; box-shadow: 0 4px 6px -1px rgba(0,0,0,.1); box-sizing: border-box;">
                                <a href="/admin/main?projectType=WEB&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• WEB</a>
                                <a href="/admin/main?projectType=APP&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• APP</a>
                                <a href="/admin/main?projectType=UI_UX&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• UI / UX</a>
                                <a href="/admin/main?projectType=DATA&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• DATA</a>
                                <a href="/admin/main?projectType=VIDEO&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• VIDEO</a>
                                <a href="/admin/main?projectType=ETC&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• ETC</a>
                            </div>
                        </div>

                        <!-- 완료 프로젝트 -->
                        <div style="display: flex; flex-direction: column; gap: 4px; width: 100%; position: relative;">
                            <div onclick="toggleCompletedMenu()"
                                 style="display: flex; align-items: center; justify-content: space-between; padding: 0 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; color: #334155; font-size: 13px; font-weight: 500; height: 38px; line-height: 38px; box-sizing: border-box; width: 100%; cursor: pointer; user-select: none;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <span style="width: 8px; height: 8px; background: #03045e; border-radius: 50%; flex-shrink: 0;"></span>
                                    완료 프로젝트
                                </div>
                                <span id="completedArrow" style="font-size: 10px; color: #94a3b8; transition: transform 0.2s; transform: rotate(-90deg);">▼</span>
                            </div>
                            <div id="completedSubMenu"
                                 style="display: none; flex-direction: column; gap: 4px; padding: 8px; margin-top: 2px; position: absolute; top: 38px; left: 0; width: 100%; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px; z-index: 999; box-shadow: 0 4px 6px -1px rgba(0,0,0,.1); box-sizing: border-box;">
                                <a href="/admin/main?statusFilter=IN_PROGRESS&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• 진행중</a>
                                <a href="/admin/main?statusFilter=COMPLETED&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• 완료</a>
                                <a href="/admin/main?statusFilter=CANCELLED&startDate={{startDate}}&endDate={{endDate}}"
                                style="display: flex; align-items: center; padding: 0 12px; background: #ffffff; border: 1px solid #f1f5f9; border-radius: 6px; color: #475569; text-decoration: none; font-size: 12px; font-weight: 500; height: 32px; line-height: 32px; box-sizing: border-box;">• 취소</a>
                            </div>
                        </div>

                        <!-- 광고 수익 -->
                        <div style="display: flex; flex-direction: column; gap: 4px; width: 100%; position: relative;">
                            <a href="/admin/main?adRevenue=true&startDate={{startDate}}&endDate={{endDate}}"
                            style="display: flex; align-items: center; justify-content: space-between; padding: 0 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; color: #334155; font-size: 13px; font-weight: 500; height: 38px; line-height: 38px; box-sizing: border-box; width: 100%; text-decoration: none;">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="width: 8px; height: 8px; background: #f59e0b; border-radius: 50%; flex-shrink: 0;"></span>
                                광고 수익
                            </div>
                            </a>
                        </div>

                    </div>
                </div>


            <div class="main-chart-wrapper"
                 style="flex: 1 !important; min-width: 0 !important; width: auto !important; max-width: none !important; height: 500px !important; max-height: 500px !important; flex-shrink: 0; background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; margin: 0 !important; display: flex; flex-direction: column;">

                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; width: 100%; box-sizing: border-box; flex-shrink: 0;">
                    <button id="btn-total-status"
                            onclick="showAllCharts()"
                            style="display: flex; align-items: center; gap: 6px; padding: 6px 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 16px; font-weight: bold; color: #1a202c; cursor: pointer; transition: all 0.2s ease; outline: none; flex-shrink: 0;"
                            onmouseover="this.style.background='#f1f5f9'; this.style.borderColor='#cbd5e1';"
                            onmouseout="this.style.background='#f8fafc'; this.style.borderColor='#e2e8f0';"
                            onmousedown="this.style.transform='scale(0.97)';"
                            onmouseup="this.style.transform='scale(1)';">
                        📊 현황 통합 통계
                    </button>

                    <div style="display: flex; gap: 16px; font-size: 13px; font-weight: 500; margin-left: auto; justify-content: flex-end; align-items: center; flex-shrink: 0;">
                        {{#selectedProjectType}}
                            <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                <span style="width: 10px; height: 10px; background: #00b4d8; border-radius: 50%;"></span>
                                {{selectedProjectType}} 프로젝트수
                            </div>
                        {{/selectedProjectType}}

                        {{#isStatusFilterActive}}
                            <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                <span style="width: 10px; height: 10px; background: #03045e; border-radius: 50%;"></span>
                                {{statusChartName}}
                            </div>
                        {{/isStatusFilterActive}}

                        {{^isStatusAll}}
                            {{^selectedProjectType}}
                                {{^isStatusFilterActive}}
                                    <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                        <span style="width: 10px; height: 10px; background: #0056ff; border-radius: 50%;"></span>
                                        {{memberChartName}}
                                    </div>
                                {{/isStatusFilterActive}}
                            {{/selectedProjectType}}
                        {{/isStatusAll}}
                        {{#isAdRevenue}}
                            <div style="display:flex;align-items:center;gap:6px;white-space:nowrap;">
                                <span style="width:10px;height:10px;background:#f59e0b;border-radius:50%;"></span>
                                광고 수익(P)
                            </div>
                        {{/isAdRevenue}}

                        {{#isStatusAll}}
                            <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                <span style="width: 10px; height: 10px; background: #0056ff; border-radius: 50%;"></span>
                                {{memberChartName}}
                            </div>
                            <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                <span style="width: 10px; height: 10px; background: #00b4d8; border-radius: 50%;"></span>
                                전체 프로젝트
                            </div>
                            <div style="display: flex; align-items: center; gap: 6px; white-space: nowrap;">
                                <span style="width: 10px; height: 10px; background: #03045e; border-radius: 50%;"></span>
                                완료 프로젝트
                            </div>
                            <div style="display:flex;align-items:center;gap:6px;white-space:nowrap;">
                                <span style="width:10px;height:10px;background:#f59e0b;border-radius:50%;"></span>
                                광고 수익
                            </div>
                        {{/isStatusAll}}
                    </div>
                </div>

                <div style="flex: 1; width: 100%; min-height: 0; display: block; position: relative; box-sizing: border-box; margin: 0 !important; padding: 0 !important;">
                    <canvas id="integratedDashboardChart"
                            style="width: 100% !important; height: 100% !important; display: block;"></canvas>
                </div>
            </div>
        </div>
    </main>
</div>


<!-- 통계 -->
<div class="admin-content-bottom"
     style="width: 100%; max-width: none !important; box-sizing: border-box; display: flex; flex-direction: column; gap: 24px; margin: 0px 0 0 0 !important; padding: 0 40px 40px 40px !important; align-items: stretch; justify-content: flex-start; background: transparent !important; position: relative; ">

    <!-- 📊 1. 사각 통계 카드 그리드 -->
    <div class="stats-grid"
         style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 24px; width: 100%; box-sizing: border-box; margin: 0 !important; padding: 0 !important;">
        <div class="stat-card" style="background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; width: 100%;">
            <div class="stat-card-label">전체 회원</div>
            <div class="stat-card-val">{{stats.size}}</div>
            <div class="stat-card-sub">이번 달 <span class="up">+{{newMemberCount}}</span></div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; width: 100%;">
            <div class="stat-card-label">전체 프로젝트</div>
            <div class="stat-card-val">{{projectCount}}</div>
            <div class="stat-card-sub">진행 중 {{activeProjectCount}}개</div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; width: 100%;">
            <div class="stat-card-label">완료 프로젝트</div>
            <div class="stat-card-val">{{completedCount}}</div>
            <div class="stat-card-sub">이번 달 <span class="up">+{{newCompletedCount}}</span></div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; width: 100%;">
            <div class="stat-card-label">승인 대기 전문가</div>
            <div class="stat-card-val">{{pendingExpertCount}}</div>
            <div class="stat-card-sub"><a href="/admin/experts" style="color:#2563eb; font-weight:700; text-decoration: none;">승인하러 가기 →</a></div>
        </div>
        <div class="stat-card" style="background: rgba(255,255,255,.6); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px; padding: 24px; box-sizing: border-box; width: 100%;">
            <div class="stat-card-label">광고 총 수익</div>
            <div class="stat-card-val" style="color:#d97706;">{{totalAdRevenue}}P</div>
            <div class="stat-card-sub">이번 달 <span class="up">+{{thisMonthAdRevenue}}P</span></div>
        </div>
    </div>

    <!-- 최근 가입 회원 -->
    <div class="admin-table-wrap">
        <div class="admin-table-header">
            <span class="admin-table-title">최근 가입 회원</span>
            <a href="/admin/members" class="admin-table-link">전체 보기 →</a>
        </div>
        <div class="admin-table-head col-member">
            <span>No</span><span>이름 / 이메일</span><span>가입일</span><span>권한</span><span>상태</span>
        </div>
        {{#recentMembers}}
            <div class="admin-table-row col-member">
                <span class="cell-id">{{id}}</span>
                <div>
                    <div class="cell-name">{{name}}</div>
                    <div class="cell-email">{{email}}</div>
                </div>
                <span class="cell-date">{{createdAt}}</span>
                <span>{{roleName}}</span>
                <span><span class="status-active">활성</span></span>
            </div>
        {{/recentMembers}}
    </div>

    <!-- 최근 등록 프로젝트 -->
    <div class="admin-table-wrap">
        <div class="admin-table-header">
            <span class="admin-table-title">최근 등록 프로젝트</span>
            <a href="/admin/projects" class="admin-table-link">전체 보기 →</a>
        </div>
        <div class="admin-table-head col-project">
            <span>No</span><span>프로젝트명</span><span>등록자</span><span>등록일</span><span>상태</span>
        </div>
        {{#recentProjects}}
            <div class="admin-table-row col-project">
                <span class="cell-id">{{id}}</span>
                <span class="cell-name">{{title}}</span>
                <span>{{memberName}}</span>
                <span class="cell-date">{{createdAt}}</span>
                <span><span class="status-active">모집중</span></span>
            </div>
        {{/recentProjects}}
    </div>

</div>
</main>
<script>
    function toggleMemberMenu() {
        const memberMenu = document.getElementById('memberSubMenu');
        const memberArrow = document.getElementById('menuArrow');

        closeProjectMenu();
        closeCompletedMenu();

        if (memberMenu.style.display === 'none' || memberMenu.style.display === '') {
            memberMenu.style.display = 'flex';
            memberArrow.style.transform = 'rotate(0deg)';
        } else {
            memberMenu.style.display = 'none';
            memberArrow.style.transform = 'rotate(-90deg)';
        }
    }

    function toggleProjectMenu() {
        const projectMenu = document.getElementById('projectSubMenu');
        const projectArrow = document.getElementById('projectArrow');

        closeMemberMenu();
        closeCompletedMenu();

        if (projectMenu.style.display === 'none' || projectMenu.style.display === '') {
            projectMenu.style.display = 'flex';
            projectArrow.style.transform = 'rotate(0deg)';
        } else {
            projectMenu.style.display = 'none';
            projectArrow.style.transform = 'rotate(-90deg)';
        }
    }

    function toggleCompletedMenu() {
        const completedMenu = document.getElementById('completedSubMenu');
        const completedArrow = document.getElementById('completedArrow');

        closeMemberMenu();
        closeProjectMenu();

        if (completedMenu.style.display === 'none' || completedMenu.style.display === '') {
            completedMenu.style.display = 'flex';
            completedArrow.style.transform = 'rotate(0deg)';
        } else {
            completedMenu.style.display = 'none';
            completedArrow.style.transform = 'rotate(-90deg)';
        }
    }

    function closeMemberMenu() {
        const menu = document.getElementById('memberSubMenu');
        const arrow = document.getElementById('menuArrow');
        if (menu) menu.style.display = 'none';
        if (arrow) arrow.style.transform = 'rotate(-90deg)';
    }

    function closeProjectMenu() {
        const menu = document.getElementById('projectSubMenu');
        const arrow = document.getElementById('projectArrow');
        if (menu) menu.style.display = 'none';
        if (arrow) arrow.style.transform = 'rotate(-90deg)';
    }

    function closeCompletedMenu() {
        const menu = document.getElementById('completedSubMenu');
        const arrow = document.getElementById('completedArrow');
        if (menu) menu.style.display = 'none';
        if (arrow) arrow.style.transform = 'rotate(-90deg)';
    }

    function showAllCharts() {
        // 1. 열려있는 모든 왼쪽 서브메뉴를 닫아 시각적 초기화
        closeMemberMenu();
        closeProjectMenu();
        closeCompletedMenu();

        const urlParams = new URLSearchParams(window.location.search);
        const startDate = urlParams.get('startDate') || '';
        const endDate = urlParams.get('endDate') || '';

        let targetUrl = '/admin/main';
        if (startDate && endDate) {
            targetUrl += `?startDate=${startDate}&endDate=${endDate}`;
        }
        window.location.href = targetUrl;
    }
</script>
</div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('integratedDashboardChart').getContext('2d');

        const chartLabels = [ {{#chartLabels}} "{{.}}", {{/chartLabels}} ""].filter(item => item !== "");
        const memberData = [ {{#memberData}} {{.}}, {{/memberData}} null].filter(item => item !== null);
        const projectData = [ {{#projectData}} {{.}}, {{/projectData}} null].filter(item => item !== null);
        const completedData = [ {{#completedData}} {{.}}, {{/completedData}} null].filter(item => item !== null);

        console.log("Labels:", chartLabels);
        console.log("Members:", memberData);

        const currentRole = '{{roleFilter}}';

        const urlParams = new URLSearchParams(window.location.search);
        const projectType = urlParams.get('projectType');
        const statusFilter = urlParams.get('statusFilter');

        let chartDatasets = [];
    const adRevenue = urlParams.get('adRevenue');
        if (adRevenue === 'true') {
    chartDatasets.push({
        label: '광고 수익(P)',
        data: [ {{#adRevenueData}} {{.}}, {{/adRevenueData}} null].filter(i => i !== null),
        borderColor: '#f59e0b',
        backgroundColor: 'rgba(245,158,11,0.10)',
        borderWidth: 2,
        pointBackgroundColor: '#f59e0b',
        pointRadius: 4,
        pointHoverRadius: 6,
        fill: true,
        tension: 0.1
    });
        }else if (projectType && projectType !== '') {
            chartDatasets.push({
                label: projectType + ' 프로젝트수',
                data: projectData,
                borderColor: '#00b4d8',
                backgroundColor: 'rgba(0, 180, 216, 0.12)',
                borderWidth: 2,
                pointBackgroundColor: '#00b4d8',
                pointRadius: 4,
                pointHoverRadius: 6,
                fill: true,
                tension: 0.1
            });
        } else if (statusFilter && statusFilter !== 'ALL' && statusFilter !== '') {
            chartDatasets.push({
                label: '{{statusChartName}}',
                data: completedData, // 완료 프로젝트용 리스트 데이터 바인딩
                borderColor: '#03045e',
                backgroundColor: 'rgba(3, 4, 94, 0.1)',
                borderWidth: 2,
                pointBackgroundColor: '#03045e',
                pointRadius: 4,
                pointHoverRadius: 6,
                fill: true,
                tension: 0.1
            });
        } else {
            chartDatasets.push({
                label: '{{memberChartName}}',
                data: memberData,
                borderColor: '#0056ff',
                backgroundColor: 'rgba(0, 86, 255, 0.12)',
                borderWidth: 2,
                pointBackgroundColor: '#0056ff',
                pointRadius: 4,
                pointHoverRadius: 6,
                fill: true,
                tension: 0.1
            });

            if (!currentRole || currentRole === 'ALL' || currentRole === '') {
                chartDatasets.push({
                    label: '전체 프로젝트',
                    data: projectData,
                    borderColor: '#00b4d8',
                    backgroundColor: 'rgba(0, 180, 216, 0.12)',
                    borderWidth: 2,
                    pointBackgroundColor: '#00b4d8',
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.1
                });
                chartDatasets.push({
                    label: '완료 프로젝트',
                    data: completedData,
                    borderColor: '#03045e',
                    backgroundColor: 'rgba(3, 4, 94, 0.1)',
                    borderWidth: 2,
                    pointBackgroundColor: '#03045e',
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.1
                });
                chartDatasets.push({
                    label: '광고 수익(P)',
                    data: [ {{#adRevenueData}} {{.}}, {{/adRevenueData}} null].filter(i => i !== null),
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245,158,11,0.10)',
                    borderWidth: 2,
                    pointBackgroundColor: '#f59e0b',
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.1
                });
            }
        }

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartLabels,
                datasets: chartDatasets
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {legend: {display: false}},
                scales: {
                    x: {grid: {color: '#f0f2f5'}, ticks: {color: '#718096', font: {size: 11}}},
                    y: {
                        grid: {color: '#f0f2f5'}, min: 0, ticks: {
                            color: '#718096', font: {size: 11}, callback: function (value) {
                                if (value % 1 === 0) {
                                    return Math.floor(value);
                                }
                            }
                        }
                    }
                }
            }
        });
    });
</script>
{{> layout/footer}}

{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 64px);
    }

    .admin-content {
        flex: 1;
        padding: 36px 36px 80px;
        background: transparent;
        position: relative;
        z-index: 1;
    }

    .admin-header {
        margin-bottom: 24px;
    }

    .admin-title {
        font-size: 22px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .admin-desc {
        font-size: 14px;
        color: #9ca3af;
    }

    .admin-table-wrap {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,.8);
        box-shadow: 0 4px 24px rgba(37,99,235,.06);
        overflow: hidden;
    }

    .admin-table-head {
        display: grid;
        grid-template-columns: 60px 1fr 120px 160px 120px 160px;
        gap: 12px;
        padding: 12px 22px;
        background: rgba(255,255,255,.4);
        border-bottom: 1px solid rgba(255,255,255,.6);
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .5px;
    }

    .admin-table-row {
        display: grid;
        grid-template-columns: 60px 1fr 120px 160px 120px 160px;
        gap: 12px;
        padding: 15px 22px;
        border-bottom: 1px solid rgba(255,255,255,.5);
        align-items: center;
        font-size: 13px;
        background: transparent;
    }

    .admin-table-row:last-child {
        border-bottom: none;
    }

    .admin-table-row:hover {
        background: rgba(239,246,255,.5);
    }

    .cell-id {
        color: #c4c9d9;
        font-weight: 500;
        text-align: center;
    }

    .cell-date {
        color: #9ca3af;
        font-size: 12px;
        text-align: center;
    }

    .status-pending {
        font-size: 11px;
        background: #fef9c3;
        color: #92400e;
        border: 1px solid #fde68a;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .status-approved {
        font-size: 11px;
        background: #ecfdf5;
        color: #059669;
        border: 1px solid #a7f3d0;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .status-rejected {
        font-size: 11px;
        background: #fff3f3;
        color: #ef4444;
        border: 1px solid #fecaca;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .btn-approve {
        padding: 5px 12px;
        background: #ecfdf5;
        color: #059669;
        border: 1px solid #a7f3d0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
    }
    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 24px; }
    .pagination .page-info { font-size: 13px; color: #6b7280; font-weight: 600; }
    .page-btn { padding: 9px 15px; border-radius: 8px; backdrop-filter: blur(8px); background: rgba(255,255,255,.6); border: 1.5px solid rgba(255,255,255,.8); font-size: 13px; font-weight: 600; color: #6b7280; text-decoration: none; transition: all .15s; }
    .page-btn:hover { border-color: #93c5fd; color: #2563eb; background: rgba(255,255,255,.9); }

    .btn-reject {
        padding: 5px 12px;
        background: #fff3f3;
        color: #ef4444;
        border: 1px solid #fecaca;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        margin-left: 4px;
    }

    .btn-approve:hover {
        background: #d1fae5;
    }

    .btn-reject:hover {
        background: #fee2e2;
    }

    .action-btns {
        display: flex;
        gap: 4px;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="admin-wrap">
    <main class="admin-content">
        <div class="admin-header">
            <h1 class="admin-title">제휴 문의 관리</h1>
            <p class="admin-desc">접수된 제휴 문의를 승인하거나 거절합니다.</p>
        </div>

        <div class="admin-table-wrap">
            <div class="admin-table-head">
                <span>No</span>
                <span>회사명 / 이메일</span>
                <span>담당자</span>
                <span>신청일</span>
                <span>상태</span>
                <span>처리</span>
            </div>
            {{#partnerships}}
                <div class="admin-table-row">
                    <span class="cell-id">{{id}}</span>
                    <div>
                        <div style="font-weight:700; color:#1c1e26;">{{companyName}}</div>
                        <div style="color:#9ca3af; font-size:12px;">{{email}}</div>
                    </div>
                    <span>{{managerName}}</span>
                    <span class="cell-date">{{createdAt}}</span>
                    <span>
                    {{#isPending}}<span class="status-pending">대기</span>{{/isPending}}
                        {{#isApproved}}
                            <span class="status-approved">승인</span>
                        {{/isApproved}}

                        {{#isRejected}}
                            <span class="status-rejected">거절</span>
                        {{/isRejected}}

                </span>
                    <div class="action-btns">
                        <form action="/admin/partnerships/{{id}}/approve" method="post" style="display:inline;">
                            <button type="submit" class="btn-approve" >승인</button>
                        </form>
                        {{^isRejected}}
                        <form action="/admin/partnerships/{{id}}/reject" method="post" style="display:inline;">
                            <button type="submit" class="btn-reject">거절</button>
                        </form>
                        {{/isRejected}}
                        {{#isRejected}}
                            <form action="/admin/partnerships/{{id}}/delete" method="post" style="display:inline;">
                                <button type="submit" class="btn-reject">삭제</button>
                            </form>
                        {{/isRejected}}
                    </div>
                </div>
            {{/partnerships}}
        </div>
        <div class="pagination">
            {{#prevPage}}<a href="/admin/partnerships?page={{prevPage}}" class="page-btn">이전</a>{{/prevPage}}
            <span class="page-info">{{currentPage}} / {{totalPages}}</span>
            {{#nextPage}}<a href="/admin/partnerships?page={{nextPage}}" class="page-btn">다음</a>{{/nextPage}}
        </div>
    </main>
</div>

{{> layout/footer}}
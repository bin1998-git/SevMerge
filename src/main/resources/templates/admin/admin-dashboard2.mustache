<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>SevMerge — Admin Analytics</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
<style>
:root {
    --black:   #06030d;
    --dp1:     #0e0720;
    --dp2:     #160c2e;
    --gc:      rgba(255,255,255,0.05);
    --gc-h:    rgba(255,255,255,0.09);
    --bdr:     rgba(255,255,255,0.08);
    --bdr-b:   rgba(167,139,250,0.30);
    --v9:      #4c1d95;
    --v7:      #7c3aed;
    --v5:      #8b5cf6;
    --v4:      #a78bfa;
    --v3:      #c4b5fd;
    --v1:      #ede9fe;
    --pk:      #ec4899;
    --pk-l:    #f9a8d4;
    --fus:     #d946ef;
    --rose:    #f43f5e;
    --amber:   #f59e0b;
    --cyan:    #06b6d4;
    --emerald: #10b981;
    --t1: #f5f3ff;
    --t2: rgba(255,255,255,0.60);
    --t3: rgba(255,255,255,0.32);
    --t4: rgba(255,255,255,0.14);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; }
body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--black);
    color: var(--t1);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: hidden;
}

/* ─── AMBIENT ─── */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
        radial-gradient(ellipse 70% 55% at 10% 20%, rgba(124,58,237,0.22) 0%, transparent 55%),
        radial-gradient(ellipse 50% 45% at 90% 75%, rgba(236,72,153,0.14) 0%, transparent 50%),
        radial-gradient(ellipse 40% 35% at 60% 10%, rgba(217,70,239,0.10) 0%, transparent 45%);
    pointer-events: none;
    z-index: 0;
}
body > * { position: relative; z-index: 1; }

/* ─── TOPBAR ─── */
.tb {
    height: 54px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 28px;
    background: rgba(6,3,13,0.90);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--bdr);
    flex-shrink: 0;
    position: sticky;
    top: 0;
    z-index: 200;
}
.tb-left { display: flex; align-items: center; gap: 10px; }
.tb-gem {
    width: 28px; height: 28px;
    border-radius: 7px;
    background: linear-gradient(135deg, var(--v7), var(--pk));
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 900; color: #fff;
}
.tb-name { font-size: 14px; font-weight: 800; letter-spacing: -0.3px; }
.tb-sep { width: 1px; height: 18px; background: var(--bdr); margin: 0 10px; }
.tb-page { font-size: 12px; color: var(--v3); font-weight: 600; }
.tb-right { display: flex; align-items: center; gap: 12px; }
.tb-tag {
    font-size: 10px; font-weight: 700;
    border-radius: 5px;
    padding: 3px 9px;
    letter-spacing: .5px;
}
.tb-tag.live { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.3); }
.tb-tag.v { background: rgba(139,92,246,0.15); color: var(--v3); border: 1px solid rgba(139,92,246,0.3); }
.tb-time { font-size: 11px; color: var(--t3); font-variant-numeric: tabular-nums; }
.tb-ava {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--v7), var(--fus));
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
    border: 1.5px solid var(--v4);
}

/* ─── SPLIT LAYOUT ─── */
.split {
    display: flex;
    flex: 1;
    min-height: 0;
}

/* ──────── LEFT PANEL ──────── */
.lp {
    width: 300px;
    flex-shrink: 0;
    background: rgba(14,7,32,0.70);
    backdrop-filter: blur(12px);
    border-right: 1px solid var(--bdr);
    overflow-y: auto;
    padding: 28px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 28px;
}
.lp::-webkit-scrollbar { width: 4px; }
.lp::-webkit-scrollbar-thumb { background: var(--v9); border-radius: 2px; }

/* BIG METRIC RING */
.ring-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
}
.ring-outer {
    position: relative;
    width: 120px;
    height: 120px;
}
.ring-svg { transform: rotate(-90deg); }
.ring-track { fill: none; stroke: var(--bdr); stroke-width: 8; }
.ring-fill { fill: none; stroke-width: 8; stroke-linecap: round; transition: stroke-dashoffset .6s ease; }
.ring-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.ring-val { font-size: 24px; font-weight: 900; letter-spacing: -1px; line-height: 1; }
.ring-sub { font-size: 9px; color: var(--t3); font-weight: 600; text-transform: uppercase; letter-spacing: .8px; margin-top: 2px; }
.ring-label { font-size: 11px; font-weight: 700; color: var(--t2); text-align: center; }
.ring-delta { font-size: 10px; color: var(--t3); }
.ring-delta .up { color: #34d399; font-weight: 700; }
.ring-delta .dn { color: var(--rose); font-weight: 700; }

.lp-divider { height: 1px; background: var(--bdr); }

/* MINI METRIC ROW */
.mm-row { display: flex; flex-direction: column; gap: 14px; }
.mm-item { display: flex; align-items: center; gap: 12px; }
.mm-icon {
    width: 36px; height: 36px; border-radius: 9px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
}
.mi-v  { background: rgba(124,58,237,0.18); }
.mi-pk { background: rgba(236,72,153,0.15); }
.mi-fu { background: rgba(217,70,239,0.15); }
.mi-cy { background: rgba(6,182,212,0.15); }
.mi-am { background: rgba(245,158,11,0.15); }
.mi-em { background: rgba(16,185,129,0.15); }
.mm-body { flex: 1; min-width: 0; }
.mm-label { font-size: 11px; color: var(--t3); font-weight: 600; margin-bottom: 3px; text-transform: uppercase; letter-spacing: .5px; }
.mm-val { font-size: 18px; font-weight: 900; line-height: 1; letter-spacing: -0.5px; }
.mm-bar { height: 3px; background: var(--bdr); border-radius: 2px; margin-top: 6px; overflow: hidden; }
.mm-bar-fill { height: 100%; border-radius: 2px; }
.fill-v { background: linear-gradient(90deg, var(--v7), var(--v4)); }
.fill-pk { background: linear-gradient(90deg, #be185d, var(--pk)); }
.fill-fu { background: linear-gradient(90deg, #a21caf, var(--fus)); }
.fill-cy { background: linear-gradient(90deg, #0e7490, var(--cyan)); }
.fill-am { background: linear-gradient(90deg, #b45309, var(--amber)); }
.fill-em { background: linear-gradient(90deg, #047857, var(--emerald)); }

/* ALERT CHIPS */
.chip-list { display: flex; flex-direction: column; gap: 6px; }
.chip {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 12px;
    border-radius: 9px;
    font-size: 12px; font-weight: 600;
    border: 1px solid;
    text-decoration: none;
    color: inherit;
    transition: all .15s;
}
.chip:hover { transform: translateX(3px); }
.chip-rose { background: rgba(244,63,94,0.08); border-color: rgba(244,63,94,0.25); color: #fda4af; }
.chip-amber { background: rgba(245,158,11,0.08); border-color: rgba(245,158,11,0.25); color: #fcd34d; }
.chip-v { background: rgba(139,92,246,0.10); border-color: rgba(139,92,246,0.28); color: var(--v3); }
.chip-count { margin-left: auto; font-size: 14px; font-weight: 900; }

/* ──────── RIGHT PANEL ──────── */
.rp {
    flex: 1;
    overflow-y: auto;
    padding: 28px 32px 60px;
    display: flex;
    flex-direction: column;
    gap: 26px;
    min-width: 0;
}
.rp::-webkit-scrollbar { width: 4px; }
.rp::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.4); border-radius: 2px; }

/* PAGE TITLE */
.rp-title-row { display: flex; align-items: flex-end; justify-content: space-between; }
.rp-title {
    font-size: 28px; font-weight: 900; letter-spacing: -1px; line-height: 1;
    background: linear-gradient(90deg, var(--v3), var(--pk-l));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
}
.rp-subtitle { font-size: 13px; color: var(--t3); margin-top: 4px; }
.rp-date { font-size: 12px; color: var(--t3); text-align: right; }
.rp-date strong { display: block; font-size: 20px; font-weight: 900; color: var(--t1); letter-spacing: -0.5px; -webkit-text-fill-color: var(--t1); }

/* TABS */
.tab-row { display: flex; gap: 4px; border-bottom: 1px solid var(--bdr); }
.tab-btn {
    padding: 9px 18px;
    font-size: 13px; font-weight: 700;
    color: var(--t3);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all .15s;
    text-decoration: none;
    display: flex; align-items: center; gap: 6px;
}
.tab-btn:hover { color: var(--v3); }
.tab-btn.act { color: var(--v4); border-bottom-color: var(--v5); }
.tab-cnt {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 18px; border-radius: 9px;
    background: rgba(139,92,246,0.25);
    font-size: 10px; font-weight: 800; padding: 0 4px;
    color: var(--v3);
}
.tab-cnt.red { background: rgba(244,63,94,0.2); color: #fda4af; }
.tab-cnt.amber { background: rgba(245,158,11,0.2); color: #fcd34d; }

/* GRID */
.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.g3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* GLASS CARD */
.gc {
    background: var(--gc);
    border: 1px solid var(--bdr);
    border-radius: 14px;
    backdrop-filter: blur(10px);
    transition: border-color .2s;
}
.gc:hover { border-color: var(--bdr-b); }
.gc-pad { padding: 20px; }
.gc-hd {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--bdr);
}
.gc-title { font-size: 13px; font-weight: 800; color: var(--t1); display: flex; align-items: center; gap: 8px; }
.gc-title-dot { width: 6px; height: 6px; border-radius: 50%; }
.gc-meta { font-size: 11px; color: var(--t3); }

/* TABLE */
.adm-tbl { width: 100%; }
.adm-tbl-hd {
    display: grid;
    padding: 9px 16px;
    font-size: 10px; font-weight: 700; color: var(--t3);
    text-transform: uppercase; letter-spacing: .5px;
    background: rgba(139,92,246,0.06);
    border-bottom: 1px solid var(--bdr);
}
.adm-tbl-row {
    display: grid;
    padding: 12px 16px;
    font-size: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    align-items: center;
    transition: background .12s;
}
.adm-tbl-row:last-child { border-bottom: none; }
.adm-tbl-row:hover { background: rgba(139,92,246,0.06); }
.col-m5 { grid-template-columns: 32px 1fr 90px 80px 70px; gap: 10px; }
.col-p5 { grid-template-columns: 32px 1fr 80px 80px 70px; gap: 10px; }
.col-e4 { grid-template-columns: 32px 1fr 90px 80px; gap: 10px; }
.c-id { color: var(--t4); font-size: 10px; font-weight: 600; }
.c-name { font-weight: 700; color: var(--t1); }
.c-sub { font-size: 10px; color: var(--t3); margin-top: 1px; }
.c-date { color: var(--t3); font-size: 10px; }

/* BADGES */
.b {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; border-radius: 20px;
    padding: 2px 9px; white-space: nowrap;
}
.b-active  { background: rgba(16,185,129,0.14); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.25); }
.b-wait    { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.25); }
.b-pend    { background: rgba(139,92,246,0.14); color: var(--v3); border: 1px solid rgba(139,92,246,0.28); }
.b-prog    { background: rgba(6,182,212,0.12); color: #67e8f9; border: 1px solid rgba(6,182,212,0.25); }
.b-done    { background: rgba(16,185,129,0.12); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.22); }
.b-closed  { background: rgba(255,255,255,0.06); color: var(--t3); border: 1px solid var(--bdr); }
.b-susp    { background: rgba(244,63,94,0.12); color: #fda4af; border: 1px solid rgba(244,63,94,0.25); }
.b-report  { background: rgba(244,63,94,0.12); color: #fda4af; border: 1px solid rgba(244,63,94,0.25); }
.b-ans     { background: rgba(139,92,246,0.14); color: var(--v3); border: 1px solid rgba(139,92,246,0.28); }
.b-no-ans  { background: rgba(245,158,11,0.12); color: #fcd34d; border: 1px solid rgba(245,158,11,0.25); }

/* ACTION BTN */
.act-btn {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 6px;
    font-size: 11px; font-weight: 700;
    text-decoration: none; cursor: pointer; border: 1px solid;
    transition: all .12s;
}
.ab-v { background: rgba(139,92,246,0.14); color: var(--v3); border-color: rgba(139,92,246,0.3); }
.ab-v:hover { background: rgba(139,92,246,0.28); }
.ab-rose { background: rgba(244,63,94,0.10); color: #fda4af; border-color: rgba(244,63,94,0.28); }
.ab-rose:hover { background: rgba(244,63,94,0.22); }
.ab-green { background: rgba(16,185,129,0.12); color: #6ee7b7; border-color: rgba(16,185,129,0.28); }
.ab-green:hover { background: rgba(16,185,129,0.24); }
.ab-amber { background: rgba(245,158,11,0.12); color: #fcd34d; border-color: rgba(245,158,11,0.28); }
.ab-amber:hover { background: rgba(245,158,11,0.24); }

/* HORIZONTAL BAR */
.hbar-list { display: flex; flex-direction: column; gap: 11px; }
.hbar-row { display: grid; grid-template-columns: 70px 1fr 36px; gap: 10px; align-items: center; font-size: 11px; }
.hbar-key { color: var(--t3); font-weight: 600; }
.hbar-track { height: 18px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; }
.hbar-fill {
    height: 100%; border-radius: 4px;
    display: flex; align-items: center; justify-content: flex-end;
    padding-right: 5px; font-size: 9px; font-weight: 800;
    color: rgba(255,255,255,0.75);
}
.hbar-num { font-weight: 800; color: var(--t1); text-align: right; }

/* QUICK ACTION GRID */
.qa-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 16px 20px; }
.qa-item {
    display: flex; flex-direction: column; gap: 6px;
    padding: 14px;
    border-radius: 10px;
    background: rgba(139,92,246,0.07);
    border: 1px solid rgba(139,92,246,0.15);
    text-decoration: none;
    color: var(--t1);
    transition: all .15s;
}
.qa-item:hover { background: rgba(139,92,246,0.15); border-color: var(--bdr-b); transform: translateY(-2px); }
.qa-icon { font-size: 18px; }
.qa-label { font-size: 12px; font-weight: 700; }
.qa-desc { font-size: 10px; color: var(--t3); }

/* NOTICE LIST */
.notice-list { display: flex; flex-direction: column; }
.notice-row {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background .12s;
}
.notice-row:last-child { border-bottom: none; }
.notice-row:hover { background: rgba(139,92,246,0.06); }
.notice-pin { font-size: 12px; }
.notice-title { flex: 1; font-size: 13px; font-weight: 600; color: var(--t1); }
.notice-date { font-size: 11px; color: var(--t3); }
.notice-new {
    font-size: 9px; font-weight: 800; background: linear-gradient(90deg, var(--v7), var(--pk));
    color: #fff; border-radius: 4px; padding: 2px 5px;
}

/* REPORT INQUIRY GRID */
.ri-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.ri-card { display: flex; flex-direction: column; }
.ri-row {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 11px 18px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 12px;
    transition: background .12s;
}
.ri-row:last-child { border-bottom: none; }
.ri-row:hover { background: rgba(236,72,153,0.05); }
.ri-idx { color: var(--t4); font-size: 10px; min-width: 20px; padding-top: 1px; }
.ri-body { flex: 1; min-width: 0; }
.ri-msg { font-weight: 600; color: var(--t1); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.ri-meta { font-size: 10px; color: var(--t3); margin-top: 2px; }

/* SYSTEM STATUS (right side) */
.sys-list { display: flex; flex-direction: column; gap: 0; }
.sys-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 12px;
}
.sys-row:last-child { border-bottom: none; }
.sys-key { color: var(--t2); font-weight: 500; display: flex; align-items: center; gap: 7px; }
.sys-dot { width: 6px; height: 6px; border-radius: 50%; }
.sys-ok   { background: #34d399; box-shadow: 0 0 6px rgba(52,211,153,0.6); }
.sys-warn { background: var(--amber); box-shadow: 0 0 6px rgba(245,158,11,0.5); }
.sys-err  { background: var(--rose); box-shadow: 0 0 6px rgba(244,63,94,0.5); }
.sys-val  { font-weight: 700; }
.sys-val.ok { color: #6ee7b7; }
.sys-val.warn { color: #fcd34d; }
.sys-val.err { color: #fda4af; }
.sys-val.info { color: var(--v3); }

/* HEATMAP (activity) */
.heatmap { padding: 16px 20px; }
.hm-label { font-size: 10px; color: var(--t3); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
.hm-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 4px;
}
.hm-cell {
    aspect-ratio: 1;
    border-radius: 3px;
    background: rgba(255,255,255,0.04);
    transition: all .15s;
}
.hm-cell:hover { transform: scale(1.3); }
.h0 { background: rgba(139,92,246,0.06); }
.h1 { background: rgba(139,92,246,0.20); }
.h2 { background: rgba(139,92,246,0.38); }
.h3 { background: rgba(139,92,246,0.58); }
.h4 { background: rgba(139,92,246,0.82); }
.hm-legend { display: flex; align-items: center; gap: 6px; margin-top: 8px; font-size: 10px; color: var(--t3); }
.hm-legend-cells { display: flex; gap: 3px; }
.hm-legend-cells span { width: 10px; height: 10px; border-radius: 2px; }

@media (max-width: 1100px) {
    .lp { width: 240px; }
    .g3 { grid-template-columns: 1fr 1fr; }
    .ri-grid { grid-template-columns: 1fr; }
}
@media (max-width: 800px) {
    .split { flex-direction: column; }
    .lp { width: 100%; border-right: none; border-bottom: 1px solid var(--bdr); }
    .rp { padding: 20px 16px 40px; }
}
</style>
</head>
<body>

<!-- ═══ TOPBAR ═══ -->
<header class="tb">
    <div class="tb-left">
        <div class="tb-gem">S</div>
        <span class="tb-name">SevMerge</span>
        <div class="tb-sep"></div>
        <span class="tb-page">Analytics Dashboard</span>
    </div>
    <div class="tb-right">
        <span class="tb-tag live">● LIVE</span>
        <span class="tb-tag v">v2.0</span>
        <span class="tb-time">2026.06.16 MON</span>
        <div class="tb-ava">관</div>
    </div>
</header>

<!-- ═══ SPLIT LAYOUT ═══ -->
<div class="split">

<!-- ──────── LEFT PANEL ──────── -->
<aside class="lp">

    <!-- BIG RING: 회원수 -->
    <div class="ring-wrap">
        <div class="ring-outer">
            <svg class="ring-svg" width="120" height="120" viewBox="0 0 120 120">
                <circle class="ring-track" cx="60" cy="60" r="50"/>
                <circle class="ring-fill" cx="60" cy="60" r="50"
                    stroke="url(#gv1)"
                    stroke-dasharray="314"
                    stroke-dashoffset="69"/>
                <defs>
                    <linearGradient id="gv1" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#7c3aed"/>
                        <stop offset="100%" stop-color="#ec4899"/>
                    </linearGradient>
                </defs>
            </svg>
            <div class="ring-center">
                <div class="ring-val" style="color:var(--v3)">1,247</div>
                <div class="ring-sub">MEMBERS</div>
            </div>
        </div>
        <div class="ring-label">전체 회원</div>
        <div class="ring-delta">이번 달 <span class="up">+23명</span></div>
    </div>

    <div class="lp-divider"></div>

    <!-- MINI METRICS -->

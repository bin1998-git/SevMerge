{{> layout/header}}

<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .admin-wrap { display: flex; min-height: calc(100vh - 64px); }
    .admin-content { flex: 1; padding: 36px 36px 80px; background: transparent; position: relative; z-index: 1; }
    .admin-title { font-size: 22px; font-weight: 900; color: #1c1e26; margin-bottom: 4px; }
    .admin-desc { font-size: 14px; color: #9ca3af; margin-bottom: 28px; }

    /* 수익 요약 카드 */
    .revenue-summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
    .rev-card {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 16px; padding: 24px;
        box-shadow: 0 4px 16px rgba(37,99,235,.06);
    }
    .rev-card-label { font-size: 12px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }
    .rev-card-val { font-size: 28px; font-weight: 900; letter-spacing: -1px; margin-bottom: 4px; }
    .rev-card-sub { font-size: 12px; color: #9ca3af; }

    /* 수익 목록 */
    .rev-table-wrap {
        backdrop-filter: blur(16px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 16px;
        overflow: hidden; box-shadow: 0 4px 24px rgba(37,99,235,.06);
    }
    .rev-table-header { padding: 18px 22px; border-bottom: 1px solid rgba(255,255,255,.6); display: flex; justify-content: space-between; align-items: center; }
    .rev-table-title { font-size: 15px; font-weight: 800; color: #1c1e26; }
    .rev-head {
        display: grid; grid-template-columns: 60px 100px 120px 1fr 100px 90px;
        gap: 12px; padding: 11px 22px;
        background: rgba(255,255,255,.4); border-bottom: 1px solid rgba(255,255,255,.6);
        font-size: 11px; font-weight: 700; color: #9ca3af; letter-spacing: .5px;
    }
    .rev-row {
        display: grid; grid-template-columns: 60px 100px 120px 1fr 100px 90px;
        gap: 12px; padding: 14px 22px;
        border-bottom: 1px solid rgba(255,255,255,.5);
        align-items: center; font-size: 13px;
    }
    .rev-row:last-child { border-bottom: none; }
    .rev-row:hover { background: rgba(239,246,255,.5); }
    .cell-id { color: #c4c9d9; font-weight: 500; }
    .cell-amount { font-weight: 800; color: #059669; }
    .cell-amount.cancelled { color: #ef4444; text-decoration: line-through; }
    .cell-date { color: #9ca3af; font-size: 12px; }

    .type-badge { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 5px; }
    .type-ad { background: #fef3c7; color: #92400e; }
    .type-partnership { background: #dbeafe; color: #1e40af; }
    .type-commission { background: #d1fae5; color: #065f46; }

    .status-confirmed { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 5px; background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }
    .status-cancelled { display: inline-block; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 5px; background: #fff3f3; color: #ef4444; border: 1px solid #fecaca; }

    .empty-state { text-align: center; padding: 60px 0; font-size: 14px; color: #9ca3af; }
</style>

<div class="admin-wrap">
    <main class="admin-content">
        <h1 class="admin-title">플랫폼 수익 현황</h1>
        <p class="admin-desc">광고 및 제휴를 통한 플랫폼 수익을 관리합니다.</p>

        <!-- 수익 요약 -->
        <div class="revenue-summary">
            <div class="rev-card">
                <div class="rev-card-label">총 확정 수익</div>
                <div class="rev-card-val" style="color:#059669;">{{totalRevenue}}P</div>
                <div class="rev-card-sub">누적 확정 수익</div>
            </div>
            <div class="rev-card">
                <div class="rev-card-label">광고 수익</div>
                <div class="rev-card-val" style="color:#d97706;">{{adRevenue}}P</div>
                <div class="rev-card-sub">광고 승인 누적 수익</div>
            </div>
            <div class="rev-card">
                <div class="rev-card-label">이번 달 수익</div>
                <div class="rev-card-val" style="color:#2563eb;">{{thisMonthRevenue}}P</div>
                <div class="rev-card-sub">당월 확정 수익</div>
            </div>
        </div>

        <!-- 수익 목록 -->
        <div class="rev-table-wrap">
            <div class="rev-table-header">
                <span class="rev-table-title">수익 내역</span>
            </div>
            <div class="rev-head">
                <span>No</span>
                <span>유형</span>
                <span>금액</span>
                <span>설명</span>
                <span>상태</span>
                <span>날짜</span>
            </div>
            {{#revenues}}
                <div class="rev-row">
                    <span class="cell-id">{{id}}</span>
                    <span>
                        {{#isAd}}<span class="type-badge type-ad">광고</span>{{/isAd}}
                        {{#isPartnership}}<span class="type-badge type-partnership">제휴</span>{{/isPartnership}}
                        {{#isCommission}}<span class="type-badge type-commission">중개</span>{{/isCommission}}
                    </span>
                    <span class="cell-amount {{#isCancelled}}cancelled{{/isCancelled}}">
                        +{{amount}}P
                    </span>
                    <span>{{description}}</span>
                    <span>
                        {{#isConfirmed}}<span class="status-confirmed">확정</span>{{/isConfirmed}}
                        {{#isCancelled}}<span class="status-cancelled">취소</span>{{/isCancelled}}
                    </span>
                    <span class="cell-date">{{createdAtFormatted}}</span>
                </div>
            {{/revenues}}
            {{^revenues}}
                <div class="empty-state">수익 내역이 없습니다.</div>
            {{/revenues}}
        </div>
    </main>
</div>

{{> layout/footer}}
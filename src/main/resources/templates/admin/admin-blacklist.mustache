{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .admin-wrap {
        display: flex;
        min-height: calc(100vh - 64px);
    }

    .admin-sidebar {
        width: 220px;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.7);
        border-right: 1px solid rgba(255,255,255,.8);
        padding: 28px 0;
        flex-shrink: 0;
        position: sticky;
        top: 64px;
        height: calc(100vh - 64px);
    }

    .sidebar-label {
        font-size: 11px;
        font-weight: 700;
        color: #c4c9d9;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0 20px;
        margin-bottom: 8px;
        margin-top: 20px;
    }

    .sidebar-label:first-child {
        margin-top: 0;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        color: #6b7280;
        text-decoration: none;
        transition: all .12s;
        border-left: 3px solid transparent;
    }

    .sidebar-link:hover {
        color: #2563eb;
        background: rgba(239,246,255,.7);
    }

    .sidebar-link.active {
        color: #2563eb;
        background: rgba(239,246,255,.6);
        border-left-color: #2563eb;
    }

    .sidebar-icon {
        font-size: 16px;
    }

    .admin-content {
        flex: 1;
        padding: 36px 36px 80px;
        background: transparent;
        position: relative;
        z-index: 1;
    }

    .admin-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .admin-title {
        font-size: 22px;
        font-weight: 900;
        color: #1c1e26;
        letter-spacing: -0.5px;
        margin-bottom: 4px;
    }

    .admin-desc {
        font-size: 14px;
        color: #9ca3af;
    }

    .search-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .search-input {
        flex: 1;
        padding: 11px 16px;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 9px;
        font-size: 14px;
        font-family: inherit;
        color: #1c1e26;
        outline: none;
        max-width: 360px;
    }

    .search-input:focus {
        border-color: #2563eb;
        background: rgba(255,255,255,.9);
        outline: none;
    }

    .search-btn {
        padding: 11px 22px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
    }

    .admin-table-wrap {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,.8);
        box-shadow: 0 4px 24px rgba(37,99,235,.06);
        overflow: hidden;
    }

    .admin-table-head, .admin-table-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 22px;
    }

    .admin-table-head {
        background: rgba(255,255,255,.4);
        border-bottom: 1px solid rgba(255,255,255,.6);
        font-size: 11px;
        font-weight: 700;
        color: #9ca3af;
        letter-spacing: .5px;
    }

    .admin-table-row {
        padding: 15px 22px;
        border-bottom: 1px solid rgba(255,255,255,.5);
        font-size: 13px;
    }

    .admin-table-head, .admin-table-row {
        display: flex !important;
        align-items: center !important;
        gap: 12px !important;
        padding: 15px 22px !important;
    }

    .admin-table-head {
        background: rgba(255,255,255,.4) !important;
        border-bottom: 1px solid rgba(255,255,255,.6) !important;
        font-size: 11px !important;
        font-weight: 700 !important;
        color: #9ca3af !important;
        letter-spacing: .5px !important;
    }

    .admin-table-row {
        border-bottom: 1px solid rgba(255,255,255,.5) !important;
        font-size: 13px !important;
        background: transparent !important;
    }



    .admin-table-head > *:nth-child(1),
    .cell-id {
        width: 60px !important;
        flex-shrink: 0 !important;
        text-align: center !important;
    }

    .admin-table-head > *:nth-child(2),
    .cell-title {
        flex: 1 !important;
        min-width: 0 !important;
        text-align: center !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
    }

    .admin-table-head > *:nth-child(3),
    .cell-date {
        width: 150px !important;
        flex-shrink: 0 !important;
        text-align: center !important;
    }


    .admin-table-row:last-child {
        border-bottom: none;
    }

    .admin-table-row:hover {
        background: rgba(239,246,255,.5) !important;
    }

    .cell-id {
        color: #c4c9d9;
        font-weight: 500;
    }

    .cell-name {
        font-weight: 700;
        color: #1c1e26;
    }

    .cell-email {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .cell-date {
        color: #9ca3af;
        font-size: 12px;
    }

    .role-admin {
        font-size: 11px;
        background: #fef3c7;
        color: #b45309;
        border: 1px solid #fde68a;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .role-member {
        font-size: 11px;
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .status-active {
        font-size: 11px;
        background: #ecfdf5;
        color: #059669;
        border: 1px solid #a7f3d0;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 700;
        display: inline-block;
    }

    .del-btn {
        padding: 5px 12px;
        background: #fff3f3;
        color: #ef4444;
        border: 1px solid #fecaca;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
    }

    .del-btn:hover {
        background: #fee2e2;
    }

    .pagination { display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 24px; }
    .pagination .page-info { font-size: 13px; color: #6b7280; font-weight: 600; }
    .unused_paging {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-top: 24px;
    }

    .page-btn {
        padding: 9px 15px;
        border-radius: 8px;
        border: 1.5px solid rgba(255,255,255,.8);
        font-size: 13px;
        font-weight: 600;
        color: #6b7280;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6);
        text-decoration: none;
        transition: all .15s;
    }

    .page-btn:hover {
        border-color: #2563eb;
        color: #2563eb;
    }

    .page-btn.active {
        background: #2563eb;
        border-color: #2563eb;
        color: #fff;
    }

    .sidebar-dropdown-group {
        display: block !important;
        width: 100% !important;
        position: relative !important;
    }

    .sidebar-submenu {
        display: none !important;
        flex-direction: column !important;
        width: 100% !important;
        background: rgba(239,246,255,.7) !important;
    }

    .sidebar-dropdown-group:hover .dropdown-trigger {
        color: #2563eb !important;
        background: #eff6ff !important;
        border-left-color: #2563eb !important;
    }

    .sidebar-dropdown-group:hover .sidebar-submenu {
        display: flex !important;
    }

    .admin-sidebar:has(.sidebar-dropdown-group:hover) .sidebar-link.active {
        color: #6b7280 !important;
        background: transparent !important;
        border-left-color: transparent !important;
    }

    .submenu-link {
        display: flex !important;
        align-items: center !important;
        padding: 10px 20px 10px 46px !important;
        font-size: 13px !important;
        font-weight: 600 !important;
        color: #6b7280 !important;
        text-decoration: none !important;
        transition: all .12s !important;
        border-left: 3px solid transparent !important;
    }

    .submenu-link:hover {
        color: #2563eb !important;
        background: #eff6ff !important;
        border-left-color: #2563eb !important;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="admin-wrap">
    <main class="admin-content">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">블랙리스트 관리</h1>
                <p class="admin-desc">신고 누적으로 차단된 회원 및 이력을 관리합니다.</p>
            </div>
        </div>

        <div class="admin-table-wrap" style="width:100% !important; box-sizing:border-box !important; margin-bottom:28px !important;">
            <div style="padding:16px 18px 6px; font-weight:800; color:#1c1e26; font-size:15px;">
                🚩 신고된 댓글
                <span style="font-weight:600; color:#6b7280; font-size:13px;">· 신고 접수 즉시 표시 (총 {{reportedCommentCount}}건)</span>
            </div>
            <div class="admin-table-head" style="display:flex !important; flex-direction:row !important; width:100% !important; font-weight:bold !important; background:rgba(255,255,255,.4) !important; padding:12px 0 !important; border-bottom:1px solid rgba(255,255,255,.6) !important; box-sizing:border-box !important;">
                <div style="width:8% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">No</div>
                <div style="width:40% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">댓글 내용</div>
                <div style="width:15% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">작성자</div>
                <div style="width:12% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">신고 수</div>
                <div style="width:15% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">상태</div>
                <div style="width:10% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">확인</div>
            </div>
            {{#reportedComments}}
                <div class="admin-table-row" style="display:flex !important; flex-direction:row !important; width:100% !important; align-items:center !important; padding:14px 0 !important; border-bottom:1px solid rgba(255,255,255,.5) !important; box-sizing:border-box !important;">
                    <div style="width:8% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">{{commentId}}</div>
                    <div style="width:40% !important; text-align:left !important; padding:0 14px !important; word-break:break-all !important; box-sizing:border-box !important; color:#374151;">
                        {{#commentDeleted}}<span style="color:#9ca3af;">(삭제된 댓글) </span>{{/commentDeleted}}{{commentContent}}
                        <div style="color:#9ca3af; font-size:12px; margin-top:4px;">사유: {{reasons}}{{#latestReportedAt}} · 최근 {{latestReportedAt}}{{/latestReportedAt}}</div>
                    </div>
                    <div style="width:15% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">{{commentWriterName}}</div>
                    <div style="width:12% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important; font-weight:bold !important; color:#e74c3c !important;">{{reportCount}}회</div>
                    <div style="width:15% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">
                        {{#reReported}}<span style="background:#fee2e2; color:#dc2626; font-weight:800; font-size:12px; padding:5px 11px; border-radius:999px;">🔴 재신고 {{reportCount}}회</span>{{/reReported}}
                        {{^reReported}}<span style="background:#fef9c3; color:#a16207; font-weight:700; font-size:12px; padding:5px 11px; border-radius:999px;">신규 신고</span>{{/reReported}}
                    </div>
                    <div style="width:10% !important; text-align:center !important; display:flex !important; justify-content:center !important; align-items:center !important;">
                        {{#boardId}}<a href="/boards/{{boardId}}" target="_blank" style="background:#2563eb; color:#fff; text-decoration:none; padding:6px 12px; border-radius:6px; font-size:0.85rem; font-weight:700;">보기</a>{{/boardId}}
                        {{^boardId}}<span style="color:#9ca3af; font-size:0.85rem;">-</span>{{/boardId}}
                    </div>
                </div>
            {{/reportedComments}}
            {{^reportedComments}}
                <div style="display:flex !important; justify-content:center !important; align-items:center !important; height:120px !important; color:#888 !important; font-size:0.95rem !important; width:100% !important;">
                    접수된 신고 댓글이 없습니다.
                </div>
            {{/reportedComments}}
        </div>

        <div style="font-weight:800; color:#1c1e26; font-size:15px; margin:8px 2px 14px;">⛔ 차단 회원</div>

        <form action="/admin/blacklists" method="get" class="search-bar">
            <input type="text" class="search-input" name="keyword" placeholder="회원명 또는 사유 검색..." value="{{keyword}}"/>
            <button type="submit" class="search-btn">검색</button>
        </form>

        <div class="admin-table-wrap" style="width: 100% !important; box-sizing: border-box !important;">
            <!-- 1. 헤더 영역 -->
            <div class="admin-table-head" style="display: flex !important; flex-direction: row !important; width: 100% !important; font-weight: bold !important; background: rgba(255,255,255,.4) !important; padding: 12px 0 !important; border-bottom: 1px solid rgba(255,255,255,.6) !important; box-sizing: border-box !important;">
                <div style="width: 10% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">No</div>
                <div style="width: 20% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">대상 회원</div>
                <div style="width: 30% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">차단 사유</div>
                <div style="width: 15% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">누적 신고 ID</div>
                <div style="width: 15% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">정지 만료일</div>
                <div style="width: 10% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">관리</div>
            </div>

            {{#blacklistLogs}}
                <!-- 2. 데이터 행 영역 -->
                <div class="admin-table-row" style="display: flex !important; flex-direction: row !important; width: 100% !important; align-items: center !important; padding: 15px 0 !important; border-bottom: 1px solid rgba(255,255,255,.5) !important; box-sizing: border-box !important;">

                    <!-- 1) 번호 -->
                    <div class="cell-id" style="width: 10% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">
                        {{id}}
                    </div>

                    <!-- 2) 대상 회원 -->
                    <div class="cell-member" style="width: 20% !important; text-align: center !important; display: flex !important; flex-direction: column !important; justify-content: center !important; align-items: center !important; font-weight: 500 !important; line-height: 1.4 !important;">
                        <span>{{member.name}}</span>
                        <small style="color: #888 !important; font-size: 0.8rem !important;">({{member.email}})</small>
                    </div>

                    <!-- 3) 차단 사유 -->
                    <div class="cell-reason" style="width: 30% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important; padding: 0 10px !important; word-break: break-all !important; box-sizing: border-box !important;">
                        {{reason}}
                    </div>

                    <!-- 4) 누적 신고 ID -->
                    <div class="cell-reports" style="width: 15% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important; color: #e74c3c !important; font-weight: bold !important;">
                        {{reportIds}}
                    </div>

                    <!-- 5) 정지 만료일 -->
                    <div class="cell-date" style="width: 15% !important; text-align: center !important; display: flex !important; justify-content: center !important; align-items: center !important;">
                        {{expiredAt}}
                    </div>

                    <!-- 6) 관리 버튼 -->
                    <div class="cell-action" style="width: 10% !important; display: flex !important; justify-content: center !important; align-items: center !important;">
                        {{#isActive}}
                            <form action="/admin/blacklist/release/{{member.id}}" method="post" onsubmit="return confirm('이 회원의 정지를 해제하시겠습니까?');" style="margin: 0 !important;">
                                <button type="submit" class="release-btn" style="background-color: #2ecc71 !important; color: white !important; border: none !important; padding: 6px 12px !important; border-radius: 4px !important; cursor: pointer !important; font-weight: bold !important; font-size: 0.85rem !important;">
                                    정지 해제
                                </button>
                            </form>
                        {{/isActive}}
                        {{^isActive}}
                            <span style="color: #95a5a6 !important; font-size: 0.85rem !important; font-weight: 500 !important;">해제 완료</span>
                        {{/isActive}}
                    </div>
                </div>
            {{/blacklistLogs}}

            {{^blacklistLogs}}
                <div style="display: flex !important; justify-content: center !important; align-items: center !important; height: 180px !important; color: #888 !important; font-size: 0.95rem !important; font-weight: 500 !important; width: 100% !important;">
                    현재 차단된 회원 내역이 없습니다.
                </div>
            {{/blacklistLogs}}
        </div>
        <div class="pagination">
            {{#prevPage}}<a href="/admin/blacklists?page={{prevPage}}&keyword={{keyword}}" class="page-btn">이전</a>{{/prevPage}}
            <span class="page-info">{{currentPage}} / {{totalPages}}</span>
            {{#nextPage}}<a href="/admin/blacklists?page={{nextPage}}&keyword={{keyword}}" class="page-btn">다음</a>{{/nextPage}}
        </div>
    </main>
</div>

{{> layout/footer}}

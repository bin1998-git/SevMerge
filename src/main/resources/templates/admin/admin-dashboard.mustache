            background: var(--blue-1);
            border-color: var(--blue-3);
            color: var(--blue-8);
        }

        /* ─── SYSTEM STATUS ─── */
        .ss-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 9px 18px;
            border-bottom: 1px solid rgba(226, 232, 240, 0.6);

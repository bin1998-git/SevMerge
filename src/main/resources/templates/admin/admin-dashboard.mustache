<script>
    // 💡 1. 주식 그래프 종류별 실제 데이터 셋 정의
    const stockDataMap = {
        members: {
            title: "총 회원수",
            value: "1,247",
            sub: "▲ 23 (+1.88%)",
            color: "#0056ff",
            fillColor: "rgba(0, 86, 255, 0.15)",
            labels: ['06.10', '06.11', '06.12', '06.13', '06.14', '06.15', '06.16 월(오늘)'],
            data: [1180, 1200, 1210, 1225, 1230, 1240, 1247] // 우상향 주식 패턴
        },
        projects: {
            title: "전체 프로젝트",
            value: "384",
            sub: "▲ 86 (+28.8%)",
            color: "#3182ce",
            fillColor: "rgba(49, 130, 206, 0.15)",
            labels: ['06.10', '06.11', '06.12', '06.13', '06.14', '06.15', '06.16 월(오늘)'],
            data: [298, 310, 305, 340, 365, 350, 384] // 등락이 있는 변동 주식 패턴
        },
        experts: {
            title: "전문가 승인 대기",
            value: "12",
            sub: "▼ 4 (-25.0%)",
            color: "#dd6b20",
            fillColor: "rgba(221, 107, 32, 0.15)",
            labels: ['06.10', '06.11', '06.12', '06.13', '06.14', '06.15', '06.16 월(오늘)'],
            data: [20, 18, 15, 22, 19, 14, 12] // 하향 및 조정 주식 패턴
        }
    };

    let mainChart = null;

    // 💡 2. 차트 초기 생성 및 주식형 스타일 옵션 선언
    function initStockChart(key) {
        const info = stockDataMap[key];
        const ctx = document.getElementById('mainStockChart').getContext('2d');

        const gradient = ctx.createLinearGradient(0, 0, 0, 350);
        gradient.addColorStop(0, info.fillColor);
        gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

        mainChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: info.labels,
                datasets: [{
                    label: info.title,
                    data: info.data,
                    borderColor: info.color,
                    borderWidth: 3,
                    pointBackgroundColor: info.color,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    backgroundColor: gradient,
                    tension: 0.2 // 주식 그래프 느낌의 정밀한 꺾임선 설정
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }, // 불필요한 범례 숨김
                    tooltip: {
                        mode: 'index',
                        intersect: false,
                        backgroundColor: '#1a202c',
                        titleColor: '#fff',
                        bodyColor: '#fff',
                        padding: 10,
                        cornerRadius: 6
                    }
                },
                scales: {
                    x: {
                        grid: { display: false } // 주식 차트 스타일을 위해 세로선 제거
                    },
                    y: {
                        position: 'right', // 💡 실제 주식 차트처럼 수치 축을 우측에 배치
                        grid: { borderDash: [4, 4] } // 가로 점선 처리
                    }
                }
            }
        });
    }

    // 💡 3. 버튼 탭 클릭 시 주식 데이터 스위칭 처리 기능
    function switchStockData(key) {
        const info = stockDataMap[key];

        // 상단 텍스트 및 인터페이스 수치 업데이트
        document.getElementById('stockChartValue').innerText = info.value;
        document.getElementById('stockChartValue').style.color = info.color;
        document.getElementById('stockChartSub').innerText = info.sub;
        document.getElementById('stockChartSub').style.color = info.color;

        // 버튼 컴포넌트 활성화 디자인 교체
        const btns = document.querySelectorAll('.stock-tab-btn');
        btns.forEach(btn => {
            btn.style.background = 'transparent';
            btn.style.color = '#4a5568';
        });

        const activeBtn = event.currentTarget;
        activeBtn.style.background = info.color;
        activeBtn.style.color = '#fff';

        // 기존 그래프 파괴 후 신규 데이터 기반으로 재생성 (부드러운 전환)
        if (mainChart) mainChart.destroy();
        initStockChart(key);
    }

    // 초기 실행문 지정
    window.addEventListener('DOMContentLoaded', () => {
        initStockChart('members');
    });
</script>


            border-bottom: none;
        }

        .ss-key {
            color: var(--t2);
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .ss-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
        }

        .d-ok {
            background: var(--green);
        }

        .d-wn {
            background: var(--amber);
        }

        .d-err {
            background: var(--red);
        }

        .ss-val {
            font-weight: 700;
            font-size: 11px;
        }

        .sv-ok {
            color: var(--green);
        }

        .sv-wn {
            color: var(--amber);
        }

        .sv-bl {
            color: var(--blue-8);
        }

        .sv-gr {
            color: var(--t3);
        }

        /* ─── STAT CALLOUT ─── */
        .callout {
            background: var(--blue-1);
            border: 1px solid var(--bdr-b);
            border-radius: 8px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .callout-icon {
            font-size: 24px;
        }

        .callout-val {
            font-size: 24px;
            font-weight: 900;
            color: var(--blue-9);
            letter-spacing: -1px;
        }

        .callout-label {
            font-size: 11px;
            color: var(--blue-8);
            font-weight: 600;
            margin-top: 1px;
        }

        /* ─── REPORT ROW ─── */
        .rr {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 10px 18px;
            border-bottom: 1px solid rgba(226, 232, 240, 0.6);
            font-size: 12px;
            transition: background .1s;

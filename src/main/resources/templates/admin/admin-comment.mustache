{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
    }
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 { width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%); top: -150px; left: -150px; }
    .bg-glow-2 { width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%); bottom: 10%; right: -100px; }

    .admin-wrap { display: flex; min-height: calc(100vh - 64px); }

    .admin-content {
        flex: 1;
        padding: 36px 36px 80px;
        background: transparent;
        position: relative;
        z-index: 1;
    }

    .admin-header {
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .admin-title { font-size: 22px; font-weight: 900; color: #1c1e26; letter-spacing: -0.5px; margin-bottom: 4px; }
    .admin-desc { font-size: 14px; color: #9ca3af; }

    .search-bar { display: flex; gap: 10px; margin-bottom: 20px; }

    .search-input {
        flex: 1; padding: 11px 16px;
        backdrop-filter: blur(8px);
        background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        border-radius: 9px; font-size: 14px;
        font-family: inherit; color: #1c1e26;
        outline: none; max-width: 360px;
    }
    .search-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); }

    .search-btn {
        padding: 11px 22px; background: #2563eb; color: #fff;
        border: none; border-radius: 9px; font-size: 13px;
        font-weight: 700; cursor: pointer; font-family: inherit;
    }

    .admin-table-wrap {
        backdrop-filter: blur(16px);
        background: rgba(255,255,255,.6);
        border-radius: 14px;
        border: 1.5px solid rgba(255,255,255,.8);
        box-shadow: 0 4px 24px rgba(37,99,235,.06);
        overflow: hidden;
    }

    .admin-table-head, .admin-table-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 15px 22px;
    }

    .admin-table-head {
        background: rgba(255,255,255,.4);
        border-bottom: 1px solid rgba(255,255,255,.6);
        font-size: 11px; font-weight: 700;
        color: #9ca3af; letter-spacing: .5px;
    }

    .admin-table-row {
        border-bottom: 1px solid rgba(255,255,255,.5);
        font-size: 13px;
    }
    .admin-table-row:last-child { border-bottom: none; }
    .admin-table-row:hover { background: rgba(239,246,255,.5); }

    .cell-id { width: 60px; flex-shrink: 0; text-align: center; color: #c4c9d9; font-weight: 500; }
    .cell-content { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cell-author { width: 120px; flex-shrink: 0; text-align: center; color: #6b7280; }
    .cell-board { width: 80px; flex-shrink: 0; text-align: center; }
    .cell-date { width: 140px; flex-shrink: 0; text-align: center; color: #9ca3af; font-size: 12px; }
    .cell-action { width: 80px; flex-shrink: 0; text-align: center; }

    .del-btn {
        padding: 5px 12px; background: #fff3f3; color: #ef4444;
        border: 1px solid #fecaca; border-radius: 6px;
        font-size: 11px; font-weight: 700; cursor: pointer; font-family: inherit;
    }
    .del-btn:hover { background: #fee2e2; }

    .board-link { color: #2563eb; text-decoration: none; font-size: 12px; font-weight: 600; }
    .board-link:hover { text-decoration: underline; }

    .empty-msg { text-align: center; padding: 48px; color: #9ca3af; font-size: 14px; }
</style>

<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="admin-wrap">
    <main class="admin-content">
        <div class="admin-header">
            <div>
                <h1 class="admin-title">댓글 관리</h1>
                <p class="admin-desc">전체 댓글을 관리합니다.</p>
            </div>
        </div>

        <form action="/admin/comments" method="get" class="search-bar">
            <input type="text" class="search-input" name="keyword" placeholder="댓글 내용 검색..." value="{{keyword}}"/>
            <button type="submit" class="search-btn">검색</button>
        </form>

        <div class="admin-table-wrap">
            <div class="admin-table-head">
                <span class="cell-id">No</span>
                <span class="cell-content">댓글 내용</span>
                <span class="cell-author">작성자</span>
                <span class="cell-board">게시글</span>
                <span class="cell-date">작성일</span>
                <span class="cell-action">관리</span>
            </div>

            {{#comments}}
            <div class="admin-table-row">
                <span class="cell-id">{{id}}</span>
                <span class="cell-content">{{comment}}</span>
                <span class="cell-author">{{memberName}}</span>
                <span class="cell-board">
                    <a href="/boards/{{boardId}}" class="board-link">#{{boardId}}</a>
                </span>
                <span class="cell-date">{{createdAt}}</span>
                <span class="cell-action">
                    <form action="/comments/{{id}}/delete" method="post" style="display:inline;"
                          onsubmit="return confirm('삭제하시겠습니까?')">
                        <input type="hidden" name="boardId" value="{{boardId}}"/>
                        <button type="submit" class="del-btn">삭제</button>
                    </form>
                </span>
            </div>
            {{/comments}}

            {{^comments}}
            <div class="empty-msg">댓글이 없습니다.</div>
            {{/comments}}
        </div>
    </main>
</div>

{{> layout/footer}}

{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .msg-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }

    /* 헤더 */
    .msg-header { padding: 26px 32px 0; border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0; }
    .msg-header-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
    .msg-title { font-size: 22px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; margin-bottom: 4px; }
    .msg-desc { font-size: 13px; color: #4a6fa5; }
    .btn-write {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 10px 20px; border-radius: 20px; font-size: 13px; font-weight: 800;
        background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff;
        border: none; cursor: pointer; font-family: inherit; text-decoration: none;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s; flex-shrink: 0;
    }
    .btn-write:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    /* 탭 */
    .msg-tabs { display: flex; gap: 0; }
    .msg-tab {
        padding: 14px 22px; font-size: 14px; font-weight: 700; color: #4a6fa5;
        border-bottom: 2.5px solid transparent; cursor: pointer; transition: all .15s;
        text-decoration: none; white-space: nowrap;
    }
    .msg-tab:hover { color: #1e3a6e; }
    .msg-tab.active { color: #2563eb; border-bottom-color: #2563eb; }

    /* 검색 툴바 */
    .msg-toolbar {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 32px; border-bottom: 1px solid rgba(37,99,235,.06); flex-shrink: 0;
    }
    .filter-select {
        padding: 9px 14px; border-radius: 12px; font-size: 13px; font-weight: 600;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        font-family: inherit; outline: none; cursor: pointer; transition: all .15s;
    }
    .filter-select:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.9); }
    .search-wrap { flex: 1; position: relative; }
    .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #93aecf; pointer-events: none; }
    .filter-search {
        width: 100%; padding: 9px 14px 9px 38px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); border-radius: 12px;
        font-size: 13px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .15s; box-sizing: border-box;
    }
    .filter-search::placeholder { color: #93aecf; }
    .filter-search:focus { border-color: rgba(37,99,235,.4); background: rgba(255,255,255,.9); }
    .btn-search {
        padding: 9px 18px; border-radius: 12px; border: none;
        background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff;
        font-weight: 700; font-size: 13px; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 10px rgba(37,99,235,.25); transition: all .15s; white-space: nowrap;
    }
    .btn-search:hover { transform: translateY(-1px); }

    /* 테이블 헤더 */
    .table-head {
        display: grid; grid-template-columns: 50px 1fr 140px 120px 80px;
        gap: 12px; padding: 11px 32px;
        background: rgba(255,255,255,.3); border-bottom: 1px solid rgba(37,99,235,.06);
        font-size: 12px; font-weight: 700; color: #4a6fa5; flex-shrink: 0;
    }

    /* 테이블 바디 */
    .table-body { flex: 1; overflow-y: auto; }
    .table-row {
        display: grid; grid-template-columns: 50px 1fr 140px 120px 80px;
        gap: 12px; padding: 15px 32px;
        border-bottom: 1px solid rgba(37,99,235,.05);
        align-items: center; transition: background .12s;
        text-decoration: none; color: inherit; cursor: pointer;
    }
    .table-row:last-child { border-bottom: none; }
    .table-row:hover { background: rgba(255,255,255,.4); }
    .table-row.unread { background: rgba(239,246,255,.3); }

    /* 셀 */
    .cell-icon { display: flex; align-items: center; justify-content: center; color: #93aecf; }
    .cell-icon.unread-icon { color: #2563eb; }
    .cell-title { font-size: 14px; font-weight: 600; color: #1e3a6e; display: flex; align-items: center; gap: 8px; overflow: hidden; }
    .cell-title-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .new-badge { font-size: 10px; background: rgba(37,99,235,.1); color: #2563eb; border: 1px solid rgba(37,99,235,.2); padding: 1px 7px; border-radius: 5px; font-weight: 700; flex-shrink: 0; }
    .cell-author { font-size: 13px; color: #4a6fa5; font-weight: 500; }
    .cell-date { font-size: 12px; color: #93aecf; }
    .cell-status { text-align: center; }
    .badge-unread { font-size: 11px; background: rgba(37,99,235,.1); color: #2563eb; border: 1px solid rgba(37,99,235,.2); padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }
    .badge-read { font-size: 11px; background: rgba(156,163,175,.1); color: #93aecf; border: 1px solid rgba(156,163,175,.2); padding: 3px 10px; border-radius: 20px; font-weight: 700; display: inline-block; }

    /* 빈 상태 */
    .empty-state { text-align: center; padding: 60px 0; font-size: 14px; color: #93aecf; }

    /* 푸터 */
    .msg-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 32px 20px; border-top: 1px solid rgba(37,99,235,.06); flex-shrink: 0;
    }
    .msg-total { font-size: 13px; color: #4a6fa5; font-weight: 500; }
    .msg-total strong { color: #1e3a6e; font-weight: 700; }
    .paging { display: flex; align-items: center; gap: 6px; }
    .page-btn {
        padding: 7px 14px; border-radius: 10px; font-size: 13px; font-weight: 600;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8); color: #2d4a7a;
        text-decoration: none; transition: all .15s;
    }
    .page-btn:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .page-info { font-size: 13px; color: #4a6fa5; font-weight: 600; padding: 0 4px; }

    @media (max-width: 640px) {
        .page-wrap { padding: 12px 12px 16px; }
        .msg-header, .msg-toolbar, .table-head, .table-row, .msg-footer { padding-left: 16px; padding-right: 16px; }
        .table-head, .table-row { grid-template-columns: 40px 1fr 80px 70px; }
        .cell-author { display: none; }
    }
</style>

<section class="page-wrap">
    <div class="msg-card">

        <!-- 헤더 -->
        <div class="msg-header">
            <div class="msg-header-top">
                <div>
                    <h1 class="msg-title">쪽지함</h1>
                    <p class="msg-desc">프로젝트 관련 쪽지를 확인하세요.</p>
                </div>
                <a href="/messages/send" class="btn-write">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4v2h16V4ZM4 6H2v14h2V6Zm18 0h-2v10h2V6Zm-4 10H6v2h12v-2Zm-8-6h8v2H10v-2Zm0-4h8v2H10V6Z"/></svg>
                    쪽지 보내기
                </a>
            </div>
            <div class="msg-tabs">
                <a href="/messages?box=received&sort={{sort}}&keyword={{keyword}}" class="msg-tab {{#isReceived}}active{{/isReceived}}">받은 쪽지함</a>
                <a href="/messages?box=sent&sort={{sort}}&keyword={{keyword}}" class="msg-tab {{#isSent}}active{{/isSent}}">보낸 쪽지함</a>
            </div>
        </div>

        <!-- 검색 툴바 -->
        <form action="/messages" method="GET">
            <input type="hidden" name="box" value="{{box}}"/>
            <input type="hidden" name="page" value="1"/>
            <div class="msg-toolbar">
                <select name="sort" class="filter-select" onchange="this.form.submit()">
                    <option value="desc" {{^isSortAsc}}selected{{/isSortAsc}}>최신순</option>
                    <option value="asc"  {{#isSortAsc}}selected{{/isSortAsc}}>오래된순</option>
                </select>
                <div class="search-wrap">
                    <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35" stroke-linecap="round"/></svg>
                    <input type="text" name="keyword" class="filter-search" placeholder="제목으로 검색" value="{{keyword}}"/>
                </div>
                <button type="submit" class="btn-search">검색</button>
            </div>
        </form>

        <!-- 받은 쪽지함 -->
        {{#isReceived}}
            <div class="table-head">
                <div></div>
                <div>제목</div>
                <div>보낸 사람</div>
                <div>날짜</div>
                <div style="text-align:center;">읽음</div>
            </div>
            <div class="table-body">
                {{#messages}}
                    <a href="/messages/{{id}}" class="table-row {{^isRead}}unread{{/isRead}}">
            <span class="cell-icon {{^isRead}}unread-icon{{/isRead}}">
                {{#isRead}}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4v2h16V4ZM4 6H2v14h2V6Zm18 0h-2v14h2V6Zm-4 12H6v2h12v-2Zm-8-6h8v2H10v-2Z"/></svg>
                {{/isRead}}
                {{^isRead}}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4v2h16V4ZM4 6H2v14h2V6Zm18 0h-2v14h2V6Zm-4 12H6v2h12v-2Zm-8-6h8v2H10v-2Zm0-4h8v2H10V8Z"/></svg>
                {{/isRead}}
            </span>
                        <span class="cell-title">
                {{^isRead}}<span class="new-badge">NEW</span>{{/isRead}}
                            <span class="cell-title-text">{{title}}</span>
            </span>
                        <span class="cell-author">{{senderName}}</span>
                        <span class="cell-date">{{createdAt}}</span>
                        <span class="cell-status">
                {{#isRead}}<span class="badge-read">읽음</span>{{/isRead}}
                            {{^isRead}}<span class="badge-unread">안읽음</span>{{/isRead}}
            </span>
                    </a>
                {{/messages}}
                {{^messages}}
                    <div class="empty-state">받은 쪽지가 없습니다.</div>
                {{/messages}}
            </div>
        {{/isReceived}}

        <!-- 보낸 쪽지함 -->
        {{#isSent}}
            <div class="table-head">
                <div></div>
                <div>제목</div>
                <div>받은 사람</div>
                <div>날짜</div>
                <div style="text-align:center;">읽음</div>
            </div>
            <div class="table-body">
                {{#messages}}
                    <a href="/messages/{{id}}" class="table-row">
            <span class="cell-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4v2h16V4ZM4 6H2v14h2V6Zm18 0h-2v14h2V6Zm-4 12H6v2h12v-2Zm-8-6h8v2H10v-2Z"/></svg>
            </span>
                        <span class="cell-title"><span class="cell-title-text">{{title}}</span></span>
                        <span class="cell-author">{{receiverName}}</span>
                        <span class="cell-date">{{createdAt}}</span>
                        <span class="cell-status">
                {{#isRead}}<span class="badge-read">읽음</span>{{/isRead}}
                            {{^isRead}}<span class="badge-unread">안읽음</span>{{/isRead}}
            </span>
                    </a>
                {{/messages}}
                {{^messages}}
                    <div class="empty-state">보낸 쪽지가 없습니다.</div>
                {{/messages}}
            </div>
        {{/isSent}}

        <!-- 푸터 -->
        <div class="msg-footer">
            <span class="msg-total">총 <strong>{{messageCount}}</strong>개의 쪽지</span>
            <div class="paging">
                {{#prevPage}}<a href="/messages?box={{box}}&sort={{sort}}&keyword={{keyword}}&page={{prevPage}}" class="page-btn">← 이전</a>{{/prevPage}}
                <span class="page-info">{{currentPage}} / {{totalPages}}</span>
                {{#nextPage}}<a href="/messages?box={{box}}&sort={{sort}}&keyword={{keyword}}&page={{nextPage}}" class="page-btn">다음 →</a>{{/nextPage}}
            </div>
        </div>

    </div>
</section>

{{> layout/footer}}
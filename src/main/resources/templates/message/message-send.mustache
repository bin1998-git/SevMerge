{{> layout/header}}
<style>
    body { background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%); background-attachment: fixed; }

    .page-wrap {
        min-height: calc(100vh - 64px);
        display: flex; align-items: stretch; justify-content: center;
        padding: 20px 28px 28px; position: relative; z-index: 1;
    }
    .send-card {
        width: 100%;
        backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
        background: rgba(255,255,255,.52);
        border: 1.5px solid rgba(255,255,255,.82);
        border-radius: 28px;
        box-shadow: 0 20px 60px rgba(37,99,235,.1), inset 0 1px 0 rgba(255,255,255,.9);
        display: flex; flex-direction: column; overflow: hidden;
    }
    .send-card form { flex: 1; display: flex; flex-direction: column; }

    /* 헤더 */
    .send-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 26px 36px 20px; border-bottom: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .send-header-left { display: flex; align-items: center; gap: 14px; }
    .btn-back {
        width: 36px; height: 36px; border-radius: 50%;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(255,255,255,.8);
        display: flex; align-items: center; justify-content: center;
        color: #4a6fa5; text-decoration: none; transition: all .15s; flex-shrink: 0;
    }
    .btn-back:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.3); color: #2563eb; }
    .send-title { font-size: 20px; font-weight: 900; color: #1e3a6e; letter-spacing: -.5px; }
    .send-desc { font-size: 13px; color: #4a6fa5; margin-top: 2px; }

    /* 폼 바디 */
    .send-body { flex: 1; }
    .form-row {
        display: grid; grid-template-columns: 160px 1fr;
        align-items: flex-start; padding: 18px 36px;
        border-bottom: 1px solid rgba(37,99,235,.06); transition: background .15s;
    }
    .form-row:focus-within { background: rgba(37,99,235,.02); }
    .form-row-label {
        display: flex; align-items: center; gap: 10px; padding-top: 13px; flex-shrink: 0;
    }
    .form-label-text { font-size: 14px; font-weight: 700; color: #1e3a6e; display: flex; align-items: center; gap: 4px; }
    .form-required { color: #ef4444; font-size: 13px; }

    .form-input {
        width: 100%; padding: 12px 16px; background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(37,99,235,.1); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #1e3a6e; outline: none; transition: all .18s; box-sizing: border-box;
    }
    .form-input::placeholder { color: #93aecf; }
    .form-input:focus { border-color: #2563eb; background: rgba(255,255,255,.9); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
    .form-textarea { resize: vertical; min-height: 260px; line-height: 1.8; }

    /* 받는 사람 커스텀 드롭다운 */
    .contact-select-wrap { position: relative; }
    .contact-trigger {
        width: 100%; padding: 12px 16px; background: rgba(255,255,255,.6);
        border: 1.5px solid rgba(37,99,235,.1); border-radius: 12px;
        font-size: 14px; font-family: inherit; color: #93aecf;
        cursor: pointer; display: flex; align-items: center; justify-content: space-between;
        box-sizing: border-box; transition: all .15s; user-select: none;
    }
    .contact-trigger.has-value { color: #1e3a6e; }
    .contact-trigger:hover, .contact-trigger.open { border-color: #2563eb; background: rgba(255,255,255,.9); }
    .contact-arrow { font-size: 11px; color: #93aecf; transition: transform .15s; }
    .contact-trigger.open .contact-arrow { transform: rotate(180deg); }
    .contact-dropdown {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0;
        backdrop-filter: blur(20px); background: rgba(255,255,255,.9);
        border: 1.5px solid rgba(255,255,255,.9); border-radius: 16px;
        box-shadow: 0 8px 32px rgba(37,99,235,.12);
        z-index: 100; overflow: hidden; display: none; max-height: 280px; overflow-y: auto;
    }
    .contact-dropdown.open { display: block; }
    .contact-item { padding: 12px 16px; cursor: pointer; border-bottom: 1px solid rgba(37,99,235,.06); transition: background .1s; }
    .contact-item:last-child { border-bottom: none; }
    .contact-item:hover { background: rgba(239,246,255,.7); }
    .contact-item-name { font-size: 14px; font-weight: 700; color: #1e3a6e; display: flex; align-items: center; gap: 8px; }
    .contact-item-project { font-size: 12px; color: #4a6fa5; margin-top: 3px; }
    .badge-selected { font-size: 10px; background: rgba(254,243,199,.9); color: #d97706; border: 1px solid rgba(253,230,138,.7); padding: 2px 7px; border-radius: 5px; font-weight: 700; }
    .contact-empty { padding: 28px 16px; text-align: center; font-size: 13px; color: #93aecf; }

    /* 파일 드롭존 */
    .file-dropzone {
        border: 2px dashed rgba(37,99,235,.2); border-radius: 14px; padding: 24px 16px;
        text-align: center; cursor: pointer; background: rgba(255,255,255,.4); transition: all .2s;
    }
    .file-dropzone:hover { border-color: #2563eb; background: rgba(239,246,255,.6); }
    .file-dropzone.dragover { border-color: #2563eb; background: rgba(239,246,255,.8); transform: scale(1.01); }
    .file-dropzone-inner { display: flex; flex-direction: column; align-items: center; gap: 6px; pointer-events: none; }
    .file-dropzone-text { font-size: 13px; color: #4a6fa5; }
    .file-add-btn {
        pointer-events: auto; margin-top: 4px; padding: 7px 16px;
        font-size: 13px; font-weight: 700; color: #2563eb;
        backdrop-filter: blur(4px); background: rgba(255,255,255,.8);
        border: 1.5px solid rgba(37,99,235,.2); border-radius: 20px;
        cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .file-add-btn:hover { background: rgba(239,246,255,.9); }
    .file-hint { font-size: 11px; color: #93aecf; margin-top: 6px; }
    .file-list { list-style: none; padding: 0; margin: 10px 0 0; display: flex; flex-direction: column; gap: 6px; }
    .file-item {
        display: flex; align-items: center; gap: 10px; padding: 8px 14px;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85); border-radius: 10px;
    }
    .file-thumb { width: 32px; height: 32px; border-radius: 6px; object-fit: cover; flex-shrink: 0; }
    .file-thumb-icon { width: 32px; height: 32px; border-radius: 6px; background: rgba(239,246,255,.8); display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; color: #2563eb; }
    .file-meta { flex: 1; min-width: 0; }
    .file-name { font-size: 13px; font-weight: 600; color: #1e3a6e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .file-size { font-size: 11px; color: #93aecf; margin-top: 2px; }
    .file-remove { flex-shrink: 0; background: none; border: none; color: #93aecf; cursor: pointer; font-size: 16px; transition: color .15s; padding: 2px; }
    .file-remove:hover { color: #ef4444; }

    /* 푸터 버튼 */
    .send-footer {
        display: flex; justify-content: flex-end; align-items: center; gap: 10px;
        padding: 18px 36px 24px; border-top: 1px solid rgba(37,99,235,.08); flex-shrink: 0;
    }
    .btn-cancel {
        padding: 11px 24px; border-radius: 20px; font-size: 14px; font-weight: 700;
        backdrop-filter: blur(8px); background: rgba(255,255,255,.65);
        border: 1.5px solid rgba(255,255,255,.85); color: #2d4a7a;
        text-decoration: none; cursor: pointer; font-family: inherit; transition: all .15s;
    }
    .btn-cancel:hover { background: rgba(255,255,255,.9); border-color: rgba(37,99,235,.2); }
    .btn-submit {
        padding: 11px 28px; border-radius: 20px; font-size: 14px; font-weight: 800;
        background: linear-gradient(135deg, #2563eb, #7c3aed); color: #fff;
        border: none; cursor: pointer; font-family: inherit;
        box-shadow: 0 4px 14px rgba(37,99,235,.3); transition: all .15s;
        display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(37,99,235,.4); }

    @media (max-width: 640px) {
        .page-wrap { padding: 12px 12px 16px; }
        .send-header, .form-row, .send-footer { padding-left: 18px; padding-right: 18px; }
        .form-row { grid-template-columns: 1fr; gap: 8px; }
        .form-row-label { padding-top: 0; }
    }
</style>

<div id="contacts-data" style="display:none;">
    {{#contacts}}
        <div class="contact-entry"
             data-receiver-id="{{receiverId}}"
             data-receiver-name="{{receiverName}}"
             data-project-id="{{projectId}}"
             data-project-title="{{projectTitle}}"
             data-selected="{{selected}}"></div>
    {{/contacts}}
</div>

<section class="page-wrap">
    <div class="send-card">

        <!-- 헤더 -->
        <div class="send-header">
            <div class="send-header-left">
                <a href="javascript:history.back()" class="btn-back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
                </a>
                <div>
                    <div class="send-title">쪽지 보내기</div>
                    <div class="send-desc">입찰이 완료된 프로젝트의 상대방에게 쪽지를 보낼 수 있습니다.</div>
                </div>
            </div>
        </div>

        <!-- 폼 -->
        <form action="/messages/send" method="POST" id="send-form" enctype="multipart/form-data">
            <input type="hidden" name="receiverId" id="receiverId"/>
            <input type="hidden" name="projectId" id="projectId"/>

            <div class="send-body">

                <!-- 받는 사람 -->
                <div class="form-row">
                    <div class="form-row-label">
                        <span class="form-label-text">받는 사람 <span class="form-required">*</span></span>
                    </div>
                    <div class="contact-select-wrap">
                        <div class="contact-trigger" id="contact-trigger">
                            <span id="contact-trigger-text">받는 사람을 선택하세요</span>
                            <span class="contact-arrow">▼</span>
                        </div>
                        <div class="contact-dropdown" id="contact-dropdown"></div>
                    </div>
                </div>

                <!-- 제목 -->
                <div class="form-row">
                    <div class="form-row-label">
                        <span class="form-label-text">제목 <span class="form-required">*</span></span>
                    </div>
                    <input type="text" name="title" class="form-input" placeholder="쪽지 제목을 입력하세요." maxlength="100" required/>
                </div>

                <!-- 내용 -->
                <div class="form-row">
                    <div class="form-row-label" style="padding-top:13px;">
                        <span class="form-label-text">내용 <span class="form-required">*</span></span>
                    </div>
                    <textarea name="content" class="form-input form-textarea" placeholder="쪽지 내용을 입력하세요." required></textarea>
                </div>

                <!-- 파일 첨부 -->
                <div class="form-row">
                    <div class="form-row-label" style="padding-top:13px;">
                        <span class="form-label-text">파일 첨부</span>
                    </div>
                    <div>
                        <div class="file-dropzone" id="file-dropzone">
                            <div class="file-dropzone-inner">
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#93aecf" stroke-width="1.5"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M16 12l-4-4m0 0L8 12m4-4v12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <span class="file-dropzone-text" id="file-dropzone-text">파일을 이곳에 끌어다 놓으세요</span>
                                <button type="button" class="file-add-btn" id="file-add-btn">+ 파일 추가</button>
                            </div>
                        </div>
                        <p class="file-hint">최대 5개 · 전체 용량 20MB 이하</p>
                        <input type="file" name="files" id="file-input" multiple hidden/>
                        <ul class="file-list" id="file-list"></ul>
                    </div>
                </div>

            </div>

            <!-- 푸터 버튼 -->
            <div class="send-footer">
                <a href="javascript:history.back()" class="btn-cancel">취소</a>
                <button type="submit" class="btn-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4v2h16V4ZM4 6H2v14h2V6Zm18 0h-2v14h2V6Zm-4 12H6v2h12v-2Zm-8-6h8v2H10v-2Zm0-4h8v2H10V8Z"/></svg>
                    쪽지 보내기
                </button>
            </div>
        </form>

    </div>
</section>

<script>
    (function () {
        const contacts = Array.from(document.querySelectorAll('#contacts-data .contact-entry')).map(el => ({
            receiverId: el.dataset.receiverId,
            receiverName: el.dataset.receiverName,
            projectId: el.dataset.projectId,
            projectTitle: el.dataset.projectTitle,
            selected: el.dataset.selected === 'true'
        }));
        const trigger = document.getElementById('contact-trigger');
        const dropdown = document.getElementById('contact-dropdown');
        const triggerText = document.getElementById('contact-trigger-text');
        const receiverIdInput = document.getElementById('receiverId');
        const projectIdInput = document.getElementById('projectId');

        if (contacts.length === 0) {
            dropdown.innerHTML = '<div class="contact-empty">연락 가능한 상대가 없습니다.<br>먼저 프로젝트 입찰을 진행해보세요.</div>';
        } else {
            dropdown.innerHTML = contacts.map((c, i) =>
                `<div class="contact-item" data-index="${i}">
                    <div class="contact-item-name">${c.receiverName}${c.selected ? ' <span class="badge-selected">낙찰</span>' : ''}</div>
                    <div class="contact-item-project">📁 ${c.projectTitle}</div>
                </div>`
            ).join('');
        }

        function selectContact(c) {
            receiverIdInput.value = c.receiverId;
            projectIdInput.value = c.projectId;
            triggerText.textContent = c.receiverName + ' · ' + c.projectTitle;
            trigger.classList.add('has-value');
            closeDropdown();
        }
        function closeDropdown() {
            trigger.classList.remove('open');
            dropdown.classList.remove('open');
        }

        dropdown.querySelectorAll('.contact-item').forEach(item => {
            item.addEventListener('click', () => selectContact(contacts[+item.dataset.index]));
        });
        trigger.addEventListener('click', () => {
            trigger.classList.toggle('open');
            dropdown.classList.toggle('open');
        });
        document.addEventListener('click', e => {
            if (!trigger.contains(e.target) && !dropdown.contains(e.target)) closeDropdown();
        });

        const params = new URLSearchParams(window.location.search);
        const preReceiverId = params.get('receiverId') || '';
        const preProjectId = params.get('projectId') || '';
        if (preReceiverId) {
            const match = contacts.find(c => c.receiverId === preReceiverId && (!preProjectId || c.projectId === preProjectId));
            if (match) selectContact(match);
        }

        document.getElementById('send-form').addEventListener('submit', e => {
            if (!receiverIdInput.value) { e.preventDefault(); alert('받는 사람을 선택해주세요.'); }
        });
    })();
</script>

<script>
    (function () {
        const MAX_FILES = 5, MAX_TOTAL = 20 * 1024 * 1024;
        const dropzone = document.getElementById('file-dropzone');
        const dropText = document.getElementById('file-dropzone-text');
        const addBtn = document.getElementById('file-add-btn');
        const input = document.getElementById('file-input');
        const listEl = document.getElementById('file-list');
        const defaultText = dropText.textContent;
        let files = [];

        function fmt(b) { return b < 1024 ? b+'B' : b < 1048576 ? (b/1024).toFixed(1)+'KB' : (b/1048576).toFixed(1)+'MB'; }
        function total() { return files.reduce((s,f) => s+f.size, 0); }
        function sync() { const dt = new DataTransfer(); files.forEach(f => dt.items.add(f)); input.files = dt.files; }

        function add(incoming) {
            let added = false;
            for (let f of incoming) {
                if (files.length >= MAX_FILES) { alert('최대 '+MAX_FILES+'개까지 첨부 가능합니다.'); break; }
                if (files.some(x => x.name===f.name && x.size===f.size)) continue;
                if (total()+f.size > MAX_TOTAL) { alert('전체 용량은 20MB를 초과할 수 없습니다.'); continue; }
                files.push(f); added = true;
            }
            if (added) { sync(); render(); }
        }

        function render() {
            listEl.innerHTML = '';
            files.forEach((f, i) => {
                const li = document.createElement('li');
                li.className = 'file-item';
                if (f.type.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.className = 'file-thumb'; img.src = URL.createObjectURL(f);
                    img.onload = () => URL.revokeObjectURL(img.src);
                    li.appendChild(img);
                } else {
                    const icon = document.createElement('div');
                    icon.className = 'file-thumb-icon';
                    icon.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/></svg>';
                    li.appendChild(icon);
                }
                const meta = document.createElement('div'); meta.className = 'file-meta';
                const name = document.createElement('div'); name.className = 'file-name'; name.textContent = f.name;
                const size = document.createElement('div'); size.className = 'file-size'; size.textContent = fmt(f.size);
                meta.appendChild(name); meta.appendChild(size); li.appendChild(meta);
                const btn = document.createElement('button'); btn.type = 'button'; btn.className = 'file-remove'; btn.textContent = '✕';
                btn.addEventListener('click', () => { files.splice(i,1); sync(); render(); });
                li.appendChild(btn);
                listEl.appendChild(li);
            });
        }

        addBtn.addEventListener('click', e => { e.stopPropagation(); input.click(); });
        dropzone.addEventListener('click', () => input.click());
        input.addEventListener('change', () => { if (input.files?.length) add([...input.files]); });
        dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); dropText.textContent = '파일을 여기에 놓으세요'; });
        dropzone.addEventListener('dragleave', () => { dropzone.classList.remove('dragover'); dropText.textContent = defaultText; });
        dropzone.addEventListener('drop', e => { e.preventDefault(); dropzone.classList.remove('dragover'); dropText.textContent = defaultText; if (e.dataTransfer?.files) add([...e.dataTransfer.files]); });
    })();
</script>


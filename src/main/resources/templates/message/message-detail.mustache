{{> layout/header}}

<style>
    body {
        background: linear-gradient(135deg, #c8d8f0 0%, #dce8f8 40%, #b8cce8 100%);
        background-attachment: fixed;
        color: #1e293b;
        line-height: 1.6;
    }

    /* ══ 배경 글로우 ══ */
    .bg-glow { position: fixed; pointer-events: none; z-index: 0; }
    .bg-glow-1 {
        width: 600px; height: 600px; border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,255,.5) 0%, transparent 70%);
        top: -150px; left: -150px;
    }
    .bg-glow-2 {
        width: 500px; height: 500px; border-radius: 50%;
        background: radial-gradient(circle, rgba(37,99,235,.12) 0%, transparent 70%);
        bottom: 10%; right: -100px;
    }
    .bg-glow-3 {
        width: 400px; height: 400px; border-radius: 50%;
        background: radial-gradient(circle, rgba(0,200,224,.08) 0%, transparent 70%);
        top: 40%; left: 30%;
    }

    .detail-section { padding: 48px 28px 80px; position: relative; z-index: 1; }
    .detail-inner { max-width: 780px; margin: 0 auto; }

    /* ── 뒤로가기 ── */
    .back-link {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 13px; color: #9ca3af; text-decoration: none;
        margin-bottom: 20px; font-weight: 500; transition: color .15s;
    }
    .back-link:hover { color: #2563eb; }

    /* ── 상세 카드 ── */
    .detail-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border-radius: 22px;
        border: 1.5px solid rgba(255,255,255,.85);
        overflow: hidden;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .detail-header {
        padding: 28px 32px 20px;
        border-bottom: 1px solid rgba(255,255,255,.6);
    }
    .detail-title { font-size: 20px; font-weight: 800; color: #1c1e26; margin-bottom: 14px; }
    .detail-meta { display: flex; gap: 24px; flex-wrap: wrap; }
    .detail-meta-item { font-size: 13px; color: #9ca3af; }
    .detail-meta-item strong { color: #4b5563; font-weight: 600; }

    .detail-project {
        display: inline-flex; align-items: center; gap: 6px; margin-top: 12px;
        backdrop-filter: blur(8px);
        background: rgba(240,244,255,.7); color: #2563eb;
        border: 1px solid rgba(191,219,254,.5);
        border-radius: 8px; padding: 6px 14px;
        font-size: 13px; font-weight: 600; text-decoration: none;
        transition: background .15s;
    }
    .detail-project:hover { background: rgba(219,234,254,.85); }

    .detail-body { padding: 28px 32px; min-height: 160px; }
    .detail-content { font-size: 15px; color: #374151; line-height: 1.8; white-space: pre-wrap; }

    .detail-file {
        display: inline-flex; align-items: center; gap: 6px; margin-top: 16px;
        backdrop-filter: blur(8px);
        background: rgba(240,244,255,.7); color: #2563eb;
        border: 1px solid rgba(191,219,254,.5);
        border-radius: 8px; padding: 8px 14px;
        font-size: 13px; font-weight: 600; text-decoration: none;
        transition: background .15s;
    }
    .detail-file:hover { background: rgba(219,234,254,.85); }

    .detail-actions {
        padding: 20px 32px;
        border-top: 1px solid rgba(255,255,255,.6);
        display: flex; gap: 10px; justify-content: flex-end;
    }
    .btn { display: inline-block; padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; font-family: inherit; transition: all .15s; text-decoration: none; }
    .btn-sm { padding: 8px 18px; font-size: 13px; border-radius: 8px; }
    .btn-danger {
        backdrop-filter: blur(8px);
        background: rgba(255,242,242,.7); color: #ef4444;
        border: 1.5px solid rgba(252,165,165,.6); font-weight: 700; cursor: pointer;
    }
    .btn-danger:hover { background: rgba(254,242,242,.95); }
    .btn-primary {
        background: #2563eb; color: #fff;
        box-shadow: 0 4px 12px rgba(37,99,235,.3);
    }
    .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); }

    /* ── 답장 카드 ── */
    .reply-card {
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.6);
        border-radius: 22px;
        border: 1.5px solid rgba(255,255,255,.85);
        margin-top: 20px; overflow: hidden;
        box-shadow: 0 8px 32px rgba(37,99,235,.08), inset 0 1px 0 rgba(255,255,255,.9);
    }
    .reply-header {
        padding: 18px 32px;
        border-bottom: 1px solid rgba(255,255,255,.6);
        background: rgba(176,200,232,.15);
    }
    .reply-title { font-size: 15px; font-weight: 700; color: #1c1e26; }
    .reply-body { padding: 20px 32px; }

    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-input {
        width: 100%; padding: 11px 14px;
        backdrop-filter: blur(4px);
        background: rgba(255,255,255,.7);
        border: 1.5px solid rgba(255,255,255,.85);
        border-radius: 9px; font-size: 14px; font-family: inherit; color: #1c1e26;
        outline: none; box-sizing: border-box; transition: border-color .15s, background .15s;
    }
    .form-input:focus { border-color: #2563eb; background: rgba(255,255,255,.95); }
    .form-input::placeholder { color: #c4c9d9; }
    .form-textarea { resize: vertical; min-height: 100px; }

    .reply-actions {
        padding: 16px 32px;
        border-top: 1px solid rgba(255,255,255,.6);
        display: flex; justify-content: flex-end;
    }
</style>

<!-- 배경 글로우 -->
<div class="bg-glow bg-glow-1"></div>
<div class="bg-glow bg-glow-2"></div>
<div class="bg-glow bg-glow-3"></div>

<section class="detail-section">
    <div class="detail-inner">

        <a href="/messages?box=received" class="back-link">← 받은 쪽지함으로</a>

        <div class="detail-card">
            <div class="detail-header">
                <p class="detail-title">{{message.title}}</p>
                <div class="detail-meta">
                    <span class="detail-meta-item">보낸 사람 <strong>{{message.senderName}}</strong></span>
                    <span class="detail-meta-item">받는 사람 <strong>{{message.receiverName}}</strong></span>
                    <span class="detail-meta-item">날짜 <strong>{{message.createdAt}}</strong></span>
                </div>
                {{#projectTitle}}
                <a href="/projects/{{message.projectId}}" class="detail-project">
                    📁 관련 프로젝트: {{message.projectTitle}}
                </a>
                {{/projectTitle}}
            </div>

            <div class="detail-body">
                <p class="detail-content">{{message.content}}</p>

                {{#message.files}}
                    <a href="/messages/files/{{id}}/download" class="detail-file">
                        📎 {{originalFilename}}
                    </a>
                {{/message.files}}
            </div>

            <div class="detail-actions">
                <form action="/messages/{{message.id}}/delete" method="POST" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm"
                            onclick="return confirm('쪽지를 삭제하시겠습니까?')">삭제</button>
                </form>
            </div>
        </div>

        <!-- 답장 폼 -->
        <div class="reply-card">
            <div class="reply-header">
                <p class="reply-title">답장 보내기</p>
            </div>
            <div class="reply-body">
                <form action="/messages/send" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="receiverId" value="{{message.senderId}}" />
                    <input type="hidden" name="projectId" value="{{message.projectId}}" />
                    <div class="form-group">
                        <label class="form-label">제목</label>
                        <input type="text" name="title" class="form-input" value="RE: {{message.title}}" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">내용</label>
                        <textarea name="content" class="form-input form-textarea" placeholder="답장 내용을 입력하세요."></textarea>
                    </div>
                    <div class="form-group">
                        <label class="form-label">파일 첨부</label>
                        <input type="file" name="files" class="form-input" multiple />
                    </div>
                    <div class="reply-actions">
                        <button type="submit" class="btn btn-primary btn-sm">답장 보내기</button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</section>

{{> layout/footer}}

<script>
    (function () {
        var path = window.location.pathname;
        document.querySelectorAll('.esn-link').forEach(function (link) {
            var target = link.getAttribute('data-esn');
            if (path === target || path.startsWith(target + '/') || (target !== '/experts/dashboard' && path.startsWith(target))) {
                link.classList.add('active');
            }
        });
    })();
</script>

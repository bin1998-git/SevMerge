<style>
    .esn-bar {
        position: sticky;
        top: 64px;
        z-index: 900;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        background: rgba(255,255,255,.72);
        border-bottom: 1px solid rgba(255,255,255,.6);
        box-shadow: 0 2px 12px rgba(37,99,235,.07);
    }
    .esn-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 28px;
        display: flex;
        align-items: center;
        gap: 2px;
        height: 46px;
        overflow-x: auto;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .esn-inner::-webkit-scrollbar { display: none; }
    .esn-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #4a6fa5;
        text-decoration: none;
        white-space: nowrap;
        transition: background .12s, color .12s;
        flex-shrink: 0;
    }
    .esn-link:hover {
        background: rgba(37,99,235,.08);
        color: #2563eb;
    }
    .esn-link.active {
        background: rgba(37,99,235,.1);
        color: #2563eb;
        font-weight: 700;
    }
    .esn-link svg { flex-shrink: 0; }
    .esn-divider {
        width: 1px;
        height: 16px;
        background: rgba(37,99,235,.12);
        margin: 0 6px;
        flex-shrink: 0;
    }
    @media (max-width: 640px) {
        .esn-inner { padding: 0 12px; gap: 0; }
        .esn-link { padding: 6px 10px; font-size: 12px; }
        .esn-divider { display: none; }
    }
</style>


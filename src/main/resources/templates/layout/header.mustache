<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SevMerge - IT 외주 입찰 플랫폼</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap"
          rel="stylesheet"/>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: #f5f6fa;
            color: #1c1e26;
            line-height: 1.6;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ── 버튼 ── */
        .btn {
            display: inline-block;
            padding: 10px 22px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-family: inherit;
            transition: all .15s;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
        }

        .btn-primary:hover {
            background: #1d4ed8;
        }

        .btn-outline {
            background: #fff;
            border: 1.5px solid #e2e5ef;
            color: #4b5563;
        }

        .btn-outline:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .btn-lg {
            padding: 14px 32px;
            font-size: 15px;
            border-radius: 10px;
        }

        /* ── NAV ── */
        .nav {
            background: #fff;
            border-bottom: 1px solid #eaecf4;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-inner {
            max-width: 1140px;
            margin: 0 auto;
            padding: 0 28px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: nowrap;
            overflow: visible;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            flex-shrink: 0;
        }
        .nav-logo img {
            display: block;
            height: 30px;
            width: auto;
        }

        .nav-links {
            display: flex;
            gap: 24px;
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
            min-width: 0;
            overflow: visible;
        }

        .nav-links a:hover {
            color: #1c1e26;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            flex-wrap: nowrap;
            white-space: nowrap;
        }

        .nav-username {
            font-size: 13px;
            color: #9ca3af;
            font-weight: 500;
            margin-right: 4px;
        }

        /* ── HERO ── */
        .hero {
            background: #fff;
            border-bottom: 1px solid #eaecf4;
            padding: 88px 28px 76px;
        }

        .hero-inner {
            max-width: 1140px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 72px;
            align-items: center;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .hero-eyebrow::before {
            content: '';
            width: 20px;
            height: 2px;
            background: #2563eb;
            border-radius: 2px;
        }

        .hero-title {
            font-size: 50px;
            font-weight: 900;
            line-height: 1.12;
            letter-spacing: -2px;
            color: #1c1e26;
            margin-bottom: 18px;
        }

        .hero-title em {
            color: #2563eb;
            font-style: normal;
        }



        /* ── 전문가 전용 탭 네비 ── */
        .nav-links.expert-links {
            flex: 1;
            gap: 0;
            justify-content: center;
            min-width: 0;
            overflow-x: auto;
            scrollbar-width: none;
        }
        .nav-links.expert-links::-webkit-scrollbar { display: none; }

        .expert-nav-tab {
            padding: 0 18px;
            height: 64px;
            display: flex;
            align-items: center;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            border-bottom: 2px solid transparent;
            white-space: nowrap;
            transition: color .15s, border-color .15s;
        }

        .expert-nav-tab:hover { color: #1c1e26; border-color: #d1d5db; }
        .expert-nav-tab.active { color: #2563eb; border-color: #2563eb; }

        /* 잔액 위젯 */
        .nav-balance-wrap { display: flex; align-items: center; gap: 6px; background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 10px; padding: 6px 12px; flex-shrink: 0; white-space: nowrap; }
        .nav-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .nav-balance-amount { font-size: 14px; font-weight: 900; color: #1d4ed8; }
        .nav-charge-btn { font-size: 11px; font-weight: 700; background: #2563eb; color: #fff; border-radius: 6px; padding: 3px 9px; text-decoration: none; transition: background .15s; white-space: nowrap; }
        .nav-charge-btn:hover { background: #1d4ed8; }
        .nav-bell { position: relative; display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; color: #6b7280; transition: background .15s,
        color .15s; }
        .nav-bell:hover { background: #eff6ff; color: #2563eb; }
        .nav-bell svg { width: 21px; height: 21px; }
        .nav-bell-dot { position: absolute; top: 8px; right: 9px; width: 9px; height: 9px; background: #22c55e; border: 2px solid #fff; border-radius: 50%; }


        .profile-menu { position: relative; }
        .profile-trigger { background: none; border: none; cursor: pointer; padding: 0; display: flex; align-items: center; }
        .profile-thumb { width: 44px; height: 44px; border-radius: 50%; background-size: cover; background-position: center; background-color: #eff6ff; border: 1.5px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 0; overflow: hidden; flex-shrink: 0; }
        .profile-thumb-default { font-size: 14px; font-weight: 800; color: #2563eb; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 0 4px; }
        .profile-dropdown { display: none; position: absolute; top: 50px; right: 0; min-width: 180px; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,.1); padding: 6px; z-index: 9999; }
        .profile-dropdown.open { display: block; }
        .pd-head { padding: 10px 12px 8px; border-bottom: 1px solid #f3f4f8; margin-bottom: 6px; }
        .pd-name { font-size: 14px; font-weight: 800; color: #1c1e26; }
        .pd-item { display: block; padding: 10px 12px; font-size: 13px; font-weight: 600; color: #4b5563; text-decoration: none; border-radius: 8px; transition: background .12s; }
        .pd-item:hover { background: #f8f9ff; color: #2563eb; }
        .pd-logout { color: #ef4444; }
        .pd-logout:hover { background: #fff3f3; color: #ef4444; }
        .pd-balance-row { display: flex; align-items: center; gap: 6px; padding: 10px 12px; margin-bottom: 4px; background: #eff6ff; border-radius: 8px; }
        .pd-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .pd-balance-amount { font-size: 13px; font-weight: 900; color: #1d4ed8; flex: 1; }
        .pd-charge-btn { font-size: 11px; font-weight: 700; background: #2563eb; color: #fff; border-radius: 6px; padding: 3px 9px; text-decoration: none; white-space: nowrap; }
        .pd-charge-btn:hover { background: #1d4ed8; }
        .admin-dropdown-trigger {
            font-size: inherit;
            font-weight: inherit;
            color: inherit;
            transition: color 0.15s;
        }

        .admin-dropdown-container:hover .nav-submenu,
        .nav-submenu.active {
            display: flex !important;
            flex-direction: column !important;
        }

        .nav-submenu {
            display: none;
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            background-color: #ffffff;
            min-width: 140px;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            padding: 4px 0;
            z-index: 9999;
        }

        .nav-submenu .submenu-link {
            position: relative !important;
            display: block !important;
            width: 100% !important;
            box-sizing: border-box !important;
            padding: 10px 0 !important;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280 !important; /* 평소 기본 회색 */
            background-color: transparent !important;
            text-decoration: none;
            white-space: nowrap;
            transition: all 0.1s;
            text-align: center !important;
            border-left: none !important;
        }

        .nav-submenu .submenu-link.active-link {
            color: #2563eb !important;
            background-color: #eff6ff !important;
        }
        .nav-submenu .submenu-link.active-link::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
            background-color: #2563eb;
        }

        .nav-submenu .submenu-link:hover {
            color: #2563eb !important;
            background-color: #eff6ff !important;
        }

        .nav-submenu .submenu-link:hover::before {
            content: "" !important;
            position: absolute !important;
            left: 0 !important;
            top: 0 !important;
            bottom: 0 !important;
            width: 4px !important;
            background-color: #2563eb !important;
        }

        .nav-submenu:hover .submenu-link.active-link:not(:hover) {
            background-color: transparent !important;
            color: #6b7280 !important;
        }
        .nav-submenu:hover .submenu-link.active-link:not(:hover)::before {
            display: none !important;
        }

        .noti-toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            background: #eff6ff;
            border: 1.5px solid #bfdbfe;
            border-radius: 14px;
            padding: 16px 20px;
            z-index: 9999;
            animation: notiToastFade 4s ease forwards;
            max-width: 320px;
            box-shadow: 0 8px 30px rgba(37, 99, 235, .12);
        }

        .noti-toast-label {
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            margin-bottom: 4px;
        }

        .noti-toast-content {
            font-size: 13px;
            color: #374151;
            line-height: 1.6;
        }

        @keyframes notiToastFade {
            0%   { opacity: 0; transform: translateY(10px); }
            15%  { opacity: 1; transform: translateY(0); }
            80%  { opacity: 1; }
            100% { opacity: 0; }
        }

        /* ── FOOTER ── */
        .footer {
            background: #f5f6fa;
            border-top: 1px solid #eaecf4;
            padding: 28px;
        }

        .footer-inner {
            max-width: 1140px;
            margin: 0 auto;
            display: flex;
            justify-content: center;
        }

        .footer-copy {
            font-size: 12px;
            color: #c4c9d9;
        }
    </style>

</head>

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SevMerge - IT 외주 입찰 플랫폼</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy:      #0d1b2e;
            --cyan:      #00c8e0;
            --cyan-dark: #00a8be;
            --blue:      #2563eb;
            --blue-dark: #1d4ed8;
            --blue-soft: #eff6ff;
            --white:     #ffffff;
            --gray:      #6b7280;
            --gray-lt:   #9ca3af;
            --border:    #e5e7eb;
        }

        body {
            font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            padding-top: 64px;
        }

        a { text-decoration: none; color: inherit; }

        /* ══ NAV ══ */
        .nav {
            position: fixed !important;
            top: 0 !important; left: 0 !important; right: 0 !important;
            width: 100% !important;
            z-index: 99999 !important;
            background: #fff;
            border-bottom: 1px solid var(--border);
            height: 64px;
            display: flex !important;
            align-items: center;
            box-shadow: 0 2px 12px rgba(0,0,0,.08);
        }
        .nav-inner {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 28px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }
        .nav-logo {
            display: flex; align-items: center; flex-shrink: 0;
        }
        .nav-logo img { display: block; height: 28px; width: auto; }

        /* ── 공통 탭 ── */
        .nav-tabs {
            flex: 1; min-width: 0;
            display: flex; align-items: center;
            justify-content: center;
            overflow: hidden; /* 잘림 방지: 햄버거로 처리 */
        }
        .nav-tab {
            padding: 0 13px; height: 64px;
            display: flex; align-items: center;
            font-size: 13px; font-weight: 600; color: #6b7280;
            border-bottom: 2px solid transparent; white-space: nowrap;
            transition: color .15s, border-color .15s;
            text-decoration: none; flex-shrink: 0;
        }
        .nav-tab:hover { color: #1c1e26; border-color: #d1d5db; }
        .nav-tab.active { color: var(--blue); border-color: var(--blue); }

        /* 햄버거 버튼 (탭 모드에서만 등장) */
        .nav-hamburger {
            display: none;
            background: none; border: none; cursor: pointer;
            padding: 8px; border-radius: 8px; color: #6b7280;
            transition: background .15s, color .15s;
            flex-shrink: 0;
        }
        .nav-hamburger:hover { background: #f3f4f6; color: #1c1e26; }
        .nav-hamburger svg { width: 22px; height: 22px; display: block; }

        /* 모바일 드로어 */
        .nav-drawer {
            display: none;
            position: fixed; top: 64px; left: 0; right: 0; bottom: 0;
            z-index: 99998;
        }
        .nav-drawer.open { display: block; }
        .nav-drawer-backdrop {
            position: absolute; inset: 0;
            background: rgba(0,0,0,.3);
        }
        .nav-drawer-panel {
            position: absolute; top: 0; left: 0;
            width: 260px; height: 100%;
            background: #fff; padding: 12px 0;
            box-shadow: 4px 0 20px rgba(0,0,0,.1);
            overflow-y: auto;
        }
        .nav-drawer-item {
            display: block; padding: 14px 24px;
            font-size: 14px; font-weight: 600; color: #4b5563;
            text-decoration: none; border-left: 3px solid transparent;
            transition: all .12s;
        }
        .nav-drawer-item:hover { background: #f8f9ff; color: var(--blue); border-color: var(--blue); }
        .nav-drawer-item.active { color: var(--blue); border-color: var(--blue); background: #eff6ff; }

        /* 비로그인/관리자 일반 링크 */
        .nav-links {
            display: flex; gap: 24px; align-items: center;
            font-size: 14px; color: #6b7280; font-weight: 500;
            flex: 1; justify-content: center;
        }
        .nav-links a:hover { color: #1c1e26; }

        /* 우측 액션 */
        .nav-actions {
            display: flex; align-items: center; gap: 8px;
            flex-shrink: 0; white-space: nowrap;
        }

        /* 버튼 */
        .btn {
            display: inline-block; padding: 9px 22px; border-radius: 25px;
            font-size: 14px; font-weight: 700; cursor: pointer;
            text-decoration: none; transition: all .15s; border: none;
            font-family: inherit;
        }
        .btn-outline { border: 1.5px solid var(--border); color: #1e293b; background: #fff; }
        .btn-outline:hover { border-color: var(--blue); color: var(--blue); }
        .btn-primary { background: var(--blue); color: #fff; }
        .btn-primary:hover { background: var(--blue-dark); }

        /* ── 대시보드/마이페이지 버튼: light gray 톤 ── */
        .btn-dashboard {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 18px; border-radius: 25px;
            font-size: 14px; font-weight: 700;
            text-decoration: none; transition: all .15s;
            background: #f3f4f6;
            color: #4b5563;
            border: 1.5px solid #d1d5db;
            white-space: nowrap;
        }
        .btn-dashboard:hover, .btn-dashboard.active {
            background: #e5e7eb; color: #1c1e26; border-color: #9ca3af;
        }
        .btn-dashboard svg { width: 15px; height: 15px; flex-shrink: 0; }

        /* 잔액 위젯 */
        .nav-balance-wrap {
            display: flex; align-items: center; gap: 6px;
            background: #eff6ff; border: 1.5px solid #bfdbfe;
            border-radius: 10px; padding: 6px 12px;
            flex-shrink: 0; white-space: nowrap;
        }
        .nav-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .nav-balance-amount { font-size: 14px; font-weight: 900; color: #1d4ed8; }
        .nav-charge-btn {
            font-size: 11px; font-weight: 700;
            background: var(--blue); color: #fff;
            border-radius: 6px; padding: 3px 9px;
            text-decoration: none; transition: background .15s;
        }
        .nav-charge-btn:hover { background: var(--blue-dark); }

        /* 알림 벨 */
        .nav-bell {
            position: relative; display: inline-flex;
            align-items: center; justify-content: center;
            width: 40px; height: 40px; border-radius: 10px;
            color: #6b7280; transition: background .15s, color .15s;
        }
        .nav-bell:hover { background: #eff6ff; color: var(--blue); }
        .nav-bell svg { width: 21px; height: 21px; }
        .nav-bell-dot {
            position: absolute; top: 8px; right: 9px;
            width: 9px; height: 9px;
            background: #22c55e; border: 2px solid #fff; border-radius: 50%;
        }

        /* 프로필 드롭다운 */
        .profile-menu { position: relative; }
        .profile-trigger {
            background: none; border: none; cursor: pointer;
            padding: 0; display: flex; align-items: center;
        }
        .profile-thumb {
            width: 44px; height: 44px; border-radius: 50%;
            background-color: #eff6ff; border: 1.5px solid #bfdbfe;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden; flex-shrink: 0;
        }
        .profile-thumb-default { font-size: 14px; font-weight: 800; color: var(--blue); }
        .profile-dropdown {
            display: none; position: absolute; top: 50px; right: 0;
            min-width: 180px; background: #fff;
            border: 1px solid #e5e7eb; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1); padding: 6px; z-index: 9999;
        }
        .profile-dropdown.open { display: block; }
        .pd-head { padding: 10px 12px 8px; border-bottom: 1px solid #f3f4f8; margin-bottom: 6px; }
        .pd-name { font-size: 14px; font-weight: 800; color: #1c1e26; }
        .pd-item {
            display: block; padding: 10px 12px;
            font-size: 13px; font-weight: 600; color: #4b5563;
            text-decoration: none; border-radius: 8px; transition: background .12s;
        }
        .pd-item:hover { background: #f8f9ff; color: var(--blue); }
        .pd-logout { color: #ef4444; }
        .pd-logout:hover { background: #fff3f3; color: #ef4444; }
        .pd-balance-row {
            display: flex; align-items: center; gap: 6px;
            padding: 10px 12px; margin-bottom: 4px;
            background: #eff6ff; border-radius: 8px;
        }
        .pd-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .pd-balance-amount { font-size: 13px; font-weight: 900; color: #1d4ed8; flex: 1; }
        .pd-charge-btn {
            font-size: 11px; font-weight: 700;
            background: var(--blue); color: #fff;
            border-radius: 6px; padding: 3px 9px; text-decoration: none;
        }
        .pd-charge-btn:hover { background: var(--blue-dark); }

        /* 관리자 드롭다운 */
        .admin-dropdown-container { position: relative; display: inline-block; }
        .admin-dropdown-trigger { cursor: pointer; }
        .admin-dropdown-container:hover .nav-submenu { display: flex !important; }
        .nav-submenu {
            display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
            background: #fff; min-width: 140px;
            border: 1px solid #e5e7eb; border-radius: 6px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,.1);
            padding: 4px 0; z-index: 9999; flex-direction: column;
        }
        .nav-submenu .submenu-link {
            display: block; width: 100%; padding: 10px 0;
            font-size: 13px; font-weight: 600; color: #6b7280;
            text-decoration: none; white-space: nowrap;
            text-align: center; transition: all .1s; position: relative;
        }
        .nav-submenu .submenu-link:hover { color: var(--blue); background: #eff6ff; }
        .nav-submenu .submenu-link.active-link { color: var(--blue); background: #eff6ff; }
        .nav-submenu .submenu-link.active-link::before,
        .nav-submenu .submenu-link:hover::before {
            content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--blue);
        }

        /* 알림 토스트 */
        .noti-toast {
            position: fixed; bottom: 24px; right: 24px;
            background: #eff6ff; border: 1.5px solid #bfdbfe;
            border-radius: 14px; padding: 16px 20px;
            z-index: 9999; animation: notiToastFade 4s ease forwards;
            max-width: 320px; box-shadow: 0 8px 30px rgba(37,99,235,.12);
        }
        .noti-toast-label { font-size: 12px; font-weight: 700; color: var(--blue); margin-bottom: 4px; }
        .noti-toast-content { font-size: 13px; color: #374151; line-height: 1.6; }
        @keyframes notiToastFade {
            0%   { opacity: 0; transform: translateY(10px); }
            15%  { opacity: 1; transform: translateY(0); }
            80%  { opacity: 1; }
            100% { opacity: 0; }
        }

        /* ── 반응형 ──
           탭이 있는 경우(로그인 + isDashboard):
           - 860px 이하: 탭 숨기고 햄버거 버튼 표시
           탭 없는 경우:
           - 960px 이하: nav-links 숨김
        */
        @media (max-width: 860px) {
            .nav-inner { padding: 0 16px; }
            .nav-tabs { display: none; }
            .nav-hamburger { display: flex !important; align-items: center; justify-content: center; }
            .nav-logo img { height: 24px; }
            .btn-dashboard { padding: 7px 14px; font-size: 13px; }
        }
        @media (max-width: 960px) {
            .nav-links { display: none; }
        }
        @media (max-width: 480px) {
            .nav-inner { padding: 0 12px; }
            .btn-dashboard { display: none; }
        }
    </style>
</head>
<body>


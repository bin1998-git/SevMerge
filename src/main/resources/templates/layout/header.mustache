<!-- ══ SSE 알림 ══ -->
{{#isLoggedIn}}
    <script>
        const sse = new EventSource('/notifications/subscribe');
        sse.addEventListener('notification', function(e) {
            const data = JSON.parse(e.data);
            showNotiToast(data);
            const bell = document.querySelector('.nav-bell');
            if (bell && !bell.querySelector('.nav-bell-dot')) {
                const dot = document.createElement('span');
                dot.className = 'nav-bell-dot';
                bell.appendChild(dot);
            }
        });
        window.addEventListener('beforeunload', function() { sse.close(); });
        function showNotiToast(data) {
            const toast = document.createElement('div');
            toast.className = 'noti-toast';
            toast.innerHTML = '<div class="noti-toast-label">' + data.typeLabel + '</div><div class="noti-toast-content">' + data.content + '</div>';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
    </script>
{{/isLoggedIn}}

<!-- ══ 공통 스크립트 ══ -->
<script>
    window.addEventListener('DOMContentLoaded', () => {
        /* 비로그인 링크 전환 */
        const isIntroPage = window.location.pathname === '/' || window.location.pathname === '';
        document.querySelectorAll('.nav-link-intro').forEach(el => el.style.display = isIntroPage ? '' : 'none');
        document.querySelectorAll('.nav-link-other').forEach(el => el.style.display = isIntroPage ? 'none' : '');

        /* 탭 active */
        const path = window.location.pathname;
        document.querySelectorAll('.nav-tab, .nav-drawer-item').forEach(tab => {
            const href = tab.getAttribute('href');
            if (href && (path === href || path.startsWith(href + '/'))) {
                tab.classList.add('active');
            }
        });

        /* 햄버거 버튼 클릭 */
        ['hamburgerExpert','hamburgerUser'].forEach(function(id) {
            const btn = document.getElementById(id);
            if (!btn) return;
            const drawerId = id === 'hamburgerExpert' ? 'drawerExpert' : 'drawerUser';
            btn.addEventListener('click', function() {
                const drawer = document.getElementById(drawerId);
                if (drawer) {
                    drawer.classList.toggle('open');
                    btn.setAttribute('aria-expanded', drawer.classList.contains('open'));
                }
            });
        });

        /* 프로필 이니셜 */
        document.querySelectorAll('.profile-thumb-default').forEach(el => {
            const name = el.textContent.trim();
            if (name) el.textContent = name.charAt(0);
        });
    });

    function closeDrawer(drawerId, btnId) {
        const drawer = document.getElementById(drawerId);
        const btn = document.getElementById(btnId);
        if (drawer) drawer.classList.remove('open');
        if (btn) btn.setAttribute('aria-expanded', 'false');
    }

    function toggleProfileMenu(e, dropdownId) {
        e.stopPropagation();
        document.getElementById(dropdownId).classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
        document.querySelectorAll('.profile-dropdown.open').forEach(function(dd) {
            const menu = dd.closest('.profile-menu');
            if (menu && !menu.contains(e.target)) dd.classList.remove('open');
        });
    });

    /* CSRF 자동 주입 */
    (function() {
        function getCsrfToken() {
            const match = document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('XSRF-TOKEN='));
            return match ? decodeURIComponent(match.split('=')[1]) : null;
        }
        function addCsrf() {
            const token = getCsrfToken();
            if (!token) return;
            document.querySelectorAll('form').forEach(function(form) {
                const method = (form.method || '').toUpperCase();
                if (['POST','PUT','DELETE','PATCH'].includes(method) && !form.querySelector('input[name="_csrf"]')) {
                    const input = document.createElement('input');
                    input.type = 'hidden'; input.name = '_csrf'; input.value = token;
                    form.appendChild(input);
                }
            });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', addCsrf);
        else addCsrf();
    })();
</script>


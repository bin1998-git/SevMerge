<!-- ══ SSE 알림 ══ -->
{{#isLoggedIn}}
    <script>
        const sse = new EventSource('/notifications/subscribe');
        sse.addEventListener('notification', function(e) {
            const data = JSON.parse(e.data);
            showNotiToast(data);
            const bell = document.querySelector('.nav-bell');
            if (bell && !bell.querySelector('.nav-bell-dot')) {
                const dot = document.createElement('span');
                dot.className = 'nav-bell-dot';
                bell.appendChild(dot);
            }
        });
        window.addEventListener('beforeunload', function() { sse.close(); });
        function showNotiToast(data) {
            const toast = document.createElement('div');
            toast.className = 'noti-toast';
            toast.innerHTML = '<div class="noti-toast-label">' + data.typeLabel + '</div><div class="noti-toast-content">' + data.content + '</div>';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
    </script>
{{/isLoggedIn}}

<!-- ══ 공통 스크립트 ══ -->
<script>
    window.addEventListener('DOMContentLoaded', () => {
        const isAdminMenuVisible = document.querySelector('.admin-main-item, .admin-dropdown-trigger');
        if (isAdminMenuVisible) {
            document.querySelectorAll('.nav-logo').forEach(logo => logo.setAttribute('href', '/admin/main'));
        }

        /* 비로그인 상태: 인트로(/) 여부에 따라 nav 링크 전환 */
        const isIntroPage = window.location.pathname === '/' || window.location.pathname === '';
        const introLinks = document.querySelectorAll('.nav-link-intro');
        const otherLinks = document.querySelectorAll('.nav-link-other');
        if (!isIntroPage) {
            introLinks.forEach(el => el.style.display = 'none');
            otherLinks.forEach(el => el.style.display = '');
        } else {
            introLinks.forEach(el => el.style.display = '');
            otherLinks.forEach(el => el.style.display = 'none');
        }

        /* nav 항상 표시 강제 적용 */
        const nav = document.querySelector('header.nav, .nav');
        if (nav) {
            nav.style.setProperty('display', 'flex', 'important');
            nav.style.setProperty('visibility', 'visible', 'important');
            nav.style.setProperty('opacity', '1', 'important');
            nav.style.setProperty('position', 'fixed', 'important');
            nav.style.setProperty('top', '0', 'important');
            nav.style.setProperty('left', '0', 'important');
            nav.style.setProperty('right', '0', 'important');
            nav.style.setProperty('z-index', '99999', 'important');
        }
    });

    function toggleProfileMenu(e, dropdownId) {
        e.stopPropagation();
        document.getElementById(dropdownId).classList.toggle('open');
    }
    document.addEventListener('click', function(e) {
        document.querySelectorAll('.profile-dropdown.open').forEach(function(dd) {
            const menu = dd.closest('.profile-menu');
            if (menu && !menu.contains(e.target)) dd.classList.remove('open');
        });
    });
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.profile-thumb-default').forEach(function(el) {
            const name = el.textContent.trim();
            if (name) el.textContent = name.charAt(0);
        });
    });

    /* CSRF 자동 주입 */
    (function injectCsrfTokens() {
        function getCsrfToken() {
            const match = document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('XSRF-TOKEN='));
            return match ? decodeURIComponent(match.split('=')[1]) : null;
        }
        function addCsrfToForms() {
            const token = getCsrfToken();
            if (!token) return;
            document.querySelectorAll('form').forEach(function(form) {
                const method = (form.method || '').toUpperCase();
                if (['POST','PUT','DELETE','PATCH'].includes(method) && !form.querySelector('input[name="_csrf"]')) {
                    const input = document.createElement('input');
                    input.type = 'hidden'; input.name = '_csrf'; input.value = token;
                    form.appendChild(input);
                }
            });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', addCsrfToForms);
        else addCsrfToForms();
    })();
</script>

<!-- ══ 관리자 활성 메뉴 스크립트 ══ -->
{{#isAdmin}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            if (!currentPath.startsWith('/admin')) return;

            document.querySelectorAll('.nav-links > .admin-main-item').forEach(function(link) {
                if (link.getAttribute('href') === currentPath)
                    link.setAttribute('style', 'color:#2563eb!important;font-weight:bold!important;');
            });

            document.querySelectorAll('.nav-submenu .submenu-link').forEach(function(link) {
                const href = link.getAttribute('href');
                const isBoardMatch   = href.includes('boards')   && (currentPath.includes('board') || currentPath.includes('boards'));
                const isNoticeMatch  = href.includes('notices')  && (currentPath.includes('notice') || currentPath.includes('notices'));
                const isExpertMatch  = (
                    (href.includes('withdraw')      && currentPath.includes('/admin/experts/withdraw')) ||
                    (href.includes('status=PENDING')&& currentPath.includes('/admin/experts') && !currentPath.includes('withdraw') && !currentPath.includes('grade')) ||
                    (href.includes('grade')         && currentPath.includes('/admin/experts/grade')) ||
                    (href.includes('refund-applications') && currentPath.includes('/admin/refund-applications'))
                );
                if (isBoardMatch || isNoticeMatch || isExpertMatch) {
                    link.classList.add('active-link');
                    const trigger = link.closest('.admin-dropdown-container')?.querySelector('.admin-dropdown-trigger');
                    if (trigger) trigger.setAttribute('style', 'color:#2563eb!important;font-weight:bold!important;');
                }
            });
        });
    </script>
{{/isAdmin}}

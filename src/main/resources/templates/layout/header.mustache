<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>코드요 — 당신의 아이디어를 코드로</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy:      #0d1b2e;
            --navy2:     #112240;
            --cyan:      #00c8e0;
            --cyan-dark: #00a8be;
            --blue:      #2563eb;
            --blue-dark: #1d4ed8;
            --blue-soft: #eff6ff;
            --white:     #ffffff;
            --gray:      #6b7280;
            --gray-lt:   #9ca3af;
            --border:    #e5e7eb;
            --surface:   #f0f4fa;
        }

        body {
            font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Apple SD Gothic Neo', sans-serif;
            background: var(--surface);
            color: #1e293b;
            line-height: 1.6;
            padding-top: 64px;
        }

        a { text-decoration: none; color: inherit; }

        /* ══════════════════════════════
           NAV — fixed, 흰 배경, max-width 맞춤
        ══════════════════════════════ */
        .nav {
            position: fixed !important;
            top: 0 !important; left: 0 !important; right: 0 !important;
            width: 100% !important;
            z-index: 99999 !important;
            background: #fff;
            border-bottom: 1px solid var(--border);
            height: 64px;
            display: flex !important;
            align-items: center;
            box-shadow: 0 2px 12px rgba(0,0,0,.08);
            padding: 0 !important;
        }
        .nav-inner {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 28px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: nowrap;
            overflow: visible;
        }
        .nav-logo {
            display: flex; align-items: center; flex-shrink: 0;
            text-decoration: none;
        }
        .nav-logo img { display: block; height: 28px; width: auto; }

        /* 일반 링크 */
        .nav-links {
            display: flex; gap: 24px; align-items: center;
            font-size: 14px; color: #6b7280; font-weight: 500;
            min-width: 0; overflow: visible;
        }
        .nav-links a:hover { color: #1c1e26; }

        /* 전문가 탭 네비 */
        .nav-links.expert-links {
            flex: 1; gap: 0; justify-content: center;
            min-width: 0; overflow-x: auto; scrollbar-width: none;
        }
        .nav-links.expert-links::-webkit-scrollbar { display: none; }
        .expert-nav-tab {
            padding: 0 18px; height: 64px;
            display: flex; align-items: center;
            font-size: 13px; font-weight: 600; color: #6b7280;
            border-bottom: 2px solid transparent; white-space: nowrap;
            transition: color .15s, border-color .15s;
        }
        .expert-nav-tab:hover { color: #1c1e26; border-color: #d1d5db; }
        .expert-nav-tab.active { color: var(--blue); border-color: var(--blue); }

        /* 우측 액션 */
        .nav-actions {
            display: flex; align-items: center; gap: 8px;
            flex-shrink: 0; flex-wrap: nowrap; white-space: nowrap;
        }

        /* 버튼 */
        .btn {
            display: inline-block; padding: 9px 22px; border-radius: 25px;
            font-size: 14px; font-weight: 700; cursor: pointer;
            text-decoration: none; transition: all .15s; border: none;
            font-family: inherit;
        }
        .btn-outline {
            border: 1.5px solid var(--border); color: #1e293b; background: #fff;
        }
        .btn-outline:hover { border-color: var(--blue); color: var(--blue); }
        .btn-primary { background: var(--blue); color: #fff; }
        .btn-primary:hover { background: var(--blue-dark); }

        /* 잔액 위젯 */
        .nav-balance-wrap {
            display: flex; align-items: center; gap: 6px;
            background: #eff6ff; border: 1.5px solid #bfdbfe;
            border-radius: 10px; padding: 6px 12px;
            flex-shrink: 0; white-space: nowrap;
        }
        .nav-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .nav-balance-amount { font-size: 14px; font-weight: 900; color: #1d4ed8; }
        .nav-charge-btn {
            font-size: 11px; font-weight: 700;
            background: var(--blue); color: #fff;
            border-radius: 6px; padding: 3px 9px;
            text-decoration: none; transition: background .15s; white-space: nowrap;
        }
        .nav-charge-btn:hover { background: var(--blue-dark); }

        /* 알림 벨 */
        .nav-bell {
            position: relative; display: inline-flex;
            align-items: center; justify-content: center;
            width: 40px; height: 40px; border-radius: 10px;
            color: #6b7280; transition: background .15s, color .15s;
        }
        .nav-bell:hover { background: #eff6ff; color: var(--blue); }
        .nav-bell svg { width: 21px; height: 21px; }
        .nav-bell-dot {
            position: absolute; top: 8px; right: 9px;
            width: 9px; height: 9px;
            background: #22c55e; border: 2px solid #fff; border-radius: 50%;
        }

        /* 프로필 드롭다운 */
        .profile-menu { position: relative; }
        .profile-trigger {
            background: none; border: none; cursor: pointer;
            padding: 0; display: flex; align-items: center;
        }
        .profile-thumb {
            width: 44px; height: 44px; border-radius: 50%;
            background-size: cover; background-position: center;
            background-color: #eff6ff; border: 1.5px solid #bfdbfe;
            display: flex; align-items: center; justify-content: center;
            font-size: 0; overflow: hidden; flex-shrink: 0;
        }
        .profile-thumb-default {
            font-size: 14px; font-weight: 800; color: var(--blue);
            max-width: 100%; overflow: hidden;
            text-overflow: ellipsis; white-space: nowrap; padding: 0 4px;
        }
        .profile-dropdown {
            display: none; position: absolute; top: 50px; right: 0;
            min-width: 180px; background: #fff;
            border: 1px solid #e5e7eb; border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,.1); padding: 6px; z-index: 9999;
        }
        .profile-dropdown.open { display: block; }
        .pd-head { padding: 10px 12px 8px; border-bottom: 1px solid #f3f4f8; margin-bottom: 6px; }
        .pd-name { font-size: 14px; font-weight: 800; color: #1c1e26; }
        .pd-item {
            display: block; padding: 10px 12px;
            font-size: 13px; font-weight: 600; color: #4b5563;
            text-decoration: none; border-radius: 8px; transition: background .12s;
        }
        .pd-item:hover { background: #f8f9ff; color: var(--blue); }
        .pd-logout { color: #ef4444; }
        .pd-logout:hover { background: #fff3f3; color: #ef4444; }
        .pd-balance-row {
            display: flex; align-items: center; gap: 6px;
            padding: 10px 12px; margin-bottom: 4px;
            background: #eff6ff; border-radius: 8px;
        }
        .pd-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .pd-balance-amount { font-size: 13px; font-weight: 900; color: #1d4ed8; flex: 1; }
        .pd-charge-btn {
            font-size: 11px; font-weight: 700;
            background: var(--blue); color: #fff;
            border-radius: 6px; padding: 3px 9px; text-decoration: none; white-space: nowrap;
        }
        .pd-charge-btn:hover { background: var(--blue-dark); }

        /* 관리자 드롭다운 */
        .admin-dropdown-trigger { font-size: inherit; font-weight: inherit; color: inherit; transition: color .15s; cursor: pointer; }
        .admin-dropdown-container { position: relative; display: inline-block; }
        .admin-dropdown-container:hover .nav-submenu,
        .nav-submenu.active { display: flex !important; flex-direction: column !important; }
        .nav-submenu {
            display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
            background: #fff; min-width: 140px;
            border: 1px solid #e5e7eb; border-radius: 6px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,.1); padding: 4px 0; z-index: 9999;
        }
        .nav-submenu .submenu-link {
            position: relative !important; display: block !important;
            width: 100% !important; box-sizing: border-box !important;
            padding: 10px 0 !important; font-size: 13px; font-weight: 600;
            color: #6b7280 !important; background-color: transparent !important;
            text-decoration: none; white-space: nowrap; transition: all .1s;
            text-align: center !important; border-left: none !important;
        }
        .nav-submenu .submenu-link.active-link { color: var(--blue) !important; background-color: #eff6ff !important; }
        .nav-submenu .submenu-link.active-link::before {
            content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background-color: var(--blue);
        }
        .nav-submenu .submenu-link:hover { color: var(--blue) !important; background-color: #eff6ff !important; }
        .nav-submenu .submenu-link:hover::before {
            content: "" !important; position: absolute !important;
            left: 0 !important; top: 0 !important; bottom: 0 !important;
            width: 4px !important; background-color: var(--blue) !important;
        }
        .nav-submenu:hover .submenu-link.active-link:not(:hover) { background-color: transparent !important; color: #6b7280 !important; }
        .nav-submenu:hover .submenu-link.active-link:not(:hover)::before { display: none !important; }

        /* 알림 토스트 */
        .noti-toast {
            position: fixed; bottom: 24px; right: 24px;
            background: #eff6ff; border: 1.5px solid #bfdbfe;
            border-radius: 14px; padding: 16px 20px;
            z-index: 9999; animation: notiToastFade 4s ease forwards;
            max-width: 320px; box-shadow: 0 8px 30px rgba(37,99,235,.12);
        }
        .noti-toast-label { font-size: 12px; font-weight: 700; color: var(--blue); margin-bottom: 4px; }
        .noti-toast-content { font-size: 13px; color: #374151; line-height: 1.6; }
        @keyframes notiToastFade {
            0%   { opacity: 0; transform: translateY(10px); }
            15%  { opacity: 1; transform: translateY(0); }
            80%  { opacity: 1; }
            100% { opacity: 0; }
        }

        /* ══════════════════════════════
           히어로
        ══════════════════════════════ */
        .hero {
            padding: 28px 28px 32px;
            display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
            max-width: 1300px; margin: 0 auto;
        }
        .hero-dark {
            background: linear-gradient(140deg, rgba(13,27,46,.82) 0%, rgba(14,42,74,.75) 60%, rgba(13,32,64,.85) 100%),
                        url('/mainBackground.jpg') center/cover no-repeat;
            border-radius: 24px; padding: 48px 44px 44px;
            position: relative; overflow: hidden; min-height: 440px;
            display: flex; flex-direction: column; justify-content: flex-end;
        }
        .hero-dark::before {
            content: ''; position: absolute; inset: 0;
            background-image:
                linear-gradient(rgba(0,200,224,.06) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,200,224,.06) 1px, transparent 1px);
            background-size: 40px 40px; pointer-events: none;
        }
        .hero-code-img {
            position: absolute; top: 24px; right: 24px;
            width: 200px; height: 375px; border-radius: 16px; object-fit: cover; opacity: .92;
        }
        .hero-badge-dark {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(0,200,224,.12); border: 1px solid rgba(0,200,224,.3);
            border-radius: 999px; padding: 4px 14px;
            font-size: 11px; font-weight: 700; color: var(--cyan);
            margin-bottom: 20px; letter-spacing: .3px; width: fit-content;
        }
        .hero-title-dark {
            font-size: clamp(28px, 3.5vw, 44px); font-weight: 900; color: #fff;
            line-height: 1.15; letter-spacing: -1.5px; margin-bottom: 14px;
        }
        .hero-title-dark .hl { color: var(--cyan); }
        .hero-desc-dark {
            font-size: 14px; color: rgba(255,255,255,.55);
            line-height: 1.75; margin-bottom: 32px; max-width: 340px;
        }
        .hero-btns-dark { display: flex; gap: 12px; flex-wrap: wrap; }
        .btn-cyan {
            background: var(--cyan); color: var(--navy);
            border-radius: 30px; padding: 12px 26px; font-size: 14px; font-weight: 800;
        }
        .btn-cyan:hover { background: var(--cyan-dark); }
        .btn-outline-dark {
            background: transparent; color: #fff;
            border: 1.5px solid rgba(255,255,255,.35);
            border-radius: 30px; padding: 12px 26px; font-size: 14px; font-weight: 700;
        }
        .btn-outline-dark:hover { border-color: rgba(255,255,255,.7); }

        .hero-light {
            background: var(--white); border-radius: 24px; padding: 32px 32px 28px;
            display: flex; flex-direction: column; justify-content: flex-start; gap: 18px;
            position: relative; overflow: hidden; min-height: 440px;
        }
        .hero-person-img {
            position: absolute; bottom: 0; right: -10px;
            width: 260px; height: auto; object-fit: contain; pointer-events: none; z-index: 2;
        }
        .hero-badge-light {
            display: inline-flex; align-items: center; gap: 6px;
            background: #eff6ff; border: 1px solid #bfdbfe;
            border-radius: 999px; padding: 4px 14px;
            font-size: 11px; font-weight: 700; color: var(--blue);
            letter-spacing: .3px; width: fit-content;
        }
        .hero-title-light {
            font-size: clamp(24px, 3vw, 38px); font-weight: 900; color: #0f172a;
            line-height: 1.2; letter-spacing: -1.5px; max-width: 62%;
        }
        .hero-title-light .hl { color: var(--blue); }
        .mini-cards {
            display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
            max-width: 62%; position: relative; z-index: 3;
        }
        .mini-card {
            background: #f8faff; border: 1.5px solid var(--border);
            border-radius: 16px; padding: 20px 14px; transition: border-color .2s;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            text-align: center; aspect-ratio: 1 / 1;
        }
        .mini-card:hover { border-color: #93c5fd; background: #fff; }
        .mini-card-ico {
            width: 52px; height: 52px; border-radius: 14px;
            background: var(--white); margin-bottom: 12px;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 2px 8px rgba(37,99,235,.1);
        }
        .mini-card-ico svg { width: 28px; height: 28px; }
        .mini-card-eyebrow { font-size: 10px; color: var(--gray-lt); font-weight: 600; margin-bottom: 4px; letter-spacing: .3px; }
        .mini-card-title { font-size: 13px; font-weight: 800; color: #0f172a; }
        .hero-btns-light {
            display: flex; gap: 8px; flex-wrap: wrap;
            max-width: 62%; position: relative; z-index: 3;
        }
        .btn-blue-light {
            background: var(--blue); color: #fff; border-radius: 30px; padding: 11px 20px;
            font-size: 13px; font-weight: 800; flex: 1; text-align: center;
        }
        .btn-blue-light:hover { background: var(--blue-dark); }
        .btn-outline-light {
            background: var(--white); color: #1e293b;
            border: 1.5px solid var(--border); border-radius: 30px; padding: 11px 20px;
            font-size: 13px; font-weight: 700; flex: 1; text-align: center;
        }
        .btn-outline-light:hover { border-color: var(--blue); color: var(--blue); }

        /* 통계 바 */
        .stats-bar {
            max-width: 1300px; margin: 0 auto; padding: 20px 28px;
            display: flex; justify-content: space-around; flex-wrap: wrap; gap: 16px;
        }
        .stat { text-align: center; }
        .stat-num { font-size: 28px; font-weight: 900; color: #0f172a; display: block; letter-spacing: -1px; }
        .stat-num em { color: var(--blue); font-style: normal; }
        .stat-label { font-size: 12px; color: var(--gray-lt); font-weight: 500; margin-top: 2px; }

        /* 공통 섹션 */
        section { padding: 80px 28px; }
        .section-inner { max-width: 1100px; margin: 0 auto; }
        .eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--blue); margin-bottom: 10px; }
        .sec-title { font-size: clamp(26px, 4vw, 38px); font-weight: 900; letter-spacing: -1.5px; color: #0f172a; margin-bottom: 12px; }
        .sec-desc { font-size: 15px; color: var(--gray); max-width: 500px; line-height: 1.8; }

        /* 서비스 소개 */
        .features { background: var(--white); }
        .section-header { margin-bottom: 52px; }
        .feature-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
        .feature-card {
            background: #f8faff; border: 1.5px solid var(--border);
            border-radius: 18px; padding: 30px 26px; transition: border-color .2s, box-shadow .2s;
        }
        .feature-card:hover { border-color: #93c5fd; box-shadow: 0 6px 24px rgba(37,99,235,.08); }
        .feature-icon {
            width: 50px; height: 50px; border-radius: 14px; background: var(--blue-soft);
            display: flex; align-items: center; justify-content: center; font-size: 22px; margin-bottom: 16px;
        }
        .feature-name { font-size: 16px; font-weight: 800; color: #0f172a; margin-bottom: 8px; letter-spacing: -.3px; }
        .feature-desc { font-size: 13px; color: var(--gray); line-height: 1.75; }

        /* 이용 방법 */
        .how { background: var(--surface); }
        .how-steps-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 52px; align-items: start; }
        .how-col { background: #fff; border: 1.5px solid var(--border); border-radius: 20px; padding: 28px 28px 32px; height: 100%; }
        .how-col-label { font-size: 13px; font-weight: 700; margin-bottom: 24px; }
        .how-col-label.client { color: var(--blue); }
        .how-col-label.expert { color: #7c3aed; }
        .steps { display: flex; flex-direction: column; gap: 22px; }
        .step { display: flex; gap: 16px; align-items: flex-start; }
        .step-num {
            width: 32px; height: 32px; border-radius: 8px; color: #fff;
            font-size: 13px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .step-num.blue { background: var(--blue); }
        .step-num.purple { background: #7c3aed; }
        .step-title { font-size: 14px; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
        .step-desc { font-size: 13px; color: var(--gray); line-height: 1.7; }
        .how-mock { margin-top: 32px; background: #fff; border: 1.5px solid var(--border); border-radius: 20px; padding: 24px 28px; }
        .how-mock-label { font-size: 11px; font-weight: 700; color: var(--gray-lt); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
        .mock-cards-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
        .mock-card { background: #f8faff; border-radius: 14px; padding: 16px 18px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 8px; }
        .mock-title { font-size: 13px; font-weight: 700; color: #0f172a; line-height: 1.4; }
        .mock-tags { display: flex; gap: 5px; flex-wrap: wrap; }
        .mock-tag { font-size: 10px; font-weight: 700; border-radius: 6px; padding: 2px 8px; }
        .tag-blue   { background: #dbeafe; color: #1e40af; }
        .tag-green  { background: #d1fae5; color: #065f46; }
        .tag-purple { background: #ede9fe; color: #5b21b6; }
        .tag-amber  { background: #fef3c7; color: #92400e; }
        .mock-price { font-size: 13px; font-weight: 900; color: var(--blue); margin-top: auto; }

        /* 분야 */
        .categories { background: var(--navy); }
        .categories .eyebrow { color: #67e8f9; }
        .categories .sec-title { color: #fff; }
        .categories .sec-desc { color: rgba(255,255,255,.45); }
        .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 40px; }
        .cat-card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.09); border-radius: 14px; padding: 22px 16px; text-align: center; transition: background .2s, border-color .2s; cursor: default; }
        .cat-card:hover { background: rgba(0,200,224,.15); border-color: rgba(0,200,224,.4); }
        .cat-emoji { font-size: 26px; margin-bottom: 10px; display: block; }
        .cat-name { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 3px; }
        .cat-sub { font-size: 11px; color: rgba(255,255,255,.35); }

        /* 신뢰 */
        .trust { background: var(--white); }
        .trust-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 52px; }
        .trust-card { border: 1.5px solid var(--border); border-radius: 18px; padding: 30px 26px; text-align: center; transition: border-color .2s; }
        .trust-card:hover { border-color: #93c5fd; }
        .trust-icon { font-size: 34px; margin-bottom: 14px; display: block; }
        .trust-name { font-size: 15px; font-weight: 800; color: #0f172a; margin-bottom: 8px; }
        .trust-desc { font-size: 13px; color: var(--gray); line-height: 1.75; }

        /* CTA */
        .cta-banner { background: linear-gradient(135deg, #0d1b2e 0%, #1a3a8f 50%, #1e1b4b 100%); padding: 88px 28px; text-align: center; }
        .cta-inner { max-width: 620px; margin: 0 auto; }
        .cta-title { font-size: clamp(28px, 5vw, 46px); font-weight: 900; color: #fff; letter-spacing: -2px; margin-bottom: 14px; }
        .cta-title .hl { color: var(--cyan); }
        .cta-desc { font-size: 16px; color: rgba(255,255,255,.6); margin-bottom: 38px; line-height: 1.8; }
        .cta-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
        .btn-cta-cyan { background: var(--cyan); color: var(--navy); border-radius: 30px; padding: 14px 32px; font-size: 15px; font-weight: 800; }
        .btn-cta-cyan:hover { background: var(--cyan-dark); }
        .btn-cta-ghost { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.3); border-radius: 30px; padding: 14px 32px; font-size: 15px; font-weight: 700; }
        .btn-cta-ghost:hover { border-color: rgba(255,255,255,.7); }

        /* 반응형 */
        @media (max-width: 960px) {

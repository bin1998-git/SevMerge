{{#isLoggedIn}}
    <script>
        const sse = new EventSource('/notifications/subscribe');

        sse.addEventListener('notification', function (e) {
            const data = JSON.parse(e.data);
            showNotiToast(data);

            const bell = document.querySelector('.nav-bell');
            if (bell && !bell.querySelector('.nav-bell-dot')) {
                const dot = document.createElement('span');
                dot.className = 'nav-bell-dot';
                bell.appendChild(dot);
            }
        });

        // 페이지 떠날 때 SSE 연결 종료 (연결 누적 방지)
        window.addEventListener('beforeunload', function () {
            sse.close();
        });

        function showNotiToast(data) {
            const toast = document.createElement('div');
            toast.className = 'noti-toast';
            toast.innerHTML =
                '<div class="noti-toast-label">' + data.typeLabel + '</div>' +
                '<div class="noti-toast-content">' + data.content + '</div>';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
    </script>
{{/isLoggedIn}}

<script>
    function toggleProfileMenu(e, dropdownId) {
        e.stopPropagation();
        document.getElementById(dropdownId).classList.toggle("open");
    }
    document.addEventListener("click", function (e) {
        document.querySelectorAll(".profile-dropdown.open").forEach(function (dd) {
            const menu = dd.closest(".profile-menu");
            if (menu && !menu.contains(e.target)) {
                dd.classList.remove("open");
            }
        });
    });
     document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".profile-thumb-default").forEach(function (el) {
            const name = el.textContent.trim();
            if (name) el.textContent = name.charAt(0);  // 첫 글자만
        });
    });
</script>

{{#isAdmin}}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const currentPath = window.location.pathname;

            if (currentPath.startsWith("/admin")) {
                // 1. 일반 메뉴 (대시보드, 회원관리, 프로젝트관리 등)
                const adminItems = document.querySelectorAll(".nav-links > .admin-main-item");
                adminItems.forEach(function (link) {
                    if (link.getAttribute("href") === currentPath) {
                        link.setAttribute("style", "color: #2563eb !important; font-weight: bold !important;");
                    }
                });

                // 2. 드롭다운 서브메뉴 활성화 로직
                const submenuLinks = document.querySelectorAll(".nav-submenu .submenu-link");
                submenuLinks.forEach(function (link) {
                    const linkHref = link.getAttribute("href");

                    // 기존 게시판/공지사항 매칭 로직
                    const isBoardMatch = linkHref.includes("boards") && (currentPath.includes("board") || currentPath.includes("boards"));
                    const isNoticeMatch = linkHref.includes("notices") && (currentPath.includes("notice") || currentPath.includes("notices"));


                   // [수정된 전문가 승인 관리 매칭 로직]
                   const isExpertMatch = (
                       (linkHref.includes("withdraw") && currentPath.includes("/admin/experts/withdraw")) ||
                       (linkHref.includes("status=PENDING") && currentPath.includes("/admin/experts") && !currentPath.includes("withdraw") && !currentPath.includes("grade")) ||
                       (linkHref.includes("grade") && currentPath.includes("/admin/experts/grade")) ||
                       (linkHref.includes("refund-applications") && currentPath.includes("/admin/refund-applications"))
                   );

                    if (isBoardMatch || isNoticeMatch || isExpertMatch) {
                        link.classList.add("active-link");

                        const parentSubmenu = link.closest(".nav-submenu");
                        if (parentSubmenu) {
                            const parentContainer = parentSubmenu.closest(".admin-dropdown-container");
                            if (parentContainer) {
                                const trigger = parentContainer.querySelector(".admin-dropdown-trigger");
                                if (trigger) {
                                    trigger.setAttribute("style", "color: #2563eb !important; font-weight: bold !important;");
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
{{/isAdmin}}
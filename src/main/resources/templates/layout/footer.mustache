<button class="chatbot-toggle" onclick="toggleChatbot()" aria-label="AI 도우미 열기">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
</button>

<div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
        <div class="chatbot-avatar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-4 4 4 4 0 0 1-4-4V6a4 4 0 0 1 4-4z"/>
                <path d="M5 20v-2a7 7 0 0 1 14 0v2"/>
            </svg>
        </div>
        <div class="chatbot-header-text">
            <div class="chatbot-title">SevMerge AI 도우미</div>
            <div class="chatbot-status">온라인</div>
        </div>
        <button class="chatbot-close" onclick="toggleChatbot()" aria-label="닫기">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <div class="chatbot-messages" id="chatbotMessages">
        <div class="chat-row bot">
            <div class="chat-bubble">안녕하세요! SevMerge 이용 중 궁금한 점이나, 프로젝트 등록을 도와드릴게요.</div>
        </div>
    </div>

    <div class="chatbot-suggestions">
        <div class="suggestion-chip" onclick="sendSuggestion('프로젝트는 어떻게 등록하나요?')">프로젝트 등록 방법</div>
        <div class="suggestion-chip" onclick="sendSuggestion('입찰은 어떻게 참여하나요?')">입찰 참여 방법</div>
    </div>

    <div class="chatbot-input-area">
        <input type="text" id="chatbotInput" placeholder="질문을 입력하세요" onkeydown="if(event.key==='Enter' && !event.isComposing) sendChatMessage()">
        <button class="chatbot-send-btn" onclick="sendChatMessage()" aria-label="전송">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
            </svg>
        </button>
    </div>
</div>

<script>
    function toggleChatbot() {
        document.getElementById('chatbotWindow').classList.toggle('active');
    }

    function sendSuggestion(text) {
        document.getElementById('chatbotInput').value = text;
        sendChatMessage();
    }

    function appendMessage(role, text) {
        const messagesDiv = document.getElementById('chatbotMessages');
        const row = document.createElement('div');
        row.className = 'chat-row ' + role;
        row.innerHTML = `<div class="chat-bubble">${text}</div>`;
        messagesDiv.appendChild(row);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        return row;
    }

    function showTyping() {
        const messagesDiv = document.getElementById('chatbotMessages');
        const row = document.createElement('div');
        row.className = 'chat-row bot';
        row.id = 'typingIndicator';
        row.innerHTML = `<div class="chat-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
        messagesDiv.appendChild(row);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }

    function removeTyping() {
        const el = document.getElementById('typingIndicator');
        if (el) el.remove();
    }

    async function sendChatMessage() {
        const input = document.getElementById('chatbotInput');
        const question = input.value.trim();
        if (!question) return;

        appendMessage('user', question);
        input.value = '';
        showTyping();

        try {
            const response = await fetch('/api/project/ai/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: question })
            });

            const data = await response.json();
            removeTyping();
            appendMessage('bot', data.answer);
        } catch (error) {
            removeTyping();
            appendMessage('bot', '오류가 발생했어요. 다시 시도해주세요.');
        }
    }
</script>

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SevMerge - IT 외주 입찰 플랫폼</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap"
          rel="stylesheet"/>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: #f5f6fa;
            color: #1c1e26;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        main { /* 또는 실제 컨텐츠 감싸는 요소 */
            flex: 1;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ── 버튼 ── */
        .btn {
            display: inline-block;
            padding: 10px 22px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            font-family: inherit;
            transition: all .15s;
        }

        .btn-primary {
            background: #2563eb;
            color: #fff;
        }

        .btn-primary:hover {
            background: #1d4ed8;
        }

        .btn-outline {
            background: #fff;
            border: 1.5px solid #e2e5ef;
            color: #4b5563;
        }

        .btn-outline:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .btn-lg {
            padding: 14px 32px;
            font-size: 15px;
            border-radius: 10px;
        }

        /* ── NAV ── */
        .nav {
            background: #fff;
            border-bottom: 1px solid #eaecf4;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-inner {
            max-width: 1140px;
            margin: 0 auto;
            padding: 0 28px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 32px;
        }

        .nav-logo {
            font-size: 20px;
            font-weight: 900;
            color: #1c1e26;
            letter-spacing: -0.5px;
        }

        .nav-logo span {
            color: #2563eb;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            font-size: 14px;
            color: #6b7280;
            font-weight: 500;
        }

        .nav-links a:hover {
            color: #1c1e26;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-username {
            font-size: 13px;
            color: #9ca3af;
            font-weight: 500;
            margin-right: 4px;
        }

        /* ── HERO ── */
        .hero {
            background: #fff;
            border-bottom: 1px solid #eaecf4;
            padding: 88px 28px 76px;
        }

        .hero-inner {
            max-width: 1140px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 72px;
            align-items: center;
        }

        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 20px;
        }

        .hero-eyebrow::before {
            content: '';
            width: 20px;
            height: 2px;
            background: #2563eb;
            border-radius: 2px;
        }

        .hero-title {
            font-size: 50px;
            font-weight: 900;
            line-height: 1.12;
            letter-spacing: -2px;
            color: #1c1e26;
            margin-bottom: 18px;
        }

        .hero-title em {
            color: #2563eb;
            font-style: normal;
        }

        .hero-desc {
            font-size: 15px;
            color: #6b7280;
            line-height: 1.9;
            margin-bottom: 36px;
            font-weight: 400;
        }

        .hero-btns {
            display: flex;
            gap: 12px;
        }

        .hero-trust {
            display: flex;
            gap: 20px;
            margin-top: 28px;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: #9ca3af;
            font-weight: 500;
        }

        .trust-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #2563eb;
        }

        /* 히어로 우측 패널 */
        .hero-panel {
            background: #f8f9ff;
            border: 1px solid #e2e8ff;
            border-radius: 20px;
            overflow: hidden;
        }

        .hero-panel-header {
            padding: 18px 24px;
            border-bottom: 1px solid #e8ecf8;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
        }

        .hero-panel-title {
            font-size: 13px;
            font-weight: 700;
            color: #374151;
        }

        .live-badge {
            font-size: 11px;
            background: #eff6ff;
            color: #2563eb;
            padding: 3px 10px;
            border-radius: 20px;
            font-weight: 700;
            border: 1px solid #bfdbfe;
        }

        .stat-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            background: #fff;
            border-bottom: 1px solid #e8ecf8;
        }

        .stat-item {
            padding: 20px 12px;
            text-align: center;
            border-right: 1px solid #e8ecf8;
        }

        .stat-item:last-child {
            border-right: none;
        }

        .stat-val {
            display: block;
            font-size: 24px;
            font-weight: 900;
            color: #2563eb;
            margin-bottom: 4px;
            letter-spacing: -0.5px;
        }

        .stat-lbl {
            font-size: 11px;
            color: #9ca3af;
            font-weight: 500;
        }

        .bid-preview {
            padding: 4px 24px 8px;
        }

        .bid-item {
            display: flex;
            align-items: center;
            gap: 13px;
            padding: 14px 0;
            border-bottom: 1px solid #f0f2f9;
        }

        .bid-item:last-child {
            border-bottom: none;
        }

        .bid-avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .bid-info {
            flex: 1;
        }

        .bid-name {
            font-size: 13px;
            font-weight: 700;
            color: #1c1e26;
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 2px;
        }

        .cert-badge {
            font-size: 10px;
            background: #fffbeb;
            color: #b45309;
            border: 1px solid #fde68a;
            padding: 1px 7px;
            border-radius: 5px;
            font-weight: 700;
        }

        .bid-spec {
            font-size: 11px;
            color: #9ca3af;
            font-weight: 400;
        }

        .bid-price {
            font-size: 15px;
            font-weight: 900;
            color: #2563eb;
            letter-spacing: -0.3px;
        }

        /* ── SEARCH ── */
        .search-section {
            background: #fff;
            border-bottom: 1px solid #eaecf4;
            padding: 32px 28px 36px;
        }

        .search-inner {
            max-width: 1140px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .search-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-input {
            flex: 1;
            padding: 13px 18px;
            background: #f8f9fc;
            border: 1.5px solid #e2e5ef;
            border-radius: 10px;
            font-size: 14px;
            font-family: inherit;
            color: #1c1e26;
            outline: none;
            transition: border-color .15s;
            font-weight: 400;
        }

        .search-input::placeholder {
            color: #c4c9d9;
        }

        .search-input:focus {
            border-color: #2563eb;
            background: #fff;
        }

        .search-btn {
            padding: 13px 28px;
            background: #2563eb;
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
        }

        .search-btn:hover {
            background: #1d4ed8;
        }

        .category-tabs {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .tab {
            padding: 8px 18px;
            border-radius: 20px;
            border: 1.5px solid #e2e5ef;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            background: #fff;
            transition: all .15s;
        }

        .tab:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .tab.active {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        .tab-certified {
            border-color: #fde68a;
            color: #b45309;
            background: #fffdf5;
        }

        .tab-certified:hover {
            border-color: #f59e0b;
            color: #92400e;
            background: #fffbeb;
        }

        /* ── PROJECT LIST ── */
        .project-section {
            padding: 52px 28px 80px;
        }

        .project-inner {
            max-width: 1140px;
            margin: 0 auto;
        }

        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .section-title {
            font-size: 20px;
            font-weight: 900;
            color: #1c1e26;
            letter-spacing: -0.5px;
        }

        .view-all {
            font-size: 13px;
            color: #2563eb;
            font-weight: 600;
        }

        .view-all:hover {
            text-decoration: underline;
        }

        .project-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
            margin-bottom: 40px;
        }

        .project-card {
            background: #fff;
            border: 1.5px solid #eaecf4;
            border-radius: 16px;
            overflow: hidden;
            transition: border-color .2s, box-shadow .2s, transform .15s;
        }

        .project-card:hover {
            border-color: #bfdbfe;
            box-shadow: 0 8px 28px rgba(37, 99, 235, .08);
            transform: translateY(-3px);
        }

        .project-card-link {
            display: block;
            padding: 24px;
        }

        .project-card-top {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 14px;
            flex-wrap: wrap;
        }

        .project-category {
            font-size: 11px;
            font-weight: 700;
            color: #2563eb;
            background: #eff6ff;
            padding: 4px 10px;
            border-radius: 6px;
            letter-spacing: .3px;
        }

        .badge-certified {
            font-size: 10px;
            font-weight: 700;
            color: #b45309;
            background: #fffbeb;
            border: 1px solid #fde68a;
            padding: 3px 9px;
            border-radius: 6px;
        }

        .project-title {
            font-size: 15px;
            font-weight: 700;
            color: #1c1e26;
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .project-desc {
            font-size: 12px;
            color: #9ca3af;
            line-height: 1.75;
            margin-bottom: 20px;
            font-weight: 400;
        }

        .project-card-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #f3f4f8;
            padding-top: 14px;
        }

        .project-budget {
            font-size: 15px;
            font-weight: 900;
            color: #1c1e26;
            letter-spacing: -0.3px;
        }

        .project-meta {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: #c4c9d9;
            font-weight: 600;
        }

        .d-day {
            color: #c4c9d9;
        }

        .d-day.urgent {
            color: #ef4444;
            font-weight: 700;
        }

        /* ── EMPTY ── */
        .empty-state {
            text-align: center;
            padding: 80px 0;
        }

        .empty-msg {
            font-size: 15px;
            color: #c4c9d9;
            margin-bottom: 20px;
        }

        /* ── PAGING ── */
        .paging {
            display: flex;
            justify-content: center;
            gap: 6px;
        }

        .page-btn {
            padding: 9px 15px;
            border-radius: 8px;
            border: 1.5px solid #e2e5ef;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            background: #fff;
            transition: all .15s;
        }

        .page-btn:hover {
            border-color: #2563eb;
            color: #2563eb;
        }

        .page-btn.active {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }

        /* ── FOOTER ── */
        .footer {
            background: #0f172a;
            padding: 0 28px;
            margin-top: auto; /* 추가 */
        }

        .footer-inner {
            max-width: 1140px;
            margin: 0 auto;
        }

        /* 상단 가로 행: 로고 | 링크 | 버튼 */
        .footer-row {
            display: flex;
            align-items: center;
            gap: 24px;
            padding: 22px 0;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .footer-brand-logo {
            font-size: 18px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -0.5px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .footer-brand-logo span { color: #60a5fa; }

        .footer-nav {
            display: flex;
            align-items: center;
            flex: 1;
            flex-wrap: wrap;
        }

        .footer-nav a {
            font-size: 13px;
            color: rgba(255,255,255,0.42);
            text-decoration: none;
            padding: 4px 14px;
            transition: color 0.15s;
            white-space: nowrap;
        }

        .footer-nav a:first-of-type { padding-left: 20px; }
        .footer-nav a:hover { color: #93c5fd; }

        .footer-nav-sep {
            display: inline-block;
            width: 1px;
            height: 13px;
            background: rgba(255,255,255,0.12);
            margin: 0 4px;
            vertical-align: middle;
        }

        .footer-actions {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .footer .btn {
            padding: 6px 14px;
            font-size: 12px;
            border-radius: 7px;
        }

        .footer .btn-outline {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.13);
            color: rgba(255,255,255,0.6);
        }

        .footer .btn-outline:hover {
            background: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.28);
            color: #fff;
        }

        /* 하단 행: 정책 링크 + 운영시간 | 저작권 */
        .footer-bottom {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 0;
            gap: 12px;
            flex-wrap: wrap;
        }

        .footer-policy-links {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
        }

        .footer-policy-links a {
            font-size: 12px;
            color: rgba(255,255,255,0.25);
            text-decoration: none;
            padding-right: 14px;
            transition: color 0.15s;
            white-space: nowrap;
        }

        .footer-policy-links .footer-policy-strong {
            color: rgba(255,255,255,0.45);
            font-weight: 600;
        }

        .footer-policy-links a:hover { color: rgba(255,255,255,0.65); }

        .footer-hours-inline {
            font-size: 12px;
            color: rgba(255,255,255,0.18);
            padding-left: 14px;
            border-left: 1px solid rgba(255,255,255,0.1);
            white-space: nowrap;
        }

        .footer-copy {
            font-size: 12px;
            color: rgba(255,255,255,0.18);
            white-space: nowrap;
        }

        @media (max-width: 768px) {
            .footer-row { flex-wrap: wrap; gap: 14px; padding: 20px 0; }
            .footer-nav a:first-of-type { padding-left: 0; }
            .footer-bottom { flex-direction: column; align-items: flex-start; }
            .footer-hours-inline { display: none; }
        }

        /* ── 전문가 전용 탭 네비 ── */
        .nav-links.expert-links {
            flex: 1;
            gap: 0;
            justify-content: center;
        }

        .expert-nav-tab {
            padding: 0 18px;
            height: 64px;
            display: flex;
            align-items: center;
            font-size: 13px;
            font-weight: 600;
            color: #6b7280;
            border-bottom: 2px solid transparent;
            white-space: nowrap;
            transition: color .15s, border-color .15s;
        }

        .expert-nav-tab:hover { color: #1c1e26; border-color: #d1d5db; }
        .expert-nav-tab.active { color: #2563eb; border-color: #2563eb; }

        /* 잔액 위젯 */
        .nav-balance-wrap { display: flex; align-items: center; gap: 6px; background: #eff6ff; border: 1.5px solid #bfdbfe; border-radius: 10px; padding: 6px 12px; }
        .nav-balance-label { font-size: 11px; font-weight: 600; color: #3b82f6; }
        .nav-balance-amount { font-size: 14px; font-weight: 900; color: #1d4ed8; }
        .nav-charge-btn { font-size: 11px; font-weight: 700; background: #2563eb; color: #fff; border-radius: 6px; padding: 3px 9px; text-decoration: none; transition: background .15s; }
        .nav-charge-btn:hover { background: #1d4ed8; }
    </style>
</head>
<body>

<style>
    .admin-dropdown-trigger {
        font-size: inherit;
        font-weight: inherit;
        color: inherit;
        transition: color 0.15s;
    }

    .admin-dropdown-container:hover .nav-submenu,
    .nav-submenu.active {
        display: flex !important;
        flex-direction: column !important;
    }

    .nav-submenu {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background-color: #ffffff;
        min-width: 140px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        padding: 4px 0;
        z-index: 9999;
    }

    .nav-submenu .submenu-link {
        position: relative !important;
        display: block !important;
        width: 100% !important;
        box-sizing: border-box !important;
        padding: 10px 0 !important;
        font-size: 13px;
        font-weight: 600;
        color: #6b7280 !important; /* 평소 기본 회색 */
        background-color: transparent !important;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.1s;
        text-align: center !important;
        border-left: none !important;
    }

    .nav-submenu .submenu-link.active-link {
        color: #2563eb !important;
        background-color: #eff6ff !important;
    }
    .nav-submenu .submenu-link.active-link::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background-color: #2563eb;
    }

    .nav-submenu .submenu-link:hover {
        color: #2563eb !important;
        background-color: #eff6ff !important;
    }

    .nav-submenu .submenu-link:hover::before {
        content: "" !important;
        position: absolute !important;
        left: 0 !important;
        top: 0 !important;
        bottom: 0 !important;
        width: 4px !important;
        background-color: #2563eb !important;
    }

    .nav-submenu:hover .submenu-link.active-link:not(:hover) {
        background-color: transparent !important;
        color: #6b7280 !important;
    }
    .nav-submenu:hover .submenu-link.active-link:not(:hover)::before {
        display: none !important;
    }
</style>
<!-- FOOTER -->
<footer class="footer">
    <div class="footer-inner">

        <!-- 상단 행: 로고 | 링크 | 버튼 -->
        <div class="footer-row">
            <a href="/" class="footer-brand-logo"><span>I</span>code<span>U</span></a>
            <div class="footer-actions">
                <a href="/supports" class="btn btn-outline">고객센터</a>
                <a href="#" class="btn btn-outline" onclick="goExpertCenter(); return false;">전문가센터</a>
            </div>

            <nav class="footer-nav">
                <a href="/supports?tab=about">회사소개</a>
                <a href="/supports?tab=careers">인재채용</a>
                <a href="/supports?tab=partnership">제휴 문의</a>
                <span class="footer-nav-sep"></span>
                <a href="/boards?boardType=NOTICE">공지게시판</a>
                <a href="/boards/save?boardType=INQUIRY">1:1 문의</a>
                <a href="/policys/faq">자주 묻는 질문</a>
            </nav>


        </div>

        <!-- 하단 행: 정책 링크 + 운영시간 | 저작권 -->
        <div class="footer-bottom">
            <div class="footer-policy-links">
                <a href="/policys/terms">이용약관</a>
                <a href="/policys/privacy" class="footer-policy-strong">개인정보처리방침</a>
                <a href="/policys/ad">광고약관</a>
                <a href="/policys/operation">운영정책</a>
                <span class="footer-hours-inline">평일 10:00~18:00 · 주말·공휴일 휴무</span>
            </div>
            <p class="footer-copy">© 2025 SevMerge. All rights reserved.</p>
        </div>

    </div>
</footer>
<script>
    document.querySelectorAll('.footer-toggle').forEach(function (title) {
        title.addEventListener('click', function () {
            const links = title.nextElementSibling;
            links.classList.toggle('active');
        });
    });

    function goExpertCenter() {
        const isExpert = {{#isExpert}}true{{/isExpert}}{{^isExpert}}false{{/isExpert}};

        if (isExpert) {
            location.href = '/experts/dashboard';
        } else {
            alert('전문가 회원만 이용할 수 있습니다. 로그인 후 이용해주세요.');
            fetch('/logout', { method: 'GET' })
                    .finally(() => {
                        location.href = '/login';
                    });
        }
    }
</script>


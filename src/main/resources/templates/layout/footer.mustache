    }

    .chatbot-header {
        background: #fff;
        border-bottom: 1px solid #eaecf4;
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .chatbot-avatar {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: linear-gradient(135deg, #2563eb, #1d4ed8);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .chatbot-avatar svg {
        width: 18px;
        height: 18px;
        color: #fff;
    }

    .chatbot-header-text {
        flex: 1;
    }

    .chatbot-title {
        font-size: 14px;
        font-weight: 700;
        color: #1c1e26;
        letter-spacing: -0.2px;
    }

    .chatbot-status {
        font-size: 11px;
        color: #9ca3af;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .chatbot-status::before {
        content: '';
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #22c55e;
    }

    .chatbot-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #9ca3af;
        padding: 4px;
        display: flex;
        border-radius: 6px;
        transition: background .15s, color .15s;
    }

    .chatbot-close:hover {
        background: #f3f4f8;
        color: #1c1e26;
    }

    .chatbot-messages {
        flex: 1;
        overflow-y: auto;
        padding: 18px 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #f8f9fc;
    }

    .chatbot-messages::-webkit-scrollbar {
        width: 5px;
    }

    .chatbot-messages::-webkit-scrollbar-thumb {
        background: #e2e5ef;
        border-radius: 10px;
    }

    .chat-row {
        display: flex;
        gap: 8px;
        align-items: flex-end;
    }

    .chat-row.user {
        flex-direction: row-reverse;
    }

    .chat-bubble {
        max-width: 78%;
        padding: 11px 14px;
        border-radius: 14px;
        font-size: 13px;
        line-height: 1.6;
        font-weight: 400;
    }

    .chat-row.bot .chat-bubble {
        background: #fff;
        color: #1c1e26;
        border: 1px solid #eaecf4;
        border-bottom-left-radius: 4px;
    }

    .chat-row.user .chat-bubble {
        background: #2563eb;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    /* 타이핑 인디케이터 */
    .typing-dots {
        display: flex;
        gap: 4px;
        padding: 12px 14px;
    }

    .typing-dots span {
        width: 6px;
        height: 6px;
        border-radius: 50%;

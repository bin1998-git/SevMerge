<style>
    /* ── 바닥 고정: body flex column, footer 항상 최하단 ── */
    html { height: 100%; }
    body {
        min-height: 100%;        /* html 100% = 100vh, can grow beyond */
        display: flex !important;
        flex-direction: column !important;
    }
    body > *:not(header):not(footer):not(style):not(script):not(.chatbot-toggle):not(.chatbot-window):not(.noti-toast) {
        flex: 1 0 auto;
    }
    .footer {
        flex-shrink: 0;
        margin-top: auto;
    }
    /* ──────────────────────────────────────────── */

    .footer {
        background: #0d1b2e;
        padding: 0 28px;
        margin-top: auto;
    }
    .footer-inner { max-width: 1300px; margin: 0 auto; }

    .footer-row {
        display: flex; align-items: center; gap: 24px;
        padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,.07); flex-wrap: wrap;
    }
    .footer-brand-logo {
        font-size: 20px; font-weight: 900; color: #fff; letter-spacing: -0.5px;
        text-decoration: none; flex-shrink: 0; font-family: 'Noto Sans KR', sans-serif;
    }
    .footer-brand-logo .hl { color: #00c8e0; }

    .footer-actions { display: flex; gap: 8px; flex-shrink: 0; }
    .footer-action-btn {
        padding: 6px 16px; font-size: 12px; font-weight: 700;
        border-radius: 20px; cursor: pointer; text-decoration: none;
        transition: all .15s; display: inline-block;
        border: 1.5px solid rgba(255,255,255,.2);
        color: rgba(255,255,255,.7); background: rgba(255,255,255,.05);
        font-family: inherit;
    }
    .footer-action-btn:hover { background: rgba(0,200,224,.15); border-color: rgba(0,200,224,.5); color: #00c8e0; }

    .footer-nav { display: flex; align-items: center; flex: 1; flex-wrap: wrap; }
    .footer-nav a {
        font-size: 13px; color: rgba(255,255,255,.38);
        text-decoration: none; padding: 4px 14px; transition: color .15s; white-space: nowrap; font-family: inherit;
    }
    .footer-nav a:hover { color: #00c8e0; }
    .footer-nav-sep { display: inline-block; width: 1px; height: 13px; background: rgba(255,255,255,.1); margin: 0 2px; vertical-align: middle; }

    .footer-bottom {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 0; gap: 12px; flex-wrap: wrap;
    }
    .footer-policy-links { display: flex; align-items: center; flex-wrap: wrap; }
    .footer-policy-links a {
        font-size: 12px; color: rgba(255,255,255,.22);
        text-decoration: none; padding-right: 14px; transition: color .15s; white-space: nowrap; font-family: inherit;
    }
    .footer-policy-links a:hover { color: rgba(255,255,255,.6); }
    .footer-policy-strong { color: rgba(255,255,255,.4) !important; font-weight: 700; }
    .footer-hours-inline {
        font-size: 12px; color: rgba(255,255,255,.18);
        padding-left: 14px; border-left: 1px solid rgba(255,255,255,.1); white-space: nowrap; font-family: inherit;
    }
    .footer-copy { font-size: 12px; color: rgba(255,255,255,.18); white-space: nowrap; font-family: inherit; }

    @media (max-width: 768px) {
        .footer-row { gap: 14px; padding: 20px 0; }
        .footer-bottom { flex-direction: column; align-items: flex-start; }
        .footer-hours-inline { display: none; }
    }

    /* ── AI 챗봇 ── */
    .chatbot-toggle {
        position: fixed; bottom: 28px; right: 28px;
        width: 56px; height: 56px; border-radius: 50%;
        background: linear-gradient(135deg, #00c8e0, #00a8be);
        color: #0d1b2e; display: flex; align-items: center; justify-content: center;
        cursor: pointer; box-shadow: 0 8px 24px rgba(0,200,224,.35);
        z-index: 1000; border: none; transition: transform .2s, box-shadow .2s;
    }
    .chatbot-toggle:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(0,200,224,.5); }
    .chatbot-toggle svg { width: 22px; height: 22px; }
    .chatbot-toggle::after {
        content: ''; position: absolute; inset: 0; border-radius: 50%;
        border: 2px solid #00c8e0; opacity: 0;
        animation: chatbot-pulse 2.4s ease-out infinite;
    }
    @keyframes chatbot-pulse { 0% { opacity: .6; transform: scale(1); } 100% { opacity: 0; transform: scale(1.5); } }

    .chatbot-window {
        position: fixed; bottom: 96px; right: 28px;
        width: 360px; height: 500px;
        background: #fff; border-radius: 18px;
        box-shadow: 0 16px 48px rgba(15,23,42,.18);
        border: 1px solid #eaecf4;
        display: flex; flex-direction: column; overflow: hidden;
        z-index: 1000; opacity: 0;
        transform: translateY(12px) scale(.98);
        pointer-events: none;
        transition: opacity .18s ease, transform .18s ease;
    }
    .chatbot-window.active { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }

    .chatbot-header { background: #fff; border-bottom: 1px solid #eaecf4; padding: 16px 20px; display: flex; align-items: center; gap: 10px; }
    .chatbot-avatar { width: 34px; height: 34px; border-radius: 10px; background: linear-gradient(135deg, #00c8e0, #2563eb); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .chatbot-avatar svg { width: 17px; height: 17px; color: #fff; }
    .chatbot-header-text { flex: 1; }
    .chatbot-title { font-size: 14px; font-weight: 700; color: #1c1e26; letter-spacing: -.2px; }
    .chatbot-status { font-size: 11px; color: #9ca3af; font-weight: 500; display: flex; align-items: center; gap: 5px; }
    .chatbot-status::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
    .chatbot-close { background: none; border: none; cursor: pointer; color: #9ca3af; padding: 4px; display: flex; border-radius: 6px; transition: background .15s, color .15s; }
    .chatbot-close:hover { background: #f3f4f8; color: #1c1e26; }

    .chatbot-messages { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; background: #f8f9fc; }
    .chatbot-messages::-webkit-scrollbar { width: 4px; }
    .chatbot-messages::-webkit-scrollbar-thumb { background: #e2e5ef; border-radius: 10px; }

    .chat-row { display: flex; gap: 8px; align-items: flex-end; }
    .chat-row.user { flex-direction: row-reverse; }
    .chat-bubble { max-width: 78%; padding: 11px 14px; border-radius: 14px; font-size: 13px; line-height: 1.6; font-family: inherit; }
    .chat-row.bot .chat-bubble { background: #fff; color: #1c1e26; border: 1px solid #eaecf4; border-bottom-left-radius: 4px; }
    .chat-row.user .chat-bubble { background: #2563eb; color: #fff; border-bottom-right-radius: 4px; }

    .typing-dots { display: flex; gap: 4px; padding: 12px 14px; }
    .typing-dots span { width: 6px; height: 6px; border-radius: 50%; background: #c4c9d9; animation: typing-bounce 1.2s infinite ease-in-out; }
    .typing-dots span:nth-child(2) { animation-delay: .15s; }
    .typing-dots span:nth-child(3) { animation-delay: .3s; }
    @keyframes typing-bounce { 0%, 60%, 100% { transform: translateY(0); opacity: .5; } 30% { transform: translateY(-4px); opacity: 1; } }

    .chatbot-suggestions { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 16px 12px; background: #f8f9fc; }
    .suggestion-chip { font-size: 12px; font-weight: 600; color: #2563eb; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 20px; padding: 5px 12px; cursor: pointer; white-space: nowrap; transition: background .15s; font-family: inherit; }
    .suggestion-chip:hover { background: #dbeafe; border-color: #93c5fd; }

    .chatbot-input-area { display: flex; align-items: center; gap: 8px; padding: 12px 14px; border-top: 1px solid #eaecf4; background: #fff; }
    .chatbot-input-area input { flex: 1; border: 1.5px solid #e2e5ef; border-radius: 22px; padding: 10px 16px; font-size: 13px; font-family: inherit; outline: none; background: #f8f9fc; transition: border-color .15s, background .15s; }
    .chatbot-input-area input:focus { border-color: #2563eb; background: #fff; }
    .chatbot-send-btn { width: 36px; height: 36px; border-radius: 50%; background: #00c8e0; border: none; color: #0d1b2e; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background .15s; }
    .chatbot-send-btn:hover { background: #00a8be; }
    .chatbot-send-btn svg { width: 15px; height: 15px; }

    @media (max-width: 480px) {
        .chatbot-window { width: calc(100vw - 32px); right: 16px; height: 70vh; }
        .chatbot-toggle { right: 16px; bottom: 16px; }
    }
</style>

<footer class="footer">
    <div class="footer-inner">
        <div class="footer-row">
            <a href="/" class="footer-brand-logo">I<span class="hl">code</span>U</a>
            <div class="footer-actions">
                <a href="/supports" class="footer-action-btn">고객센터</a>
                <a href="#" class="footer-action-btn" onclick="goExpertCenter(); return false;">전문가센터</a>
            </div>
            <nav class="footer-nav">
                <a href="/supports?tab=about">회사소개</a>
                <a href="/supports?tab=careers">인재채용</a>
                <a href="/supports?tab=partnership">제휴 문의</a>
                <span class="footer-nav-sep"></span>
                <a href="/boards?boardType=NOTICE">공지게시판</a>
                <a href="/boards/save?boardType=INQUIRY">1:1 문의</a>
                <a href="/policys/faq">자주 묻는 질문</a>
            </nav>
        </div>
        <div class="footer-bottom">
            <div class="footer-policy-links">
                <a href="/policys/terms">이용약관</a>
                <a href="/policys/privacy" class="footer-policy-strong">개인정보처리방침</a>
                <a href="/policys/ad">광고약관</a>
                <a href="/policys/operation">운영정책</a>
                <span class="footer-hours-inline">평일 10:00~18:00 · 주말·공휴일 휴무</span>
            </div>
            <p class="footer-copy">© 2025 SevMerge. All rights reserved.</p>
        </div>
    </div>
</footer>

<button class="chatbot-toggle" onclick="toggleChatbot()" aria-label="AI 도우미 열기">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    </svg>
</button>

<div class="chatbot-window" id="chatbotWindow">
    <div class="chatbot-header">
        <div class="chatbot-avatar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a4 4 0 0 1 4 4v1a4 4 0 0 1-4 4 4 4 0 0 1-4-4V6a4 4 0 0 1 4-4z"/>
                <path d="M5 20v-2a7 7 0 0 1 14 0v2"/>
            </svg>
        </div>
        <div class="chatbot-header-text">
            <div class="chatbot-title">코드요 AI 도우미</div>
            <div class="chatbot-status">온라인</div>
        </div>
        <button class="chatbot-close" onclick="toggleChatbot()" aria-label="닫기">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
        </button>
    </div>
    <div class="chatbot-messages" id="chatbotMessages">
        <div class="chat-row bot">
            <div class="chat-bubble">안녕하세요! 코드요 이용 중 궁금한 점이나 프로젝트 등록을 도와드릴게요. 😊</div>
        </div>
    </div>
    <div class="chatbot-suggestions">
        <div class="suggestion-chip" onclick="sendSuggestion('프로젝트는 어떻게 등록하나요?')">프로젝트 등록 방법</div>
        <div class="suggestion-chip" onclick="sendSuggestion('입찰은 어떻게 참여하나요?')">입찰 참여 방법</div>
    </div>
    <div class="chatbot-input-area">
        <input type="text" id="chatbotInput" placeholder="질문을 입력하세요"
               onkeydown="if(event.key==='Enter' && !event.isComposing) sendChatMessage()">
        <button class="chatbot-send-btn" onclick="sendChatMessage()" aria-label="전송">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 2 11 13M22 2 15 22l-4-9-9-4 20-7z"/>
            </svg>
        </button>
    </div>
</div>

<script>
    function goExpertCenter() {
        const isExpert = {{#isExpert}}true{{/isExpert}}{{^isExpert}}false{{/isExpert}};
        if (isExpert) { location.href = '/experts/dashboard'; }
        else { alert('전문가 회원만 이용할 수 있습니다.'); fetch('/logout', { method: 'POST' }).finally(() => { location.href = '/login'; }); }
    }
    function toggleChatbot() { document.getElementById('chatbotWindow').classList.toggle('active'); }
    function sendSuggestion(text) { document.getElementById('chatbotInput').value = text; sendChatMessage(); }
    function appendMessage(role, text) {
        const el = document.getElementById('chatbotMessages');
        const row = document.createElement('div');
        row.className = 'chat-row ' + role;
        row.innerHTML = `<div class="chat-bubble">${text}</div>`;
        el.appendChild(row); el.scrollTop = el.scrollHeight;
    }
    function showTyping() {
        const el = document.getElementById('chatbotMessages');
        const row = document.createElement('div');
        row.className = 'chat-row bot'; row.id = 'typingIndicator';
        row.innerHTML = `<div class="chat-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
        el.appendChild(row); el.scrollTop = el.scrollHeight;
    }
    function removeTyping() { const el = document.getElementById('typingIndicator'); if (el) el.remove(); }
    async function sendChatMessage() {
        const input = document.getElementById('chatbotInput');
        const question = input.value.trim();
        if (!question) return;
        appendMessage('user', question); input.value = ''; showTyping();
        try {
            const res = await fetch('/api/project/ai/ask', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ question }) });
            const data = await res.json(); removeTyping(); appendMessage('bot', data.answer);
        } catch { removeTyping(); appendMessage('bot', '오류가 발생했어요. 다시 시도해주세요.'); }
    }
</script>

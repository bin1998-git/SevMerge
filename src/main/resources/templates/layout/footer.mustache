        flex-shrink: 0;
        transition: background .15s;
    }

    .chatbot-send-btn:hover {
        background: #1d4ed8;
    }

    .chatbot-send-btn svg {
        width: 16px;
        height: 16px;
    }

    @media (max-width: 480px) {
        .chatbot-window {
            width: calc(100vw - 32px);
            right: 16px;
            height: 70vh;
        }
        .chatbot-toggle {
            right: 16px;
            bottom: 16px;
        }
